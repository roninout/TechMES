@inherits LayoutComponentBase
@implements IDisposable
@inject QrScannerState QrScannerState
@inject SelectedEquipmentState SelectedEquipmentState
@inject DialogService DialogService
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider

<RadzenLayout>
    <RadzenHeader class="app-header">
        <div class="app-header-bar">
            <div class="app-brand">
                <RadzenText Text="TechMES WEB" TextStyle="TextStyle.H6" />
            </div>

            <nav class="top-nav" aria-label="Main navigation">
                @* Верхний пункт Equipment теперь ведет в общий модуль оборудования.
                   Переключение Info/Param вынесено в локальный SelectBar на странице Equipment,
                   поэтому отдельная кнопка Param в глобальном меню больше не нужна. *@
                <NavLink class="top-nav-link"
                         href="@SelectedEquipmentState.EquipmentRoute"
                         Match="NavLinkMatch.Prefix">
                    <RadzenIcon Icon="precision_manufacturing" />
                    <span>Equipment</span>
                </NavLink>

                <NavLink class="top-nav-link" href="/operation-actions">
                    <RadzenIcon Icon="fact_check" />
                    <span>Operation actions</span>
                </NavLink>

                <NavLink class="top-nav-link" href="/alarm-history">
                    <RadzenIcon Icon="history" />
                    <span>Alarm history</span>
                </NavLink>

                <NavLink class="top-nav-link" href="/soe">
                    <RadzenIcon Icon="timeline" />
                    <span>SOE</span>
                </NavLink>

                <NavLink class="top-nav-link" href="/messages">
                    <RadzenIcon Icon="mail" />
                    <span>Messages</span>
                </NavLink>

                <button type="button"
                        class="top-nav-link top-nav-button"
                        title="Scan QR"
                        aria-label="Scan QR"
                        @onclick="OpenQrScannerAsync">
                    <RadzenIcon Icon="qr_code_scanner" />
                    <span>Scan QR</span>
                </button>
            </nav>

            <div class="header-spacer"></div>

            @* Все глобальные действия собраны справа в одном flex-контейнере:
               переключение темы и Footer не влияют на ширину основного меню. *@
            <div class="header-actions">
                <RadzenButton Icon="@GetAuthButtonIcon()"
                              ButtonStyle="ButtonStyle.Light"
                              Variant="Variant.Text"
                              class="@GetAuthButtonCssClass()"
                              title="@GetAuthButtonTitle()"
                              aria-label="@GetAuthButtonTitle()"
                              Click="@OpenAuthDialogAsync" />

                <RadzenAppearanceToggle LightTheme="standard"
                                        DarkTheme="standard-dark"
                                        ButtonStyle="ButtonStyle.Light"
                                        ToggleButtonStyle="ButtonStyle.Light"
                                        Variant="Variant.Text"
                                        class="header-icon-button header-appearance-toggle"
                                        title="Switch light/dark theme"
                                        aria-label="Switch light/dark theme" />

                <RadzenButton Icon="@(_isFooterVisible ? "bottom_panel_close" : "bottom_panel_open")"
                              ButtonStyle="ButtonStyle.Light"
                              Variant="Variant.Text"
                              class="header-icon-button"
                              title="@(_isFooterVisible ? "Hide footer" : "Show footer")"
                              aria-label="@(_isFooterVisible ? "Hide footer" : "Show footer")"
                              Click="@ToggleFooter" />

                @* PNG используется как прозрачная маска, а цвет логотипа задается активной темой.
                   Благодаря этому один и тот же файл остается читаемым и в светлом, и в темном режиме. *@
                <span class="app-logo"
                      role="img"
                      aria-label="Techinservice Intelligence"></span>
            </div>
        </div>
    </RadzenHeader>

    <RadzenBody>
        <div class="@GetPageContentCssClass()">
            @Body
        </div>
    </RadzenBody>

    @* При скрытии Footer компонент удаляется целиком, а не маскируется через visibility:
       это освобождает место для основной рабочей области. *@
    @if (_isFooterVisible)
    {
        <RadzenFooter class="app-footer">
            <div class="app-footer-bar">
                <EquipmentFooterCountsBlock />

                <div class="footer-spacer"></div>

                <RuntimeStatusBlock />
            </div>
        </RadzenFooter>
    }
</RadzenLayout>

<RadzenDialog />
<RadzenNotification />
<QrScannerDialog @ref="_qrScannerDialog" OnScanned="@OnQrScannedAsync" />

@code {
    private QrScannerDialog? _qrScannerDialog;
    private bool _isAuthenticated;
    private string? _authUserName;

    /// <summary>
    /// Определяет, отображается ли диагностическая Footer-зона.
    /// Состояние относится только к текущей пользовательской Blazor-сессии и после обновления страницы
    /// возвращается к значению по умолчанию: Footer скрыт.
    /// </summary>
    private bool _isFooterVisible;

    /// <summary>
    /// Подписывается на состояние Equipment, чтобы верхняя кнопка Equipment
    /// сразу вела в последний выбранный режим: Info или Param.
    /// </summary>
    protected override void OnInitialized()
    {
        SelectedEquipmentState.Changed += OnSelectedEquipmentStateChanged;
    }

    /// <summary>
    /// Читает эффективное состояние авторизации для Header-кнопки.
    /// Без Windows login сайт остается доступным, но WEB показывает read-only режим.
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        await RefreshAuthStateAsync();
    }

    /// <summary>
    /// Обновляет Header после смены выбранного оборудования или режима Equipment.
    /// </summary>
    private void OnSelectedEquipmentStateChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    /// <summary>
    /// Возвращает CSS-классы рабочей области с учетом состояния Footer.
    /// Когда Footer скрыт, дополнительный класс разрешает содержимому занять освободившуюся высоту окна.
    /// </summary>
    private string GetPageContentCssClass()
    {
        return _isFooterVisible
            ? "page-content"
            : "page-content footer-hidden";
    }

    /// <summary>
    /// Переключает видимость Footer-зоны.
    /// Компонент Footer удаляется из render tree, поэтому его счетчики и runtime-status не занимают место,
    /// а основная рабочая область сразу расширяется до нижней границы окна.
    /// </summary>
    private void ToggleFooter()
    {
        _isFooterVisible = !_isFooterVisible;
    }

    /// <summary>
    /// Открывает глобальный QR-сканер из header bar.
    /// Жизненным циклом камеры управляет сам dialog-компонент.
    /// </summary>
    private Task OpenQrScannerAsync()
    {
        return _qrScannerDialog?.OpenAsync() ?? Task.CompletedTask;
    }

    /// <summary>
    /// Открывает явный диалог Login/Logout вместо системного prompt при входе на сайт.
    /// </summary>
    private async Task OpenAuthDialogAsync()
    {
        await RefreshAuthStateAsync();

        await DialogService.OpenAsync<AuthDialog>(
            "Authentication",
            new Dictionary<string, object?>
            {
                ["IsAuthenticated"] = _isAuthenticated,
                ["UserName"] = _authUserName ?? "",
                ["ReturnUrl"] = GetCurrentLocalUrl()
            },
            new DialogOptions
            {
                Width = "430px",
                Resizable = false,
                Draggable = false
            });
    }

    /// <summary>
    /// Обновляет имя пользователя, которое Blazor видит после optional Windows authentication.
    /// </summary>
    private async Task RefreshAuthStateAsync()
    {
        var authenticationState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        _isAuthenticated = authenticationState.User.Identity?.IsAuthenticated == true;
        _authUserName = _isAuthenticated
            ? authenticationState.User.Identity?.Name
            : null;
    }

    /// <summary>
    /// Возвращает локальный путь текущей страницы для возврата после Login/Logout.
    /// </summary>
    private string GetCurrentLocalUrl()
    {
        var relativePath = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        return string.IsNullOrWhiteSpace(relativePath)
            ? "/"
            : "/" + relativePath;
    }

    private string GetAuthButtonIcon()
    {
        return _isAuthenticated ? "account_circle" : "login";
    }

    private string GetAuthButtonTitle()
    {
        return _isAuthenticated
            ? $"Logged in: {_authUserName}"
            : "Read-only mode. Click to login.";
    }

    private string GetAuthButtonCssClass()
    {
        return _isAuthenticated
            ? "header-icon-button header-auth-button authenticated"
            : "header-icon-button header-auth-button anonymous";
    }

    /// <summary>
    /// Публикует считанный QR-текст в scoped state.
    /// Страница Equipment подписывается на это событие и выбирает найденный узел оборудования.
    /// </summary>
    private Task OnQrScannedAsync(string qrText)
    {
        return QrScannerState.NotifyScannedAsync(qrText);
    }

    /// <summary>
    /// Отписывается от состояния Equipment при уничтожении layout.
    /// </summary>
    public void Dispose()
    {
        SelectedEquipmentState.Changed -= OnSelectedEquipmentStateChanged;
    }
}
