@inherits LayoutComponentBase
@inject QrScannerState QrScannerState

<RadzenLayout>
    <RadzenHeader class="app-header">
        <div class="app-header-bar">
            <div class="app-brand">
                <RadzenText Text="TechMES WEB" TextStyle="TextStyle.H6" />
            </div>

            <nav class="top-nav" aria-label="Main navigation">
                <NavLink class="top-nav-link" href="/equipment">
                    <RadzenIcon Icon="precision_manufacturing" />
                    <span>Equipment</span>
                </NavLink>

                <NavLink class="top-nav-link" href="/param">
                    <RadzenIcon Icon="tune" />
                    <span>Param</span>
                </NavLink>

                <NavLink class="top-nav-link" href="/messages">
                    <RadzenIcon Icon="mail" />
                    <span>Messages</span>
                </NavLink>
            </nav>

            <div class="header-spacer"></div>

            <RadzenButton Icon="photo_camera"
                          Text="Scan QR"
                          ButtonStyle="ButtonStyle.Light"
                          class="header-qr-button"
                          Click="@OpenQrScannerAsync" />

            <img class="app-logo"
                 src="images/TIS_logo_intellegence_g.png"
                 alt="Techinservice Intelligence" />
        </div>
    </RadzenHeader>

    <RadzenBody>
        <div class="page-content">
            @Body
        </div>
    </RadzenBody>

    <RadzenFooter class="app-footer">
        <div class="app-footer-bar">
            <EquipmentFooterCountsBlock />

            <div class="footer-spacer"></div>

            <RuntimeStatusBlock />
        </div>
    </RadzenFooter>
</RadzenLayout>

<RadzenDialog />
<RadzenNotification />
<QrScannerDialog @ref="_qrScannerDialog" OnScanned="@OnQrScannedAsync" />

@code {
    private QrScannerDialog? _qrScannerDialog;

    /// <summary>
    /// Opens the global QR scanner from the header bar. The dialog component owns
    /// camera lifecycle; the layout only places the command near the app logo.
    /// </summary>
    private Task OpenQrScannerAsync()
    {
        return _qrScannerDialog?.OpenAsync() ?? Task.CompletedTask;
    }

    /// <summary>
    /// Publishes scanned QR text to whichever page is currently interested in it.
    /// Equipment.razor subscribes and selects the matching equipment node.
    /// </summary>
    private Task OnQrScannedAsync(string qrText)
    {
        return QrScannerState.NotifyScannedAsync(qrText);
    }
}
