@using TechMES.Contracts.Param

<div class="ai-settings-page">
    @RenderGroup("PLC settings", "manufacturing", PlcRows)
    @RenderGroup("Chanel settings", "settings_input_component", ChannelRows)
    @RenderForcedGroup()
</div>

@code {
    /// <summary>
    /// Полный набор Param item-ов текущего AI-оборудования.
    /// Компонент сам выбирает из него только поля, нужные для WPF-like вкладки Settings.
    /// </summary>
    [Parameter]
    public IReadOnlyList<ParamItemDto>? Items { get; set; }

    /// <summary>
    /// Команда записи, которую родительский EquipmentParamPanel уже реализует через Radzen Dialog и Runtime.Service.
    /// </summary>
    [Parameter]
    public EventCallback<ParamItemDto> OnWriteRequested { get; set; }

    /// <summary>
    /// Команда записи boolean item-а с заранее выбранным новым значением.
    /// Используется для ForceCmd, чтобы клик по switch открывал диалог уже с инверсией текущего состояния.
    /// </summary>
    [Parameter]
    public EventCallback<ParamWriteDialogRequest> OnBooleanWriteRequested { get; set; }

    /// <summary>
    /// Поля верхнего блока PLC settings для AI.
    /// </summary>
    private static readonly AiSettingRow[] PlcRows =
    [
        new("Max", "Max"),
        new("Min", "Min"),
        new("Filtration", "Flt")
    ];

    /// <summary>
    /// Поля нижнего блока Chanel settings; название оставлено как в WPF-экране.
    /// </summary>
    private static readonly AiSettingRow[] ChannelRows =
    [
        new("MaxR", "MaxR"),
        new("MinR", "MinR"),
        new("Coefficient", "Coef")
    ];

    /// <summary>
    /// Рисует нижний WPF-like блок Forced.
    /// В WPF для AI здесь использовалась пара ForceCmd/HmiForced: switch включает режим force,
    /// а HmiForced показывает/задает принудительное HMI-значение канала.
    /// </summary>
    private RenderFragment RenderForcedGroup() => @<ParamAiPanel Title="Forced" Icon="flash_on">
        @{
            var switchItem = FindItem("ForceCmd");
            var valueItem = FindItem("HmiForced");
        }

        <div class="ai-forced-body">
            <div class="ai-forced-row">
                <div class="@GetSwitchShellClass(switchItem)"
                     title="@GetFieldTitle(switchItem)"
                     @onclick="@(() => RequestSwitchWriteAsync(switchItem))">
                    <RadzenStack Orientation="Orientation.Horizontal"
                                 AlignItems="AlignItems.Center"
                                 Gap="0.5rem"
                                 class="ai-forced-switch-stack">
                        <RadzenLabel Text="@GetSwitchText(switchItem)"
                                     Component="ForceCmd" />
                        <RadzenSwitch Value="@GetSwitchValue(switchItem)"
                                      Disabled="@(switchItem is null)"
                                      Name="ForceCmd" />
                    </RadzenStack>
                </div>

                <span class="ai-forced-description">Forcing the chanel</span>

                <div class="@GetForcedFieldShellClass(valueItem)"
                     title="@GetFieldTitle(valueItem)"
                     @onclick="@(() => RequestWriteAsync(valueItem))">
                    <RadzenFormField AllowFloatingLabel="false"
                                     Text="HmiForced"
                                     Variant="Variant.Outlined"
                                     class="ai-forced-form-field">
                        <RadzenTextBox Value="@FormatValue(valueItem)"
                                       ReadOnly="true"
                                       Disabled="@(valueItem is null)"
                                       class="ai-forced-value" />
                    </RadzenFormField>
                </div>
            </div>
        </div>
    </ParamAiPanel>;

    /// <summary>
    /// Рисует одну WPF-like группу настроек с заголовком и строками FormField.
    /// </summary>
    private RenderFragment RenderGroup(string title, string icon, IReadOnlyList<AiSettingRow> rows) => @<ParamAiPanel Title="@title" Icon="@icon">
        <div class="ai-settings-group-body">
            @foreach (var row in rows)
            {
                var item = FindItem(row.ItemName);

                <div class="ai-setting-row">
                    <span class="ai-setting-label">@row.Label</span>

                    <div class="@GetFieldShellClass(item)"
                         title="@GetFieldTitle(item)"
                         @onclick="@(() => RequestWriteAsync(item))">
                        <RadzenFormField AllowFloatingLabel="false"
                                         Text="@row.Label"
                                         Variant="Variant.Outlined"
                                         class="ai-setting-form-field">
                            <RadzenTextBox Value="@FormatValue(item)"
                                           ReadOnly="true"
                                           Disabled="@(item is null)"
                                           class="ai-setting-value" />
                        </RadzenFormField>
                    </div>
                </div>
            }
        </div>
    </ParamAiPanel>;

    /// <summary>
    /// Ищет Param item по имени EquipItem без учета регистра.
    /// </summary>
    private ParamItemDto? FindItem(string itemName)
    {
        return Items?.FirstOrDefault(item => item.Name.Equals(itemName, StringComparison.OrdinalIgnoreCase));
    }

    /// <summary>
    /// Вызывает общий write-dialog только для writable item-ов.
    /// </summary>
    private async Task RequestWriteAsync(ParamItemDto? item)
    {
        if (item is null || !item.CanWrite)
            return;

        await OnWriteRequested.InvokeAsync(item);
    }

    /// <summary>
    /// Открывает write-dialog для switch-а уже с противоположным boolean-значением.
    /// Это устраняет ситуацию, когда оператор кликает switch, а диалог предлагает записать старое состояние.
    /// </summary>
    private async Task RequestSwitchWriteAsync(ParamItemDto? item)
    {
        if (item is null || !item.CanWrite)
            return;

        var request = new ParamWriteDialogRequest
        {
            Item = item,
            InitialBooleanValue = !GetSwitchValue(item)
        };

        if (OnBooleanWriteRequested.HasDelegate)
        {
            await OnBooleanWriteRequested.InvokeAsync(request);
            return;
        }

        await OnWriteRequested.InvokeAsync(item);
    }

    /// <summary>
    /// CSS-класс контейнера FormField: writable поля выглядят кликабельными, read-only остаются спокойными.
    /// </summary>
    private static string GetFieldShellClass(ParamItemDto? item)
    {
        return item?.CanWrite == true
            ? "ai-setting-field-shell is-writable"
            : "ai-setting-field-shell is-read-only";
    }

    /// <summary>
    /// Возвращает boolean-состояние ForceCmd для RadzenSwitch.
    /// Switch не пишет напрямую: клик открывает общий write-dialog родительской Param-панели.
    /// </summary>
    private static bool GetSwitchValue(ParamItemDto? item)
    {
        if (item is null)
            return false;

        if (item.BooleanValue.HasValue)
            return item.BooleanValue.Value;

        if (item.NumericValue.HasValue)
            return Math.Abs(item.NumericValue.Value) > double.Epsilon;

        var text = item.ValueText?.Trim();
        return text is not null
            && (text.Equals("true", StringComparison.OrdinalIgnoreCase)
                || text.Equals("on", StringComparison.OrdinalIgnoreCase)
                || text.Equals("1", StringComparison.OrdinalIgnoreCase)
                || text.Equals("yes", StringComparison.OrdinalIgnoreCase));
    }

    /// <summary>
    /// Текст рядом со switch: вместо WPF-подписи Disabled показываем текущее состояние on/off.
    /// </summary>
    private static string GetSwitchText(ParamItemDto? item)
    {
        return GetSwitchValue(item) ? "on" : "off";
    }

    /// <summary>
    /// CSS-класс контейнера switch в блоке Forced с учетом доступности write.
    /// </summary>
    private static string GetSwitchShellClass(ParamItemDto? item)
    {
        return item?.CanWrite == true
            ? "ai-forced-switch-shell is-writable"
            : "ai-forced-switch-shell is-read-only";
    }

    /// <summary>
    /// CSS-класс контейнера HmiForced FormField с учетом доступности write.
    /// </summary>
    private static string GetForcedFieldShellClass(ParamItemDto? item)
    {
        return item?.CanWrite == true
            ? "ai-forced-field-shell is-writable"
            : "ai-forced-field-shell is-read-only";
    }

    /// <summary>
    /// Tooltip помогает отличать writable поле от отсутствующего или read-only item-а.
    /// </summary>
    private static string GetFieldTitle(ParamItemDto? item)
    {
        if (item is null)
            return "Param item is not available";

        return item.CanWrite ? "Write value" : "Read only";
    }

    /// <summary>
    /// Форматирует значение так же, как общая Param-таблица.
    /// </summary>
    private static string FormatValue(ParamItemDto? item)
    {
        if (item is null)
            return "-";

        if (item.BooleanValue.HasValue)
            return item.BooleanValue.Value ? "on" : "off";

        return string.IsNullOrWhiteSpace(item.ValueText) ? "-" : item.ValueText;
    }

    /// <summary>
    /// Описание строки AI Settings: человекочитаемый label и реальное имя Param item.
    /// </summary>
    private sealed record AiSettingRow(string Label, string ItemName);
}
