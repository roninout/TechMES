@using System.Globalization
@using TechMES.Contracts.Equipment
@using TechMES.Contracts.Param

@if (ShouldRenderPanel)
{
    <aside class="@PanelClass" aria-label="Param graph state">
        @switch (PanelType)
        {
            case EquipmentTypeGroup.AI:
                <div class="param-side-stack">
                    <div class="param-side-bars param-side-bars-two">
                        <ParamGraphVerticalBar Label="PLC value"
                                               Value='@GetNumber("Value")'
                                               Min='@GetNumber("Min")'
                                               Max='@GetNumber("Max")'
                                               FillColor="#6f6f6f" />
                        <ParamGraphVerticalBar Label="R"
                                               Value='@GetNumber("R")'
                                               Min='@GetNumber("MinR")'
                                               Max='@GetNumber("MaxR")'
                                               FillColor="#228b22"
                                               ScaleOnRight="true" />
                    </div>

                    <div class="param-side-unit">@DisplayUnit</div>
                </div>
                break;

            case EquipmentTypeGroup.DI:
            case EquipmentTypeGroup.DO:
                <div class="param-side-stack">
                    <div class="param-side-bars param-side-bars-digital">
                        <div class="param-digital-diagram">
                            <div class="@GetLedClass("ValueTrue") param-digital-led-channel">Chanel</div>
                            <div class="@GetLedClass("ValueForced") param-digital-led-forced">Forced<br />Value</div>
                            <div class="param-digital-bus" aria-hidden="true">
                                <span class="param-digital-line param-digital-line-top"></span>
                                <span class="param-digital-line param-digital-line-bottom"></span>
                                <span class="param-digital-line param-digital-line-middle"></span>
                                <span class="param-digital-line param-digital-line-vertical"></span>
                            </div>
                            <div class="@GetLedClass("Value") param-digital-led-show">Show<br />Value</div>
                        </div>
                    </div>
                </div>
                break;

            case EquipmentTypeGroup.Motor:
                <div class="param-side-stack param-motor-side-stack">
                    @* Motor повторяет геометрию VGA_EL: в боковой области остается только рабочий орган,
                       а State и TimeWork выводятся родительской Graph-панелью в верхней строке. *@
                    <div class="param-motor-button-station">
                        <div class="param-motor-button-station-frame">
                            <RadzenButton Text="On"
                                          ButtonStyle="@GetMotorManualButtonStyle(true)"
                                          Variant="Variant.Flat"
                                          Shade="@GetMotorManualButtonShade(true)"
                                          Disabled="@IsMotorManualButtonDisabled"
                                          class="@GetMotorManualButtonClass(true)"
                                          Click="@(() => RequestManualWriteAsync(true))" />
                            <RadzenButton Text="Off"
                                          ButtonStyle="@GetMotorManualButtonStyle(false)"
                                          Variant="Variant.Flat"
                                          Shade="@GetMotorManualButtonShade(false)"
                                          Disabled="@IsMotorManualButtonDisabled"
                                          class="@GetMotorManualButtonClass(false)"
                                          Click="@(() => RequestManualWriteAsync(false))" />
                        </div>
                    </div>

                    <div class="param-vga-mode-button-shell">
                        <RadzenButton Text="@FormatMotorMode()"
                                      ButtonStyle='@(IsOn("Mode") ? ButtonStyle.Success : ButtonStyle.Light)'
                                      Disabled="@IsModeButtonDisabled"
                                      class="param-vga-mode-button"
                                      Click="@RequestModeWriteAsync" />
                    </div>
                </div>
                break;

            case EquipmentTypeGroup.ATV:
                <div class="param-side-stack param-vga-side-stack">
                    @* ATV repeats the VGA side layout, but shows only one manual-output bar. *@
                    <div class="param-side-bars param-side-bars-one">
                        <ParamGraphVerticalBar Label="ManTrue"
                                               Value='@GetNumber("ManTrue", "Man")'
                                               Min="0"
                                               Max="100"
                                               FillColor="#4f81bd"
                                               ScaleOnRight="true" />
                    </div>

                    <div class="param-side-unit">@DisplayUnit</div>
                    <div class="param-vga-mode-button-shell">
                        <RadzenButton Text="@FormatAutoMode()"
                                      ButtonStyle='@(IsOn("Mode") ? ButtonStyle.Success : ButtonStyle.Light)'
                                      Disabled="@IsModeButtonDisabled"
                                      class="param-vga-mode-button"
                                      Click="@RequestModeWriteAsync" />
                    </div>
                </div>
                break;

            case EquipmentTypeGroup.VGA:
                <div class="param-side-stack param-vga-side-stack">
                    <div class="param-side-bars param-side-bars-two">
                        <ParamGraphVerticalBar Label="PLC value"
                                               Value='@GetNumber("Value")'
                                               Min='@GetNumber("Min")'
                                               Max='@GetNumber("Max")'
                                               FillColor="#6f6f6f" />
                        <ParamGraphVerticalBar Label="ManTrue"
                                               Value='@GetNumber("ManTrue", "R")'
                                               Min='@GetNumber("MinR")'
                                               Max='@GetNumber("MaxR")'
                                               FillColor="#4f81bd"
                                               ScaleOnRight="true" />
                    </div>

                    <div class="param-side-unit">@DisplayUnit</div>
                    <div class="param-vga-mode-button-shell">
                        <RadzenButton Text="@FormatAutoMode()"
                                      ButtonStyle='@(IsOn("Mode") ? ButtonStyle.Success : ButtonStyle.Light)'
                                      Disabled="@IsModeButtonDisabled"
                                      class="param-vga-mode-button"
                                      Click="@RequestModeWriteAsync" />
                    </div>
                </div>
                break;

            case EquipmentTypeGroup.VGA_EL:
                <div class="param-side-stack param-vga-side-stack">
                    <div class="param-side-bars param-side-bars-two">
                        <ParamGraphVerticalBar Label="CurrPos"
                                               Value='@GetNumber("CurrPos")'
                                               Min='@GetNumber("OutMin")'
                                               Max='@GetNumber("OutMax")'
                                               FillColor="#6f6f6f" />
                        <ParamGraphVerticalBar Label="R"
                                               Value='@GetNumber("R")'
                                               Min='@GetNumber("OutMin")'
                                               Max='@GetNumber("OutMax")'
                                               FillColor="#4f81bd"
                                               ScaleOnRight="true" />
                    </div>

                    <div class="param-side-unit">@DisplayUnit</div>
                    <div class="param-vga-mode-button-shell">
                        <RadzenButton Text="@FormatAutoMode()"
                                      ButtonStyle='@(IsOn("Mode") ? ButtonStyle.Success : ButtonStyle.Light)'
                                      Disabled="@IsModeButtonDisabled"
                                      class="param-vga-mode-button"
                                      Click="@RequestModeWriteAsync" />
                    </div>
                </div>
                break;

            case EquipmentTypeGroup.VGD:
                <div class="param-side-stack param-motor-side-stack">
                    @* VGD использует такую же геометрию ручной станции, как Motor:
                       верхний State выводится родительской Graph-панелью, а здесь остаются только Open/Close и Mode. *@
                    <div class="param-motor-button-station">
                        <div class="param-motor-button-station-frame">
                            <RadzenButton Text="Open"
                                          ButtonStyle="@GetMotorManualButtonStyle(true)"
                                          Variant="Variant.Flat"
                                          Shade="@GetMotorManualButtonShade(true)"
                                          Disabled="@IsMotorManualButtonDisabled"
                                          class="@GetMotorManualButtonClass(true)"
                                          Click="@(() => RequestManualWriteAsync(true))" />
                            <RadzenButton Text="Close"
                                          ButtonStyle="@GetMotorManualButtonStyle(false)"
                                          Variant="Variant.Flat"
                                          Shade="@GetMotorManualButtonShade(false)"
                                          Disabled="@IsMotorManualButtonDisabled"
                                          class="@GetMotorManualButtonClass(false)"
                                          Click="@(() => RequestManualWriteAsync(false))" />
                        </div>
                    </div>

                    <div class="param-vga-mode-button-shell">
                        <RadzenButton Text="@FormatAutoMode()"
                                      ButtonStyle='@(IsOn("Mode") ? ButtonStyle.Success : ButtonStyle.Light)'
                                      Disabled="@IsModeButtonDisabled"
                                      class="param-vga-mode-button"
                                      Click="@RequestModeWriteAsync" />
                    </div>
                </div>
                break;
        }
    </aside>
}

@code {
    /// <summary>
    /// Выбранное оборудование. Компонент использует его как запасной источник TypeGroup,
    /// если snapshot еще не успел прийти с backend-а.
    /// </summary>
    [Parameter]
    public EquipmentDto? Equipment { get; set; }

    /// <summary>
    /// Текущий Param snapshot из Runtime.Service.
    /// Все значения левой области берутся только из этого DTO; компонент ничего не пишет в SCADA.
    /// </summary>
    [Parameter]
    public ParamSnapshotResponse? Snapshot { get; set; }

    /// <summary>
    /// Команда записи обычного Param item-а. Используется VGA-полем Man на Graph:
    /// компонент только выбирает item, а диалог и backend-запись остаются в родительской Param-панели.
    /// </summary>
    [Parameter]
    public EventCallback<ParamItemDto> OnWriteRequested { get; set; }

    /// <summary>
    /// Команда записи boolean item-а с уже выбранным новым состоянием.
    /// Нужна для VGA Mode, чтобы кнопка Auto/Manual открывала общий write-dialog с инверсией текущего режима.
    /// </summary>
    [Parameter]
    public EventCallback<ParamWriteDialogRequest> OnBooleanWriteRequested { get; set; }

    /// <summary>
    /// Нормализованная группа оборудования, по которой выбирается WPF-подобный шаблон.
    /// </summary>
    private EquipmentTypeGroup PanelType => Snapshot?.TypeGroup ?? Equipment?.TypeGroup ?? EquipmentTypeGroup.Unknown;

    /// <summary>
    /// Единица измерения из snapshot-а. Для дискретных типов она обычно пустая,
    /// но место оставляем стабильным для аналоговых и исполнительных механизмов.
    /// </summary>
    private string DisplayUnit => string.IsNullOrWhiteSpace(Snapshot?.Unit)
        ? "-"
        : Snapshot.Unit.Trim();

    /// <summary>
    /// CSS-класс корневой панели. Ширина отличается: DI/DO нужно больше места для схемы,
    /// Motor/VGD - для ручной станции, аналоговым типам достаточно компактной шкалы.
    /// </summary>
    private string PanelClass => PanelType switch
    {
        EquipmentTypeGroup.AI => "param-graph-side-panel param-graph-side-panel-aligned-bars",
        EquipmentTypeGroup.ATV => "param-graph-side-panel param-graph-side-panel-aligned-bars param-graph-side-panel-atv",
        EquipmentTypeGroup.VGA => "param-graph-side-panel param-graph-side-panel-aligned-bars param-graph-side-panel-vga",
        EquipmentTypeGroup.VGA_EL => "param-graph-side-panel param-graph-side-panel-aligned-bars param-graph-side-panel-vga-el",
        EquipmentTypeGroup.DI or EquipmentTypeGroup.DO => "param-graph-side-panel param-graph-side-panel-aligned-bars param-graph-side-panel-digital",
        EquipmentTypeGroup.Motor => "param-graph-side-panel param-graph-side-panel-aligned-bars param-graph-side-panel-motor",
        EquipmentTypeGroup.VGD => "param-graph-side-panel param-graph-side-panel-aligned-bars param-graph-side-panel-motor param-graph-side-panel-vgd",
        _ => "param-graph-side-panel"
    };

    /// <summary>
    /// Панель нужна только для Param Graph и только для поддержанных технологических типов.
    /// Для Info и группового Equipment эта область намеренно не рисуется.
    /// </summary>
    private bool ShouldRenderPanel => Snapshot?.Supported == true
        && PanelType is EquipmentTypeGroup.AI
            or EquipmentTypeGroup.DI
            or EquipmentTypeGroup.DO
            or EquipmentTypeGroup.Motor
            or EquipmentTypeGroup.ATV
            or EquipmentTypeGroup.VGA
            or EquipmentTypeGroup.VGA_EL
            or EquipmentTypeGroup.VGD;

    /// <summary>
    /// Ищет Param item по имени без учета регистра.
    /// Несколько имен нужны для fallback-логики: например, у ATV WPF показывает ManTrue,
    /// а при неполном snapshot-е можно безопасно показать Man.
    /// </summary>
    private ParamItemDto? FindItem(params string[] names)
    {
        if (Snapshot is null || names.Length == 0)
            return null;

        return Snapshot.Items.FirstOrDefault(item =>
            names.Any(name => item.Name.Equals(name, StringComparison.OrdinalIgnoreCase)));
    }

    /// <summary>
    /// Возвращает числовое значение Param item-а.
    /// Если backend прислал только текст, пробуем разобрать его в invariant-формате.
    /// </summary>
    private double? GetNumber(params string[] names)
    {
        var item = FindItem(names);

        if (item is null)
            return null;

        if (item.NumericValue.HasValue)
            return item.NumericValue.Value;

        if (double.TryParse(
                item.ValueText?.Replace(',', '.'),
                NumberStyles.Float,
                CultureInfo.InvariantCulture,
                out var parsed))
        {
            return parsed;
        }

        return item.BooleanValue.HasValue
            ? item.BooleanValue.Value ? 1d : 0d
            : null;
    }

    /// <summary>
    /// Возвращает bool-состояние Param item-а.
    /// Поддерживает BooleanValue, числовой 0/1 и типовые строки, которые может вернуть CtApi.
    /// </summary>
    private bool IsOn(params string[] names)
    {
        var item = FindItem(names);

        if (item is null)
            return false;

        if (item.BooleanValue.HasValue)
            return item.BooleanValue.Value;

        if (item.NumericValue.HasValue)
            return Math.Abs(item.NumericValue.Value) > double.Epsilon;

        var text = item.ValueText?.Trim();
        return text is not null
            && (text.Equals("true", StringComparison.OrdinalIgnoreCase)
                || text.Equals("on", StringComparison.OrdinalIgnoreCase)
                || text.Equals("1", StringComparison.OrdinalIgnoreCase));
    }

    /// <summary>
    /// Форматирует значение item-а для маленьких readout-полей в боковой панели.
    /// </summary>
    private string GetDisplayValue(params string[] names)
    {
        var item = FindItem(names);

        if (item is null)
            return "-";

        if (item.BooleanValue.HasValue)
            return item.BooleanValue.Value ? "on" : "off";

        if (item.NumericValue.HasValue)
            return item.NumericValue.Value.ToString("0.###", CultureInfo.InvariantCulture);

        return string.IsNullOrWhiteSpace(item.ValueText)
            ? "-"
            : item.ValueText;
    }

    /// <summary>
    /// CSS-класс цифрового индикатора DI/DO.
    /// Зеленая заливка повторяет WPF LedBoxValue*Style.
    /// </summary>
    private string GetLedClass(params string[] names)
    {
        return IsOn(names)
            ? "param-digital-led is-on"
            : "param-digital-led";
    }

    /// <summary>
    /// CSS-класс read-only кнопки ручной станции.
    /// В Auto-режиме WPF блокировал кнопки; здесь мы затемняем их, потому что WEB пока read-only.
    /// </summary>
    private static string GetManualButtonClass(bool isActive, bool isAuto)
    {
        var classes = "param-manual-button";

        if (isActive)
            classes += " is-active";

        if (isAuto)
            classes += " is-disabled";

        return classes;
    }

    /// <summary>
    /// CSS-класс нижнего Mode-индикатора.
    /// </summary>
    private string GetModeClass()
    {
        return IsOn("Mode")
            ? "param-side-mode is-auto"
            : "param-side-mode";
    }

    /// <summary>
    /// Текст режима для Motor. В WPF у двигателя ручной режим назывался Service,
    /// поэтому оставляем это отличие от клапанов/ATV.
    /// </summary>
    private string FormatMotorMode()
    {
        return IsOn("Mode") ? "Auto" : "Service";
    }

    /// <summary>
    /// Текст режима для ATV/VGA/VGA_EL/VGD.
    /// </summary>
    private string FormatAutoMode()
    {
        return IsOn("Mode") ? "Auto" : "Manual";
    }

    /// <summary>
    /// true, когда VGA находится в ручном режиме. В WPF поле Man редактировалось только при Mode=false.
    /// </summary>
    private bool IsVgaManualMode => !IsOn("Mode");

    /// <summary>
    /// true, когда поле Man нужно сделать визуально отключенным: нет item-а, нет права записи или VGA в Auto.
    /// </summary>
    private bool IsVgaManFieldDisabled => FindItem("Man")?.CanWrite != true || !IsVgaManualMode;

    /// <summary>
    /// true, когда кнопка Mode не должна открывать запись.
    /// </summary>
    private bool IsModeButtonDisabled => FindItem("Mode")?.CanWrite != true;

    /// <summary>
    /// true, когда кнопки On/Off двигателя не должны запускать запись:
    /// нет Man item-а, он read-only или двигатель находится в Auto.
    /// </summary>
    private bool IsMotorManualButtonDisabled => FindItem("Man")?.CanWrite != true || IsOn("Mode");

    /// <summary>
    /// CSS-класс поля Man. В ручном режиме writable-поле выглядит кликабельным, в Auto - приглушенным.
    /// </summary>
    private string GetVgaManFieldShellClass()
    {
        return IsVgaManFieldDisabled
            ? "param-vga-man-field-shell is-read-only"
            : "param-vga-man-field-shell is-writable";
    }

    /// <summary>
    /// Tooltip для поля Man объясняет, почему оно может быть недоступно.
    /// </summary>
    private string GetVgaManFieldTitle()
    {
        var item = FindItem("Man");

        if (item is null)
            return "Param item is not available";

        if (!item.CanWrite)
            return "Read only";

        return IsVgaManualMode ? "Write value" : "Available only in Manual mode";
    }

    /// <summary>
    /// Открывает общий write-dialog для VGA Man только в ручном режиме.
    /// </summary>
    private async Task RequestVgaManWriteAsync()
    {
        var item = FindItem("Man");

        if (item is null || !item.CanWrite || !IsVgaManualMode)
            return;

        await OnWriteRequested.InvokeAsync(item);
    }

    /// <summary>
    /// Выбирает Radzen-стиль для Motor-кнопки On/Off по текущему значению Man.
    /// </summary>
    private ButtonStyle GetMotorManualButtonStyle(bool requestedValue)
    {
        return IsOn("Man") == requestedValue ? ButtonStyle.Success : ButtonStyle.Base;
    }

    /// <summary>
    /// Задает оттенок Radzen-кнопки Motor On/Off: активная кнопка получает светлый Success-стиль,
    /// чтобы внешний вид соответствовал стандартному варианту Variant.Flat + Shade.Light.
    /// </summary>
    private Shade GetMotorManualButtonShade(bool requestedValue)
    {
        return IsOn("Man") == requestedValue ? Shade.Light : Shade.Default;
    }

    /// <summary>
    /// CSS-класс Motor-кнопки On/Off: активная кнопка получает дополнительный класс,
    /// а в Auto-режиме кнопки визуально остаются заблокированными.
    /// </summary>
    private string GetMotorManualButtonClass(bool requestedValue)
    {
        var classes = "param-motor-manual-button";

        if (IsOn("Man") == requestedValue)
            classes += " is-active";

        if (IsMotorManualButtonDisabled)
            classes += " is-disabled";

        return classes;
    }

    /// <summary>
    /// Открывает общий write-flow для Motor Man с уже выбранным новым boolean-состоянием.
    /// </summary>
    private async Task RequestManualWriteAsync(bool value)
    {
        var item = FindItem("Man");

        if (item is null || !item.CanWrite || IsOn("Mode"))
            return;

        var request = new ParamWriteDialogRequest
        {
            Item = item,
            InitialBooleanValue = value
        };

        if (OnBooleanWriteRequested.HasDelegate)
        {
            await OnBooleanWriteRequested.InvokeAsync(request);
            return;
        }

        await OnWriteRequested.InvokeAsync(item);
    }

    /// <summary>
    /// Открывает общий write-dialog для VGA Mode с инверсией текущего Auto/Manual состояния.
    /// </summary>
    private async Task RequestModeWriteAsync()
    {
        var item = FindItem("Mode");

        if (item is null || !item.CanWrite)
            return;

        var request = new ParamWriteDialogRequest
        {
            Item = item,
            InitialBooleanValue = !IsOn("Mode")
        };

        if (OnBooleanWriteRequested.HasDelegate)
        {
            await OnBooleanWriteRequested.InvokeAsync(request);
            return;
        }

        await OnWriteRequested.InvokeAsync(item);
    }

    /// <summary>
    /// Повторяет WPF-конвертер PlcMotorStatusToTextConverter.
    /// </summary>
    private static string FormatMotorState(double? state)
    {
        if (!state.HasValue)
            return "-";

        var code = (int)Math.Round(state.Value);
        return code switch
        {
            0 => "stop",
            1 => "run",
            2 or 3 => "alarm",
            4 => "starting",
            5 => "stopping",
            6 => "waiting",
            _ => code.ToString(CultureInfo.InvariantCulture)
        };
    }

    /// <summary>
    /// Повторяет WPF-конвертер VGDStateToTextConverter, который используется и для VGA_EL.
    /// </summary>
    private static string FormatValveState(double? state)
    {
        if (!state.HasValue)
            return "-";

        var code = (int)Math.Round(state.Value);
        return code switch
        {
            0 => "closed",
            1 => "opened",
            2 => "alarm opening",
            3 => "alarm closure",
            4 => "opening",
            5 => "closing",
            _ => $"unknown ({code})"
        };
    }
}
