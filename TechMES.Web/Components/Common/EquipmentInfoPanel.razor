    private string GetNoteCardClass(EquipmentInfoNoteDto note)
    {
        var className = "note-card";

        if (_selectedNoteId == note.Id)
            className += " is-selected";

        if (IsNoteEditorActive || _isBusy)
            className += " is-disabled";

        return className;
    }

