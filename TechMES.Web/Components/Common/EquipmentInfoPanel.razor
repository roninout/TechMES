    private static bool ShouldShowLocation(EquipmentDto equipment)
    {
        return !string.IsNullOrWhiteSpace(equipment.Location)
            && !string.Equals(equipment.Location, "Unknown", StringComparison.OrdinalIgnoreCase);
    }

    private static string FormatLocation(string? raw)
    {
        raw = (raw ?? "").Trim();

        if (string.IsNullOrWhiteSpace(raw))
            return "";

        if (raw.Equals("Unknown", StringComparison.OrdinalIgnoreCase))
            return raw;

        var parts = raw.Split('.', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);

        if (parts.Length >= 2)
            return $"module: {parts[0]}, chanel: {parts[1]}";

        return raw;
    }

    private static string GetDescriptionText(EquipmentDto equipment)
    {
        return string.IsNullOrWhiteSpace(equipment.Description)
            ? "-"
            : equipment.Description;
    }

    private static string DisplayValue(string? value)
    {
        return string.IsNullOrWhiteSpace(value)
            ? "-"
            : value.Trim();
    }

    private static string BuildTabText(string text, int count)
    {
        return count > 0
            ? $"{text} ({count})"
            : text;
    }

    /// <summary>
    /// Builds the iframe URL with the remembered page/zoom fragment understood by
    /// common browser PDF viewers.
    /// </summary>
    private string BuildPdfUrl(EquipmentInfoFileDto file)
    {
        var zoom = Math.Clamp(_pdfZoom, 25, 400)
            .ToString("0", System.Globalization.CultureInfo.InvariantCulture);

        return $"{file.ContentUrl}#page={Math.Max(1, _pdfPage)}&zoom={zoom}";
    }

    /// <summary>
    /// Generates the downloadable QR image directly in Blazor, so the QR tab does
    /// not need any backend endpoint for this simple equipment-name payload.
    /// </summary>
    private static string BuildQrPngDataUrl(string text)
    {
        text = (text ?? string.Empty).Trim();
        if (string.IsNullOrWhiteSpace(text))
            text = "qr";

        using var generator = new QRCodeGenerator();
        using var data = generator.CreateQrCode(text, QRCodeGenerator.ECCLevel.Q);
        var png = new PngByteQRCode(data);
        var bytes = png.GetGraphic(pixelsPerModule: 12);

        return "data:image/png;base64," + Convert.ToBase64String(bytes);
    }

    private static string MakeSafeFileName(string text)
    {
        var invalid = Path.GetInvalidFileNameChars();
        var safe = new string((text ?? "qr")
            .Trim()
            .Select(ch => invalid.Contains(ch) ? '_' : ch)
            .ToArray());

        return string.IsNullOrWhiteSpace(safe)
            ? "qr"
            : safe[..Math.Min(safe.Length, 80)];
    }

