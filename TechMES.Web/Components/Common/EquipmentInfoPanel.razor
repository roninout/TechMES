@using QRCoder
@inject InfoApiClient InfoApi
@inject DialogService DialogService
@inject NotificationService NotificationService
@inject EquipmentFooterState EquipmentFooterState
@inject IJSRuntime JSRuntime
@implements IDisposable

<div class="equipment-info-panel">
    @if (Equipment is null)
    {
        <RadzenCard>
            <RadzenText Text="No selected equipment"
                        TextStyle="TextStyle.Subtitle1"
                        Style="color: gray;" />
        </RadzenCard>
    }
    else
    {
        <RadzenCard class="equipment-info-summary-card">
            <div class="equipment-info-summary">
                <div class="equipment-info-main">
                    <div class="equipment-selected-header">
                        <EquipmentTypeBadge TypeGroup="@Equipment.TypeGroup" />

                        <div class="equipment-selected-title">
                            <RadzenText Text="@Equipment.Name" TextStyle="TextStyle.H6" />
                        </div>

                        @if (!Equipment.IsGroup)
                        {
                            <RadzenButton Icon="@GetFavoriteIcon(Equipment)"
                                          ButtonStyle="ButtonStyle.Light"
                                          Size="ButtonSize.Small"
                                          Disabled="@IsFavoriteSaving"
                                          class="@GetFavoriteButtonClass(Equipment)"
                                          title="Favorite"
                                          Click="@ToggleFavoriteAsync" />
                        }
                    </div>

                    <div class="equipment-selected-fields">
                        <span class="equipment-field-label">Type:</span>
                        <span>@DisplayValue(Equipment.TypeName)</span>

                        @if (ShouldShowLocation(Equipment))
                        {
                            <span class="equipment-field-label">Location:</span>
                            <span>@FormatLocation(Equipment.Location)</span>
                        }

                        <span class="equipment-field-label">Supplier:</span>
                        <span>@DisplayValue(_info?.Supplier)</span>

                        <span class="equipment-field-label">Product code:</span>
                        <span>@DisplayValue(_info?.ProductCode)</span>

                        <span class="equipment-field-label">Desc:</span>
                        <span>@GetDescriptionText(Equipment)</span>
                    </div>
                </div>

                <div class="equipment-info-side">
                    @if (!string.IsNullOrWhiteSpace(_info?.SupplierLogoDataUrl))
                    {
                        <img class="supplier-logo"
                             src="@_info.SupplierLogoDataUrl"
                             alt="@DisplayValue(_info.Supplier)" />
                    }

                    @if (GetSummaryPhoto() is { } summaryPhoto)
                    {
                        <img class="summary-photo"
                             src="@summaryPhoto.ContentUrl"
                             alt="@summaryPhoto.DisplayName" />
                    }
                </div>
            </div>
        </RadzenCard>

        @if (!string.IsNullOrWhiteSpace(_statusText))
        {
            <RadzenAlert AlertStyle="@_statusStyle"
                         ShowIcon="true"
                         AllowClose="true"
                         Close="@(() => _statusText = string.Empty)">
                @_statusText
            </RadzenAlert>
        }

        <div class="equipment-info-tabs">
            @if (_isLoading)
            {
                <TechMesLoadingBar />
            }
            else if (_info is null)
            {
                <RadzenAlert AlertStyle="AlertStyle.Info" ShowIcon="true">
                    Info data is not loaded.
                </RadzenAlert>
            }
            else
            {
                <RadzenTabs>
                    <Tabs>
                        @* Иконки вкладок используем через штатный RadzenTabsItem.Icon.
                           Цвет не задается вручную, поэтому активные/неактивные состояния наследуются от текущей темы. *@
                        <RadzenTabsItem Text="Description" Icon="description">
                            <div class="description-block">
                                <div class="description-actions">
                                    @if (_isDescriptionEditing)
                                    {
                                        <RadzenStack Orientation="Orientation.Horizontal" Gap="6px">
                                            <RadzenButton Icon="save"
                                                          Text="Save"
                                                          ButtonStyle="ButtonStyle.Primary"
                                                          Disabled="@_isBusy"
                                                          Click="@SaveDescriptionAsync" />

                                            <RadzenButton Icon="close"
                                                          Text="Cancel"
                                                          ButtonStyle="ButtonStyle.Light"
                                                          Disabled="@_isBusy"
                                                          Click="@CancelDescriptionEdit" />
                                        </RadzenStack>
                                    }
                                    else
                                    {
                                        <RadzenButton Icon="edit"
                                                      Text="Edit"
                                                      ButtonStyle="ButtonStyle.Light"
                                                      Disabled="@_isBusy"
                                                      Click="@BeginDescriptionEdit" />
                                    }
                                </div>

                                @if (_isDescriptionEditing)
                                {
                                    <RadzenTextArea @bind-Value="_editDescription"
                                                    Rows="6"
                                                    class="full-width"
                                                    Disabled="@_isBusy" />
                                }
                                else
                                {
                                    <div class="description-text">@DisplayValue(_info.Description)</div>
                                }
                            </div>
                        </RadzenTabsItem>

                        <RadzenTabsItem>
                            <Template>
                                @RenderTabHeader("Images", "image", PhotoTabCount)
                            </Template>

                            <ChildContent>
                                @if (_info.Photos.Count == 0)
                                {
                                    <RadzenText Text="No images"
                                                TextStyle="TextStyle.Caption"
                                                class="muted-text" />
                                }
                                else
                                {
                                    <RadzenCarousel Auto="false"
                                                    AllowNavigation="@(_info.Photos.Count > 1)"
                                                    AllowPaging="@(_info.Photos.Count > 1)"
                                                    PagerPosition="PagerPosition.Bottom"
                                                    class="photo-carousel">
                                        <Items>
                                            @foreach (var file in _info.Photos)
                                            {
                                                <RadzenCarouselItem>
                                                    <div class="photo-carousel-item">
                                                        <img class="photo-preview"
                                                             src="@file.ContentUrl"
                                                             alt="@file.DisplayName" />

                                                        <div class="photo-caption">@file.DisplayName</div>
                                                    </div>
                                                </RadzenCarouselItem>
                                            }
                                        </Items>
                                    </RadzenCarousel>
                                }
                            </ChildContent>
                        </RadzenTabsItem>

                        <RadzenTabsItem>
                            <Template>
                                @RenderTabHeader("PDF", "picture_as_pdf", PdfTabCount)
                            </Template>

                            <ChildContent>
                                @RenderDocumentPanel(_info.Instructions, _selectedInstruction, SelectInstructionByIdAsync, "No PDF files", "Select PDF", "instruction-pdf-preview")
                            </ChildContent>
                        </RadzenTabsItem>

                        <RadzenTabsItem>
                            <Template>
                                @RenderTabHeader("Schemes", "account_tree", SchemeTabCount)
                            </Template>

                            <ChildContent>
                                @RenderDocumentPanel(_info.Schemes, _selectedScheme, SelectSchemeByIdAsync, "No schemes", "Select scheme", "scheme-pdf-preview")
                            </ChildContent>
                        </RadzenTabsItem>

                        <RadzenTabsItem>
                            <Template>
                                @RenderTabHeader("Notes", "notes", NoteTabCount)
                            </Template>

                            <ChildContent>
                                @{
                                    var selectedNote = GetSelectedNote();
                                }

                                <div class="notes-tab">
                                    <div class="notes-layout">
                                        <div class="notes-list">
                                            @if (_info.Notes.Count == 0)
                                            {
                                                <RadzenText Text="No notes"
                                                            TextStyle="TextStyle.Caption"
                                                            class="muted-text" />
                                            }
                                            else
                                            {
                                                <div class="note-card-list">
                                                    @foreach (var note in _info.Notes)
                                                    {
                                                        <article class="@GetNoteCardClass(note)"
                                                                 @onclick="@(() => SelectNote(note))">
                                                            <div class="note-card-author">@DisplayValue(note.CreatedBy)</div>
                                                            <div class="note-card-date">@FormatNoteDate(note.CreatedAt)</div>
                                                            <div class="note-card-preview">@note.PreviewText</div>
                                                        </article>
                                                    }
                                                </div>
                                            }
                                        </div>

                                        <div class="notes-editor">
                                            <div class="notes-editor-actions">
                                                @if (IsNoteEditorActive)
                                                {
                                                    <RadzenButton Icon="save"
                                                                  Text="Save"
                                                                  ButtonStyle="ButtonStyle.Primary"
                                                                  Disabled="@(_isBusy || string.IsNullOrWhiteSpace(_editNoteText))"
                                                                  Click="@SaveNoteAsync" />

                                                    <RadzenButton Icon="close"
                                                                  Text="Cancel"
                                                                  ButtonStyle="ButtonStyle.Light"
                                                                  Disabled="@_isBusy"
                                                                  Click="@CancelNoteEdit" />
                                                }
                                                else
                                                {
                                                    <RadzenButton Icon="add"
                                                                  Text="Add"
                                                                  ButtonStyle="ButtonStyle.Light"
                                                                  Disabled="@_isBusy"
                                                                  Click="@BeginNoteCreate" />

                                                    <RadzenButton Icon="edit"
                                                                  Text="Edit"
                                                                  ButtonStyle="ButtonStyle.Light"
                                                                  Disabled="@(_isBusy || selectedNote is null)"
                                                                  Click="@BeginSelectedNoteEdit" />

                                                    <RadzenButton Icon="delete"
                                                                  Text="Delete"
                                                                  ButtonStyle="ButtonStyle.Danger"
                                                                  Disabled="@(_isBusy || selectedNote is null)"
                                                                  Click="@DeleteSelectedNoteAsync" />
                                                }
                                            </div>

                                            @if (IsNoteEditorActive)
                                            {
                                                <RadzenTextArea @bind-Value="_editNoteText"
                                                                Placeholder="New note..."
                                                                Rows="12"
                                                                class="note-editor-text full-width"
                                                                Disabled="@_isBusy" />
                                            }
                                            else if (selectedNote is null)
                                            {
                                                <div class="empty-note-view">
                                                    <RadzenText Text="No selected note"
                                                                TextStyle="TextStyle.Caption"
                                                                class="muted-text" />
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="note-view-text">@selectedNote.NoteText</div>

                                                <div class="note-meta note-view-meta">
                                                    <span>Created: @FormatNoteDate(selectedNote.CreatedAt)</span>
                                                    <span>By: @DisplayValue(selectedNote.CreatedBy)</span>

                                                    @if (selectedNote.UpdatedAt is not null)
                                                    {
                                                        <span>Updated: @FormatNoteDate(selectedNote.UpdatedAt.Value)</span>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </ChildContent>
                        </RadzenTabsItem>

                        <RadzenTabsItem Text="QR" Icon="qr_code">
                            <div class="qr-tab">
                                <div class="qr-code-block">
                                    <div class="qr-caption">@Equipment.Name</div>

                                    <img class="qr-image"
                                         src="@QrPngDataUrl"
                                         alt="@($"QR {Equipment.Name}")" />

                                    <a class="qr-download-link"
                                       href="@QrPngDataUrl"
                                       download="@QrFileName">
                                        Download PNG
                                    </a>
                                </div>

                            </div>
                        </RadzenTabsItem>
                    </Tabs>
                </RadzenTabs>
            }
        </div>
    }
</div>

@code {
    /// <summary>
    /// Оборудование, выбранное в дереве слева.
    /// </summary>
    [Parameter]
    public EquipmentDto? Equipment { get; set; }

    /// <summary>
    /// true, пока родительская Equipment.razor сохраняет favorite-флаг.
    /// </summary>
    [Parameter]
    public bool IsFavoriteSaving { get; set; }

    /// <summary>
    /// Команда переключения favorite, реализованная на уровне Equipment.razor.
    /// </summary>
    [Parameter]
    public EventCallback OnToggleFavorite { get; set; }

    /// <summary>
    /// Событие изменения счетчиков фото/PDF/схем/notes для обновления дерева и footer.
    /// </summary>
    [Parameter]
    public EventCallback OnInfoCountsChanged { get; set; }

    /// <summary>
    /// Текущий snapshot Info-модуля для выбранного оборудования.
    /// </summary>
    private EquipmentInfoDto? _info;

    /// <summary>
    /// Выбранное фото в Images carousel.
    /// </summary>
    private EquipmentInfoFileDto? _selectedPhoto;

    /// <summary>
    /// Выбранный PDF instruction.
    /// </summary>
    private EquipmentInfoFileDto? _selectedInstruction;

    /// <summary>
    /// Выбранная PDF scheme.
    /// </summary>
    private EquipmentInfoFileDto? _selectedScheme;

    /// <summary>
    /// true, пока идет загрузка Info DTO.
    /// </summary>
    private bool _isLoading;

    /// <summary>
    /// true, пока идет сохранение description/note/document position.
    /// </summary>
    private bool _isSaving;

    /// <summary>
    /// Режим редактирования вкладки Description.
    /// </summary>
    private bool _isDescriptionEditing;

    /// <summary>
    /// Режим создания новой note.
    /// </summary>
    private bool _isNoteCreating;

    /// <summary>
    /// Режим редактирования существующей note.
    /// </summary>
    private bool _isNoteEditing;

    /// <summary>
    /// Id note, которая сейчас редактируется.
    /// </summary>
    private long? _editingNoteId;

    /// <summary>
    /// Id note, выбранной в списке cards слева.
    /// </summary>
    private long? _selectedNoteId;

    /// <summary>
    /// Версия загрузки. Помогает отбросить устаревшие HTTP-ответы.
    /// </summary>
    private int _loadVersion;

    /// <summary>
    /// Имя оборудования, для которого сейчас загружен _info.
    /// </summary>
    private string? _loadedEquipmentName;

    /// <summary>
    /// Текст description во время редактирования.
    /// </summary>
    private string _editDescription = string.Empty;

    /// <summary>
    /// Текст note во время создания или редактирования.
    /// </summary>
    private string _editNoteText = string.Empty;

    /// <summary>
    /// Status message панели Info.
    /// </summary>
    private string _statusText = string.Empty;

    /// <summary>
    /// Стиль status alert панели Info.
    /// </summary>
    private AlertStyle _statusStyle = AlertStyle.Info;

    /// <summary>
    /// Сохраненная/текущая PDF page для iframe fragment.
    /// </summary>
    private int _pdfPage = 1;

    /// <summary>
    /// Редактируемое значение PDF page в Remember editor.
    /// </summary>
    private int _editPdfPage = 1;

    /// <summary>
    /// Сохраненный/текущий PDF zoom в процентах.
    /// </summary>
    private double _pdfZoom = 100;

    /// <summary>
    /// Редактируемое значение PDF zoom в Remember editor.
    /// </summary>
    private double _editPdfZoom = 100;

    /// <summary>
    /// true, когда открыт встроенный editor позиции PDF.
    /// </summary>
    private bool _isDocumentPositionEditing;

    /// <summary>
    /// Общий busy-флаг для отключения кнопок во время загрузки/сохранения.
    /// </summary>
    private bool _isBusy => _isLoading || _isSaving;

    /// <summary>
    /// true, когда textarea note должна быть видимой.
    /// </summary>
    private bool IsNoteEditorActive => _isNoteCreating || _isNoteEditing;

    /// <summary>
    /// Количество фото для вкладки Images и footer.
    /// </summary>
    private int PhotoTabCount => _info is null ? 0 : Math.Max(_info.PhotoCount, _info.Photos.Count);

    /// <summary>
    /// Количество PDF-инструкций для вкладки PDF и footer.
    /// </summary>
    private int PdfTabCount => _info is null ? 0 : Math.Max(_info.InstructionCount, _info.Instructions.Count);

    /// <summary>
    /// Количество схем для вкладки Schemes и footer.
    /// </summary>
    private int SchemeTabCount => _info is null ? 0 : Math.Max(_info.SchemeCount, _info.Schemes.Count);

    /// <summary>
    /// Количество notes для вкладки Notes и footer.
    /// </summary>
    private int NoteTabCount => _info?.Notes.Count ?? 0;

    /// <summary>
    /// Заголовок вкладки Images со счетчиком, если он больше нуля.
    /// </summary>
    private string ImagesTabText => BuildTabText("Images", PhotoTabCount);

    /// <summary>
    /// Заголовок вкладки PDF со счетчиком, если он больше нуля.
    /// </summary>
    private string PdfTabText => BuildTabText("PDF", PdfTabCount);

    /// <summary>
    /// Заголовок вкладки Schemes со счетчиком, если он больше нуля.
    /// </summary>
    private string SchemesTabText => BuildTabText("Schemes", SchemeTabCount);

    /// <summary>
    /// Заголовок вкладки Notes со счетчиком, если он больше нуля.
    /// </summary>
    private string NotesTabText => BuildTabText("Notes", NoteTabCount);

    /// <summary>
    /// Data URL QR-кода для текущего оборудования.
    /// </summary>
    private string QrPngDataUrl => Equipment is null ? string.Empty : BuildQrPngDataUrl(Equipment.Name);

    /// <summary>
    /// Безопасное имя файла для скачивания QR PNG.
    /// </summary>
    private string QrFileName => MakeSafeFileName(Equipment?.Name ?? "qr") + ".png";

    /// <summary>
    /// Рисует шаблон заголовка вкладки Info-раздела.
    /// Счетчик выводится отдельным RadzenBadge и не смешивается с текстом вкладки.
    /// При count = 0 badge не рисуется, чтобы не показывать пустые "(0)".
    /// </summary>
    private static RenderFragment RenderTabHeader(string text, string icon, int count) => @<span class="@GetInfoTabHeaderClass(count)">
        <RadzenIcon Icon="@icon" />
        <span>@text</span>
        @if (count > 0)
        {
            <RadzenBadge Text="@count.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                         BadgeStyle="BadgeStyle.Primary"
                         Variant="Variant.Outlined"
                         IsPill="true"
                         class="info-tab-counter-badge" />
        }
    </span>;

    /// <summary>
    /// Выбирает CSS-класс заголовка вкладки: если есть счетчик, вкладка получает вид компактной Radzen-кнопки с badge.
    /// </summary>
    private static string GetInfoTabHeaderClass(int count)
    {
        return count > 0 ? "info-tab-header has-count" : "info-tab-header";
    }

    /// <summary>
    /// Общий RenderFragment для вкладок PDF и Schemes:
    /// selector файла, fullscreen, Remember editor и iframe preview.
    /// </summary>
    private RenderFragment RenderDocumentPanel(
        IReadOnlyList<EquipmentInfoFileDto> files,
        EquipmentInfoFileDto? selectedFile,
        Func<long?, Task> selectFileByIdAsync,
        string emptyText,
        string placeholderText,
        string frameId) => @<div class="document-view">
            @if (files.Count == 0)
            {
                <RadzenText Text="@emptyText"
                            TextStyle="TextStyle.Caption"
                            class="muted-text" />
            }
            else
            {
                <div class="document-toolbar">
                    <RadzenDropDown TValue="long?"
                                    Data="@files"
                                    TextProperty="@nameof(EquipmentInfoFileDto.DisplayName)"
                                    ValueProperty="@nameof(EquipmentInfoFileDto.Id)"
                                    Value="@selectedFile?.Id"
                                    Change="@((object? value) => selectFileByIdAsync(ToNullableLong(value)))"
                                    Placeholder="@placeholderText"
                                    class="document-file-selector" />

                    <div class="document-toolbar-actions">
                        <RadzenButton Icon="fullscreen"
                                      Text="Full screen"
                                      ButtonStyle="ButtonStyle.Light"
                                      Disabled="@(selectedFile is null)"
                                      Click="@(() => OpenDocumentFullScreenAsync(selectedFile))" />

                        <RadzenButton Icon="my_location"
                                      Text="Remember"
                                      ButtonStyle="ButtonStyle.Light"
                                      Disabled="@(_isBusy || selectedFile is null)"
                                      Click="@(() => selectedFile is null ? Task.CompletedTask : BeginPdfPositionEditAsync(selectedFile, frameId))" />
                    </div>
                </div>

                @if (_isDocumentPositionEditing && selectedFile is not null)
                {
                    <div class="document-position-editor">
                        <RadzenNumeric TValue="int"
                                       @bind-Value="_editPdfPage"
                                       Min="1"
                                       Placeholder="Page"
                                       class="document-position-input" />

                        <RadzenNumeric TValue="double"
                                       @bind-Value="_editPdfZoom"
                                       Min="25"
                                       Max="400"
                                       Step="5"
                                       Placeholder="Zoom"
                                       class="document-position-input" />

                        <RadzenButton Icon="save"
                                      Text="Save"
                                      ButtonStyle="ButtonStyle.Primary"
                                      Disabled="@_isBusy"
                                      Click="@(() => SavePdfPositionEditAsync(selectedFile))" />

                        <RadzenButton Icon="close"
                                      Text="Cancel"
                                      ButtonStyle="ButtonStyle.Light"
                                      Disabled="@_isBusy"
                                      Click="@CancelPdfPositionEdit" />
                    </div>
                }

                @if (selectedFile is null)
                {
                    <RadzenText Text="@placeholderText"
                                TextStyle="TextStyle.Caption"
                                class="muted-text" />
                }
                else
                {
                    <iframe id="@frameId"
                            class="pdf-preview"
                            src="@BuildPdfUrl(selectedFile)"
                            title="@selectedFile.DisplayName"></iframe>
                }
            }
        </div>;

    protected override async Task OnParametersSetAsync()
    {
        if (Equipment is null)
        {
            ClearInfoState();
            return;
        }

        if (string.Equals(_loadedEquipmentName, Equipment.Name, StringComparison.OrdinalIgnoreCase))
            return;

        await LoadInfoAsync(Equipment.Name);
    }

    /// <summary>
    /// Загружает snapshot Info-модуля для выбранного оборудования.
    /// Если пользователь быстро переключил оборудование, устаревший ответ игнорируется.
    /// </summary>
    private async Task LoadInfoAsync(string equipmentName)
    {
        equipmentName = (equipmentName ?? string.Empty).Trim();
        if (string.IsNullOrWhiteSpace(equipmentName))
            return;

        var loadVersion = ++_loadVersion;

        _isLoading = true;
        _info = null;
        _loadedEquipmentName = equipmentName;
        EquipmentFooterState.ClearInfoCounts();
        ClearEditState();
        ResetPdfViewState();

        try
        {
            var info = await InfoApi.GetInfoAsync(equipmentName);

            if (loadVersion != _loadVersion)
                return;

            _info = info;
            _editDescription = _info.Description ?? string.Empty;
            EnsureSelectedNote();
            UpdateFooterInfoCounts();
            await ApplyDefaultFileSelectionAsync();
            ClearStatus();
        }
        catch (Exception ex)
        {
            if (loadVersion != _loadVersion)
                return;

            SetStatus(AlertStyle.Warning, "Cannot load equipment info: " + ex.Message);
        }
        finally
        {
            if (loadVersion == _loadVersion)
                _isLoading = false;
        }
    }

    private void BeginDescriptionEdit()
    {
        if (_info is null)
            return;

        _editDescription = _info.Description ?? string.Empty;
        _isDescriptionEditing = true;
    }

    private void CancelDescriptionEdit()
    {
        _editDescription = _info?.Description ?? string.Empty;
        _isDescriptionEditing = false;
    }

    /// <summary>
    /// Сохраняет редактируемое описание через Runtime.Service и восстанавливает
    /// текущий выбор file/note, потому что backend возвращает свежий Info DTO.
    /// </summary>
    private async Task SaveDescriptionAsync()
    {
        if (_info is null)
            return;

        _isSaving = true;

        try
        {
            var photoId = _selectedPhoto?.Id;
            var instructionId = _selectedInstruction?.Id;
            var schemeId = _selectedScheme?.Id;
            var selectedNoteId = _selectedNoteId;

            _info = await InfoApi.SaveDescriptionAsync(
                _info.EquipName,
                _editDescription);

            _editDescription = _info.Description ?? string.Empty;
            _isDescriptionEditing = false;
            _selectedNoteId = SelectPreferredNoteId(selectedNoteId);
            UpdateFooterInfoCounts();
            await ApplyFileSelectionAsync(photoId, instructionId, schemeId);

            Notify(NotificationSeverity.Success, "Info", "Description saved.");
            ClearStatus();
        }
        catch (Exception ex)
        {
            SetStatus(AlertStyle.Danger, "Cannot save description: " + ex.Message);
            Notify(NotificationSeverity.Error, "Info", "Cannot save description.");
        }
        finally
        {
            _isSaving = false;
        }
    }

    /// <summary>
    /// Выбирает первый доступный image/PDF/scheme после загрузки данных,
    /// но старается сохранить прежний выбор file/note пользователя.
    /// </summary>
    private async Task ApplyDefaultFileSelectionAsync()
    {
        await ApplyFileSelectionAsync(
            _selectedPhoto?.Id,
            _selectedInstruction?.Id,
            _selectedScheme?.Id);
    }

    private async Task ApplyFileSelectionAsync(
        long? preferredPhotoId,
        long? preferredInstructionId,
        long? preferredSchemeId)
    {
        if (_info is null)
        {
            _selectedPhoto = null;
            _selectedInstruction = null;
            _selectedScheme = null;
            return;
        }

        _selectedPhoto = SelectPreferredFile(_info.Photos, preferredPhotoId);
        _selectedInstruction = SelectPreferredFile(_info.Instructions, preferredInstructionId);
        _selectedScheme = SelectPreferredFile(_info.Schemes, preferredSchemeId);

        if (_selectedInstruction is not null)
            await LoadPdfViewStateAsync(_selectedInstruction);
        else if (_selectedScheme is not null)
            await LoadPdfViewStateAsync(_selectedScheme);
        else
            ResetPdfViewState();
    }

    private static EquipmentInfoFileDto? SelectPreferredFile(
        IReadOnlyList<EquipmentInfoFileDto> files,
        long? preferredId)
    {
        if (files.Count == 0)
            return null;

        if (preferredId is not null)
        {
            var preferred = files.FirstOrDefault(x => x.Id == preferredId.Value);
            if (preferred is not null)
                return preferred;
        }

        return files[0];
    }

    private Task SelectInstructionByIdAsync(long? fileId)
    {
        var file = FindFile(_info?.Instructions, fileId);
        return file is null
            ? Task.CompletedTask
            : SelectInstructionAsync(file);
