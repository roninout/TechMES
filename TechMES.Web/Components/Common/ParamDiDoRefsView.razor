@using TechMES.Contracts.Param

@if (Response is null)
{
    <RadzenAlert AlertStyle="AlertStyle.Info" ShowIcon="true">
        DI/DO references are not loaded yet.
    </RadzenAlert>
}
else if (!Response.Supported)
{
    <RadzenAlert AlertStyle="AlertStyle.Info" ShowIcon="true">
        @DisplayValue(Response.Message)
    </RadzenAlert>
}
else
{
    <div class="param-dido-layout">
        @RenderPanel("DI", "input", Response.DiRows, "No DI references.")
        @RenderPanel("DO", "input", Response.DoRows, "No DO references.", "is-rotated-180")
    </div>
}

@code {
    /// <summary>
    /// Ответ Runtime.Service с DI/DO reference rows.
    /// Данные уже включают текущее значение, force-флаги и короткий номер канала.
    /// </summary>
    [Parameter]
    public ParamDiDoRefsResponse? Response { get; set; }

    /// <summary>
    /// Событие выбора связанного оборудования из DI/DO строки.
    /// Родительская Param-панель переключает выбранный equipment в общем списке.
    /// </summary>
    [Parameter]
    public EventCallback<string> OnSelectEquipment { get; set; }

    /// <summary>
    /// Рисует одну вертикальную панель DI или DO.
    /// Панель сделана через общий ParamAiPanel, чтобы заголовок, бордер и themed-цвета совпадали с Settings/Alarm.
    /// </summary>
    private RenderFragment RenderPanel(
        string title,
        string icon,
        IReadOnlyList<ParamDiDoRefDto> rows,
        string emptyText,
        string? iconClass = null) => @<ParamAiPanel Title="@title" Icon="@icon" IconClass="@iconClass">
        <div class="param-dido-panel-body">
            @if (rows.Count == 0)
            {
                <div class="param-ref-empty">@emptyText</div>
            }
            else
            {
                @foreach (var row in rows)
                {
                    @RenderRow(row)
                }
            }
        </div>
    </ParamAiPanel>;

    /// <summary>
    /// Рисует одну строку DI/DO в WPF-like стиле: описание, forced-индикатор, read-only on/off, канал и кнопка перехода.
    /// </summary>
    private RenderFragment RenderRow(ParamDiDoRefDto row) => @<div class="param-dido-row">
        <div class="param-dido-row-title" title="@row.Title">
            <span class="param-dido-row-equipment">@row.EquipmentName</span>
            @if (!string.IsNullOrWhiteSpace(row.Description))
            {
                <span class="param-dido-row-separator">:</span>
                <span class="param-dido-row-description">@row.Description</span>
            }
        </div>

        <span class="@GetForcedClass(row)">Forced</span>
        <span class="@GetValueClass(row)">@FormatValue(row)</span>
        <span class="param-dido-channel">@DisplayValue(row.ChanelShort)</span>

        <RadzenButton Icon="open_in_new"
                      ButtonStyle="ButtonStyle.Light"
                      Size="ButtonSize.Small"
                      class="param-dido-go-button"
                      title="Go to equipment"
                      Click="@(() => SelectEquipmentAsync(row.EquipmentName))" />
    </div>;

    /// <summary>
    /// Передает выбранное equipment name родительской Param-панели.
    /// </summary>
    private Task SelectEquipmentAsync(string equipmentName)
    {
        return OnSelectEquipment.HasDelegate
            ? OnSelectEquipment.InvokeAsync(equipmentName)
            : Task.CompletedTask;
    }

    /// <summary>
    /// Форматирует DI/DO value в компактный on/off или исходный текст, если значение не boolean.
    /// </summary>
    private static string FormatValue(ParamDiDoRefDto row)
    {
        if (row.BooleanValue.HasValue)
            return row.BooleanValue.Value ? "on" : "off";

        return string.IsNullOrWhiteSpace(row.ValueText)
            ? "-"
            : row.ValueText;
    }

    /// <summary>
    /// CSS-класс read-only кнопки значения.
    /// Зеленый on и серый off повторяют смысл WPF-прямоугольника значения.
    /// </summary>
    private static string GetValueClass(ParamDiDoRefDto row)
    {
        if (row.BooleanValue == true)
            return "param-dido-value is-on";

        if (row.BooleanValue == false)
            return "param-dido-value is-off";

        return "param-dido-value";
    }

    /// <summary>
    /// CSS-класс forced-индикатора. Невидимый вариант сохраняет ширину колонки, чтобы строки не прыгали.
    /// </summary>
    private static string GetForcedClass(ParamDiDoRefDto row)
    {
        return row.ForceCmd || row.ValueForced
            ? "param-dido-forced is-active"
            : "param-dido-forced";
    }

    /// <summary>
    /// Нормализует пустые значения для UI.
    /// </summary>
    private static string DisplayValue(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? "-" : value;
    }
}
