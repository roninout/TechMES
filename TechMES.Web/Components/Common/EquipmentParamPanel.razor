    /// <summary>
    /// Открывает Radzen Dialog для ввода нового значения Param item.
    /// Диалог возвращает только значение; audit-comment формируется автоматически.
    /// </summary>
    private async Task BeginParamWriteAsync(ParamItemDto item)
    {
        if (Equipment is null || item is null || !item.CanWrite || _isWriting)
            return;

        var result = await DialogService.OpenAsync<ParamWriteDialog>(
            $"Write: {item.Name}",
            new Dictionary<string, object?>
            {
                [nameof(ParamWriteDialog.Item)] = item
            },
            new DialogOptions
            {
                Width = "420px",
                CloseDialogOnOverlayClick = false,
                CloseDialogOnEsc = true
            });

        if (result is not ParamWriteDialogResult writeResult)
            return;

        await SaveParamWriteAsync(item, writeResult.Value);
    }

    /// <summary>
    /// Выполняет write-flow после закрытия диалога: опциональный confirm,
    /// POST в Runtime.Service, отображение результата и повторное чтение snapshot.
    /// </summary>
    private async Task SaveParamWriteAsync(ParamItemDto item, string value)
    {
        if (Equipment is null || item is null || !item.CanWrite || string.IsNullOrWhiteSpace(value))
            return;

        var equipmentName = Equipment.Name;
        var comment = BuildDefaultWriteComment(item);

        if (_confirmWrites && !await ConfirmParamWriteAsync(equipmentName, item, value))
            return;

        _isWriting = true;

        try
        {
            var response = await ParamApi.WriteAsync(
                equipmentName,
                new ParamWriteRequest
                {
                    ItemName = item.Name,
                    Value = value,
                    Comment = comment
                },
                GetActiveLoadToken());

            if (response.Success)
            {
                var auditWarning = !response.DryRun && response.AuditAttempted && !response.AuditSucceeded;
                _statusStyle = response.DryRun
                    ? AlertStyle.Info
                    : auditWarning
                        ? AlertStyle.Warning
                        : AlertStyle.Success;
                _statusText = BuildWriteStatus(response, item);

                NotificationService.Notify(new NotificationMessage
                {
                    Severity = response.DryRun
                        ? NotificationSeverity.Info
                        : auditWarning
                            ? NotificationSeverity.Warning
                            : NotificationSeverity.Success,
                    Summary = "Param write",
                    Detail = response.Message ?? _statusText,
                    Duration = 3500
                });

                await LoadAsync(showLoading: false, includeTrend: IsGraphTabVisible, ct: GetActiveLoadToken());
            }
            else
            {
                _statusStyle = AlertStyle.Warning;
                _statusText = response.Error ?? response.Message ?? "Param write was rejected.";

                NotificationService.Notify(new NotificationMessage
                {
                    Severity = NotificationSeverity.Warning,
                    Summary = "Param write",
                    Detail = _statusText,
                    Duration = 4500
                });
            }
        }
        catch (Exception ex)
        {
            _statusStyle = AlertStyle.Danger;
            _statusText = "Cannot write Param value: " + ex.Message;

            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Error,
                Summary = "Param write",
                Detail = "Cannot write Param value.",
                Duration = 4500
            });
        }
        finally
        {
            _isWriting = false;
        }
    }

    /// <summary>
    /// Открывает встроенный редактор записи для одного Param item.
    /// Метод вызывается из ParamItemsTable только для CanWrite=true.
    /// </summary>
    private void BeginParamWrite(ParamItemDto item)
    {
        if (Equipment is null || item is null || !item.CanWrite || _isWriting)
            return;

        _writeItem = item;
        _writeComment = item.Name;

        if (item.Kind == ParamValueKind.Boolean)
        {
            _writeBooleanValue = item.BooleanValue == true;
            _writeValueText = _writeBooleanValue ? "1" : "0";
        }
        else
        {
            _writeValueText = !string.IsNullOrWhiteSpace(item.ValueText)
                ? item.ValueText
                : item.NumericValue.HasValue
                    ? FormatWriteNumber(item.NumericValue.Value)
                    : "";
        }
    }

    /// <summary>
    /// Закрывает редактор записи без отправки запроса в Runtime.Service.
    /// Во время активной записи закрытие запрещено, чтобы не потерять состояние операции.
    /// </summary>
    private void CancelParamWrite()
    {
        if (_isWriting)
            return;

        _writeItem = null;
        _writeValueText = "";
        _writeBooleanValue = false;
        _writeComment = "";
    }

    /// <summary>
    /// Проверяет, можно ли нажать Write: выбран item, есть комментарий и новое значение.
    /// Backend все равно повторно валидирует запрос, это только UX-фильтр.
    /// </summary>
    private bool CanSubmitParamWrite()
    {
        if (_writeItem is null)
            return false;

        if (string.IsNullOrWhiteSpace(_writeComment))
            return false;

        return _writeItem.Kind == ParamValueKind.Boolean
            || !string.IsNullOrWhiteSpace(_writeValueText);
    }

    /// <summary>
    /// Полный UI write-flow: подтверждение оператора, POST в Runtime.Service,
    /// отображение результата и повторное чтение snapshot после успешной операции.
    /// </summary>
    private async Task SaveParamWriteAsync()
    {
        if (Equipment is null || _writeItem is null || !CanSubmitParamWrite())
            return;

        var equipmentName = Equipment.Name;
        var item = _writeItem;
        var value = item.Kind == ParamValueKind.Boolean
            ? (_writeBooleanValue ? "1" : "0")
            : _writeValueText.Trim();

        if (!await ConfirmParamWriteAsync(equipmentName, item, value))
            return;

        _isWriting = true;

        try
        {
            var response = await ParamApi.WriteAsync(
                equipmentName,
                new ParamWriteRequest
                {
                    ItemName = item.Name,
                    Value = value,
                    Comment = _writeComment.Trim()
                },
                GetActiveLoadToken());

            if (response.Success)
            {
                var auditWarning = !response.DryRun && response.AuditAttempted && !response.AuditSucceeded;
                _statusStyle = response.DryRun
                    ? AlertStyle.Info
                    : auditWarning
                        ? AlertStyle.Warning
                        : AlertStyle.Success;
                _statusText = BuildWriteStatus(response, item);

                NotificationService.Notify(new NotificationMessage
                {
                    Severity = response.DryRun
                        ? NotificationSeverity.Info
                        : auditWarning
                            ? NotificationSeverity.Warning
                            : NotificationSeverity.Success,
                    Summary = "Param write",
                    Detail = response.Message ?? _statusText,
                    Duration = 3500
                });

                CancelParamWriteAfterSave();
                await LoadAsync(showLoading: false, includeTrend: IsGraphTabVisible, ct: GetActiveLoadToken());
            }
            else
            {
                _statusStyle = AlertStyle.Warning;
                _statusText = response.Error ?? response.Message ?? "Param write was rejected.";

                NotificationService.Notify(new NotificationMessage
                {
                    Severity = NotificationSeverity.Warning,
                    Summary = "Param write",
                    Detail = _statusText,
                    Duration = 4500
                });
            }
        }
        catch (Exception ex)
        {
            _statusStyle = AlertStyle.Danger;
            _statusText = "Cannot write Param value: " + ex.Message;

            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Error,
                Summary = "Param write",
                Detail = "Cannot write Param value.",
                Duration = 4500
            });
        }
        finally
        {
            _isWriting = false;
        }
    }

    /// <summary>
    /// Показывает подтверждение перед записью.
    /// Для ForceCmd=on текст сделан более строгим, как в WPF-проекте.
    /// </summary>
    private async Task<bool> ConfirmParamWriteAsync(string equipmentName, ParamItemDto item, string value)
    {
        var current = FormatValue(item);
        var enablesForce = item.Name.Equals("ForceCmd", StringComparison.OrdinalIgnoreCase)
            && item.Kind == ParamValueKind.Boolean
            && value == "1";

        var title = enablesForce ? "Attention!!!" : "Confirm Param write";
        var message = enablesForce
            ? $"Do you really want to enable channel forcing?\n\nEquipment: {equipmentName}\nItem: {item.Name}\nCurrent: {current}\nNew: on"
            : $"Write Param value?\n\nEquipment: {equipmentName}\nItem: {item.Name}\nCurrent: {current}\nNew: {DisplayValue(value)}";

        var confirmed = await DialogService.Confirm(
            message,
            title,
            new ConfirmOptions
            {
                OkButtonText = "Write",
                CancelButtonText = "Cancel"
            });

        return confirmed == true;
    }

    /// <summary>
    /// Формирует автоматический комментарий для audit/Cicode SaveActionOperators.
    /// Поле ввода комментария в UI убрано, поэтому по договоренности используем имя изменяемого Param item.
    /// </summary>
    private static string BuildDefaultWriteComment(ParamItemDto item)
    {
        return item.Name;
    }

    /// <summary>
    /// Собирает короткую строку статуса после записи: режим, старое/новое значение,
    /// tag и результат audit, если он выполнялся.
    /// </summary>
    private static string BuildWriteStatus(ParamWriteResponse response, ParamItemDto item)
    {
        var mode = response.DryRun ? "Dry-run OK" : "Wrote";
        var current = string.IsNullOrWhiteSpace(response.CurrentValue)
            ? "-"
            : response.CurrentValue;
        var written = string.IsNullOrWhiteSpace(response.WrittenValue)
            ? "-"
            : response.WrittenValue;

        var parts = new List<string>
        {
            $"{mode}: {response.EquipmentName}.{item.Name} {current} -> {written}"
        };

        if (!string.IsNullOrWhiteSpace(response.TagName))
            parts.Add($"Tag: {response.TagName}");

        if (response.AuditAttempted)
            parts.Add(response.AuditSucceeded ? "Audit: OK" : "Audit: failed");

        return string.Join(" | ", parts);
    }

    /// <summary>
    /// Сбрасывает editor после успешной операции.
    /// Вынесено отдельно, чтобы не смешивать cleanup с логикой HTTP-запроса.
    /// </summary>
    private void CancelParamWriteAfterSave()
    {
        _writeItem = null;
        _writeValueText = "";
        _writeBooleanValue = false;
        _writeComment = "";
    }

    /// <summary>
    /// Загружает reference page для текущей вкладки: PLC, DI/DO, DryRun или ATV.
    /// </summary>
    private async Task LoadSelectedReferencePageAsync(CancellationToken ct)
    {
        if (Equipment is null || !IsActive || ct.IsCancellationRequested)
            return;

        var selectedTab = SelectedTabKind;

        if (selectedTab is not (
            ParamPanelTabKind.Plc
            or ParamPanelTabKind.DiDo
            or ParamPanelTabKind.DryRun
            or ParamPanelTabKind.Atv))
        {
            return;
        }

        _isRefsLoading = selectedTab switch
        {
            ParamPanelTabKind.Plc => _plcRefs is null,
            ParamPanelTabKind.DiDo => _diDoRefs is null,
            ParamPanelTabKind.DryRun => _dryRun is null,
            ParamPanelTabKind.Atv => _atvRef is null,
            _ => false
        };

        try
        {
            if (selectedTab == ParamPanelTabKind.Plc)
            {
                _plcRefs = await ParamApi.GetPlcRefsAsync(Equipment.Name, ct);
            }
            else if (selectedTab == ParamPanelTabKind.DiDo)
            {
                _diDoRefs = await ParamApi.GetDiDoRefsAsync(Equipment.Name, ct);
            }
            else if (selectedTab == ParamPanelTabKind.DryRun)
            {
                _dryRun = await ParamApi.GetDryRunAsync(Equipment.Name, ct);
            }
            else if (selectedTab == ParamPanelTabKind.Atv)
            {
                _atvRef = await ParamApi.GetAtvRefAsync(Equipment.Name, ct);
            }
        }
        catch (OperationCanceledException) when (ct.IsCancellationRequested || _isDisposed || !IsActive)
        {
        }
        catch (Exception ex)
        {
            if (_isDisposed || !IsActive)
                return;

            _statusStyle = AlertStyle.Warning;
            _statusText = $"Cannot load {GetReferencePageTitle(selectedTab)} references: {ex.Message}";
        }
        finally
        {
            if (!_isDisposed)
                _isRefsLoading = false;
        }
    }

    /// <summary>
    /// Возвращает UTC-диапазон исторического буфера, который нужно запросить у Runtime.Service.
