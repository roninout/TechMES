@using TechMES.Contracts.Equipment
@using TechMES.Contracts.Param
@using System.Globalization
@using TechMES.Web.Settings
@inject ParamApiClient ParamApi
@inject Microsoft.Extensions.Options.IOptions<ParamUiOptions> ParamOptions
@inject DialogService DialogService
@inject NotificationService NotificationService
@implements IDisposable

<div class="equipment-param-panel">
    @if (Equipment is null)
    {
        <RadzenCard>
            <RadzenText Text="No selected equipment"
                        TextStyle="TextStyle.Subtitle1"
                        Style="color: gray;" />
        </RadzenCard>
    }
    else
    {
        <RadzenCard class="equipment-param-summary-card">
            <div class="equipment-param-summary">
                @* Param намеренно показывает только идентификационную строку.
                   Полная карточка с полями, логотипом и фотографией остается в EquipmentInfoPanel. *@
                <div class="equipment-selected-header equipment-param-selected-header">
                    <EquipmentTypeBadge TypeGroup="@Equipment.TypeGroup" />

                    <div class="equipment-param-title-block">
                        <div class="equipment-param-title-row">
                            <div class="equipment-selected-title">
                                <RadzenText Text="@Equipment.Name" TextStyle="TextStyle.H6" />
                            </div>

                            @if (!Equipment.IsGroup)
                            {
                                <RadzenButton Icon="@GetFavoriteIcon(Equipment)"
                                              ButtonStyle="ButtonStyle.Light"
                                              Size="ButtonSize.Small"
                                              Disabled="@IsFavoriteSaving"
                                              class="@GetFavoriteButtonClass(Equipment)"
                                              title="Favorite"
                                              Click="@ToggleFavoriteAsync" />
                            }
                        </div>

                        @* В Param показываем компактную подпись тем же текстом, который виден в дереве слева.
                           Пустое описание или дубль имени не отображаются, чтобы верхняя карточка не раздувалась. *@
                        @{
                            var paramDescription = GetParamDescriptionText(Equipment);
                        }

                        @if (!string.IsNullOrWhiteSpace(paramDescription))
                        {
                            <div class="equipment-param-description">@paramDescription</div>
                        }
                    </div>
                </div>
            </div>
        </RadzenCard>

        @if (!string.IsNullOrWhiteSpace(_statusText))
        {
            <RadzenAlert AlertStyle="@_statusStyle"
                         ShowIcon="true"
                         AllowClose="true"
                         Close="@(() => _statusText = string.Empty)">
                @_statusText
            </RadzenAlert>
        }

        <div class="equipment-param-tabs">
            @if (_isLoading)
            {
                <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" />
            }
            else if (_snapshot is null)
            {
                <RadzenAlert AlertStyle="AlertStyle.Info" ShowIcon="true">
                    Param data is not loaded.
                </RadzenAlert>
            }
            else if (!_snapshot.Supported)
            {
                <RadzenAlert AlertStyle="AlertStyle.Warning" ShowIcon="true">
                    @DisplayValue(_snapshot.Message)
                </RadzenAlert>
            }
            else
            {
                <RadzenTabs RenderMode="TabRenderMode.Server"
                            @bind-SelectedIndex="_selectedTabIndex"
                            Change="@OnTabChangedAsync">
                    <Tabs>
                        @* Иконки вкладок Param остаются themed: Radzen сам окрашивает их по активной теме и состоянию вкладки. *@
                        <RadzenTabsItem Text="Graph" Icon="area_chart">
                            <div class="param-graph-panel">
                                <div class="param-toolbar">
                                    <div class="param-toolbar-side-slot">
                                        @if (IsAiEquipment)
                                        {
                                            @* Поле R вынесено в общий верхний row Graph, чтобы оно не попадало
                                               внутрь абсолютной зоны барграфов и не нарушало их выравнивание с ECharts. *@
                                            <div class="param-toolbar-r-field-shell">
                                                <RadzenFormField AllowFloatingLabel="false"
                                                                 Text="R"
                                                                 Variant="Variant.Outlined"
                                                                 class="param-toolbar-r-field">
                                                    <RadzenTextBox Value='@GetSnapshotItemDisplayValue("R")'
                                                                   ReadOnly="true"
                                                                   class="param-toolbar-r-value" />
                                                </RadzenFormField>
                                            </div>
                                        }
                                        else if (IsVgaEquipment)
                                        {
                                            @* Поле Man для VGA вынесено в ту же верхнюю строку, где у AI находится R.
                                               Так боковая WPF-like панель остается только шкалой и не сдвигает барграфы относительно plot-area ECharts. *@
                                            <div class="@GetVgaManToolbarFieldShellClass()"
                                                 title="@GetVgaManToolbarFieldTitle()"
                                                 @onclick="@RequestVgaManToolbarWriteAsync">
                                                <RadzenFormField AllowFloatingLabel="false"
                                                                 Text="Man"
                                                                 Variant="Variant.Outlined"
                                                                 class="param-toolbar-r-field">
                                                    <RadzenTextBox Value='@GetSnapshotItemDisplayValue("Man")'
                                                                   ReadOnly="true"
                                                                   Disabled="@IsVgaManToolbarFieldDisabled"
                                                                   class="param-toolbar-r-value" />
                                                </RadzenFormField>
                                            </div>
                                        }
                                        else if (IsVgaElEquipment)
                                        {
                                            @* VGA_EL повторяет WPF-логику Graph: State находится над Man.
                                               Оба поля держим в верхней строке, чтобы левая шкала CurrPos/R оставалась выровненной с plot-area ECharts. *@
                                            <div class="param-toolbar-vga-el-state-man">
                                                <div class="@GetVgaManToolbarFieldShellClass()"
                                                     title="@GetVgaManToolbarFieldTitle()"
                                                     @onclick="@RequestVgaManToolbarWriteAsync">
                                                    <RadzenFormField AllowFloatingLabel="false"
                                                                     Text="Man"
                                                                     Variant="Variant.Outlined"
                                                                     class="param-toolbar-r-field">
                                                        <RadzenTextBox Value='@GetSnapshotItemDisplayValue("Man")'
                                                       ReadOnly="true"
                                                                       Disabled="@IsVgaManToolbarFieldDisabled"
                                                                       class="param-toolbar-r-value" />
                                                    </RadzenFormField>
                                                </div>

                                                <div class="param-toolbar-vga-el-state-text">
                                                    @GetVgaElStateDisplayValue()
                                                </div>
                                            </div>
                                        }
                                        else if (IsMotorEquipment)
                                        {
                                            @* У Motor нет верхнего writable-поля вроде VGA Man, но State должен жить в том же
                                               месте, что и у VGA_EL: над левой WPF-like зоной, не внутри самой кнопочной станции. *@
                                            <div class="param-toolbar-vga-el-state-man param-toolbar-motor-state-shell">
                                                <div class="param-toolbar-motor-state-anchor" aria-hidden="true"></div>

                                                <div class="param-toolbar-vga-el-state-text param-toolbar-motor-state-text">
                                                    @GetMotorStateDisplayValue()
                                                </div>
                                            </div>
                                        }
                                        else if (IsVgdEquipment)
                                        {
                                            @* VGD repeats the Motor graph layout: State is shown above the side command station,
                                               while the station itself only contains Open/Close and Mode. *@
                                            <div class="param-toolbar-vga-el-state-man param-toolbar-motor-state-shell">
                                                <div class="param-toolbar-motor-state-anchor" aria-hidden="true"></div>

                                                <div class="param-toolbar-vga-el-state-text param-toolbar-motor-state-text">
                                                    @GetVgdStateDisplayValue()
                                                </div>
                                            </div>
                                        }
                                    </div>

                                    @* Пустая колонка между полем R и уведомлением Forced.
                                       Ее ширина задается в CSS через --param-toolbar-spacer-width,
                                       чтобы можно было точно подвинуть alert, не меняя разметку графика. *@
                                    <div class="param-toolbar-spacer" aria-hidden="true"></div>

                                    <div class="param-toolbar-alert-slot">
                                        @if (IsGraphForcedChannelActive)
                                        {
                                            @* Forced-состояние выводим над графиком, чтобы боковая панель с барграфами
                                               не меняла свою геометрию и продолжала совпадать с plot-area ECharts. *@
                                            <RadzenAlert AllowClose="false"
                                                         AlertStyle="AlertStyle.Warning"
                                                         Variant="Variant.Flat"
                                                         Shade="Shade.Lighter"
                                                         ShowIcon="true"
                                                         class="param-graph-alert param-forced-alert">
                                                Forced chanel!
                                            </RadzenAlert>
                                        }

                                        @if (IsGraphChannelErrorActive)
                                        {
                                            @* AlarmHealth переносим из бокового WPF-блока наверх:
                                               предупреждение остается видимым, но больше не меняет высоту/позицию барграфов. *@
                                            <RadzenAlert AllowClose="false"
                                                         AlertStyle="AlertStyle.Danger"
                                                         Variant="Variant.Flat"
                                                         Shade="Shade.Lighter"
                                                         ShowIcon="true"
                                                         class="param-graph-alert param-channel-error-alert">
                                                Chanel error!
                                            </RadzenAlert>
                                        }

                                        @if (IsGraphVgaElAlarmActive)
                                        {
                                            <RadzenAlert AllowClose="false"
                                                         AlertStyle="AlertStyle.Danger"
                                                         Variant="Variant.Flat"
                                                         Shade="Shade.Lighter"
                                                         ShowIcon="true"
                                                         class="param-graph-alert param-channel-error-alert">
                                                Alarm active!
                                            </RadzenAlert>
                                        }

                                        @if (IsGraphVgaElOpenAlarmActive)
                                        {
                                            <RadzenAlert AllowClose="false"
                                                         AlertStyle="AlertStyle.Danger"
                                                         Variant="Variant.Flat"
                                                         Shade="Shade.Lighter"
                                                         ShowIcon="true"
                                                         class="param-graph-alert param-channel-error-alert">
                                                Open alarm!
                                            </RadzenAlert>
                                        }

                                        @if (IsGraphVgaElCloseAlarmActive)
                                        {
                                            <RadzenAlert AllowClose="false"
                                                         AlertStyle="AlertStyle.Danger"
                                                         Variant="Variant.Flat"
                                                         Shade="Shade.Lighter"
                                                         ShowIcon="true"
                                                         class="param-graph-alert param-channel-error-alert">
                                                Close alarm!
                                            </RadzenAlert>
                                        }

                                        @if (IsGraphMotorTimeWorkActive)
                                        {
                                            @* Time Work у Motor больше не находится внутри боковой станции:
                                               предупреждение выводим в общей alert-строке Graph рядом с другими состояниями. *@
                                            <RadzenAlert AllowClose="false"
                                                         AlertStyle="AlertStyle.Info"
                                                         Variant="Variant.Flat"
                                                         Shade="Shade.Lighter"
                                                         ShowIcon="true"
                                                         class="param-graph-alert param-motor-time-work-alert">
                                                Time Work!
                                            </RadzenAlert>
                                        }

                                        @if (IsGraphVgdAlarmActive)
                                        {
                                            <RadzenAlert AllowClose="false"
                                                         AlertStyle="AlertStyle.Danger"
                                                         Variant="Variant.Flat"
                                                         Shade="Shade.Lighter"
                                                         ShowIcon="true"
                                                         class="param-graph-alert param-channel-error-alert">
                                                Alarm active!
                                            </RadzenAlert>
                                        }
                                    </div>

                                    <RadzenButton Icon="skip_next"
                                                  ButtonStyle="ButtonStyle.Light"
                                                  class="param-live-button"
                                                  title="Go to latest"
                                                  Click="@GoLiveAsync" />
                                </div>

                                <div class="param-graph-layout">
                                    <ParamGraphSidePanel Equipment="@Equipment"
                                                         Snapshot="@_snapshot"
                                                         OnWriteRequested="@(item => BeginParamWriteAsync(item))"
                                                         OnBooleanWriteRequested="@(request => BeginParamWriteAsync(request))" />

                                    <div class="param-graph-main">
                                        @if (_trend is null || _trend.Points.Count == 0)
                                        {
                                            <RadzenAlert AlertStyle="AlertStyle.Info" ShowIcon="true">
                                                @DisplayValue(_trend?.Message ?? "Trend points are not loaded yet.")
                                            </RadzenAlert>
                                        }
                                        else
                                        {
                                            <div class="param-chart-shell">
                                                <EquipmentTrendChart Trend="@_trend"
                                                                     ViewKey="@ChartViewKey"
                                                                     Unit="@_snapshot.Unit"
                                                                     VisibleFromUtc="@GetVisibleFromUtc()"
                                                                     VisibleToUtc="@GetVisibleToUtc()"
                                                                     CanLoadOlder="@CanScrollGraphBackward"
                                                                     CanLoadNewer="@CanScrollGraphForward"
                                                                     OnHistoryRequested="@OnChartHistoryRequestedAsync" />
                                            </div>
                                        }
                                    </div>
                                </div>

                                <div class="param-graph-footer">
                                    <span class="param-status">@FormatGraphStatus()</span>
                                </div>
                            </div>
                        </RadzenTabsItem>

                        @if (IsMotorEquipment)
                        {
                            @* Для Motor порядок вкладок повторяет текущий WEB/WPF-сценарий:
                               сначала reference pages, затем аварии и в самом конце общий список All. *@
                            @if (HasPage(ParamPageKind.Plc))
                            {
                                <RadzenTabsItem Text="PLC" Icon="developer_board">
                                    @if (_isRefsLoading && SelectedTabKind == ParamPanelTabKind.Plc)
                                    {
                                        <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" />
                                    }
                                    else
                                    {
                                        <ParamPlcRefsView Response="@_plcRefs"
                                                          OnSelectEquipment="@SelectEquipmentByNameAsync"
                                                          OnWriteRequested="@BeginTargetParamWriteAsync" />
                                    }
                                </RadzenTabsItem>
                            }

                            @if (HasPage(ParamPageKind.Atv))
                            {
                                <RadzenTabsItem Text="ATV" Icon="electric_bolt">
                                    @if (_isRefsLoading && SelectedTabKind == ParamPanelTabKind.Atv)
                                    {
                                        <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" />
                                    }
                                    else
                                    {
                                        <ParamAtvRefView Response="@_atvRef"
                                                         OnSelectEquipment="@SelectEquipmentByNameAsync"
                                                         OnWriteRequested="@BeginTargetParamWriteAsync" />
                                    }
                                </RadzenTabsItem>
                            }

                            @if (HasTimeItems)
                            {
                                <RadzenTabsItem Text="TimeWork" Icon="timer">
                                    <ParamMotorTimeWorkView Items="@_snapshot.Items"
                                                            OnWriteRequested="@(item => BeginParamWriteAsync(item))"
                                                            OnBooleanWriteRequested="@(request => BeginParamWriteAsync(request))" />
                                </RadzenTabsItem>
                            }

                            @if (HasPage(ParamPageKind.DryRun))
                            {
                                <RadzenTabsItem Text="DryRun" Icon="speed">
                                    @if (_isRefsLoading && SelectedTabKind == ParamPanelTabKind.DryRun)
                                    {
                                        <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" />
                                    }
                                    else
                                    {
                                        <ParamDryRunView Response="@_dryRun"
                                                         OnSelectEquipment="@SelectEquipmentByNameAsync"
                                                         OnWriteRequested="@BeginTargetParamWriteAsync" />
                                    }
                                </RadzenTabsItem>
                            }

                            @if (HasPage(ParamPageKind.DiDo))
                            {
                                <RadzenTabsItem Text="DI/DO" Icon="settings_input_component">
                                    @if (_isRefsLoading && SelectedTabKind == ParamPanelTabKind.DiDo)
                                    {
                                        <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" />
                                    }
                                    else
                                    {
                                        <ParamDiDoRefsView Response="@_diDoRefs"
                                                           OnSelectEquipment="@SelectEquipmentByNameAsync" />
                                    }
                                </RadzenTabsItem>
                            }

                            @if (HasAlarmItems)
                            {
                                <RadzenTabsItem Text="Alarm" Icon="notifications_active">
                                    <ParamMotorAlarmView Items="@_snapshot.Items"
                                                         OnWriteRequested="@(item => BeginParamWriteAsync(item))"
                                                         OnBooleanWriteRequested="@(request => BeginParamWriteAsync(request))" />
                                </RadzenTabsItem>
                            }

                            <RadzenTabsItem Text="All" Icon="dataset">
                                <div class="param-motor-all-panels">
                                    <ParamAiPanel Title="Motor values" Icon="dataset">
                                        <ParamItemsTable Items="@_snapshot.Items"
                                                         OnWriteRequested="@BeginParamWriteAsync" />
                                    </ParamAiPanel>

                                    <ParamAiPanel Title="ATV" Icon="electric_bolt">
                                        @if (_isRefsLoading && SelectedTabKind == ParamPanelTabKind.MotorAll)
                                        {
                                            <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" />
                                        }
                                        else
                                        {
                                            <ParamAtvRefView Response="@_atvRef"
                                                             TableOnly="true"
                                                             OnSelectEquipment="@SelectEquipmentByNameAsync"
                                                             OnWriteRequested="@BeginTargetParamWriteAsync" />
                                        }
                                    </ParamAiPanel>
                                </div>
                            </RadzenTabsItem>
                        }
                        else if (IsVgdEquipment)
                        {
                            @* VGD keeps a compact WPF-like order: Graph, PLC, DI/DO, Alarm, then the raw All table. *@
                            @if (HasPage(ParamPageKind.Plc))
                            {
                                <RadzenTabsItem Text="PLC" Icon="developer_board">
                                    @if (_isRefsLoading && SelectedTabKind == ParamPanelTabKind.Plc)
                                    {
                                        <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" />
                                    }
                                    else
                                    {
                                        <ParamPlcRefsView Response="@_plcRefs"
                                                          OnSelectEquipment="@SelectEquipmentByNameAsync"
                                                          OnWriteRequested="@BeginTargetParamWriteAsync" />
                                    }
                                </RadzenTabsItem>
                            }

                            @if (HasPage(ParamPageKind.DiDo))
                            {
                                <RadzenTabsItem Text="DI/DO" Icon="settings_input_component">
                                    @if (_isRefsLoading && SelectedTabKind == ParamPanelTabKind.DiDo)
                                    {
                                        <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" />
                                    }
                                    else
                                    {
                                        <ParamDiDoRefsView Response="@_diDoRefs"
                                                           OnSelectEquipment="@SelectEquipmentByNameAsync" />
                                    }
                                </RadzenTabsItem>
                            }

                            @if (HasAlarmItems)
                            {
                                <RadzenTabsItem Text="Alarm" Icon="notifications_active">
                                    <ParamVgdAlarmView Items="@_snapshot.Items"
                                                       OnWriteRequested="@(item => BeginParamWriteAsync(item))"
                                                       OnBooleanWriteRequested="@(request => BeginParamWriteAsync(request))" />
                                </RadzenTabsItem>
                            }

                            <RadzenTabsItem Text="All" Icon="dataset">
                                <ParamItemsTable Items="@_snapshot.Items"
                                                 OnWriteRequested="@BeginParamWriteAsync" />
                            </RadzenTabsItem>
                        }
                        else
                        {
                        @if (HasSpecializedSettingsItems)
                        {
                            <RadzenTabsItem Text="Settings" Icon="tune">
                                @if (IsDiDoEquipment)
                                {
                                    <ParamDigitalSettingsView Items="@_snapshot.Items"
                                                              OnWriteRequested="@(item => BeginParamWriteAsync(item))"
                                                              OnBooleanWriteRequested="@(request => BeginParamWriteAsync(request))" />
                                }
                                else if (IsVgaEquipment)
                                {
                                    <ParamVgaSettingsView Items="@_snapshot.Items"
                                                          OnWriteRequested="@(item => BeginParamWriteAsync(item))"
                                                          OnBooleanWriteRequested="@(request => BeginParamWriteAsync(request))" />
                                }
                                else if (IsVgaElEquipment)
                                {
                                    <ParamVgaElSettingsView Items="@_snapshot.Items"
                                                            OnWriteRequested="@(item => BeginParamWriteAsync(item))"
                                                            OnBooleanWriteRequested="@(request => BeginParamWriteAsync(request))" />
                                }
                                else
                                {
                                    <ParamAiSettingsView Items="@_snapshot.Items"
                                                         OnWriteRequested="@(item => BeginParamWriteAsync(item))"
                                                         OnBooleanWriteRequested="@(request => BeginParamWriteAsync(request))" />
                                }
                            </RadzenTabsItem>
                        }

                        @if (!UsesSpecializedParamTabs && !IsMotorEquipment)
                        {
                            <RadzenTabsItem Text="All" Icon="dataset">
                                <ParamItemsTable Items="@_snapshot.Items"
                                                 OnWriteRequested="@BeginParamWriteAsync" />
                            </RadzenTabsItem>
                        }

                        @if (HasAlarmItems)
                        {
                            <RadzenTabsItem Text="Alarm" Icon="notifications_active">
                                @if (IsMotorEquipment)
                                {
                                    <ParamMotorAlarmView Items="@_snapshot.Items"
                                                         OnWriteRequested="@(item => BeginParamWriteAsync(item))"
                                                         OnBooleanWriteRequested="@(request => BeginParamWriteAsync(request))" />
                                }
                                else if (UsesAnalogSpecializedTabs)
                                {
                                    @if (IsVgaElEquipment)
                                    {
                                        <ParamVgaElAlarmView Items="@_snapshot.Items"
                                                             OnWriteRequested="@(item => BeginParamWriteAsync(item))"
                                                             OnBooleanWriteRequested="@(request => BeginParamWriteAsync(request))" />
                                    }
                                    else
                                    {
                                        <ParamAiAlarmView Items="@_snapshot.Items"
                                                          OnWriteRequested="@(item => BeginParamWriteAsync(item))"
                                                          OnBooleanWriteRequested="@(request => BeginParamWriteAsync(request))" />
                                    }
                                }
                                else
                                {
                                    <ParamItemsTable Items="@GetAlarmItems()"
                                                     OnWriteRequested="@BeginParamWriteAsync" />
                                }
                            </RadzenTabsItem>
                        }

                        @if (IsVgaElEquipment && HasPage(ParamPageKind.DiDo))
                        {
                            <RadzenTabsItem Text="DI/DO" Icon="settings_input_component">
                                @if (_isRefsLoading && SelectedTabKind == ParamPanelTabKind.DiDo)
                                {
                                    <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" />
                                }
                                else
                                {
                                    <ParamDiDoRefsView Response="@_diDoRefs"
                                                       OnSelectEquipment="@SelectEquipmentByNameAsync" />
                                }
                            </RadzenTabsItem>
                        }

                        @if (UsesSpecializedParamTabs)
                        {
                            <RadzenTabsItem Text="All" Icon="dataset">
                                <ParamItemsTable Items="@_snapshot.Items"
                                                 OnWriteRequested="@BeginParamWriteAsync" />
                            </RadzenTabsItem>
                        }

                        @if (HasTimeItems)
                        {
                            <RadzenTabsItem Text="TimeWork" Icon="timer">
                                @if (IsMotorEquipment)
                                {
                                    <ParamMotorTimeWorkView Items="@_snapshot.Items"
                                                            OnWriteRequested="@(item => BeginParamWriteAsync(item))"
                                                            OnBooleanWriteRequested="@(request => BeginParamWriteAsync(request))" />
                                }
                                else
                                {
                                    <ParamItemsTable Items="@GetTimeItems()"
                                                     OnWriteRequested="@BeginParamWriteAsync" />
                                }
                            </RadzenTabsItem>
                        }

                        @if (HasPage(ParamPageKind.Plc))
                        {
                            <RadzenTabsItem Text="PLC" Icon="developer_board">
                                @if (_isRefsLoading && SelectedTabKind == ParamPanelTabKind.Plc)
                                {
                                    <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" />
                                }
                                else
                                {
                                    <ParamPlcRefsView Response="@_plcRefs"
                                                      OnSelectEquipment="@SelectEquipmentByNameAsync"
                                                      OnWriteRequested="@BeginTargetParamWriteAsync" />
                                }
                            </RadzenTabsItem>
                        }

                        @if (!IsVgaElEquipment && HasPage(ParamPageKind.DiDo))
                        {
                            <RadzenTabsItem Text="DI/DO" Icon="settings_input_component">
                                @if (_isRefsLoading && SelectedTabKind == ParamPanelTabKind.DiDo)
                                {
                                    <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" />
                                }
                                else
                                {
                                    <ParamDiDoRefsView Response="@_diDoRefs"
                                                       OnSelectEquipment="@SelectEquipmentByNameAsync" />
                                }
                            </RadzenTabsItem>
                        }

                        @if (HasPage(ParamPageKind.DryRun))
                        {
                            <RadzenTabsItem Text="DryRun" Icon="speed">
                                @if (_isRefsLoading && SelectedTabKind == ParamPanelTabKind.DryRun)
                                {
                                    <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" />
                                }
                                else
                                {
                                    <ParamDryRunView Response="@_dryRun"
                                                     OnSelectEquipment="@SelectEquipmentByNameAsync"
                                                     OnWriteRequested="@BeginTargetParamWriteAsync" />
                                }
                            </RadzenTabsItem>
                        }

                        @if (HasPage(ParamPageKind.Atv))
                        {
                            <RadzenTabsItem Text="ATV" Icon="electric_bolt">
                                @if (_isRefsLoading && SelectedTabKind == ParamPanelTabKind.Atv)
                                {
                                    <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" />
                                }
                                else
                                {
                                    <ParamAtvRefView Response="@_atvRef"
                                                     OnSelectEquipment="@SelectEquipmentByNameAsync"
                                                     OnWriteRequested="@BeginTargetParamWriteAsync" />
                                }
                            </RadzenTabsItem>
                        }

                        @if (IsMotorEquipment)
                        {
                            @* Motor оставляет All последней вкладкой. Первая панель показывает весь текущий snapshot,
