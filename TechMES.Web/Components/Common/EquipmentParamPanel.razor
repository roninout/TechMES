    /// </summary>
    private AlertStyle _statusStyle = AlertStyle.Info;

    /// <summary>
    /// Param item, для которого открыт write editor.
    /// </summary>
    private bool _confirmWrites;

    /// <summary>
    /// Legacy-state для старого inline write-flow.
    /// Разметка этого flow уже удалена, а новые записи идут через ParamWriteDialog.
    /// Поля оставлены до отдельной чистки методов, чтобы не смешивать UI-перенос с большим refactor.
    /// </summary>
    private ParamItemDto? _writeItem;

    /// <summary>
    /// Legacy-value для старого inline write-flow.
    /// </summary>
    private string _writeValueText = "";

    /// <summary>
    /// Legacy-bool для старого inline write-flow.
    /// </summary>
    private bool _writeBooleanValue;

    /// <summary>
    /// Legacy-comment для старого inline write-flow; в новом flow комментарий формируется автоматически.
    /// </summary>
    private string _writeComment = "";

    /// <summary>
    /// Текстовое значение write editor для numeric/string параметров.
    /// </summary>

    /// <summary>
    /// Boolean значение write editor для bool-параметров.
    /// </summary>

    /// <summary>
    /// Комментарий оператора, который уйдет в audit через CiCode SaveActionOperators.
    /// </summary>

    /// <summary>
    /// Оборудование, выбранное в дереве Equipment.razor.
    /// </summary>
    [Parameter]
    public EquipmentDto? Equipment { get; set; }

    /// <summary>
    /// true, когда пользователь находится в Param route.
    /// При false polling прекращается, чтобы не грузить CtApi лишними запросами.
    /// </summary>
    [Parameter]
    public bool IsActive { get; set; } = true;

    /// <summary>
    /// true, пока родитель сохраняет favorite-флаг.
    /// </summary>
    [Parameter]
    public bool IsFavoriteSaving { get; set; }

    /// <summary>
    /// Команда переключения favorite, реализованная в Equipment.razor.
    /// </summary>
    [Parameter]
    public EventCallback OnToggleFavorite { get; set; }

    /// <summary>
    /// Событие выбора оборудования из reference page.
    /// </summary>
    [Parameter]
    public EventCallback<string> OnSelectEquipment { get; set; }

    /// <summary>
    /// Читает UI-настройки Param-графика из appsettings.json.
    /// </summary>
    protected override void OnInitialized()
    {
        var options = ParamOptions.Value;

        _windowMinutes = Math.Clamp(options.TrendWindowMinutes, 1, 240);
        _trendHistoryMinutes = Math.Clamp(
            Math.Max(options.TrendHistoryMinutes, _windowMinutes),
            _windowMinutes,
            24 * 60);
        _confirmWrites = options.ConfirmWrites;
    }

    /// <summary>
    /// Реагирует на смену Equipment/route mode: отменяет старые запросы,
    /// загружает новую панель и включает polling только когда Param видим.
    /// </summary>
    protected override async Task OnParametersSetAsync()
    {
        if (!IsActive)
        {
            StopRefreshLoop();
            CancelActiveLoads();
            return;
        }

        var currentName = Equipment?.Name;

        if (string.Equals(_loadedEquipmentName, currentName, StringComparison.OrdinalIgnoreCase))
        {
            StartRefreshLoop();
            return;
        }

        StopRefreshLoop();
        CancelActiveLoads();

        _loadedEquipmentName = currentName;
        _snapshot = null;
        _trend = null;
        _plcRefs = null;
        _diDoRefs = null;
        _dryRun = null;
        _atvRef = null;
        _fixedTrendToUtc = null;
        _chartViewVersion++;
        _statusText = "";

        if (Equipment is null)
            return;

        await LoadAsync(showLoading: true, includeTrend: IsGraphTabVisible, ct: GetActiveLoadToken());
        StartRefreshLoop();
    }

    /// <summary>
    /// Выполняет ручное обновление текущей вкладки.
    /// </summary>
    private async Task RefreshNowAsync()
    {
        await LoadAsync(showLoading: false, includeTrend: IsGraphTabVisible, ct: GetActiveLoadToken());
    }

    /// <summary>
    /// Обрабатывает переключение вкладок: Graph грузит trend,
    /// reference-вкладки грузят только свои read-only страницы.
    /// </summary>
    private async Task OnTabChangedAsync(int index)
    {
        _selectedTabIndex = index;

        if (IsGraphTabVisible && _snapshot?.Supported == true)
        {
            await LoadAsync(showLoading: false, includeTrend: true, ct: GetActiveLoadToken());
            return;
        }

        if (_snapshot?.Supported == true)
            await LoadSelectedReferencePageAsync(GetActiveLoadToken());
    }

    /// <summary>
    /// Получает от JS-графика запрос подгрузить older/newer segment истории.
    /// </summary>
    private async Task OnChartHistoryRequestedAsync(string direction)
    {
        if (_isRefreshing)
            return;

        if (direction.Equals("older", StringComparison.OrdinalIgnoreCase) && CanScrollGraphBackward)
        {
            await LoadHistorySegmentAsync(direction);
            return;
        }

        if (direction.Equals("newer", StringComparison.OrdinalIgnoreCase) && CanScrollGraphForward)
        {
            await LoadHistorySegmentAsync(direction);
        }
    }

    /// <summary>
    /// Возвращает график в live-режим: правая граница снова равна текущему времени.
    /// </summary>
    private async Task GoLiveAsync()
    {
        _fixedTrendToUtc = null;
        _chartViewVersion++;

        await RefreshNowAsync();
    }

    /// <summary>
    /// Загружает Param snapshot и при необходимости trend.
    /// Info DTO здесь намеренно не запрашивается: полная карточка оборудования принадлежит Info-режиму,
    /// а Param-режиму для идентификационной строки достаточно выбранного EquipmentDto.
    /// Метод специально защищен от параллельных refresh-ов, чтобы не перегружать CtApi.
    /// </summary>
    private async Task LoadAsync(
        bool showLoading,
        bool includeTrend,
        CancellationToken ct)
    {
        if (!IsActive || Equipment is null || _isRefreshing || ct.IsCancellationRequested)
            return;

        _isRefreshing = true;

        if (showLoading)
            _isLoading = true;

        try
        {
            _statusText = "";

            var equipmentName = Equipment.Name;

            _snapshot = await ParamApi.GetSnapshotAsync(equipmentName, ct);

            if (_snapshot.Supported && includeTrend)
            {
                if (IsGraphLive || _trend is null)
                {
                    var (fromUtc, toUtc) = GetTrendRequestBufferUtc();
                    _trend = await ParamApi.GetTrendAsync(
                        equipmentName,
                        _trendHistoryMinutes,
                        fromUtc,
                        toUtc,
                        ct);
                }
            }
            else
            {
                _trend = _snapshot.Supported && !includeTrend ? _trend : null;
            }

            if (_snapshot.Supported)
                await LoadSelectedReferencePageAsync(ct);
        }
        catch (OperationCanceledException) when (ct.IsCancellationRequested || _isDisposed || !IsActive)
        {
        }
        catch (Exception ex)
        {
            if (_isDisposed || !IsActive)
                return;

            _statusStyle = AlertStyle.Danger;
            _statusText = "Cannot load Param data: " + ex.Message;

            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Error,
                Summary = "Param",
                Detail = "Cannot load Param data.",
                Duration = 3500
            });
        }
        finally
        {
            if (!_isDisposed)
            {
                _isLoading = false;
                _isRefreshing = false;
            }
        }
    }

    /// <summary>
    /// Загружает дополнительный historical segment и сливает его с текущим буфером тренда.
    /// </summary>
    private async Task LoadHistorySegmentAsync(string direction)
    {
        if (Equipment is null || _trend is null)
            return;

        var existingTrend = _trend;
        var chunkMinutes = Math.Max(_windowMinutes, _trendHistoryMinutes / 2);
        DateTime fromUtc;
        DateTime toUtc;

        if (direction.Equals("older", StringComparison.OrdinalIgnoreCase))
        {
            toUtc = existingTrend.FromUtc;
            fromUtc = toUtc.AddMinutes(-chunkMinutes);
            _fixedTrendToUtc ??= existingTrend.ToUtc;
        }
        else
        {
            fromUtc = existingTrend.ToUtc;
            toUtc = fromUtc.AddMinutes(chunkMinutes);

            var nowUtc = DateTime.UtcNow;
            if (toUtc >= nowUtc)
            {
                toUtc = nowUtc;
                _fixedTrendToUtc = null;
            }
            else
            {
                _fixedTrendToUtc = toUtc;
            }
        }

        if (toUtc <= fromUtc.AddSeconds(1))
            return;

        _isRefreshing = true;

        try
        {
            var chunk = await ParamApi.GetTrendAsync(
                Equipment.Name,
                (int)Math.Ceiling((toUtc - fromUtc).TotalMinutes),
                fromUtc,
                toUtc,
                GetActiveLoadToken());

            if (chunk.Supported)
            {
                _trend = MergeTrends(existingTrend, chunk);
            }
        }
        catch (OperationCanceledException) when (_isDisposed || !IsActive)
        {
        }
        catch (Exception ex)
        {
            if (_isDisposed || !IsActive)
                return;

            _statusStyle = AlertStyle.Warning;
            _statusText = "Cannot load more trend history: " + ex.Message;
        }
        finally
        {
            if (!_isDisposed)
                _isRefreshing = false;
        }
    }

    /// <summary>
    /// Запускает polling loop, если Param-панель активна и loop еще не запущен.
    /// </summary>
    private void StartRefreshLoop()
    {
        if (_refreshCts is not null || _isDisposed || !IsActive || Equipment is null)
            return;

        _refreshCts = new CancellationTokenSource();
        _refreshTask = RefreshLoopAsync(_refreshCts.Token);
    }

    /// <summary>
    /// Периодический опрос snapshot/trend.
    /// Работает только когда пользователь находится в Param-режиме.
    /// </summary>
    private async Task RefreshLoopAsync(CancellationToken ct)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(5));

        try
        {
            while (await timer.WaitForNextTickAsync(ct))
            {
                if (_isWriting)
                    continue;

                await InvokeAsync(async () =>
                {
                    await LoadAsync(
                        showLoading: false,
                        includeTrend: IsGraphTabVisible,
                        ct);
                    StateHasChanged();
                });
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    /// <summary>
    /// Останавливает polling loop при уходе из Param, смене оборудования или Dispose.
    /// </summary>
    private void StopRefreshLoop()
    {
        var refreshCts = _refreshCts;
        _refreshCts = null;
        _refreshTask = null;

        try
        {
            refreshCts?.Cancel();
        }
        catch
        {
        }

        refreshCts?.Dispose();
    }

    /// <summary>
    /// Возвращает рабочий cancellation token текущей загрузки, пересоздавая CTS после отмены.
    /// </summary>
    private CancellationToken GetActiveLoadToken()
    {
        if (_loadCts.IsCancellationRequested)
        {
            _loadCts = new CancellationTokenSource();
            _isRefreshing = false;
        }

        return _loadCts.Token;
    }

    /// <summary>
    /// Отменяет активные HTTP/CtApi-загрузки текущей панели.
    /// </summary>
    private void CancelActiveLoads()
    {
        try
        {
            _loadCts.Cancel();
        }
        catch
        {
        }
    }

    /// <summary>
    /// Передает favorite-команду родительской Equipment.razor.
    /// </summary>
    private Task ToggleFavoriteAsync()
    {
        return OnToggleFavorite.InvokeAsync();
    }

    /// <summary>
    /// Передает выбор связанного оборудования из reference page в Equipment.razor.
    /// </summary>
    private Task SelectEquipmentByNameAsync(string equipmentName)
    {
        return OnSelectEquipment.HasDelegate
            ? OnSelectEquipment.InvokeAsync(equipmentName)
            : Task.CompletedTask;
    }

    /// <summary>
    /// Открывает Radzen Dialog для ввода нового значения Param item.
    /// Диалог возвращает только значение; audit-comment формируется автоматически.
    /// </summary>
    private Task BeginParamWriteAsync(ParamWriteDialogRequest request)
    {
        return request.Item is null
            ? Task.CompletedTask
            : BeginParamWriteAsync(request.Item, request.InitialBooleanValue);
    }

    /// <summary>
    /// Открывает write-dialog для item-а, который принадлежит связанному target equipment.
    /// Это нужно DryRun-вкладке: выбран Motor, а настройки DryRun читаются и пишутся через WinOpened reference.
    /// </summary>
    private Task BeginTargetParamWriteAsync(ParamTargetWriteDialogRequest request)
    {
        return request.Item is null || string.IsNullOrWhiteSpace(request.EquipmentName)
            ? Task.CompletedTask
            : BeginParamWriteAsync(
                request.EquipmentName,
                request.Item,
                request.InitialBooleanValue,
                reloadTargetReference: true,
                allowReadOnlyItemDialog: request.AllowReadOnlyItemDialog,
                referenceSourceEquipmentName: request.ReferenceSourceEquipmentName,
                referenceValueKind: request.ReferenceValueKind);
    }

    /// <summary>
    /// Открывает Radzen Dialog для ввода нового значения Param item.
    /// initialBooleanValue используется для switch-строк: диалог открывается с уже выбранным новым состоянием.
    /// </summary>
    private async Task BeginParamWriteAsync(ParamItemDto item)
    {
        await BeginParamWriteAsync(item, initialBooleanValue: null);
    }

    /// <summary>
    /// Открывает Radzen Dialog для ввода нового значения Param item.
    /// Диалог возвращает только значение; audit-comment формируется автоматически.
    /// </summary>
    private async Task BeginParamWriteAsync(ParamItemDto item, bool? initialBooleanValue)
    {
        if (Equipment is null || item is null || !item.CanWrite || _isWriting)
            return;

        await BeginParamWriteAsync(
            Equipment.Name,
            item,
            initialBooleanValue,
            reloadTargetReference: false);
    }

    /// <summary>
    /// Открывает Radzen Dialog для конкретного target equipment.
    /// target equipment совпадает с выбранным оборудованием для обычного Param и отличается для DryRun settings.
    /// </summary>
    private async Task BeginParamWriteAsync(
        string equipmentName,
        ParamItemDto item,
        bool? initialBooleanValue,
        bool reloadTargetReference,
        bool allowReadOnlyItemDialog = false,
        string? referenceSourceEquipmentName = null,
        ParamValueKind? referenceValueKind = null)
    {
        if (Equipment is null
            || string.IsNullOrWhiteSpace(equipmentName)
            || item is null
            || (!item.CanWrite && !allowReadOnlyItemDialog)
            || _isWriting
            || _isWriteDialogOpen)
            return;

        object? result;

        _isWriteDialogOpen = true;

        try
        {
            result = await DialogService.OpenAsync<ParamWriteDialog>(
                $"Write: {item.Name}",
                new Dictionary<string, object?>
                {
                    [nameof(ParamWriteDialog.Item)] = item,
                    [nameof(ParamWriteDialog.InitialBooleanValue)] = initialBooleanValue
                },
                new DialogOptions
                {
                    Width = "420px",
                    CloseDialogOnOverlayClick = false,
                    CloseDialogOnEsc = true
                });
        }
        finally
        {
            _isWriteDialogOpen = false;
        }

        if (result is not ParamWriteDialogResult writeResult)
            return;

        await SaveParamWriteAsync(
            item,
            writeResult.Value,
            equipmentName,
            reloadTargetReference,
            allowReadOnlyItemDialog,
            referenceSourceEquipmentName,
            referenceValueKind);
    }

    /// <summary>
    /// Выполняет write-flow после закрытия диалога: опциональный confirm,
    /// POST в Runtime.Service, отображение результата и повторное чтение snapshot.
    /// </summary>
    private async Task SaveParamWriteAsync(
        ParamItemDto item,
        string value,
        string? targetEquipmentName = null,
        bool reloadTargetReference = false,
        bool allowReadOnlyItemWrite = false,
        string? referenceSourceEquipmentName = null,
        ParamValueKind? referenceValueKind = null)
    {
        if (Equipment is null || item is null || (!item.CanWrite && !allowReadOnlyItemWrite) || string.IsNullOrWhiteSpace(value))
            return;

        var equipmentName = string.IsNullOrWhiteSpace(targetEquipmentName)
            ? Equipment.Name
            : targetEquipmentName;
        var writesCurrentEquipment = equipmentName.Equals(Equipment.Name, StringComparison.OrdinalIgnoreCase);
        var comment = BuildDefaultWriteComment(item);

        if (_confirmWrites && !await ConfirmParamWriteAsync(equipmentName, item, value))
            return;

        _isWriting = true;

        try
        {
            var response = await ParamApi.WriteAsync(
                equipmentName,
                new ParamWriteRequest
                {
                    ItemName = item.Name,
                    Value = value,
                    Comment = comment,
                    ReferenceSourceEquipmentName = referenceSourceEquipmentName,
                    ReferenceValueKind = referenceValueKind
                },
                GetActiveLoadToken());

            if (response.Success)
            {
                var auditWarning = !response.DryRun && response.AuditAttempted && !response.AuditSucceeded;
                _statusStyle = response.DryRun
                    ? AlertStyle.Info
                    : auditWarning
                        ? AlertStyle.Warning
                        : AlertStyle.Success;
                _statusText = BuildWriteStatus(response, item);

                NotificationService.Notify(new NotificationMessage
                {
                    Severity = response.DryRun
                        ? NotificationSeverity.Info
                        : auditWarning
                            ? NotificationSeverity.Warning
                            : NotificationSeverity.Success,
                    Summary = "Param write",
                    Detail = response.Message ?? _statusText,
                    Duration = 3500
                });

                var writtenValue = response.WrittenValue ?? value;
                var isPulseAction = IsPulseActionWrite(item, writtenValue);

                if (writesCurrentEquipment)
                {
                    ApplyWrittenValueToSnapshot(item, writtenValue);
                    await InvokeAsync(StateHasChanged);
                }

                if (isPulseAction)
                {
                    _ = ResetPulseActionInBackgroundAsync(equipmentName, item, comment);
                }
                else if (reloadTargetReference)
                {
                    _dryRun = null;
                    await LoadSelectedReferencePageAsync(GetActiveLoadToken());
                    await InvokeAsync(StateHasChanged);
                }
                else
                {
                    await ReloadAfterWriteAsync(item, writtenValue);
                }
            }
            else
            {
                _statusStyle = AlertStyle.Warning;
                _statusText = response.Error ?? response.Message ?? "Param write was rejected.";

                NotificationService.Notify(new NotificationMessage
                {
                    Severity = NotificationSeverity.Warning,
                    Summary = "Param write",
                    Detail = _statusText,
                    Duration = 4500
                });
            }
        }
        catch (Exception ex)
        {
            _statusStyle = AlertStyle.Danger;
            _statusText = "Cannot write Param value: " + ex.Message;

            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Error,
                Summary = "Param write",
                Detail = "Cannot write Param value.",
                Duration = 4500
            });
        }
        finally
        {
            _isWriting = false;
        }
    }

    /// <summary>
    /// Определяет Motor-команды, которые в SCADA работают как one-shot pulse.
    /// Пользователь подтверждает запись 1 в диалоге, а WEB после успешного ответа Runtime.Service сам возвращает тег в 0.
    /// </summary>
    private static bool IsPulseActionWrite(ParamItemDto item, string value)
    {
        return item.Kind == ParamValueKind.Boolean
            && TryParseBooleanValue(value, out var boolValue)
            && boolValue
            && (item.Name.Equals("TimeWorkAlarmWAck", StringComparison.OrdinalIgnoreCase)
                || item.Name.Equals("TimeReset", StringComparison.OrdinalIgnoreCase));
    }

    /// <summary>
    /// Фоново завершает one-shot pulse для Ack/Reset: после короткой WPF-like паузы пишет 0.
    /// Отдельный reset не открывает диалог и не требует подтверждения, потому что это техническое завершение уже подтвержденной команды.
    /// </summary>
    private async Task ResetPulseActionInBackgroundAsync(string equipmentName, ParamItemDto item, string comment)
    {
        try
        {
            await Task.Delay(ParamPulseResetDelay);

            var response = await ParamApi.WriteAsync(
                equipmentName,
                new ParamWriteRequest
                {
                    ItemName = item.Name,
                    Value = "0",
                    Comment = comment
                },
                CancellationToken.None);

            if (response.Success)
            {
                var resetValue = response.WrittenValue ?? "0";

                if (!_isDisposed)
                {
                    await InvokeAsync(async () =>
                    {
                        ApplyWrittenValueToSnapshot(item, resetValue);
                        StateHasChanged();
                        await ReloadAfterWriteAsync(item, resetValue);
                    });
                }

                return;
            }

            if (!_isDisposed)
            {
                await InvokeAsync(() =>
                {
                    NotificationService.Notify(new NotificationMessage
                    {
                        Severity = NotificationSeverity.Warning,
                        Summary = "Param pulse reset",
                        Detail = response.Error ?? response.Message ?? $"Cannot reset {item.Name} to 0.",
                        Duration = 4500
                    });
                });
            }
        }
        catch (Exception ex)
        {
            if (_isDisposed)
                return;

            await InvokeAsync(() =>
            {
                NotificationService.Notify(new NotificationMessage
                {
                    Severity = NotificationSeverity.Error,
                    Summary = "Param pulse reset",
                    Detail = $"Cannot reset {item.Name} to 0: {ex.Message}",
                    Duration = 4500
                });
            });
        }
    }

    /// <summary>
    /// Открывает встроенный редактор записи для одного Param item.
    /// Метод вызывается из ParamItemsTable только для CanWrite=true.
    /// </summary>
    private void BeginParamWrite(ParamItemDto item)
    {
        if (Equipment is null || item is null || !item.CanWrite || _isWriting)
            return;

        _writeItem = item;
        _writeComment = item.Name;

        if (item.Kind == ParamValueKind.Boolean)
        {
            _writeBooleanValue = item.BooleanValue == true;
            _writeValueText = _writeBooleanValue ? "1" : "0";
        }
        else
        {
            _writeValueText = !string.IsNullOrWhiteSpace(item.ValueText)
                ? item.ValueText
                : item.NumericValue.HasValue
                    ? FormatWriteNumber(item.NumericValue.Value)
                    : "";
        }
    }

    /// <summary>
    /// Закрывает редактор записи без отправки запроса в Runtime.Service.
    /// Во время активной записи закрытие запрещено, чтобы не потерять состояние операции.
    /// </summary>
    private void CancelParamWrite()
    {
        if (_isWriting)
            return;

        _writeItem = null;
        _writeValueText = "";
        _writeBooleanValue = false;
        _writeComment = "";
    }

    /// <summary>
    /// Проверяет, можно ли нажать Write: выбран item, есть комментарий и новое значение.
    /// Backend все равно повторно валидирует запрос, это только UX-фильтр.
    /// </summary>
    private bool CanSubmitParamWrite()
    {
        if (_writeItem is null)
            return false;

        if (string.IsNullOrWhiteSpace(_writeComment))
            return false;

        return _writeItem.Kind == ParamValueKind.Boolean
            || !string.IsNullOrWhiteSpace(_writeValueText);
    }

    /// <summary>
    /// Полный UI write-flow: подтверждение оператора, POST в Runtime.Service,
    /// отображение результата и повторное чтение snapshot после успешной операции.
    /// </summary>
    private async Task SaveParamWriteAsync()
    {
        if (Equipment is null || _writeItem is null || !CanSubmitParamWrite())
            return;

        var equipmentName = Equipment.Name;
        var item = _writeItem;
        var value = item.Kind == ParamValueKind.Boolean
            ? (_writeBooleanValue ? "1" : "0")
            : _writeValueText.Trim();

        if (!await ConfirmParamWriteAsync(equipmentName, item, value))
            return;

        _isWriting = true;

        try
        {
            var response = await ParamApi.WriteAsync(
                equipmentName,
                new ParamWriteRequest
                {
                    ItemName = item.Name,
                    Value = value,
                    Comment = _writeComment.Trim()
                },
                GetActiveLoadToken());

            if (response.Success)
            {
                var auditWarning = !response.DryRun && response.AuditAttempted && !response.AuditSucceeded;
                _statusStyle = response.DryRun
                    ? AlertStyle.Info
                    : auditWarning
                        ? AlertStyle.Warning
                        : AlertStyle.Success;
                _statusText = BuildWriteStatus(response, item);

                NotificationService.Notify(new NotificationMessage
                {
                    Severity = response.DryRun
                        ? NotificationSeverity.Info
                        : auditWarning
                            ? NotificationSeverity.Warning
                            : NotificationSeverity.Success,
                    Summary = "Param write",
                    Detail = response.Message ?? _statusText,
                    Duration = 3500
                });

                CancelParamWriteAfterSave();
                await LoadAsync(showLoading: false, includeTrend: IsGraphTabVisible, ct: GetActiveLoadToken());
            }
            else
            {
                _statusStyle = AlertStyle.Warning;
                _statusText = response.Error ?? response.Message ?? "Param write was rejected.";

                NotificationService.Notify(new NotificationMessage
                {
                    Severity = NotificationSeverity.Warning,
                    Summary = "Param write",
                    Detail = _statusText,
                    Duration = 4500
                });
            }
        }
        catch (Exception ex)
        {
            _statusStyle = AlertStyle.Danger;
            _statusText = "Cannot write Param value: " + ex.Message;

            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Error,
                Summary = "Param write",
                Detail = "Cannot write Param value.",
                Duration = 4500
            });
        }
        finally
        {
            _isWriting = false;
        }
    }

    /// <summary>
    /// Локально применяет записанное значение к текущему snapshot.
    /// Это сразу обновляет switch-и в UI и не ждет, пока CtApi начнет возвращать новое значение.
    /// </summary>
    private void ApplyWrittenValueToSnapshot(ParamItemDto item, string value)
    {
        var snapshotItem = _snapshot?.Items.FirstOrDefault(candidate =>
            candidate.Name.Equals(item.Name, StringComparison.OrdinalIgnoreCase));

        if (snapshotItem is null)
            return;

        snapshotItem.ValueText = value;
        snapshotItem.NumericValue = null;
        snapshotItem.BooleanValue = null;

        if (snapshotItem.Kind == ParamValueKind.Boolean && TryParseBooleanValue(value, out var boolValue))
        {
            snapshotItem.BooleanValue = boolValue;
            snapshotItem.NumericValue = boolValue ? 1 : 0;
            snapshotItem.ValueText = boolValue ? "true" : "false";
            return;
        }

        if (snapshotItem.Kind == ParamValueKind.Number
            && double.TryParse(value.Replace(',', '.'), NumberStyles.Float, CultureInfo.InvariantCulture, out var number))
        {
            snapshotItem.NumericValue = number;
            snapshotItem.ValueText = FormatWriteNumber(number);
        }
    }

    /// <summary>
    /// Повторно читает snapshot после write.
    /// Для boolean ждем короткую паузу и при необходимости делаем несколько попыток:
    /// CtApi иногда еще один цикл возвращает старое значение сразу после TagWrite.
    /// </summary>
    private async Task ReloadAfterWriteAsync(ParamItemDto item, string value)
    {
        var ct = GetActiveLoadToken();
        var attempts = item.Kind == ParamValueKind.Boolean ? 3 : 1;

        for (var attempt = 0; attempt < attempts; attempt++)
        {
            if (attempt > 0)
                await Task.Delay(250, ct);

            await WaitForRefreshIdleAsync(ct);
            await LoadAsync(showLoading: false, includeTrend: IsGraphTabVisible, ct: ct);

            if (item.Kind != ParamValueKind.Boolean || SnapshotMatchesWrittenValue(item.Name, value))
                return;
        }
    }

    /// <summary>
    /// Ждет завершения уже запущенного background refresh, чтобы write-refresh не был пропущен из-за _isRefreshing.
    /// </summary>
    private async Task WaitForRefreshIdleAsync(CancellationToken ct)
    {
        for (var i = 0; i < 10 && _isRefreshing && !ct.IsCancellationRequested; i++)
            await Task.Delay(100, ct);
    }

    /// <summary>
    /// Проверяет, что перечитанный snapshot уже содержит записанное boolean-значение.
    /// </summary>
    private bool SnapshotMatchesWrittenValue(string itemName, string value)
    {
        if (!TryParseBooleanValue(value, out var expected))
            return true;

        var snapshotItem = _snapshot?.Items.FirstOrDefault(candidate =>
            candidate.Name.Equals(itemName, StringComparison.OrdinalIgnoreCase));

        return snapshotItem is not null
            && TryReadBooleanValue(snapshotItem, out var actual)
            && actual == expected;
    }

    /// <summary>
    /// Показывает подтверждение перед записью.
    /// Для ForceCmd=on текст сделан более строгим, как в WPF-проекте.
    /// </summary>
    private async Task<bool> ConfirmParamWriteAsync(string equipmentName, ParamItemDto item, string value)
    {
        var current = FormatValue(item);
        var enablesForce = item.Name.Equals("ForceCmd", StringComparison.OrdinalIgnoreCase)
            && item.Kind == ParamValueKind.Boolean
            && value == "1";

        var title = enablesForce ? "Attention!!!" : "Confirm Param write";
        var message = enablesForce
            ? $"Do you really want to enable channel forcing?\n\nEquipment: {equipmentName}\nItem: {item.Name}\nCurrent: {current}\nNew: on"
            : $"Write Param value?\n\nEquipment: {equipmentName}\nItem: {item.Name}\nCurrent: {current}\nNew: {DisplayValue(value)}";

        var confirmed = await DialogService.Confirm(
            message,
            title,
            new ConfirmOptions
            {
                OkButtonText = "Write",
                CancelButtonText = "Cancel"
            });

        return confirmed == true;
    }

    /// <summary>
    /// Формирует автоматический комментарий для audit/Cicode SaveActionOperators.
    /// Поле ввода комментария в UI убрано, поэтому по договоренности используем имя изменяемого Param item.
    /// </summary>
    private static string BuildDefaultWriteComment(ParamItemDto item)
    {
        return item.Name;
    }

    /// <summary>
    /// Собирает короткую строку статуса после записи: режим, старое/новое значение,
    /// tag и результат audit, если он выполнялся.
    /// </summary>
    private static string BuildWriteStatus(ParamWriteResponse response, ParamItemDto item)
    {
        var mode = response.DryRun ? "Dry-run OK" : "Wrote";
        var current = string.IsNullOrWhiteSpace(response.CurrentValue)
            ? "-"
            : response.CurrentValue;
        var written = string.IsNullOrWhiteSpace(response.WrittenValue)
            ? "-"
            : response.WrittenValue;

        var parts = new List<string>
        {
            $"{mode}: {response.EquipmentName}.{item.Name} {current} -> {written}"
        };

        if (!string.IsNullOrWhiteSpace(response.TagName))
            parts.Add($"Tag: {response.TagName}");

        if (response.AuditAttempted)
            parts.Add(response.AuditSucceeded ? "Audit: OK" : "Audit: failed");

        return string.Join(" | ", parts);
    }

    /// <summary>
    /// Сбрасывает editor после успешной операции.
    /// Вынесено отдельно, чтобы не смешивать cleanup с логикой HTTP-запроса.
    /// </summary>
    private void CancelParamWriteAfterSave()
    {
        _writeItem = null;
        _writeValueText = "";
        _writeBooleanValue = false;
        _writeComment = "";
    }

    /// <summary>
    /// Загружает reference page для текущей вкладки: PLC, DI/DO, DryRun или ATV.
    /// </summary>
    private async Task LoadSelectedReferencePageAsync(CancellationToken ct)
    {
        if (Equipment is null || !IsActive || ct.IsCancellationRequested)
            return;

        var selectedTab = SelectedTabKind;

        var isMotorAllAtvPage = selectedTab == ParamPanelTabKind.MotorAll;

        if (!isMotorAllAtvPage
            && selectedTab is not (
                ParamPanelTabKind.Plc
                or ParamPanelTabKind.DiDo
                or ParamPanelTabKind.DryRun
                or ParamPanelTabKind.Atv))
        {
            return;
        }

        _isRefsLoading = selectedTab switch
        {
            ParamPanelTabKind.Plc => _plcRefs is null,
            ParamPanelTabKind.DiDo => _diDoRefs is null,
            ParamPanelTabKind.DryRun => _dryRun is null,
            ParamPanelTabKind.Atv => _atvRef is null,
            ParamPanelTabKind.MotorAll => _atvRef is null,
            _ => false
        };

        try
        {
            if (selectedTab == ParamPanelTabKind.Plc)
            {
                _plcRefs = await ParamApi.GetPlcRefsAsync(Equipment.Name, ct);
            }
            else if (selectedTab == ParamPanelTabKind.DiDo)
            {
                _diDoRefs = await ParamApi.GetDiDoRefsAsync(Equipment.Name, ct);
            }
            else if (selectedTab == ParamPanelTabKind.DryRun)
            {
                _dryRun = await ParamApi.GetDryRunAsync(Equipment.Name, ct);
            }
            else if (selectedTab == ParamPanelTabKind.Atv || isMotorAllAtvPage)
            {
                _atvRef = await ParamApi.GetAtvRefAsync(Equipment.Name, ct);
            }
        }
        catch (OperationCanceledException) when (ct.IsCancellationRequested || _isDisposed || !IsActive)
        {
        }
        catch (Exception ex)
        {
            if (_isDisposed || !IsActive)
                return;

            _statusStyle = AlertStyle.Warning;
            _statusText = $"Cannot load {GetReferencePageTitle(selectedTab)} references: {ex.Message}";
        }
        finally
        {
            if (!_isDisposed)
                _isRefsLoading = false;
        }
    }

    /// <summary>
    /// Возвращает UTC-диапазон исторического буфера, который нужно запросить у Runtime.Service.
    /// </summary>
    private (DateTime FromUtc, DateTime ToUtc) GetTrendRequestBufferUtc()
    {
        var toUtc = _fixedTrendToUtc ?? DateTime.UtcNow;
        return (toUtc.AddMinutes(-_trendHistoryMinutes), toUtc);
    }

    /// <summary>
    /// true, если график привязан к текущему времени.
    /// </summary>
    private bool IsGraphLive => !_fixedTrendToUtc.HasValue;

    /// <summary>
    /// Можно ли прокручивать график назад и просить старую историю.
    /// </summary>
    private bool CanScrollGraphBackward => _trend?.Supported == true;

    /// <summary>
    /// Можно ли прокручивать график вперед к live-краю.
    /// </summary>
    private bool CanScrollGraphForward =>
        _trend?.Supported == true && _trend.ToUtc < DateTime.UtcNow.AddSeconds(-3);

    /// <summary>
    /// true, когда активна вкладка Graph.
    /// </summary>
    private bool IsGraphTabVisible => SelectedTabKind == ParamPanelTabKind.Graph;

    /// <summary>
    /// Тип активной вкладки с учетом динамического набора tabs.
    /// </summary>
    private ParamPanelTabKind SelectedTabKind => GetTabKindByIndex(_selectedTabIndex);

    /// <summary>
    /// Переводит индекс RadzenTabs в логический тип вкладки.
    /// </summary>
    private ParamPanelTabKind GetTabKindByIndex(int index)
    {
        if (index-- == 0)
            return ParamPanelTabKind.Graph;

        if (IsMotorEquipment)
        {
            if (HasPage(ParamPageKind.Plc) && index-- == 0)
                return ParamPanelTabKind.Plc;

            if (HasPage(ParamPageKind.Atv) && index-- == 0)
                return ParamPanelTabKind.Atv;

            if (HasTimeItems && index-- == 0)
                return ParamPanelTabKind.TimeWork;

            if (HasPage(ParamPageKind.DryRun) && index-- == 0)
                return ParamPanelTabKind.DryRun;

            if (HasPage(ParamPageKind.DiDo) && index-- == 0)
                return ParamPanelTabKind.DiDo;

            if (HasAlarmItems && index-- == 0)
                return ParamPanelTabKind.Alarm;

            if (index-- == 0)
                return ParamPanelTabKind.MotorAll;

            return ParamPanelTabKind.None;
        }

        if (IsVgdEquipment)
        {
            if (HasPage(ParamPageKind.Plc) && index-- == 0)
                return ParamPanelTabKind.Plc;

            if (HasPage(ParamPageKind.DiDo) && index-- == 0)
                return ParamPanelTabKind.DiDo;

            if (HasAlarmItems && index-- == 0)
                return ParamPanelTabKind.Alarm;

            if (index-- == 0)
                return ParamPanelTabKind.Values;

            return ParamPanelTabKind.None;
        }

        if (HasSpecializedSettingsItems && index-- == 0)
            return ParamPanelTabKind.Settings;

        if (!UsesSpecializedParamTabs && !IsMotorEquipment && index-- == 0)
            return ParamPanelTabKind.Values;

        if (HasAlarmItems && index-- == 0)
            return ParamPanelTabKind.Alarm;

        if (IsVgaElEquipment && HasPage(ParamPageKind.DiDo) && index-- == 0)
            return ParamPanelTabKind.DiDo;

        if (UsesSpecializedParamTabs && index-- == 0)
            return ParamPanelTabKind.Values;

        if (HasTimeItems && index-- == 0)
            return ParamPanelTabKind.TimeWork;

        if (HasPage(ParamPageKind.Plc) && index-- == 0)
            return ParamPanelTabKind.Plc;

        if (!IsVgaElEquipment && HasPage(ParamPageKind.DiDo) && index-- == 0)
            return ParamPanelTabKind.DiDo;

        if (HasPage(ParamPageKind.DryRun) && index-- == 0)
            return ParamPanelTabKind.DryRun;

        if (HasPage(ParamPageKind.Atv) && index-- == 0)
            return ParamPanelTabKind.Atv;

        if (IsMotorEquipment && index-- == 0)
            return ParamPanelTabKind.MotorAll;

        return ParamPanelTabKind.None;
    }

    /// <summary>
    /// Возвращает короткое имя reference page для status/error сообщений.
    /// </summary>
    private static string GetReferencePageTitle(ParamPanelTabKind tab)
    {
        return tab switch
        {
            ParamPanelTabKind.Plc => "PLC",
            ParamPanelTabKind.DiDo => "DI/DO",
            ParamPanelTabKind.DryRun => "DryRun",
            ParamPanelTabKind.Atv => "ATV",
            ParamPanelTabKind.MotorAll => "ATV",
            _ => "Param"
        };
    }

    /// <summary>
    /// Ключ ECharts состояния: меняется при смене оборудования или принудительном reset live.
    /// </summary>
    private string ChartViewKey =>
        $"{Equipment?.Name ?? ""}|{_windowMinutes}|{_chartViewVersion}";

    /// <summary>
    /// Левая граница видимого окна графика.
    /// </summary>
    private DateTime? GetVisibleFromUtc()
    {
        return _trend?.ToUtc.AddMinutes(-_windowMinutes);
    }

    /// <summary>
    /// Правая граница видимого окна графика.
    /// </summary>
    private DateTime? GetVisibleToUtc()
    {
        return _trend?.ToUtc;
    }

    /// <summary>
    /// Сливает уже загруженный trend с новым historical chunk без дублей точек.
    /// </summary>
    private static ParamTrendResponse MergeTrends(
        ParamTrendResponse existing,
        ParamTrendResponse chunk)
    {
        var series = existing.Series.Count > 0
            ? existing.Series
            : chunk.Series;

        return new ParamTrendResponse
        {
            EquipmentName = existing.EquipmentName,
            TypeGroup = existing.TypeGroup,
            Supported = existing.Supported || chunk.Supported,
            Message = existing.Message,
            FromUtc = existing.FromUtc <= chunk.FromUtc ? existing.FromUtc : chunk.FromUtc,
            ToUtc = existing.ToUtc >= chunk.ToUtc ? existing.ToUtc : chunk.ToUtc,
            AxisYMin = existing.AxisYMin ?? chunk.AxisYMin,
            AxisYMax = existing.AxisYMax ?? chunk.AxisYMax,
            Series = series,
            Points = existing.Points
                .Concat(chunk.Points)
                .GroupBy(
                    point => new
                    {
                        Series = point.Series.ToUpperInvariant(),
                        Time = point.Time.Ticks
                    })
                .Select(group => group.First())
                .OrderBy(point => point.Time)
                .ThenBy(point => point.Series, StringComparer.OrdinalIgnoreCase)
                .ToList()
        };
    }

    /// <summary>
    /// Проверяет, поддерживает ли текущий тип оборудования reference page.
    /// </summary>
    private bool HasPage(ParamPageKind page)
    {
        return _snapshot?.Pages.Contains(page) == true;
    }

    /// <summary>
    /// Есть ли параметры alarm-группы для отдельной вкладки.
    /// </summary>
    /// <summary>
    /// true, когда выбран AI-объект и для него нужно показать специализированную вкладку Settings.
    /// </summary>
    private bool HasSpecializedSettingsItems => UsesSpecializedParamTabs && _snapshot?.Items.Count > 0;

    /// <summary>
    /// true, когда выбранное оборудование относится к типу AI.
    /// Специализированные вкладки Settings/Alarm пока включаем только для этого типа.
    /// </summary>
    private bool IsAiEquipment => Equipment?.TypeGroup == EquipmentTypeGroup.AI;

    /// <summary>
    /// true, когда выбран клапан VGA. Для него используем тот же WPF-like набор вкладок, что и для AI,
    /// но с отдельной вкладкой Settings и writable-полем ручного задания на Graph.
    /// </summary>
    private bool IsVgaEquipment => Equipment?.TypeGroup == EquipmentTypeGroup.VGA;

    /// <summary>
    /// true, когда выбран VGA_EL. Для него используем VGA-like Graph, но отдельные Settings/Alarm по WPF-шаблону.
    /// </summary>
    private bool IsVgaElEquipment => Equipment?.TypeGroup == EquipmentTypeGroup.VGA_EL;

    /// <summary>
    /// true, когда выбран двигатель. Motor пока остается generic Param-типом,
    /// но вкладку All для него переносим в конец и дополняем бывшим ATV-разделом.
    /// </summary>
    private bool IsMotorEquipment => Equipment?.TypeGroup == EquipmentTypeGroup.Motor;

    /// <summary>
    /// true, when the selected equipment is a discrete valve VGD.
    /// VGD uses a Motor-like command station on Graph, but has its own Alarm layout.
    /// </summary>
    private bool IsVgdEquipment => Equipment?.TypeGroup == EquipmentTypeGroup.VGD;

    /// <summary>
    /// true, когда выбран цифровой вход или цифровой выход. Для DI/DO показываем Settings с форсированием,
    /// но не показываем Alarm, потому что аварийных настроек у этих типов нет.
    /// </summary>
    private bool IsDiDoEquipment => Equipment?.TypeGroup is EquipmentTypeGroup.DI or EquipmentTypeGroup.DO;

    /// <summary>
    /// true для аналоговых типов, у которых уже есть специализированные WEB-вкладки Settings/Alarm/All.
    /// Это сохраняет старый generic All-first режим для остальных типов Param.
    /// </summary>
    private bool UsesAnalogSpecializedTabs => IsAiEquipment || IsVgaEquipment || IsVgaElEquipment;

    /// <summary>
    /// true для типов, где generic All-вкладка не должна быть первой.
    /// Для них порядок вкладок становится WPF-like: Graph, Settings, Alarm если есть, затем All.
    /// </summary>
    private bool UsesSpecializedParamTabs => UsesAnalogSpecializedTabs || IsDiDoEquipment;

    private bool HasAlarmItems =>
        IsDiDoEquipment
            ? false
            : IsMotorEquipment
            ? _snapshot?.Items.Any(IsMotorAlarmItem) == true
            : IsVgdEquipment
            ? _snapshot?.Items.Any(IsVgdAlarmItem) == true
            : IsVgaElEquipment
            ? _snapshot?.Items.Any(IsVgaElAlarmItem) == true
            : UsesAnalogSpecializedTabs
            ? _snapshot?.Items.Any(IsAnalogAlarmItem) == true
            : _snapshot?.Items.Any(IsAlarmItem) == true;

    /// <summary>
    /// Есть ли параметры времени работы для отдельной вкладки.
    /// </summary>
    private bool HasTimeItems => !IsVgaElEquipment && _snapshot?.Items.Any(IsTimeItem) == true;

    /// <summary>
    /// Возвращает items для вкладки Alarm.
    /// </summary>
    private IReadOnlyList<ParamItemDto> GetAlarmItems()
    {
        return _snapshot?.Items.Where(IsAlarmItem).ToList() ?? [];
    }

    /// <summary>
    /// Возвращает items для вкладки TimeWork.
    /// </summary>
    private IReadOnlyList<ParamItemDto> GetTimeItems()
    {
        return _snapshot?.Items.Where(IsTimeItem).ToList() ?? [];
    }

    /// <summary>
    /// Простая классификация alarm-настроек по имени параметра.
    /// </summary>
    private static bool IsAlarmItem(ParamItemDto item)
    {
        return item.Name.Contains("Alarm", StringComparison.OrdinalIgnoreCase)
            || item.Name.StartsWith("SetL", StringComparison.OrdinalIgnoreCase)
            || item.Name.StartsWith("SetH", StringComparison.OrdinalIgnoreCase);
    }

    /// <summary>
    /// Распознает alarm-поля AI, которые должны отображаться в специализированной вкладке Alarm.
    /// </summary>
    private static bool IsAnalogAlarmItem(ParamItemDto item)
    {
        return item.Name.Equals("AlarmHAEn", StringComparison.OrdinalIgnoreCase)
            || item.Name.Equals("AlarmHWEn", StringComparison.OrdinalIgnoreCase)
            || item.Name.Equals("AlarmLWEn", StringComparison.OrdinalIgnoreCase)
            || item.Name.Equals("AlarmLAEn", StringComparison.OrdinalIgnoreCase)
            || item.Name.Equals("SetHA", StringComparison.OrdinalIgnoreCase)
            || item.Name.Equals("SetHW", StringComparison.OrdinalIgnoreCase)
            || item.Name.Equals("SetLW", StringComparison.OrdinalIgnoreCase)
            || item.Name.Equals("SetLA", StringComparison.OrdinalIgnoreCase)
            || item.Name.Equals("SetHyst", StringComparison.OrdinalIgnoreCase);
    }

    /// <summary>
    /// Распознает alarm-настройку VGA_EL. В WPF для этого типа в Alarm settings был только AlarmEn.
    /// </summary>
    private static bool IsVgaElAlarmItem(ParamItemDto item)
    {
        return item.Name.Equals("AlarmEn", StringComparison.OrdinalIgnoreCase);
    }

    /// <summary>
    /// Распознает основную настройку аварийной сигнализации Motor.
    /// В WPF вкладка Alarm для двигателя содержит switch AlarmAEn с подписью Alarm message signaling status.
    /// </summary>
    private static bool IsMotorAlarmItem(ParamItemDto item)
    {
        return item.Name.Equals("AlarmAEn", StringComparison.OrdinalIgnoreCase);
    }

    /// <summary>
    /// Recognizes VGD alarm settings from the WPF page: alarm signaling enable and open/close control times.
    /// </summary>
    private static bool IsVgdAlarmItem(ParamItemDto item)
    {
        return item.Name.Equals("AlarmEn", StringComparison.OrdinalIgnoreCase)
            || item.Name.Equals("TOpen", StringComparison.OrdinalIgnoreCase)
            || item.Name.Equals("TClose", StringComparison.OrdinalIgnoreCase);
    }

    /// <summary>
    /// Простая классификация time-настроек по имени параметра.
    /// </summary>
    private static bool IsTimeItem(ParamItemDto item)
    {
        return item.Name.Contains("Time", StringComparison.OrdinalIgnoreCase);
    }

    /// <summary>
    /// Форматирует время последнего snapshot-а для нижней строки графика.
    /// </summary>
    private string FormatSnapshotTime()
    {
        return _snapshot is null
            ? ""
            : $"Last update: {_snapshot.Time:HH:mm:ss}";
    }

    /// <summary>
    /// Формирует строку статуса графика: время snapshot-а и диапазон trend buffer.
    /// </summary>
    private string FormatGraphStatus()
    {
        var status = FormatSnapshotTime();

        if (_trend is null)
            return status;

        var from = _trend.FromUtc.ToLocalTime();
        var to = _trend.ToUtc.ToLocalTime();

        return $"{status} | {from:HH:mm:ss} - {to:HH:mm:ss}";
    }

    /// <summary>
    /// true, если текущий snapshot сообщает о принудительном режиме канала.
    /// Предупреждение показывается в верхней зоне Graph, отдельно от левого блока барграфов,
    /// чтобы предупреждающий текст не сдвигал WPF-like шкалы относительно plot-area ECharts.
    /// </summary>
    private bool IsGraphForcedChannelActive => IsSnapshotItemOn("ForceCmd");

    /// <summary>
    /// true, если snapshot сообщает об ошибке канала через AlarmHealth.
    /// Этот сигнал показывается в верхней строке Graph рядом с Forced, чтобы боковая WPF-панель оставалась только шкалой/состоянием.
    /// </summary>
    private bool IsGraphChannelErrorActive => IsSnapshotItemOn("AlarmHealth");

    /// <summary>
    /// true, если VGA_EL сообщает об общей аварии.
    /// </summary>
    private bool IsGraphVgaElAlarmActive => IsVgaElEquipment && IsSnapshotItemOn("Alarm");

    /// <summary>
    /// true, если VGA_EL сообщает об аварии открытия.
    /// </summary>
    private bool IsGraphVgaElOpenAlarmActive => IsVgaElEquipment && IsSnapshotItemOn("OpenAl");

    /// <summary>
    /// true, если VGA_EL сообщает об аварии закрытия.
    /// </summary>
    private bool IsGraphVgaElCloseAlarmActive => IsVgaElEquipment && IsSnapshotItemOn("CloseAl");

    /// <summary>
    /// true, если Motor сообщает о превышении времени работы.
    /// Это состояние показывается в общей строке уведомлений Graph, а не в кнопочной станции.
    /// </summary>
    private bool IsGraphMotorTimeWorkActive => IsMotorEquipment && IsSnapshotItemOn("TimeWorkAlarmW");

    /// <summary>
    /// true, when VGD reports an active alarm. It is shown in the shared Graph alert row.
    /// </summary>
    private bool IsGraphVgdAlarmActive => IsVgdEquipment && IsSnapshotItemOn("Alarm");

    /// <summary>
    /// true, когда VGA находится в ручном режиме. В исходном WPF поле Man было доступно только при Mode=false.
    /// </summary>
    private bool IsVgaManualMode => !IsSnapshotItemOn("Mode");

    /// <summary>
    /// true, когда верхнее поле Man для VGA должно быть отключено: item отсутствует, read-only или клапан в Auto.
    /// </summary>
    private bool IsVgaManToolbarFieldDisabled => FindSnapshotItem("Man")?.CanWrite != true || !IsVgaManualMode;

    /// <summary>
    /// CSS-класс верхнего поля Man. Используем те же размеры, что у AI-поля R, но добавляем состояние writable/read-only.
    /// </summary>
    private string GetVgaManToolbarFieldShellClass()
    {
        return IsVgaManToolbarFieldDisabled
            ? "param-toolbar-r-field-shell param-toolbar-man-field-shell is-read-only"
            : "param-toolbar-r-field-shell param-toolbar-man-field-shell is-writable";
    }

    /// <summary>
    /// Tooltip объясняет, почему поле Man может быть недоступно для записи.
    /// </summary>
    private string GetVgaManToolbarFieldTitle()
    {
        var item = FindSnapshotItem("Man");

        if (item is null)
            return "Param item is not available";

        if (!item.CanWrite)
            return "Read only";

        return IsVgaManualMode ? "Write value" : "Available only in Manual mode";
    }

    /// <summary>
    /// Возвращает текст состояния VGA_EL для верхнего Graph-блока.
    /// Повторяет WPF-конвертер VGDStateToTextConverter, который использовался и для VGA_EL.
    /// </summary>
    private string GetVgaElStateDisplayValue()
    {
        var item = FindSnapshotItem("State");

        if (item is null)
            return "-";

        if (item.NumericValue.HasValue)
            return FormatVgaElValveState(item.NumericValue.Value);

        if (double.TryParse(
                item.ValueText?.Replace(',', '.'),
                NumberStyles.Float,
                CultureInfo.InvariantCulture,
                out var parsed))
        {
            return FormatVgaElValveState(parsed);
        }

        return GetSnapshotItemDisplayValue("State");
    }

    /// <summary>
    /// Возвращает читаемый текст State для Motor в верхней строке Graph.
    /// Повторяет тот же WPF-конвертер, что используется в боковой панели двигателя.
    /// </summary>
    private string GetMotorStateDisplayValue()
    {
        var item = FindSnapshotItem("State");

        if (item is null)
            return "-";

        if (item.NumericValue.HasValue)
            return FormatMotorState(item.NumericValue.Value);

        if (double.TryParse(
                item.ValueText?.Replace(',', '.'),
                NumberStyles.Float,
                CultureInfo.InvariantCulture,
                out var parsed))
        {
            return FormatMotorState(parsed);
        }

        return GetSnapshotItemDisplayValue("State");
    }

    /// <summary>
    /// Returns readable VGD State text for the top Graph row.
    /// VGD uses the same state codes as VGA_EL in the WPF converter.
    /// </summary>
    private string GetVgdStateDisplayValue()
    {
        var item = FindSnapshotItem("State");

        if (item is null)
            return "-";

        if (item.NumericValue.HasValue)
            return FormatVgaElValveState(item.NumericValue.Value);

        if (double.TryParse(
                item.ValueText?.Replace(',', '.'),
                NumberStyles.Float,
                CultureInfo.InvariantCulture,
                out var parsed))
        {
            return FormatVgaElValveState(parsed);
        }

        return GetSnapshotItemDisplayValue("State");
    }

    /// <summary>
    /// Преобразует код состояния Motor в короткую строку, как это делал WPF-конвертер PlcMotorStatusToTextConverter.
    /// </summary>
    private static string FormatMotorState(double state)
    {
        var code = (int)Math.Round(state);
        return code switch
        {
            0 => "stop",
            1 => "run",
            2 or 3 => "alarm",
            4 => "starting",
            5 => "stopping",
            6 => "waiting",
            _ => code.ToString(CultureInfo.InvariantCulture)
        };
    }

    /// <summary>
    /// Преобразует код состояния VGA_EL/VGD в читаемый текст.
    /// </summary>
    private static string FormatVgaElValveState(double state)
    {
        var code = (int)Math.Round(state);
        return code switch
        {
            0 => "closed",
            1 => "opened",
            2 => "alarm opening",
            3 => "alarm closure",
            4 => "opening",
            5 => "closing",
            _ => $"unknown ({code})"
        };
    }

    /// <summary>
    /// Открывает общий write-dialog для VGA Man из верхней строки Graph.
    /// Запись намеренно блокируется в Auto-режиме, как это было сделано в WPF.
    /// </summary>
    private async Task RequestVgaManToolbarWriteAsync()
    {
        var item = FindSnapshotItem("Man");

        if (item is null || !item.CanWrite || !IsVgaManualMode)
            return;

        await BeginParamWriteAsync(item);
    }

    /// <summary>
    /// Ищет Param item в текущем snapshot без дополнительного обращения к Runtime.Service.
    /// Helper нужен верхней Graph-строке: она читает R/Man/Mode из уже загруженного snapshot.
    /// </summary>
    private ParamItemDto? FindSnapshotItem(params string[] names)
    {
        if (_snapshot is null || names.Length == 0)
            return null;

        return _snapshot.Items.FirstOrDefault(candidate =>
            names.Any(name => candidate.Name.Equals(name, StringComparison.OrdinalIgnoreCase)));
    }

    /// <summary>
    /// Читает boolean-состояние Param item из текущего snapshot без дополнительных запросов к Runtime.Service.
    /// Поддерживает BooleanValue, числовой 0/1 и строковые значения, которые может вернуть CtApi.
    /// </summary>
    private bool IsSnapshotItemOn(params string[] names)
    {
        if (_snapshot is null || names.Length == 0)
            return false;

        var item = _snapshot.Items.FirstOrDefault(candidate =>
            names.Any(name => candidate.Name.Equals(name, StringComparison.OrdinalIgnoreCase)));

        if (item is null)
            return false;

        return TryReadBooleanValue(item, out var value) && value;
    }

    /// <summary>
    /// Возвращает отображаемое значение Param item из текущего snapshot без дополнительного запроса.
    /// Используется в верхней Graph-строке для read-only поля R.
    /// </summary>
    private string GetSnapshotItemDisplayValue(params string[] names)
    {
        if (_snapshot is null || names.Length == 0)
            return "-";

        var item = _snapshot.Items.FirstOrDefault(candidate =>
            names.Any(name => candidate.Name.Equals(name, StringComparison.OrdinalIgnoreCase)));

        return item is null ? "-" : FormatValue(item);
    }

    /// <summary>
    /// Выбирает Material icon для favorite-кнопки.
    /// </summary>
    private static string GetFavoriteIcon(EquipmentDto equipment)
    {
        return equipment.IsFavorite ? "star" : "star_border";
    }

    /// <summary>
    /// Возвращает CSS-класс favorite-кнопки с учетом активного состояния.
    /// </summary>
    private static string GetFavoriteButtonClass(EquipmentDto equipment)
    {
        return equipment.IsFavorite
            ? "equipment-favorite-button is-favorite"
            : "equipment-favorite-button";
    }

    /// <summary>
    /// Определяет, нужно ли показывать описание в компактной Param-карточке.
    /// Логика повторяет левый список оборудования: техническое имя уже видно крупно,
    /// поэтому description показываем только когда оно несет дополнительный смысл.
    /// </summary>
    /// <summary>
    /// Формирует подпись для компактной Param-карточки так же, как это делает левый список оборудования:
    /// сначала DisplayName, затем Description через разделитель, если это разные тексты.
    /// </summary>
    private static string GetParamDescriptionText(EquipmentDto equipment)
    {
        var displayName = equipment.DisplayName?.Trim() ?? "";
        var description = equipment.Description?.Trim() ?? "";

        if (string.IsNullOrWhiteSpace(displayName)
            || string.Equals(displayName, equipment.Name, StringComparison.OrdinalIgnoreCase))
        {
            displayName = "";
        }

        if (string.IsNullOrWhiteSpace(description)
            || string.Equals(description, equipment.Name, StringComparison.OrdinalIgnoreCase)
            || string.Equals(description, displayName, StringComparison.OrdinalIgnoreCase))
        {
            description = "";
        }

        if (!string.IsNullOrWhiteSpace(displayName) && !string.IsNullOrWhiteSpace(description))
            return $"{displayName} · {description}";

        return !string.IsNullOrWhiteSpace(displayName)
            ? displayName
            : description;
    }

    private static bool ShouldShowParamDescription(EquipmentDto equipment)
    {
        return !string.IsNullOrWhiteSpace(equipment.Description)
            && !string.Equals(equipment.Description, equipment.Name, StringComparison.OrdinalIgnoreCase)
            && !string.Equals(equipment.Description, equipment.DisplayName, StringComparison.OrdinalIgnoreCase);
    }

    /// <summary>
    /// Нормализует пустые строки для отображения в UI.
    /// </summary>
    private static string DisplayValue(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? "-" : value;
    }

    /// <summary>
    /// Форматирует текущее значение Param item для таблиц и write dialog.
    /// </summary>
    private static string FormatValue(ParamItemDto item)
    {
        if (item.Kind == ParamValueKind.Boolean && TryReadBooleanValue(item, out var boolValue))
            return boolValue ? "on" : "off";

        return string.IsNullOrWhiteSpace(item.ValueText)
            ? "-"
            : item.ValueText;
    }

    /// <summary>
    /// Читает boolean из Param item независимо от того, как Runtime.Service его заполнил:
    /// BooleanValue, NumericValue или строка 1/0/on/off.
    /// </summary>
    private static bool TryReadBooleanValue(ParamItemDto item, out bool value)
    {
        if (item.BooleanValue.HasValue)
        {
            value = item.BooleanValue.Value;
            return true;
        }

        if (item.NumericValue.HasValue)
        {
            value = Math.Abs(item.NumericValue.Value) > double.Epsilon;
            return true;
        }

        return TryParseBooleanValue(item.ValueText, out value);
    }

    /// <summary>
    /// Разбирает boolean-текст в вариантах, которые встречаются в UI и CtApi.
    /// </summary>
    private static bool TryParseBooleanValue(string? raw, out bool value)
    {
        raw = (raw ?? "").Trim();

        if (raw.Equals("1", StringComparison.OrdinalIgnoreCase)
            || raw.Equals("true", StringComparison.OrdinalIgnoreCase)
            || raw.Equals("on", StringComparison.OrdinalIgnoreCase)
            || raw.Equals("yes", StringComparison.OrdinalIgnoreCase))
        {
            value = true;
            return true;
        }

        if (raw.Equals("0", StringComparison.OrdinalIgnoreCase)
            || raw.Equals("false", StringComparison.OrdinalIgnoreCase)
            || raw.Equals("off", StringComparison.OrdinalIgnoreCase)
            || raw.Equals("no", StringComparison.OrdinalIgnoreCase))
        {
            value = false;
            return true;
        }

        value = false;
        return false;
    }

    /// <summary>
    /// Форматирует число для поля ввода записи без артефактов double вроде 5.4800000000000004.
    /// </summary>
    private static string FormatWriteNumber(double value)
    {
        return value.ToString("0.###############", CultureInfo.InvariantCulture);
    }

    /// <summary>
    /// Останавливает polling и отменяет активные запросы при уничтожении Param-панели.
    /// </summary>
    public void Dispose()
    {
        _isDisposed = true;
        StopRefreshLoop();
        CancelActiveLoads();
        _loadCts.Dispose();
    }

    /// <summary>
    /// Логические вкладки Param-панели. Нужны, потому что реальные tabs создаются динамически.
    /// </summary>
    private enum ParamPanelTabKind
    {
        None,
        Graph,
        Settings,
        Values,
        Alarm,
        TimeWork,
        Plc,
        DiDo,
        DryRun,
        Atv,
        MotorAll
    }
}
