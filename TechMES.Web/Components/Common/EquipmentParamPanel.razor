    /// <summary>
    /// Простая классификация alarm-настроек по имени параметра.
    /// </summary>
    private static bool IsAlarmItem(ParamItemDto item)
    {
        return item.Name.Contains("Alarm", StringComparison.OrdinalIgnoreCase)
            || item.Name.StartsWith("SetL", StringComparison.OrdinalIgnoreCase)
            || item.Name.StartsWith("SetH", StringComparison.OrdinalIgnoreCase);
    }

    /// <summary>
    /// Распознает alarm-поля AI, которые должны отображаться в специализированной вкладке Alarm.
    /// </summary>
    private static bool IsAiAlarmItem(ParamItemDto item)
    {
        return item.Name.Equals("AlarmHAEn", StringComparison.OrdinalIgnoreCase)
            || item.Name.Equals("AlarmHWEn", StringComparison.OrdinalIgnoreCase)
            || item.Name.Equals("AlarmLWEn", StringComparison.OrdinalIgnoreCase)
            || item.Name.Equals("AlarmLAEn", StringComparison.OrdinalIgnoreCase)
            || item.Name.Equals("SetHA", StringComparison.OrdinalIgnoreCase)
            || item.Name.Equals("SetHW", StringComparison.OrdinalIgnoreCase)
            || item.Name.Equals("SetLW", StringComparison.OrdinalIgnoreCase)
            || item.Name.Equals("SetLA", StringComparison.OrdinalIgnoreCase)
            || item.Name.Equals("SetHyst", StringComparison.OrdinalIgnoreCase);
    }

    /// <summary>
    /// Простая классификация time-настроек по имени параметра.
    /// </summary>
    private static bool IsTimeItem(ParamItemDto item)
    {
        return item.Name.Contains("Time", StringComparison.OrdinalIgnoreCase);
    }

    /// <summary>
    /// Форматирует время последнего snapshot-а для нижней строки графика.
    /// </summary>
    private string FormatSnapshotTime()
    {
        return _snapshot is null
            ? ""
            : $"Last update: {_snapshot.Time:HH:mm:ss}";
    }

    /// <summary>
    /// Формирует строку статуса графика: время snapshot-а и диапазон trend buffer.
    /// </summary>
    private string FormatGraphStatus()
    {
        var status = FormatSnapshotTime();

        if (_trend is null)
            return status;

        var from = _trend.FromUtc.ToLocalTime();
        var to = _trend.ToUtc.ToLocalTime();

        return $"{status} | {from:HH:mm:ss} - {to:HH:mm:ss}";
    }

    /// <summary>
    /// true, если текущий snapshot сообщает о принудительном режиме канала.
    /// Предупреждение показывается в верхней зоне Graph, отдельно от левого блока барграфов,
    /// чтобы предупреждающий текст не сдвигал WPF-like шкалы относительно plot-area ECharts.
    /// </summary>
    private bool IsGraphForcedChannelActive => IsSnapshotItemOn("ForceCmd");

    /// <summary>
    /// Читает boolean-состояние Param item из текущего snapshot без дополнительных запросов к Runtime.Service.
    /// Поддерживает BooleanValue, числовой 0/1 и строковые значения, которые может вернуть CtApi.
    /// </summary>
    private bool IsSnapshotItemOn(params string[] names)
    {
        if (_snapshot is null || names.Length == 0)
            return false;

        var item = _snapshot.Items.FirstOrDefault(candidate =>
            names.Any(name => candidate.Name.Equals(name, StringComparison.OrdinalIgnoreCase)));

        if (item is null)
            return false;

        if (item.BooleanValue.HasValue)
            return item.BooleanValue.Value;

        if (item.NumericValue.HasValue)
            return Math.Abs(item.NumericValue.Value) > double.Epsilon;

        var text = item.ValueText?.Trim();
        return text is not null
            && (text.Equals("true", StringComparison.OrdinalIgnoreCase)
                || text.Equals("on", StringComparison.OrdinalIgnoreCase)
                || text.Equals("1", StringComparison.OrdinalIgnoreCase));
    }

    /// <summary>
    /// Возвращает отображаемое значение Param item из текущего snapshot без дополнительного запроса.
    /// Используется в верхней Graph-строке для read-only поля R.
    /// </summary>
    private string GetSnapshotItemDisplayValue(params string[] names)
    {
        if (_snapshot is null || names.Length == 0)
            return "-";

        var item = _snapshot.Items.FirstOrDefault(candidate =>
            names.Any(name => candidate.Name.Equals(name, StringComparison.OrdinalIgnoreCase)));

        return item is null ? "-" : FormatValue(item);
    }

    /// <summary>
    /// Выбирает Material icon для favorite-кнопки.
    /// </summary>
    private static string GetFavoriteIcon(EquipmentDto equipment)
    {
        return equipment.IsFavorite ? "star" : "star_border";
    }

    /// <summary>
    /// Возвращает CSS-класс favorite-кнопки с учетом активного состояния.
    /// </summary>
    private static string GetFavoriteButtonClass(EquipmentDto equipment)
    {
        return equipment.IsFavorite
            ? "equipment-favorite-button is-favorite"
            : "equipment-favorite-button";
    }

    /// <summary>
    /// Определяет, нужно ли показывать описание в компактной Param-карточке.
    /// Логика повторяет левый список оборудования: техническое имя уже видно крупно,
    /// поэтому description показываем только когда оно несет дополнительный смысл.
    /// </summary>
    /// <summary>
    /// Формирует подпись для компактной Param-карточки так же, как это делает левый список оборудования:
    /// сначала DisplayName, затем Description через разделитель, если это разные тексты.
    /// </summary>
    private static string GetParamDescriptionText(EquipmentDto equipment)
    {
        var displayName = equipment.DisplayName?.Trim() ?? "";
        var description = equipment.Description?.Trim() ?? "";

        if (string.IsNullOrWhiteSpace(displayName)
            || string.Equals(displayName, equipment.Name, StringComparison.OrdinalIgnoreCase))
        {
            displayName = "";
        }

        if (string.IsNullOrWhiteSpace(description)
            || string.Equals(description, equipment.Name, StringComparison.OrdinalIgnoreCase)
            || string.Equals(description, displayName, StringComparison.OrdinalIgnoreCase))
        {
            description = "";
        }

        if (!string.IsNullOrWhiteSpace(displayName) && !string.IsNullOrWhiteSpace(description))
            return $"{displayName} · {description}";

        return !string.IsNullOrWhiteSpace(displayName)
            ? displayName
            : description;
    }

    private static bool ShouldShowParamDescription(EquipmentDto equipment)
    {
        return !string.IsNullOrWhiteSpace(equipment.Description)
            && !string.Equals(equipment.Description, equipment.Name, StringComparison.OrdinalIgnoreCase)
            && !string.Equals(equipment.Description, equipment.DisplayName, StringComparison.OrdinalIgnoreCase);
    }

    /// <summary>
    /// Нормализует пустые строки для отображения в UI.
    /// </summary>
    private static string DisplayValue(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? "-" : value;
    }

    /// <summary>
    /// Форматирует текущее значение Param item для таблиц и write dialog.
    /// </summary>
    private static string FormatValue(ParamItemDto item)
    {
        if (item.BooleanValue.HasValue)
            return item.BooleanValue.Value ? "on" : "off";

        return string.IsNullOrWhiteSpace(item.ValueText)
            ? "-"
            : item.ValueText;
    }

    /// <summary>
    /// Форматирует число для поля ввода записи без артефактов double вроде 5.4800000000000004.
    /// </summary>
    private static string FormatWriteNumber(double value)
    {
        return value.ToString("0.###############", CultureInfo.InvariantCulture);
    }

    /// <summary>
    /// Останавливает polling и отменяет активные запросы при уничтожении Param-панели.
    /// </summary>
    public void Dispose()
    {
        _isDisposed = true;
        StopRefreshLoop();
        CancelActiveLoads();
        _loadCts.Dispose();
    }

    /// <summary>
    /// Логические вкладки Param-панели. Нужны, потому что реальные tabs создаются динамически.
    /// </summary>
    private enum ParamPanelTabKind
    {
        None,
        Graph,
        Settings,
        Values,
        Alarm,
        TimeWork,
        Plc,
        DiDo,
        DryRun,
        Atv
    }
}
