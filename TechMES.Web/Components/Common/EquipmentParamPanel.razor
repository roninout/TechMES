@using TechMES.Contracts.Equipment
@using TechMES.Contracts.Param
@using System.Globalization
@using TechMES.Web.Settings
@inject ParamApiClient ParamApi
@inject Microsoft.Extensions.Options.IOptions<ParamUiOptions> ParamOptions
@inject DialogService DialogService
@inject NotificationService NotificationService
@implements IDisposable

<div class="equipment-param-panel">
    @if (Equipment is null)
    {
        <RadzenCard>
            <RadzenText Text="No selected equipment"
                        TextStyle="TextStyle.Subtitle1"
                        Style="color: gray;" />
        </RadzenCard>
    }
    else
    {
        <RadzenCard class="equipment-param-summary-card">
            <div class="equipment-param-summary">
                @* Param намеренно показывает только идентификационную строку.
                   Полная карточка с полями, логотипом и фотографией остается в EquipmentInfoPanel. *@
                <div class="equipment-selected-header equipment-param-selected-header">
                    <EquipmentTypeBadge TypeGroup="@Equipment.TypeGroup" />

                    <div class="equipment-param-title-block">
                        <div class="equipment-param-title-row">
                            <div class="equipment-selected-title">
                                <RadzenText Text="@Equipment.Name" TextStyle="TextStyle.H6" />
                            </div>

                            @if (!Equipment.IsGroup)
                            {
                                <RadzenButton Icon="@GetFavoriteIcon(Equipment)"
                                              ButtonStyle="ButtonStyle.Light"
                                              Size="ButtonSize.Small"
                                              Disabled="@IsFavoriteSaving"
                                              class="@GetFavoriteButtonClass(Equipment)"
                                              title="Favorite"
                                              Click="@ToggleFavoriteAsync" />
                            }
                        </div>

                        @* В Param показываем компактную подпись тем же текстом, который виден в дереве слева.
                           Пустое описание или дубль имени не отображаются, чтобы верхняя карточка не раздувалась. *@
                        @{
                            var paramDescription = GetParamDescriptionText(Equipment);
                        }

                        @if (!string.IsNullOrWhiteSpace(paramDescription))
                        {
                            <div class="equipment-param-description">@paramDescription</div>
                        }
                    </div>
                </div>
            </div>
        </RadzenCard>

        @if (!string.IsNullOrWhiteSpace(_statusText))
        {
            <RadzenAlert AlertStyle="@_statusStyle"
                         ShowIcon="true"
                         AllowClose="true"
                         Close="@(() => _statusText = string.Empty)">
                @_statusText
            </RadzenAlert>
        }

        <div class="equipment-param-tabs">
            @if (_isLoading)
            {
                <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" />
            }
            else if (_snapshot is null)
            {
                <RadzenAlert AlertStyle="AlertStyle.Info" ShowIcon="true">
                    Param data is not loaded.
                </RadzenAlert>
            }
            else if (!_snapshot.Supported)
            {
                <RadzenAlert AlertStyle="AlertStyle.Warning" ShowIcon="true">
                    @DisplayValue(_snapshot.Message)
                </RadzenAlert>
            }
            else
            {
                <RadzenTabs RenderMode="TabRenderMode.Server"
                            @bind-SelectedIndex="_selectedTabIndex"
                            Change="@OnTabChangedAsync">
                    <Tabs>
                        @* Иконки вкладок Param остаются themed: Radzen сам окрашивает их по активной теме и состоянию вкладки. *@
                        <RadzenTabsItem Text="Graph" Icon="area_chart">
                            <div class="param-graph-panel">
                                <div class="param-toolbar">
                                    <div class="param-toolbar-side-slot">
                                        @if (IsAiEquipment)
                                        {
                                            @* Поле R вынесено в общий верхний row Graph, чтобы оно не попадало
                                               внутрь абсолютной зоны барграфов и не нарушало их выравнивание с ECharts. *@
                                            <div class="param-toolbar-r-field-shell">
                                                <RadzenFormField AllowFloatingLabel="false"
                                                                 Text="R"
                                                                 Variant="Variant.Outlined"
                                                                 class="param-toolbar-r-field">
                                                    <RadzenTextBox Value='@GetSnapshotItemDisplayValue("R")'
                                                                   ReadOnly="true"
                                                                   class="param-toolbar-r-value" />
                                                </RadzenFormField>
                                            </div>
                                        }
                                    </div>

                                    @* Пустая колонка между полем R и уведомлением Forced.
                                       Ее ширина задается в CSS через --param-toolbar-spacer-width,
                                       чтобы можно было точно подвинуть alert, не меняя разметку графика. *@
                                    <div class="param-toolbar-spacer" aria-hidden="true"></div>

                                    <div class="param-toolbar-alert-slot">
                                        @if (IsGraphForcedChannelActive)
                                        {
                                            @* Forced-состояние выводим над графиком, чтобы боковая панель с барграфами
                                               не меняла свою геометрию и продолжала совпадать с plot-area ECharts. *@
                                            <RadzenAlert AllowClose="false"
                                                         AlertStyle="AlertStyle.Warning"
                                                         Variant="Variant.Flat"
                                                         Shade="Shade.Lighter"
                                                         ShowIcon="true"
                                                         class="param-forced-alert">
                                                Forced chanel!
                                            </RadzenAlert>
                                        }
                                    </div>

                                    <RadzenButton Icon="skip_next"
                                                  ButtonStyle="ButtonStyle.Light"
                                                  class="param-live-button"
                                                  title="Go to latest"
                                                  Click="@GoLiveAsync" />
                                </div>

                                <div class="param-graph-layout">
                                    <ParamGraphSidePanel Equipment="@Equipment"
                                                         Snapshot="@_snapshot" />

                                    <div class="param-graph-main">
                                        @if (_trend is null || _trend.Points.Count == 0)
                                        {
                                            <RadzenAlert AlertStyle="AlertStyle.Info" ShowIcon="true">
                                                @DisplayValue(_trend?.Message ?? "Trend points are not loaded yet.")
                                            </RadzenAlert>
                                        }
                                        else
                                        {
                                            <div class="param-chart-shell">
                                                <EquipmentTrendChart Trend="@_trend"
                                                                     ViewKey="@ChartViewKey"
                                                                     Unit="@_snapshot.Unit"
                                                                     VisibleFromUtc="@GetVisibleFromUtc()"
                                                                     VisibleToUtc="@GetVisibleToUtc()"
                                                                     CanLoadOlder="@CanScrollGraphBackward"
                                                                     CanLoadNewer="@CanScrollGraphForward"
                                                                     OnHistoryRequested="@OnChartHistoryRequestedAsync" />
                                            </div>
                                        }
                                    </div>
                                </div>

                                <div class="param-graph-footer">
                                    <span class="param-status">@FormatGraphStatus()</span>
                                </div>
                            </div>
                        </RadzenTabsItem>

                        @if (HasAiSettingsItems)
                        {
                            <RadzenTabsItem Text="Settings" Icon="tune">
                                <ParamAiSettingsView Items="@_snapshot.Items"
                                                     OnWriteRequested="@BeginParamWriteAsync" />
                            </RadzenTabsItem>
                        }

                        @if (!IsAiEquipment)
                        {
                            <RadzenTabsItem Text="All" Icon="dataset">
                                <ParamItemsTable Items="@_snapshot.Items"
                                                 OnWriteRequested="@BeginParamWriteAsync" />
                            </RadzenTabsItem>
                        }

                        @if (HasAlarmItems)
                        {
                            <RadzenTabsItem Text="Alarm" Icon="notifications_active">
                                @if (IsAiEquipment)
                                {
                                    <ParamAiAlarmView Items="@_snapshot.Items"
                                                      OnWriteRequested="@BeginParamWriteAsync" />
                                }
                                else
                                {
                                    <ParamItemsTable Items="@GetAlarmItems()"
                                                     OnWriteRequested="@BeginParamWriteAsync" />
                                }
                            </RadzenTabsItem>
                        }

                        @if (IsAiEquipment)
                        {
                            <RadzenTabsItem Text="All" Icon="dataset">
                                <ParamItemsTable Items="@_snapshot.Items"
                                                 OnWriteRequested="@BeginParamWriteAsync" />
                            </RadzenTabsItem>
                        }

                        @if (HasTimeItems)
                        {
                            <RadzenTabsItem Text="TimeWork" Icon="timer">
                                <ParamItemsTable Items="@GetTimeItems()"
                                                 OnWriteRequested="@BeginParamWriteAsync" />
                            </RadzenTabsItem>
                        }

                        @if (HasPage(ParamPageKind.Plc))
                        {
                            <RadzenTabsItem Text="PLC" Icon="developer_board">
                                @if (_isRefsLoading && SelectedTabKind == ParamPanelTabKind.Plc)
                                {
                                    <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" />
                                }
                                else
                                {
                                    <ParamPlcRefsView Response="@_plcRefs"
                                                      OnSelectEquipment="@SelectEquipmentByNameAsync" />
                                }
                            </RadzenTabsItem>
                        }

                        @if (HasPage(ParamPageKind.DiDo))
                        {
                            <RadzenTabsItem Text="DI/DO" Icon="settings_input_component">
                                @if (_isRefsLoading && SelectedTabKind == ParamPanelTabKind.DiDo)
                                {
                                    <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" />
                                }
                                else
                                {
                                    <ParamDiDoRefsView Response="@_diDoRefs"
                                                       OnSelectEquipment="@SelectEquipmentByNameAsync" />
                                }
                            </RadzenTabsItem>
                        }

                        @if (HasPage(ParamPageKind.DryRun))
                        {
                            <RadzenTabsItem Text="DryRun" Icon="speed">
                                @if (_isRefsLoading && SelectedTabKind == ParamPanelTabKind.DryRun)
                                {
                                    <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" />
                                }
                                else
                                {
                                    <ParamDryRunView Response="@_dryRun"
                                                     OnSelectEquipment="@SelectEquipmentByNameAsync" />
                                }
                            </RadzenTabsItem>
                        }

                        @if (HasPage(ParamPageKind.Atv))
                        {
                            <RadzenTabsItem Text="ATV" Icon="electric_bolt">
                                @if (_isRefsLoading && SelectedTabKind == ParamPanelTabKind.Atv)
                                {
                                    <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" />
                                }
                                else
                                {
                                    <ParamAtvRefView Response="@_atvRef"
                                                     OnSelectEquipment="@SelectEquipmentByNameAsync" />
                                }
                            </RadzenTabsItem>
                        }
                    </Tabs>
                </RadzenTabs>
            }
        </div>
    }
</div>

@code {
    /// <summary>
    /// Токен текущей загрузки snapshot/trend/reference pages.
    /// При переключении оборудования старые запросы отменяются.
    /// </summary>
    private CancellationTokenSource _loadCts = new();

    /// <summary>
    /// Токен фонового polling-а Param snapshot/trend.
    /// </summary>
    private CancellationTokenSource? _refreshCts;

    /// <summary>
    /// Задача фонового polling loop.
    /// </summary>
    private Task? _refreshTask;

    /// <summary>
    /// Имя оборудования, для которого сейчас загружена Param-панель.
    /// </summary>
    private string? _loadedEquipmentName;

    /// <summary>
    /// Последний snapshot текущих значений Param items.
    /// </summary>
    private ParamSnapshotResponse? _snapshot;

    /// <summary>
    /// Буфер тренда для вкладки Graph.
    /// </summary>
    private ParamTrendResponse? _trend;

    /// <summary>
    /// Read-only reference page PLC.
    /// </summary>
    private ParamPlcRefsResponse? _plcRefs;

    /// <summary>
    /// Read-only reference page DI/DO.
    /// </summary>
    private ParamDiDoRefsResponse? _diDoRefs;

    /// <summary>
    /// Read-only reference page DryRun.
    /// </summary>
    private ParamDryRunResponse? _dryRun;

    /// <summary>
    /// Read-only reference page ATV.
    /// </summary>
    private ParamAtvRefResponse? _atvRef;

    /// <summary>
    /// Индекс выбранной вкладки RadzenTabs.
    /// </summary>
    private int _selectedTabIndex;

    /// <summary>
    /// Видимое live-окно графика в минутах.
    /// </summary>
    private int _windowMinutes = 30;

    /// <summary>
    /// Исторический буфер, который заранее загружается для плавной прокрутки графика.
    /// </summary>
    private int _trendHistoryMinutes = 240;

    /// <summary>
    /// Правая граница фиксированного исторического окна; null означает live-режим.
    /// </summary>
    private DateTime? _fixedTrendToUtc;

    /// <summary>
    /// Версия графика. Увеличение версии сбрасывает JS zoom state.
    /// </summary>
    private int _chartViewVersion;

    /// <summary>
    /// true, пока идет первая загрузка панели.
    /// </summary>
    private bool _isLoading;

    /// <summary>
    /// true, пока идет refresh snapshot/trend, чтобы не запускать параллельные опросы CtApi.
    /// </summary>
    private bool _isRefreshing;

    /// <summary>
    /// true, пока загружается выбранная reference page.
    /// </summary>
    private bool _isRefsLoading;

    /// <summary>
    /// true, пока выполняется write-запрос в Runtime.Service.
    /// </summary>
    private bool _isWriting;

    /// <summary>
    /// Защита от обновления UI после уничтожения компонента.
    /// </summary>
    private bool _isDisposed;

    /// <summary>
    /// Status message Param-панели.
    /// </summary>
    private string _statusText = "";

    /// <summary>
    /// Стиль status alert Param-панели.
    /// </summary>
    private AlertStyle _statusStyle = AlertStyle.Info;

    /// <summary>
    /// Param item, для которого открыт write editor.
    /// </summary>
    private bool _confirmWrites;

    /// <summary>
    /// Legacy-state для старого inline write-flow.
    /// Разметка этого flow уже удалена, а новые записи идут через ParamWriteDialog.
    /// Поля оставлены до отдельной чистки методов, чтобы не смешивать UI-перенос с большим refactor.
    /// </summary>
    private ParamItemDto? _writeItem;

    /// <summary>
    /// Legacy-value для старого inline write-flow.
    /// </summary>
    private string _writeValueText = "";

    /// <summary>
    /// Legacy-bool для старого inline write-flow.
    /// </summary>
    private bool _writeBooleanValue;

    /// <summary>
    /// Legacy-comment для старого inline write-flow; в новом flow комментарий формируется автоматически.
    /// </summary>
    private string _writeComment = "";

    /// <summary>
    /// Текстовое значение write editor для numeric/string параметров.
    /// </summary>

    /// <summary>
    /// Boolean значение write editor для bool-параметров.
    /// </summary>

    /// <summary>
    /// Комментарий оператора, который уйдет в audit через CiCode SaveActionOperators.
    /// </summary>

    /// <summary>
    /// Оборудование, выбранное в дереве Equipment.razor.
    /// </summary>
    [Parameter]
    public EquipmentDto? Equipment { get; set; }

    /// <summary>
    /// true, когда пользователь находится в Param route.
    /// При false polling прекращается, чтобы не грузить CtApi лишними запросами.
    /// </summary>
    [Parameter]
    public bool IsActive { get; set; } = true;

    /// <summary>
    /// true, пока родитель сохраняет favorite-флаг.
    /// </summary>
    [Parameter]
    public bool IsFavoriteSaving { get; set; }

    /// <summary>
    /// Команда переключения favorite, реализованная в Equipment.razor.
    /// </summary>
    [Parameter]
    public EventCallback OnToggleFavorite { get; set; }

    /// <summary>
    /// Событие выбора оборудования из reference page.
    /// </summary>
    [Parameter]
    public EventCallback<string> OnSelectEquipment { get; set; }

    /// <summary>
    /// Читает UI-настройки Param-графика из appsettings.json.
    /// </summary>
    protected override void OnInitialized()
    {
        var options = ParamOptions.Value;

        _windowMinutes = Math.Clamp(options.TrendWindowMinutes, 1, 240);
        _trendHistoryMinutes = Math.Clamp(
            Math.Max(options.TrendHistoryMinutes, _windowMinutes),
            _windowMinutes,
            24 * 60);
        _confirmWrites = options.ConfirmWrites;
    }

    /// <summary>
    /// Реагирует на смену Equipment/route mode: отменяет старые запросы,
    /// загружает новую панель и включает polling только когда Param видим.
    /// </summary>
    protected override async Task OnParametersSetAsync()
    {
        if (!IsActive)
        {
            StopRefreshLoop();
            CancelActiveLoads();
            return;
        }

        var currentName = Equipment?.Name;

        if (string.Equals(_loadedEquipmentName, currentName, StringComparison.OrdinalIgnoreCase))
        {
            StartRefreshLoop();
            return;
        }

        StopRefreshLoop();
        CancelActiveLoads();

        _loadedEquipmentName = currentName;
        _snapshot = null;
        _trend = null;
        _plcRefs = null;
        _diDoRefs = null;
        _dryRun = null;
        _atvRef = null;
        _fixedTrendToUtc = null;
        _chartViewVersion++;
        _statusText = "";

        if (Equipment is null)
            return;

        await LoadAsync(showLoading: true, includeTrend: IsGraphTabVisible, ct: GetActiveLoadToken());
        StartRefreshLoop();
    }

    /// <summary>
    /// Выполняет ручное обновление текущей вкладки.
    /// </summary>
    private async Task RefreshNowAsync()
    {
        await LoadAsync(showLoading: false, includeTrend: IsGraphTabVisible, ct: GetActiveLoadToken());
    }

    /// <summary>
    /// Обрабатывает переключение вкладок: Graph грузит trend,
    /// reference-вкладки грузят только свои read-only страницы.
    /// </summary>
    private async Task OnTabChangedAsync(int index)
    {
        _selectedTabIndex = index;

        if (IsGraphTabVisible && _snapshot?.Supported == true)
        {
            await LoadAsync(showLoading: false, includeTrend: true, ct: GetActiveLoadToken());
            return;
        }

        if (_snapshot?.Supported == true)
            await LoadSelectedReferencePageAsync(GetActiveLoadToken());
    }

    /// <summary>
    /// Получает от JS-графика запрос подгрузить older/newer segment истории.
    /// </summary>
    private async Task OnChartHistoryRequestedAsync(string direction)
    {
        if (_isRefreshing)
            return;

        if (direction.Equals("older", StringComparison.OrdinalIgnoreCase) && CanScrollGraphBackward)
        {
            await LoadHistorySegmentAsync(direction);
            return;
        }

        if (direction.Equals("newer", StringComparison.OrdinalIgnoreCase) && CanScrollGraphForward)
        {
            await LoadHistorySegmentAsync(direction);
        }
    }

    /// <summary>
    /// Возвращает график в live-режим: правая граница снова равна текущему времени.
    /// </summary>
    private async Task GoLiveAsync()
    {
        _fixedTrendToUtc = null;
        _chartViewVersion++;

        await RefreshNowAsync();
    }

    /// <summary>
    /// Загружает Param snapshot и при необходимости trend.
    /// Info DTO здесь намеренно не запрашивается: полная карточка оборудования принадлежит Info-режиму,
    /// а Param-режиму для идентификационной строки достаточно выбранного EquipmentDto.
    /// Метод специально защищен от параллельных refresh-ов, чтобы не перегружать CtApi.
    /// </summary>
    private async Task LoadAsync(
        bool showLoading,
        bool includeTrend,
        CancellationToken ct)
    {
        if (!IsActive || Equipment is null || _isRefreshing || ct.IsCancellationRequested)
            return;

        _isRefreshing = true;

        if (showLoading)
            _isLoading = true;

        try
        {
            _statusText = "";

            var equipmentName = Equipment.Name;

            _snapshot = await ParamApi.GetSnapshotAsync(equipmentName, ct);

            if (_snapshot.Supported && includeTrend)
            {
                if (IsGraphLive || _trend is null)
                {
                    var (fromUtc, toUtc) = GetTrendRequestBufferUtc();
                    _trend = await ParamApi.GetTrendAsync(
                        equipmentName,
                        _trendHistoryMinutes,
                        fromUtc,
                        toUtc,
                        ct);
                }
            }
            else
            {
                _trend = _snapshot.Supported && !includeTrend ? _trend : null;
            }

            if (_snapshot.Supported)
                await LoadSelectedReferencePageAsync(ct);
        }
        catch (OperationCanceledException) when (ct.IsCancellationRequested || _isDisposed || !IsActive)
        {
        }
        catch (Exception ex)
        {
            if (_isDisposed || !IsActive)
                return;

            _statusStyle = AlertStyle.Danger;
            _statusText = "Cannot load Param data: " + ex.Message;

            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Error,
                Summary = "Param",
                Detail = "Cannot load Param data.",
                Duration = 3500
            });
        }
        finally
        {
            if (!_isDisposed)
            {
                _isLoading = false;
                _isRefreshing = false;
            }
        }
    }

    /// <summary>
    /// Загружает дополнительный historical segment и сливает его с текущим буфером тренда.
    /// </summary>
    private async Task LoadHistorySegmentAsync(string direction)
    {
        if (Equipment is null || _trend is null)
            return;

        var existingTrend = _trend;
        var chunkMinutes = Math.Max(_windowMinutes, _trendHistoryMinutes / 2);
        DateTime fromUtc;
        DateTime toUtc;

        if (direction.Equals("older", StringComparison.OrdinalIgnoreCase))
        {
            toUtc = existingTrend.FromUtc;
            fromUtc = toUtc.AddMinutes(-chunkMinutes);
            _fixedTrendToUtc ??= existingTrend.ToUtc;
        }
        else
        {
            fromUtc = existingTrend.ToUtc;
            toUtc = fromUtc.AddMinutes(chunkMinutes);

            var nowUtc = DateTime.UtcNow;
            if (toUtc >= nowUtc)
            {
                toUtc = nowUtc;
                _fixedTrendToUtc = null;
            }
            else
            {
                _fixedTrendToUtc = toUtc;
            }
        }

        if (toUtc <= fromUtc.AddSeconds(1))
            return;

        _isRefreshing = true;

        try
        {
            var chunk = await ParamApi.GetTrendAsync(
                Equipment.Name,
                (int)Math.Ceiling((toUtc - fromUtc).TotalMinutes),
                fromUtc,
                toUtc,
                GetActiveLoadToken());

            if (chunk.Supported)
            {
                _trend = MergeTrends(existingTrend, chunk);
            }
        }
        catch (OperationCanceledException) when (_isDisposed || !IsActive)
        {
        }
        catch (Exception ex)
        {
            if (_isDisposed || !IsActive)
                return;

            _statusStyle = AlertStyle.Warning;
            _statusText = "Cannot load more trend history: " + ex.Message;
        }
        finally
        {
            if (!_isDisposed)
                _isRefreshing = false;
        }
    }

    /// <summary>
    /// Запускает polling loop, если Param-панель активна и loop еще не запущен.
    /// </summary>
    private void StartRefreshLoop()
    {
        if (_refreshCts is not null || _isDisposed || !IsActive || Equipment is null)
            return;

        _refreshCts = new CancellationTokenSource();
        _refreshTask = RefreshLoopAsync(_refreshCts.Token);
    }

    /// <summary>
    /// Периодический опрос snapshot/trend.
    /// Работает только когда пользователь находится в Param-режиме.
    /// </summary>
    private async Task RefreshLoopAsync(CancellationToken ct)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(5));

        try
        {
            while (await timer.WaitForNextTickAsync(ct))
            {
                await InvokeAsync(async () =>
                {
                    await LoadAsync(
                        showLoading: false,
                        includeTrend: IsGraphTabVisible,
                        ct);
                    StateHasChanged();
                });
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    /// <summary>
    /// Останавливает polling loop при уходе из Param, смене оборудования или Dispose.
    /// </summary>
    private void StopRefreshLoop()
    {
        var refreshCts = _refreshCts;
        _refreshCts = null;
        _refreshTask = null;

        try
        {
            refreshCts?.Cancel();
        }
        catch
        {
        }

        refreshCts?.Dispose();
    }

    /// <summary>
