    /// WPF держал единицу около трех секунд, чтобы Citect успел обработать one-shot команду.
    /// </summary>
    private static readonly TimeSpan ParamPulseResetDelay = TimeSpan.FromSeconds(3);

    /// <summary>
    /// Защита от обновления UI после уничтожения компонента.
    /// </summary>
    private bool _isDisposed;

    /// <summary>
