@using TechMES.Contracts.Param
@using Microsoft.JSInterop
@inject IJSRuntime JSRuntime
@implements IAsyncDisposable

<div class="param-echart" @ref="_chartElement"></div>

@code {
    /// <summary>
    /// DOM-ссылка на контейнер, внутри которого Apache ECharts рисует график.
    /// </summary>
    private ElementReference _chartElement;

    /// <summary>
    /// Ссылка на Blazor-компонент для обратных вызовов из JavaScript.
    /// </summary>
    private DotNetObjectReference<EquipmentTrendChart>? _selfReference;

    /// <summary>
    /// Флаг первого render-а: JS interop можно вызывать только после появления DOM-элемента.
    /// </summary>
    private bool _hasRendered;

    /// <summary>
    /// Защита от JS interop после уничтожения компонента.
    /// </summary>
    private bool _isDisposed;

    /// <summary>
    /// Буфер тренда, полученный от Runtime.Service.
    /// </summary>
    [Parameter]
    public ParamTrendResponse? Trend { get; set; }

    /// <summary>
    /// Ключ состояния графика. При смене оборудования/версии JS сбрасывает старый zoom.
    /// </summary>
    [Parameter]
    public string? ViewKey { get; set; }

    /// <summary>
    /// Единица измерения, которая выводится в tooltip.
    /// </summary>
    [Parameter]
    public string? Unit { get; set; }

    /// <summary>
    /// Левая граница видимого окна тренда.
    /// </summary>
    [Parameter]
    public DateTime? VisibleFromUtc { get; set; }

    /// <summary>
    /// Правая граница видимого окна тренда.
    /// </summary>
    [Parameter]
    public DateTime? VisibleToUtc { get; set; }

    /// <summary>
    /// Можно ли запросить более старый исторический сегмент.
    /// </summary>
    [Parameter]
    public bool CanLoadOlder { get; set; }

    /// <summary>
    /// Можно ли вернуться ближе к текущему времени историческим сегментом.
    /// </summary>
    [Parameter]
    public bool CanLoadNewer { get; set; }

    /// <summary>
    /// Событие, через которое JS просит родительскую Param-панель подгрузить историю.
    /// </summary>
    [Parameter]
    public EventCallback<string> OnHistoryRequested { get; set; }

    /// <summary>
    /// После первого render-а передает график в JS.
    /// </summary>
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _hasRendered = true;
        }

        await RenderChartAsync();
    }

    /// <summary>
    /// Повторно отправляет данные в ECharts при изменении входных параметров.
    /// </summary>
    protected override async Task OnParametersSetAsync()
    {
        if (_hasRendered)
        {
            await RenderChartAsync();
        }
    }

    /// <summary>
    /// Рендерит или обновляет Apache ECharts-график через JS interop.
    /// </summary>
    private async Task RenderChartAsync()
    {
        var trend = Trend;

        if (!_hasRendered || _isDisposed || trend is null)
            return;

        try
        {
            _selfReference ??= DotNetObjectReference.Create(this);

            // Сам график принадлежит Apache ECharts; Blazor передает только компактный DTO.
            await JSRuntime.InvokeVoidAsync(
                "techMesParamTrendChart.render",
                _chartElement,
                BuildPayload(trend),
                _selfReference);
        }
        catch (OperationCanceledException)
        {
            // Нормально при навигации/смене вкладок: Blazor может отменить JS-вызов,
            // когда компонент уже начал уходить из render tree.
        }
        catch (JSDisconnectedException)
        {
        }
        catch (ObjectDisposedException)
        {
        }
    }

    /// <summary>
    /// Преобразует backend DTO в структуру, удобную для JavaScript/ECharts.
    /// </summary>
    private object BuildPayload(ParamTrendResponse trend)
    {
        var series = GetSeries(trend)
            .Select(item => new
            {
                name = item.Name,
                color = item.Color,
                fill = ToAreaFill(item.Color),
                data = trend.Points
                    .Where(point => point.Series.Equals(item.Name, StringComparison.OrdinalIgnoreCase))
                    .OrderBy(point => point.Time)
                    .Select(point => new object[]
                    {
                        ToUnixMilliseconds(point.Time),
                        point.Value,
                        point.RawValue,
                        point.Quality
                    })
                    .ToList()
            })
            .ToList();

        return new
        {
            fromUtcMs = ToUnixMilliseconds(trend.FromUtc),
            toUtcMs = ToUnixMilliseconds(trend.ToUtc),
            yMin = trend.AxisYMin,
            yMax = trend.AxisYMax,
            viewKey = ViewKey ?? trend.EquipmentName,
            unit = Unit ?? "",
            visibleFromUtcMs = VisibleFromUtc.HasValue
                ? ToUnixMilliseconds(VisibleFromUtc.Value)
                : (long?)null,
            visibleToUtcMs = VisibleToUtc.HasValue
                ? ToUnixMilliseconds(VisibleToUtc.Value)
                : (long?)null,
            canLoadOlder = CanLoadOlder,
            canLoadNewer = CanLoadNewer,
            series
        };
    }

    /// <summary>
    /// JS вызывает этот метод, когда пользователь дотянул график к краю доступного буфера.
    /// </summary>
    [JSInvokable]
    public async Task RequestHistoryAsync(string direction)
    {
        if (_isDisposed)
            return;

        if (direction is not ("older" or "newer"))
            return;

        await OnHistoryRequested.InvokeAsync(direction);
    }

    /// <summary>
    /// Возвращает список серий. Если backend не прислал метаданные серий,
    /// восстанавливает их из самих точек тренда.
    /// </summary>
    private static IEnumerable<ParamTrendItemDto> GetSeries(ParamTrendResponse trend)
    {
        if (trend.Series.Count > 0)
            return trend.Series;

        return trend.Points
            .Select(point => point.Series)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .Select(name => new ParamTrendItemDto { Name = name })
            .ToList();
    }

    /// <summary>
    /// Переводит DateTime в Unix milliseconds для оси времени ECharts.
    /// </summary>
    private static long ToUnixMilliseconds(DateTime value)
    {
        var utc = value.Kind switch
        {
            DateTimeKind.Utc => value,
            DateTimeKind.Local => value.ToUniversalTime(),
            _ => DateTime.SpecifyKind(value, DateTimeKind.Local).ToUniversalTime()
        };

        return new DateTimeOffset(utc).ToUnixTimeMilliseconds();
    }

    /// <summary>
    /// Делает полупрозрачную заливку area-графика из основного цвета линии.
    /// </summary>
    private static string ToAreaFill(string color)
    {
        color = (color ?? "").Trim();

        if (color.Length == 7 && color[0] == '#')
        {
            var r = Convert.ToInt32(color[1..3], 16);
            var g = Convert.ToInt32(color[3..5], 16);
            var b = Convert.ToInt32(color[5..7], 16);

            return $"rgba({r}, {g}, {b}, 0.18)";
        }

        return color;
    }

    /// <summary>
    /// Освобождает ECharts instance и DotNetObjectReference при закрытии вкладки/страницы.
    /// </summary>
    public async ValueTask DisposeAsync()
    {
        _isDisposed = true;

        try
        {
            await JSRuntime.InvokeVoidAsync(
                "techMesParamTrendChart.dispose",
                _chartElement);
        }
        catch
        {
        }

        _selfReference?.Dispose();
    }
}
