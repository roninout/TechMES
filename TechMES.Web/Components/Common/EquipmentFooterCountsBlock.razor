@inject EquipmentFooterState EquipmentFooterState
@implements IDisposable

<RadzenStack Orientation="Orientation.Horizontal"
             AlignItems="AlignItems.Center"
             Gap="6px">

    <RadzenBadge Text="@($"Nodes: {EquipmentFooterState.NodeCount}")"
                 BadgeStyle="BadgeStyle.Light" />

    <RadzenBadge Text="@($"Photos: {EquipmentFooterState.PhotoCount}")"
                 BadgeStyle="BadgeStyle.Light" />

    <RadzenBadge Text="@($"PDF: {EquipmentFooterState.PdfCount}")"
                 BadgeStyle="BadgeStyle.Light" />

    <RadzenBadge Text="@($"Schemes: {EquipmentFooterState.SchemeCount}")"
                 BadgeStyle="BadgeStyle.Light" />

    <RadzenBadge Text="@($"Notes: {EquipmentFooterState.NoteCount}")"
                 BadgeStyle="BadgeStyle.Light" />
</RadzenStack>

@code {
    protected override void OnInitialized()
    {
        EquipmentFooterState.Changed += OnCountsChanged;
    }

    private void OnCountsChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        EquipmentFooterState.Changed -= OnCountsChanged;
    }
}
