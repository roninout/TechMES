@page "/param"
@inject NavigationManager NavigationManager

<PageTitle>Param</PageTitle>

<RadzenStack Gap="12px">
    <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" />
</RadzenStack>

@code {
    /// <summary>
    /// Страница /param оставлена как redirect-wrapper.
    /// Реальный Param UI живет на /equipment/param, чтобы использовать общее дерево оборудования.
    /// </summary>
    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            NavigationManager.NavigateTo("/equipment/param", replace: true);
        }
    }
}
