@page "/operation-actions"
@inject EventLogApiClient EventLogApi
@inject SelectedEquipmentState SelectedEquipmentState
@inject NotificationService NotificationService

<PageTitle>Operation actions</PageTitle>

<div class="event-log-page">
    <div class="event-log-toolbar">
        <RadzenDatePicker TValue="DateTime"
                          @bind-Value="_selectedDate"
                          DateFormat="dd.MM.yyyy"
                          Style="width: 160px;" />

        <RadzenTextBox @bind-Value="_equipmentFilter"
                       Placeholder="Equipment filter..."
                       Style="width: 260px;" />

        <RadzenButton Text="Refresh"
                      Icon="refresh"
                      ButtonStyle="ButtonStyle.Light"
                      Disabled="@_isLoading"
                      Click="@LoadAsync" />

        <div class="event-log-toolbar-spacer"></div>

        <div class="event-log-toolbar-stats">
            <RadzenBadge Text="@($"Count: {_rows.Count}")" BadgeStyle="BadgeStyle.Light" />
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_statusText))
    {
        <RadzenAlert AlertStyle="@_statusStyle"
                     ShowIcon="true"
                     AllowClose="true"
                     Close="@(() => _statusText = string.Empty)">
            @_statusText
        </RadzenAlert>
    }

    @if (_isLoading)
    {
        <TechMesLoadingBar />
    }

    <RadzenDataGrid Data="@_rows"
                    TItem="OperatorActionDto"
                    AllowSorting="true"
                    AllowPaging="true"
                    PageSize="30"
                    Density="Density.Compact"
                    class="event-log-grid">
        <Columns>
            @* Колонки повторяют WPF GridControl: показываем только операторски полезные поля,
               а Type/Client/Tag/Page остаются в DTO, но не занимают место в таблице. *@
            <RadzenDataGridColumn TItem="OperatorActionDto" Property="Time" Title="Time" Width="80px" />
            <RadzenDataGridColumn TItem="OperatorActionDto" Property="User" Title="User" Width="100px" />
            <RadzenDataGridColumn TItem="OperatorActionDto" Property="Equip" Title="Equip" Width="200px" />
            <RadzenDataGridColumn TItem="OperatorActionDto" Property="Desc" Title="Desc" />
            <RadzenDataGridColumn TItem="OperatorActionDto" Property="OldValue" Title="Old" Width="100px" />
            <RadzenDataGridColumn TItem="OperatorActionDto" Property="NewValue" Title="New" Width="100px" />
        </Columns>
    </RadzenDataGrid>
</div>

@code {
    /// <summary>
    /// Дата, за которую читается журнал действий операторов.
    /// </summary>
    private DateTime _selectedDate = DateTime.Today;

    /// <summary>
    /// Фильтр по оборудованию/tag/comment. По умолчанию берется выбранное equipment.
    /// </summary>
    private string _equipmentFilter = "";

    /// <summary>
    /// Строки журнала Operation actions.
    /// </summary>
    private List<OperatorActionDto> _rows = [];

    /// <summary>
    /// true, пока идет HTTP-загрузка журнала.
    /// </summary>
    private bool _isLoading;

    /// <summary>
    /// Status message страницы.
    /// </summary>
    private string _statusText = "";

    /// <summary>
    /// Стиль status alert.
    /// </summary>
    private AlertStyle _statusStyle = AlertStyle.Info;

    /// <summary>
    /// Подставляет выбранное оборудование и загружает первый набор данных.
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        _equipmentFilter = SelectedEquipmentState.SelectedEquipmentName ?? "";
        await LoadAsync();
    }

    /// <summary>
    /// Загружает действия операторов из существующей EventPicker/PostgreSQL БД через Runtime.Service.
    /// </summary>
    private async Task LoadAsync()
    {
        _isLoading = true;
        _statusText = "";

        try
        {
            var response = await EventLogApi.GetOperatorActionsAsync(
                _selectedDate,
                _equipmentFilter);

            _rows = response.Rows;
        }
        catch (Exception ex)
        {
            _rows = [];
            _statusStyle = AlertStyle.Danger;
            _statusText = "Cannot load operation actions: " + ex.Message;

            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Error,
                Summary = "Operation actions",
                Detail = "Cannot load data.",
                Duration = 3500
            });
        }
        finally
        {
            _isLoading = false;
        }
    }
}
