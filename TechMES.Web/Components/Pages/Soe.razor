@page "/soe"
@inject SoeApiClient SoeApi
@inject SelectedEquipmentState SelectedEquipmentState
@inject NotificationService NotificationService

<PageTitle>SOE</PageTitle>

<div class="soe-page">
    <div class="soe-toolbar">
        <RadzenTextBox @bind-Value="_equipmentName"
                       Placeholder="Equipment name..."
                       Style="width: 260px;" />

        <RadzenButton Text="Refresh"
                      Icon="refresh"
                      ButtonStyle="ButtonStyle.Light"
                      Disabled="@_isLoading"
                      Click="@LoadAsync" />

        <div class="soe-toolbar-spacer"></div>

        <div class="soe-toolbar-stats">
            <RadzenBadge Text="@($"Count: {_rows.Count}")" BadgeStyle="BadgeStyle.Light" />

            @if (_loadedAt is not null)
            {
                <span class="soe-loaded-text">Loaded: @_loadedAt.Value.ToString("HH:mm:ss")</span>
            }
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_statusText))
    {
        <RadzenAlert AlertStyle="@_statusStyle"
                     ShowIcon="true"
                     AllowClose="true"
                     Close="@(() => _statusText = string.Empty)">
            @_statusText
        </RadzenAlert>
    }

    @if (_isLoading)
    {
        <TechMesLoadingBar />
    }

    <RadzenDataGrid Data="@_rows"
                    TItem="SoeEventDto"
                    AllowSorting="true"
                    AllowPaging="true"
                    PageSize="30"
                    Density="Density.Compact"
                    class="soe-grid">
        <Columns>
            @* Колонки повторяют WPF SOE GridControl: Date, Time, Type, Equipment и подсвеченный Event. *@
            <RadzenDataGridColumn TItem="SoeEventDto" Title="Date" Width="90px">
                <Template Context="row">
                    @row.TimeLocal.ToString("dd.MM.yyyy")
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="SoeEventDto" Title="Time" Width="90px">
                <Template Context="row">
                    @row.TimeLocal.ToString("HH:mm:ss")
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="SoeEventDto" Title="Type" Width="110px">
                <Template Context="row">
                    <EquipmentTypeBadge TypeGroup="@row.TypeGroup" />
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="SoeEventDto" Property="Equipment" Title="Equipment" Width="160px" />

            <RadzenDataGridColumn TItem="SoeEventDto" Title="Event">
                <Template Context="row">
                    <div class="@($"soe-event-cell {GetEventCellClass(row.EventKey)}")" title="@row.Event">
                        @row.Event
                    </div>
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
</div>

@code {
    /// <summary>
    /// Имя оборудования, для которого читается SOE.
    /// </summary>
    private string _equipmentName = "";

    /// <summary>
    /// Строки SOE, собранные Runtime.Service из trend tags.
    /// </summary>
    private List<SoeEventDto> _rows = [];

    /// <summary>
    /// Время последней успешной загрузки SOE.
    /// </summary>
    private DateTime? _loadedAt;

    /// <summary>
    /// true, пока идет HTTP-загрузка SOE.
    /// </summary>
    private bool _isLoading;

    /// <summary>
    /// Status message страницы.
    /// </summary>
    private string _statusText = "";

    /// <summary>
    /// Стиль status alert.
    /// </summary>
    private AlertStyle _statusStyle = AlertStyle.Info;

    /// <summary>
    /// Подставляет выбранное оборудование и загружает SOE.
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        _equipmentName = SelectedEquipmentState.SelectedEquipmentName ?? "";
        await LoadAsync();
    }

    /// <summary>
    /// Загружает SOE для указанного оборудования через Runtime.Service.
    /// </summary>
    private async Task LoadAsync()
    {
        _statusText = "";

        if (string.IsNullOrWhiteSpace(_equipmentName))
        {
            _rows = [];
            _loadedAt = null;
            _statusStyle = AlertStyle.Info;
            _statusText = "Select equipment on Info/Param page or enter equipment name.";
            return;
        }

        _isLoading = true;

        try
        {
            var response = await SoeApi.GetSoeAsync(_equipmentName.Trim());

            _rows = response.Rows;
            _loadedAt = response.LoadedAt;

            if (!response.Supported || !string.IsNullOrWhiteSpace(response.Message))
            {
                _statusStyle = response.Supported ? AlertStyle.Info : AlertStyle.Warning;
                _statusText = response.Message ?? "SOE is not available for this equipment.";
            }
        }
        catch (Exception ex)
        {
            _rows = [];
            _loadedAt = null;
            _statusStyle = AlertStyle.Danger;
            _statusText = "Cannot load SOE: " + ex.Message;

            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Error,
                Summary = "SOE",
                Detail = "Cannot load data.",
                Duration = 3500
            });
        }
        finally
        {
            _isLoading = false;
        }
    }

    /// <summary>
    /// Повторяет WPF-подсветку Event-ячейки по ключу события из SOE mapper.
    /// </summary>
    private static string GetEventCellClass(string? eventKey)
    {
        var key = (eventKey ?? "").Trim();
        if (key.Length == 0)
            return "";

        if (key.EndsWith("_Off", StringComparison.OrdinalIgnoreCase) ||
            key.EndsWith("_Down", StringComparison.OrdinalIgnoreCase) ||
            key.EndsWith("_Man", StringComparison.OrdinalIgnoreCase))
        {
            return "soe-event-off";
        }

        if (key.Contains("_EN_On", StringComparison.OrdinalIgnoreCase))
            return "soe-event-enable";

        if (key.Equals("VALUE_TRUE_On", StringComparison.OrdinalIgnoreCase) ||
            key.Equals("VALUE_FORCED_On", StringComparison.OrdinalIgnoreCase) ||
            key.Equals("FORCE_CMD_On", StringComparison.OrdinalIgnoreCase))
        {
            return "soe-event-forced";
        }

        if (key.Equals("MODE_Auto", StringComparison.OrdinalIgnoreCase) ||
            key.Equals("VALUE_On", StringComparison.OrdinalIgnoreCase) ||
            key.Equals("CMD_On", StringComparison.OrdinalIgnoreCase) ||
            key.Equals("MAN_On", StringComparison.OrdinalIgnoreCase))
        {
            return "soe-event-on";
        }

        if (key.Equals("AL_LW_Up", StringComparison.OrdinalIgnoreCase) ||
            key.Equals("AL_HW_Up", StringComparison.OrdinalIgnoreCase) ||
            key.Equals("AL_W_Up", StringComparison.OrdinalIgnoreCase) ||
            key.Equals("T_WORK_AL_On", StringComparison.OrdinalIgnoreCase))
        {
            return "soe-event-warning";
        }

        if (key.Equals("AL_LA_Up", StringComparison.OrdinalIgnoreCase) ||
            key.Equals("AL_HA_Up", StringComparison.OrdinalIgnoreCase) ||
            key.Equals("AL_A_Up", StringComparison.OrdinalIgnoreCase) ||
            key.Equals("AL_HEALTH_Up", StringComparison.OrdinalIgnoreCase) ||
            key.Equals("AL_On", StringComparison.OrdinalIgnoreCase))
        {
            return "soe-event-danger";
        }

        return "";
    }
}
