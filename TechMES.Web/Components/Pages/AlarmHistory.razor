@page "/alarm-history"
@inject EventLogApiClient EventLogApi
@inject SelectedEquipmentState SelectedEquipmentState
@inject NotificationService NotificationService

<PageTitle>Alarm history</PageTitle>

<div class="event-log-page">
    <div class="event-log-toolbar">
        <RadzenDatePicker TValue="DateTime"
                          @bind-Value="_selectedDate"
                          DateFormat="dd.MM.yyyy"
                          Style="width: 160px;" />

        <RadzenTextBox @bind-Value="_equipmentFilter"
                       Placeholder="Equipment filter..."
                       Style="width: 260px;" />

        <RadzenButton Text="Refresh"
                      Icon="refresh"
                      ButtonStyle="ButtonStyle.Light"
                      Disabled="@_isLoading"
                      Click="@LoadAsync" />

        <div class="event-log-toolbar-spacer"></div>

        <div class="event-log-toolbar-stats">
            <RadzenBadge Text="@($"Count: {_rows.Count}")" BadgeStyle="BadgeStyle.Light" />
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_statusText))
    {
        <RadzenAlert AlertStyle="@_statusStyle"
                     ShowIcon="true"
                     AllowClose="true"
                     Close="@(() => _statusText = string.Empty)">
            @_statusText
        </RadzenAlert>
    }

    @if (_isLoading)
    {
        <TechMesLoadingBar />
    }

    <RadzenDataGrid Data="@_rows"
                    TItem="AlarmHistoryDto"
                    AllowSorting="true"
                    AllowPaging="true"
                    PageSize="30"
                    Density="Density.Compact"
                    class="event-log-grid">
        <Columns>
            @* Набор и порядок колонок повторяют WPF Alarm history.
               Location остается в DTO для будущих фильтров/деталей, но в таблице не выводится. *@
            <RadzenDataGridColumn TItem="AlarmHistoryDto" Property="Time" Title="Time" Width="80px" />
            <RadzenDataGridColumn TItem="AlarmHistoryDto" Property="Category" Title="Category" Width="120px" />
            <RadzenDataGridColumn TItem="AlarmHistoryDto" Property="User" Title="User" Width="140px" />
            <RadzenDataGridColumn TItem="AlarmHistoryDto" Property="Equipment" Title="Equipment" Width="200px" />
            <RadzenDataGridColumn TItem="AlarmHistoryDto" Property="Item" Title="Item" Width="110px" />
            <RadzenDataGridColumn TItem="AlarmHistoryDto" Property="Comment" Title="Comment" />
            <RadzenDataGridColumn TItem="AlarmHistoryDto" Property="State" Title="State" Width="150px" />
        </Columns>
    </RadzenDataGrid>
</div>

@code {
    /// <summary>
    /// Дата, за которую читается alarm history.
    /// </summary>
    private DateTime _selectedDate = DateTime.Today;

    /// <summary>
    /// Фильтр по оборудованию/alarm item.
    /// </summary>
    private string _equipmentFilter = "";

    /// <summary>
    /// Строки истории аварий.
    /// </summary>
    private List<AlarmHistoryDto> _rows = [];

    /// <summary>
    /// true, пока идет HTTP-загрузка alarm history.
    /// </summary>
    private bool _isLoading;

    /// <summary>
    /// Status message страницы.
    /// </summary>
    private string _statusText = "";

    /// <summary>
    /// Стиль status alert.
    /// </summary>
    private AlertStyle _statusStyle = AlertStyle.Info;

    /// <summary>
    /// Подставляет выбранное оборудование и загружает первый набор данных.
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        _equipmentFilter = SelectedEquipmentState.SelectedEquipmentName ?? "";
        await LoadAsync();
    }

    /// <summary>
    /// Загружает alarm history из существующей EventPicker/PostgreSQL БД через Runtime.Service.
    /// </summary>
    private async Task LoadAsync()
    {
        _isLoading = true;
        _statusText = "";

        try
        {
            var response = await EventLogApi.GetAlarmHistoryAsync(
                _selectedDate,
                _equipmentFilter);

            _rows = response.Rows;
        }
        catch (Exception ex)
        {
            _rows = [];
            _statusStyle = AlertStyle.Danger;
            _statusText = "Cannot load alarm history: " + ex.Message;

            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Error,
                Summary = "Alarm history",
                Detail = "Cannot load data.",
                Duration = 3500
            });
        }
        finally
        {
            _isLoading = false;
        }
    }
}
