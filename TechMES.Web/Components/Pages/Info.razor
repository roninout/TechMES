@page "/info"
@inject SelectedEquipmentState SelectedEquipmentState
@inject InfoApiClient InfoApi
@inject DialogService DialogService
@inject NotificationService NotificationService
@implements IDisposable

<PageTitle>Info</PageTitle>

<RadzenStack Gap="12px" class="info-page">
    <RadzenStack Orientation="Orientation.Horizontal"
                 AlignItems="AlignItems.Center"
                 JustifyContent="JustifyContent.SpaceBetween"
                 class="info-toolbar">
        <RadzenStack Orientation="Orientation.Horizontal"
                     AlignItems="AlignItems.Center"
                     Gap="10px"
                     class="info-target">
            @if (SelectedEquipmentState.SelectedEquipment is not null)
            {
                <EquipmentTypeBadge TypeGroup="@SelectedEquipmentState.SelectedEquipment.TypeGroup" />
            }

            <RadzenTextBox @bind-Value="_equipmentName"
                           Placeholder="Equipment name"
                           class="info-equipment-input"
                           Disabled="@_isBusy" />

            <RadzenButton Icon="refresh"
                          Text="Load"
                          ButtonStyle="ButtonStyle.Light"
                          Disabled="@(_isBusy || string.IsNullOrWhiteSpace(_equipmentName))"
                          Click="@LoadByInputAsync" />
        </RadzenStack>

        @if (_info is not null)
        {
            <RadzenStack Orientation="Orientation.Horizontal" Gap="8px" AlignItems="AlignItems.Center">
                <RadzenBadge Text="@($"Photos: {_info.PhotoCount}")" BadgeStyle="BadgeStyle.Light" />
                <RadzenBadge Text="@($"PDF: {_info.InstructionCount}")" BadgeStyle="BadgeStyle.Light" />
                <RadzenBadge Text="@($"Schemes: {_info.SchemeCount}")" BadgeStyle="BadgeStyle.Light" />
                <RadzenBadge Text="@($"Notes: {_info.Notes.Count}")" BadgeStyle="BadgeStyle.Info" />
            </RadzenStack>
        }
    </RadzenStack>

    @if (!string.IsNullOrWhiteSpace(_statusText))
    {
        <RadzenAlert AlertStyle="@_statusStyle"
                     ShowIcon="true"
                     AllowClose="true"
                     Close="@(() => _statusText = string.Empty)">
            @_statusText
        </RadzenAlert>
    }

    @if (_isLoading)
    {
        <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" />
    }
    else if (string.IsNullOrWhiteSpace(_equipmentName))
    {
        <RadzenAlert AlertStyle="AlertStyle.Warning" ShowIcon="true">
            Оборудование не выбрано. Выберите его на странице Equipment или введите имя вручную.
        </RadzenAlert>
    }
    else if (_info is null)
    {
        <RadzenAlert AlertStyle="AlertStyle.Info" ShowIcon="true">
            Нажмите Load, чтобы открыть Info-карточку оборудования.
        </RadzenAlert>
    }
    else
    {
        <div class="info-grid">
            <section class="info-main">
                <div class="info-header-row">
                    <div>
                        <RadzenText Text="@_info.EquipName" TextStyle="TextStyle.H5" />

                        @if (SelectedEquipmentState.SelectedEquipment is not null)
                        {
                            <RadzenText Text="@SelectedEquipmentState.SelectedEquipment.DisplayName"
                                        TextStyle="TextStyle.Caption"
                                        class="muted-text" />
                        }
                    </div>

                    @if (!string.IsNullOrWhiteSpace(_info.SupplierLogoDataUrl))
                    {
                        <img class="supplier-logo"
                             src="@_info.SupplierLogoDataUrl"
                             alt="@(_info.Supplier ?? "Supplier")" />
                    }
                </div>

                <div class="info-fields">
                    <div class="info-field">
                        <span>Name:</span>
                        <strong>@_info.EquipName</strong>
                    </div>

                    <div class="info-field">
                        <span>Type:</span>
                        <strong>@GetSelectedTypeName()</strong>
                    </div>

                    <div class="info-field">
                        <span>Location:</span>
                        <strong>@GetSelectedLocation()</strong>
                    </div>

                    <div class="info-field">
                        <span>Product code:</span>
                        <strong>@DisplayValue(_info.ProductCode)</strong>
                    </div>

                    <div class="info-field">
                        <span>Supplier:</span>
                        <strong>@DisplayValue(_info.Supplier)</strong>
                    </div>

                    <div class="info-field">
                        <span>Updated:</span>
                        <strong>@FormatDate(_info.UpdatedAt)</strong>
                    </div>
                </div>

                <div class="description-block">
                    <div class="block-title-row">
                        <RadzenText Text="Desc" TextStyle="TextStyle.Subtitle1" />

                        @if (_isDescriptionEditing)
                        {
                            <RadzenStack Orientation="Orientation.Horizontal" Gap="6px">
                                <RadzenButton Icon="save"
                                              Text="Save"
                                              ButtonStyle="ButtonStyle.Primary"
                                              Disabled="@_isBusy"
                                              Click="@SaveDescriptionAsync" />

                                <RadzenButton Icon="close"
                                              Text="Cancel"
                                              ButtonStyle="ButtonStyle.Light"
                                              Disabled="@_isBusy"
                                              Click="@CancelDescriptionEdit" />
                            </RadzenStack>
                        }
                        else
                        {
                            <RadzenButton Icon="edit"
                                          Text="Edit"
                                          ButtonStyle="ButtonStyle.Light"
                                          Disabled="@_isBusy"
                                          Click="@BeginDescriptionEdit" />
                        }
                    </div>

                    @if (_isDescriptionEditing)
                    {
                        <RadzenTextArea @bind-Value="_editDescription"
                                        Rows="5"
                                        class="full-width"
                                        Disabled="@_isBusy" />
                    }
                    else
                    {
                        <div class="description-text">@DisplayValue(_info.Description)</div>
                    }
                </div>
            </section>

            <section class="notes-panel">
                <div class="block-title-row">
                    <RadzenText Text="Notes" TextStyle="TextStyle.Subtitle1" />
                </div>

                <RadzenStack Gap="8px" class="new-note-box">
                    <RadzenTextArea @bind-Value="_newNoteText"
                                    Placeholder="New note..."
                                    Rows="3"
                                    class="full-width"
                                    Disabled="@_isBusy" />

                    <RadzenButton Icon="add"
                                  Text="Add note"
                                  ButtonStyle="ButtonStyle.Primary"
                                  Disabled="@(_isBusy || string.IsNullOrWhiteSpace(_newNoteText))"
                                  Click="@AddNoteAsync" />
                </RadzenStack>

                @if (_info.Notes.Count == 0)
                {
                    <RadzenText Text="No notes"
                                TextStyle="TextStyle.Caption"
                                class="muted-text" />
                }
                else
                {
                    <div class="notes-list">
                        @foreach (var note in _info.Notes)
                        {
                            <article class="note-item">
                                @if (_editingNoteId == note.Id)
                                {
                                    <RadzenTextArea @bind-Value="_editNoteText"
                                                    Rows="5"
                                                    class="full-width"
                                                    Disabled="@_isBusy" />

                                    <RadzenStack Orientation="Orientation.Horizontal" Gap="6px">
                                        <RadzenButton Icon="save"
                                                      Text="Save"
                                                      ButtonStyle="ButtonStyle.Primary"
                                                      Disabled="@(_isBusy || string.IsNullOrWhiteSpace(_editNoteText))"
                                                      Click="@(() => SaveNoteEditAsync(note))" />

                                        <RadzenButton Icon="close"
                                                      Text="Cancel"
                                                      ButtonStyle="ButtonStyle.Light"
                                                      Disabled="@_isBusy"
                                                      Click="@CancelNoteEdit" />
                                    </RadzenStack>
                                }
                                else
                                {
                                    <div class="note-text">@note.NoteText</div>

                                    <div class="note-meta">
                                        <span>@note.CreatedBy</span>
                                        <span>@note.CreatedAt.ToString("dd.MM.yyyy HH:mm")</span>

                                        @if (note.UpdatedAt is not null)
                                        {
                                            <span>Updated @note.UpdatedAt.Value.ToString("dd.MM.yyyy HH:mm")</span>
                                        }
                                    </div>

                                    <RadzenStack Orientation="Orientation.Horizontal" Gap="6px">
                                        <RadzenButton Icon="edit"
                                                      Text="Edit"
                                                      ButtonStyle="ButtonStyle.Light"
                                                      Disabled="@_isBusy"
                                                      Click="@(() => BeginNoteEdit(note))" />

                                        <RadzenButton Icon="delete"
                                                      Text="Delete"
                                                      ButtonStyle="ButtonStyle.Danger"
                                                      Disabled="@_isBusy"
                                                      Click="@(() => DeleteNoteAsync(note))" />
                                    </RadzenStack>
                                }
                            </article>
                        }
                    </div>
                }
            </section>
        </div>
    }
</RadzenStack>

@code {
    private EquipmentInfoDto? _info;
    private bool _isLoading;
    private bool _isSaving;
    private bool _isDescriptionEditing;
    private long? _editingNoteId;

    private string _equipmentName = string.Empty;
    private string _editDescription = string.Empty;
    private string _newNoteText = string.Empty;
    private string _editNoteText = string.Empty;
    private string _statusText = string.Empty;
    private AlertStyle _statusStyle = AlertStyle.Info;

    private bool _isBusy => _isLoading || _isSaving;

    protected override async Task OnInitializedAsync()
    {
        SelectedEquipmentState.Changed += OnSelectedEquipmentChanged;

        if (SelectedEquipmentState.SelectedEquipment is not null)
        {
            _equipmentName = SelectedEquipmentState.SelectedEquipment.Name;
            await LoadInfoAsync(_equipmentName);
        }
    }

    private void OnSelectedEquipmentChanged()
    {
        _ = InvokeAsync(async () =>
        {
            var selectedName = SelectedEquipmentState.SelectedEquipment?.Name ?? string.Empty;

            if (string.Equals(_equipmentName, selectedName, StringComparison.OrdinalIgnoreCase))
                return;

            _equipmentName = selectedName;

            if (!string.IsNullOrWhiteSpace(_equipmentName))
                await LoadInfoAsync(_equipmentName);
            else
                _info = null;

            StateHasChanged();
        });
    }

    private async Task LoadByInputAsync()
    {
        await LoadInfoAsync(_equipmentName);
    }

    private async Task LoadInfoAsync(string equipmentName)
    {
        equipmentName = (equipmentName ?? string.Empty).Trim();
        if (string.IsNullOrWhiteSpace(equipmentName))
            return;

        _isLoading = true;
        ClearEditState();

        try
        {
            _info = await InfoApi.GetInfoAsync(equipmentName);
            _equipmentName = _info.EquipName;
            _editDescription = _info.Description ?? string.Empty;
            ClearStatus();
        }
        catch (Exception ex)
        {
            SetStatus(AlertStyle.Danger, "Cannot load info: " + ex.Message);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void BeginDescriptionEdit()
    {
        if (_info is null)
            return;

        _editDescription = _info.Description ?? string.Empty;
        _isDescriptionEditing = true;
    }

    private void CancelDescriptionEdit()
    {
        _editDescription = _info?.Description ?? string.Empty;
        _isDescriptionEditing = false;
    }

    private async Task SaveDescriptionAsync()
    {
        if (_info is null)
            return;

        _isSaving = true;

        try
        {
            _info = await InfoApi.SaveDescriptionAsync(
                _info.EquipName,
                _editDescription);

            _editDescription = _info.Description ?? string.Empty;
            _isDescriptionEditing = false;

            Notify(NotificationSeverity.Success, "Info", "Description saved.");
            ClearStatus();
        }
        catch (Exception ex)
        {
            SetStatus(AlertStyle.Danger, "Cannot save description: " + ex.Message);
            Notify(NotificationSeverity.Error, "Info", "Cannot save description.");
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task AddNoteAsync()
    {
        if (_info is null || string.IsNullOrWhiteSpace(_newNoteText))
            return;

        _isSaving = true;

        try
        {
            var note = await InfoApi.AddNoteAsync(
                _info.EquipName,
                _newNoteText);

            _info.Notes.Insert(0, note);
            _newNoteText = string.Empty;

            Notify(NotificationSeverity.Success, "Info", "Note added.");
            ClearStatus();
        }
        catch (Exception ex)
        {
            SetStatus(AlertStyle.Danger, "Cannot add note: " + ex.Message);
            Notify(NotificationSeverity.Error, "Info", "Cannot add note.");
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void BeginNoteEdit(EquipmentInfoNoteDto note)
    {
        _editingNoteId = note.Id;
        _editNoteText = note.NoteText;
    }

    private void CancelNoteEdit()
    {
        _editingNoteId = null;
        _editNoteText = string.Empty;
    }

    private async Task SaveNoteEditAsync(EquipmentInfoNoteDto note)
    {
        if (_info is null || string.IsNullOrWhiteSpace(_editNoteText))
            return;

        _isSaving = true;

        try
        {
            var updated = await InfoApi.UpdateNoteAsync(
                _info.EquipName,
                note.Id,
                _editNoteText);

            var index = _info.Notes.FindIndex(x => x.Id == updated.Id);
            if (index >= 0)
                _info.Notes[index] = updated;

            CancelNoteEdit();

            Notify(NotificationSeverity.Success, "Info", "Note saved.");
            ClearStatus();
        }
        catch (Exception ex)
        {
            SetStatus(AlertStyle.Danger, "Cannot save note: " + ex.Message);
            Notify(NotificationSeverity.Error, "Info", "Cannot save note.");
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task DeleteNoteAsync(EquipmentInfoNoteDto note)
    {
        if (_info is null)
            return;

        var confirmed = await DialogService.Confirm(
            "Delete selected note?",
            "Delete note",
            new ConfirmOptions
            {
                OkButtonText = "Delete",
                CancelButtonText = "Cancel"
            });

        if (confirmed != true)
            return;

        _isSaving = true;

        try
        {
            await InfoApi.DeleteNoteAsync(_info.EquipName, note.Id);
            _info.Notes.Remove(note);

            if (_editingNoteId == note.Id)
                CancelNoteEdit();

            Notify(NotificationSeverity.Success, "Info", "Note deleted.");
            ClearStatus();
        }
        catch (Exception ex)
        {
            SetStatus(AlertStyle.Danger, "Cannot delete note: " + ex.Message);
            Notify(NotificationSeverity.Error, "Info", "Cannot delete note.");
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void ClearEditState()
    {
        _isDescriptionEditing = false;
        _editingNoteId = null;
        _editNoteText = string.Empty;
    }

    private string GetSelectedTypeName()
    {
        var selected = SelectedEquipmentState.SelectedEquipment;
        if (selected is null || string.IsNullOrWhiteSpace(selected.TypeName))
            return "—";

        return selected.TypeName;
    }

    private string GetSelectedLocation()
    {
        var selected = SelectedEquipmentState.SelectedEquipment;
        if (selected is null || string.IsNullOrWhiteSpace(selected.Location))
            return "—";

        return selected.Location;
    }

    private static string DisplayValue(string? value)
    {
        return string.IsNullOrWhiteSpace(value)
            ? "—"
            : value.Trim();
    }

    private static string FormatDate(DateTime? value)
    {
        return value is null
            ? "—"
            : value.Value.ToString("dd.MM.yyyy HH:mm");
    }

    private void SetStatus(AlertStyle style, string text)
    {
        _statusStyle = style;
        _statusText = text;
    }

    private void ClearStatus()
    {
        _statusText = string.Empty;
    }

    private void Notify(NotificationSeverity severity, string summary, string detail)
    {
        NotificationService.Notify(new NotificationMessage
        {
            Severity = severity,
            Summary = summary,
            Detail = detail,
            Duration = 3500
        });
    }

    public void Dispose()
    {
        SelectedEquipmentState.Changed -= OnSelectedEquipmentChanged;
    }
}
