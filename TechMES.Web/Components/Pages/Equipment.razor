@page "/"
@page "/equipment"
@page "/equipment/param"
@using Microsoft.AspNetCore.Components.Routing
@inject EquipmentApiClient EquipmentApi
@inject NotificationService NotificationService
@inject SelectedEquipmentState SelectedEquipmentState
@inject EquipmentFooterState EquipmentFooterState
@inject QrScannerState QrScannerState
@inject NavigationManager NavigationManager
@implements IDisposable

<PageTitle>@(IsParamMode ? "Param" : "Info")</PageTitle>

<div class="equipment-page">
    <div class="equipment-filter-layout">
        <div class="equipment-tree-filters">
            <RadzenDropDown TValue="string"
                            Data="@_stationItems"
                            @bind-Value="_selectedStation"
                            Change="@(_ => ApplyFilters())"
                            Style="width: 100%;" />

            <RadzenDropDown TValue="string"
                            Data="@_typeItems"
                            @bind-Value="_selectedType"
                            Change="@(_ => ApplyFilters())"
                            Style="width: 100%;">
                <Template Context="typeItem">
                    <div class="type-filter-item">
                        @if (IsFavoritesType(typeItem))
                        {
                            <RadzenIcon Icon="star" class="favorite-filter-icon is-favorite" />
                        }
                        else if (TryGetTypeGroup(typeItem, out EquipmentTypeGroup typeGroup))
                        {
                            <EquipmentTypeBadge TypeGroup="@typeGroup" Style="margin-right: 8px;" />
                        }
                        <span>@typeItem</span>
                    </div>
                </Template>
                <ValueTemplate Context="typeItem">
                    <div class="type-filter-item">
                        @if (IsFavoritesType(typeItem))
                        {
                            <RadzenIcon Icon="star" class="favorite-filter-icon is-favorite" />
                        }
                        else if (TryGetTypeGroup(typeItem, out EquipmentTypeGroup typeGroup))
                        {
                            <EquipmentTypeBadge TypeGroup="@typeGroup" Style="margin-right: 8px;" />
                        }
                        <span>@typeItem</span>
                    </div>
                </ValueTemplate>
            </RadzenDropDown>
        </div>

        <div class="equipment-search-actions">
            <div class="equipment-search-wrapper">
                <RadzenAutoComplete Data="@_searchSuggestions"
                                    @bind-Value="_searchText"
                                    Change="@OnSearchChanged"
                                    Placeholder="Search equipment..."
                                    MinLength="0"
                                    FilterDelay="150"
                                    OpenOnFocus="true"
                                    class="equipment-search-box"
                                    Style="width: 100%;" />

                @if (!string.IsNullOrWhiteSpace(_searchText))
                {
                    <RadzenButton Icon="close"
                                  ButtonStyle="ButtonStyle.Light"
                                  Size="ButtonSize.Small"
                                  class="equipment-search-clear-button"
                                  Click="@ClearSearch" />
                }
            </div>

            <RadzenButton Text="Refresh"
                          Icon="refresh"
                          ButtonStyle="ButtonStyle.Light"
                          Disabled="@_isLoading"
                          class="equipment-refresh-button"
                          Click="@LoadAsync" />
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_statusText))
    {
        <RadzenAlert AlertStyle="@_statusStyle"
                     ShowIcon="true"
                     AllowClose="true"
                     Close="@(() => _statusText = string.Empty)">
            @_statusText
        </RadzenAlert>
    }

    @if (_isLoading)
    {
        <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" />
    }

    <RadzenSplitter class="equipment-main-splitter">
        <RadzenSplitterPane Size="400px" Min="400px" Max="400px" class="equipment-left-pane">
            @if (_treeRows.Count == 0 && !_isLoading)
            {
                <RadzenCard>
                    <RadzenText Text="No equipment found." TextStyle="TextStyle.Subtitle1" />
                </RadzenCard>
            }
            else
            {
                <RadzenCard Style="height: 100%; padding: 0; overflow: hidden;">
                    <div style="height: 100%; overflow: auto; padding: 8px;">
                        @foreach (var row in _treeRows)
                        {
                            <div class="equipment-tree-row"
                                 style="@GetTreeRowStyle(row)"
                                 @onclick="() => SelectEquipment(row.Node)">

                                <div class="equipment-tree-main-row">
                                    <span class="equipment-tree-indent" style="width:@(row.Level * 22)px;"></span>

                                    @if (row.HasChildren)
                                    {
                                        <span class="equipment-tree-expand" @onclick:stopPropagation="true">
                                            <RadzenButton Icon="@(row.IsExpanded ? "expand_more" : "chevron_right")"
                                                          ButtonStyle="ButtonStyle.Light"
                                                          Size="ButtonSize.Small"
                                                          Click="@(() => ToggleNode(row.Node))"
                                                          Style="width: 28px; height: 28px; min-width: 28px; padding: 0;" />
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="equipment-tree-expand-placeholder"></span>
                                    }

                                    <EquipmentTypeBadge TypeGroup="@row.Node.TypeGroup" Style="margin-right: 8px;" />

                                    <span class="equipment-tree-name">@row.Node.Name</span>
                                    <span class="equipment-tree-spacer"></span>

                                    @if (HasInfoIndicators(row.Node))
                                    {
                                        <div class="equipment-tree-indicators">
                                            @if (row.Node.PhotoCount > 0)
                                            {
                                                <RadzenIcon Icon="image" class="equipment-tree-indicator" title="Images" />
                                            }

                                            @if (row.Node.InstructionCount > 0)
                                            {
                                                <RadzenIcon Icon="picture_as_pdf" class="equipment-tree-indicator" title="PDF" />
                                            }

                                            @if (row.Node.SchemeCount > 0)
                                            {
                                                <RadzenIcon Icon="account_tree" class="equipment-tree-indicator" title="Schemes" />
                                            }

                                            @if (row.Node.NoteCount > 0)
                                            {
                                                <RadzenIcon Icon="sticky_note_2" class="equipment-tree-indicator" title="Notes" />
                                            }
                                        </div>
                                    }

                                    @if (row.Node.IsFavorite)
                                    {
                                        <RadzenIcon Icon="star" class="equipment-tree-favorite" title="Favorite" />
                                    }
                                </div>

                                <div class="equipment-tree-description" style="margin-left:@(row.Level * 22 + TreeDescriptionBaseIndent)px;">
                                    @row.Node.DisplayName
                                    @if (!string.IsNullOrWhiteSpace(row.Node.Description)
                                        && !string.Equals(row.Node.Description, row.Node.DisplayName, StringComparison.OrdinalIgnoreCase))
                                    {
                                        <span> · @row.Node.Description</span>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </RadzenCard>
            }
        </RadzenSplitterPane>

        <RadzenSplitterPane class="equipment-right-pane">
            <div @key="IsParamMode" class="equipment-right-mode-host">
                @if (IsParamMode)
                {
                    <EquipmentParamPanel Equipment="@_selectedEquipment"
                                         IsActive="@IsParamMode"
                                         IsFavoriteSaving="@_isFavoriteSaving"
                                         OnToggleFavorite="@ToggleSelectedFavoriteAsync"
                                         OnSelectEquipment="@SelectEquipmentByNameAsync" />
                }
                else
                {
                    <EquipmentInfoPanel Equipment="@_selectedEquipment"
                                        IsFavoriteSaving="@_isFavoriteSaving"
                                        OnToggleFavorite="@ToggleSelectedFavoriteAsync"
                                        OnInfoCountsChanged="@OnInfoCountsChanged" />
                }
            </div>
        </RadzenSplitterPane>
    </RadzenSplitter>
</div>

@code {
    private const string AllStationsText = "All stations";
    private const string AllTypesText = "All types";
    private const string FavoritesTypeText = "Favorites";
    private const string RootParentNodeId = "0";
    private const int TreeDescriptionBaseIndent = 73;

    private List<EquipmentDto> _allEquipments = [];
    private List<TreeRow> _treeRows = [];
    private List<string> _searchSuggestions = [];

    private EquipmentDto? _selectedEquipment;

    private List<string> _stationItems = [AllStationsText];
    private List<string> _typeItems = [AllTypesText];

    private readonly HashSet<string> _expandedNodeIds = new(StringComparer.OrdinalIgnoreCase);

    private string _selectedStation = AllStationsText;
    private string _selectedType = AllTypesText;
    private string _searchText = "";

    private bool _isLoading;
    private bool _isFavoriteSaving;

    private string _statusText = "";
    private AlertStyle _statusStyle = AlertStyle.Info;

    private bool IsParamMode =>
        NavigationManager
            .ToBaseRelativePath(NavigationManager.Uri)
            .StartsWith("equipment/param", StringComparison.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync()
    {
        NavigationManager.LocationChanged += OnLocationChanged;
        QrScannerState.Scanned += SelectEquipmentFromQrAsync;
        await LoadAsync();
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs args)
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private async Task LoadAsync()
    {
        _isLoading = true;

        // Если в текущей странице выбранного equipment ещё нет,
        // пробуем взять выбор из глобального state.
        // Это пригодится, когда пользователь вернулся на /equipment с другой страницы.
        var preferredName = _selectedEquipment?.Name ?? SelectedEquipmentState.SelectedEquipmentName;
        var preferredNodeId = _selectedEquipment?.NodeId;

        try
        {
            var response = await EquipmentApi.GetEquipmentListAsync();

            _allEquipments = response.Equipments.ToList();
            NormalizeTreeFields(_allEquipments);
            _searchSuggestions = BuildSearchSuggestions(_allEquipments);

            _stationItems = [AllStationsText];
            _stationItems.AddRange(response.Stations);

            _typeItems = [AllTypesText, FavoritesTypeText];
            _typeItems.AddRange(response.TypeGroups.Select(x => x.ToString()));

            // При первой загрузке раскрываем группы, чтобы пользователь сразу увидел,
            // что WEB уже получил не плоский список, а структуру для дерева.
            foreach (var group in _allEquipments.Where(x => x.IsGroup))
            {
                _expandedNodeIds.Add(GetNodeId(group));
            }

            ApplyFilters(preferredName, preferredNodeId);

            _statusText = "";
        }
        catch (Exception ex)
        {
            EquipmentFooterState.SetTreeCount(0);
            EquipmentFooterState.ClearInfoCounts();

            _statusStyle = AlertStyle.Danger;
            _statusText = "Cannot load equipment catalog from Runtime Service: " + ex.Message;

            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Error,
                Summary = "Equipment",
                Detail = "Cannot load equipment catalog.",
                Duration = 3500
            });
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void ApplyFilters()
    {
        ApplyFilters(_selectedEquipment?.Name, _selectedEquipment?.NodeId);
    }

    private void OnSearchChanged(object? value)
    {
        _searchText = Convert.ToString(value) ?? string.Empty;
        ApplyFilters();
    }

    private void ClearSearch()
    {
        if (string.IsNullOrWhiteSpace(_searchText))
            return;

        _searchText = string.Empty;
        ApplyFilters();
    }

    private void ApplyFilters(string? preferredName, string? preferredNodeId)
    {
        var directlyMatched = _allEquipments
            .Where(MatchesFilters)
            .ToList();

        var includedNodeIds = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        var isEquipmentTypeFilter = IsEquipmentTypeFilterActive();

        foreach (var equipment in directlyMatched)
        {
            IncludeNodeWithParents(equipment, includedNodeIds);

            // Особенность Tree-фильтра для Type = Equipment:
            // сама group-нода имеет TypeGroup=Equipment, а её дочерние узлы могут быть Motor/AI/VGA/etc.
            // Если оставить обычную фильтрацию только по TypeGroup, группа будет показана пустой.
            // Поэтому в режиме Equipment дополнительно включаем дочерние узлы выбранной группы.
            if (isEquipmentTypeFilter && equipment.IsGroup)
            {
                IncludeNodeWithChildren(equipment, includedNodeIds);
                _expandedNodeIds.Add(GetNodeId(equipment));
            }
        }

        // Если есть активный поиск или фильтр типа, автоматически раскрываем родителей найденных child-нод.
        // Иначе совпадение могло бы быть внутри закрытой группы, и пользователь не увидел бы результат.
        if (IsAnyNarrowFilterActive())
        {
            foreach (var equipment in directlyMatched)
            {
                ExpandParents(equipment);

                if (isEquipmentTypeFilter && equipment.IsGroup)
                {
                    _expandedNodeIds.Add(GetNodeId(equipment));
                }
            }
        }

        _treeRows = BuildTreeRows(includedNodeIds);
        EquipmentFooterState.SetTreeCount(_treeRows.Count);

        ApplySelectionAfterFilter(preferredName, preferredNodeId);
    }

    private bool MatchesFilters(EquipmentDto equipment)
    {
        if (!string.Equals(_selectedStation, AllStationsText, StringComparison.OrdinalIgnoreCase)
            && !string.Equals(equipment.Station, _selectedStation, StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }

        if (IsFavoritesTypeFilterActive())
        {
            if (!IsPhysicalEquipment(equipment) || !equipment.IsFavorite)
            {
                return false;
            }
        }
        else if (!string.Equals(_selectedType, AllTypesText, StringComparison.OrdinalIgnoreCase)
            && !string.Equals(equipment.TypeGroup.ToString(), _selectedType, StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }

        if (!string.IsNullOrWhiteSpace(_searchText))
        {
            var search = _searchText.Trim();

            return equipment.Name.Contains(search, StringComparison.OrdinalIgnoreCase)
                || equipment.DisplayName.Contains(search, StringComparison.OrdinalIgnoreCase)
                || equipment.Description.Contains(search, StringComparison.OrdinalIgnoreCase)
                || equipment.Location.Contains(search, StringComparison.OrdinalIgnoreCase)
                || equipment.TypeName.Contains(search, StringComparison.OrdinalIgnoreCase);
        }

        return true;
    }

    private bool IsAnyNarrowFilterActive()
    {
        return !string.Equals(_selectedType, AllTypesText, StringComparison.OrdinalIgnoreCase)
            || !string.IsNullOrWhiteSpace(_searchText);
    }

    private void IncludeNodeWithParents(
        EquipmentDto equipment,
        HashSet<string> includedNodeIds)
    {
        var current = equipment;

        while (true)
        {
            includedNodeIds.Add(GetNodeId(current));

            if (string.IsNullOrWhiteSpace(current.ParentNodeId)
                || string.Equals(current.ParentNodeId, RootParentNodeId, StringComparison.OrdinalIgnoreCase))
            {
                break;
            }

            var parent = _allEquipments.FirstOrDefault(x =>
                string.Equals(GetNodeId(x), current.ParentNodeId, StringComparison.OrdinalIgnoreCase));

            if (parent is null)
                break;

            current = parent;
        }
    }

    private void IncludeNodeWithChildren(
        EquipmentDto equipment,
        HashSet<string> includedNodeIds)
    {
        var parentNodeId = GetNodeId(equipment);

        var children = _allEquipments
            .Where(x => string.Equals(x.ParentNodeId, parentNodeId, StringComparison.OrdinalIgnoreCase))
            .ToList();

        foreach (var child in children)
        {
            includedNodeIds.Add(GetNodeId(child));

            // Оставляем метод рекурсивным на будущее.
            // Сейчас у нас обычно один уровень: Equipment group -> child equipment.
            IncludeNodeWithChildren(child, includedNodeIds);
        }
    }

    private bool IsEquipmentTypeFilterActive()
    {
        return string.Equals(
            _selectedType,
            EquipmentTypeGroup.Equipment.ToString(),
            StringComparison.OrdinalIgnoreCase);
    }

    private bool IsFavoritesTypeFilterActive()
    {
        return IsFavoritesType(_selectedType);
    }

    private static bool IsFavoritesType(string? typeText)
    {
        return string.Equals(typeText, FavoritesTypeText, StringComparison.OrdinalIgnoreCase);
    }

    private static bool IsPhysicalEquipment(EquipmentDto equipment)
    {
        return !equipment.IsGroup && !equipment.IsEquipmentChildNode;
    }

    private void ExpandParents(EquipmentDto equipment)
    {
        var current = equipment;

        while (!string.IsNullOrWhiteSpace(current.ParentNodeId)
            && !string.Equals(current.ParentNodeId, RootParentNodeId, StringComparison.OrdinalIgnoreCase))
        {
            var parent = _allEquipments.FirstOrDefault(x =>
                string.Equals(GetNodeId(x), current.ParentNodeId, StringComparison.OrdinalIgnoreCase));

            if (parent is null)
                break;

            _expandedNodeIds.Add(GetNodeId(parent));
            current = parent;
        }
    }

    private List<TreeRow> BuildTreeRows(HashSet<string> includedNodeIds)
    {
        var includedItems = _allEquipments
            .Where(x => includedNodeIds.Contains(GetNodeId(x)))
            .ToList();

        var childrenByParent = includedItems
            .GroupBy(x => string.IsNullOrWhiteSpace(x.ParentNodeId) ? RootParentNodeId : x.ParentNodeId)
            .ToDictionary(
                x => x.Key,
                x => x.OrderBy(item => item.IsGroup ? 0 : 1)
                    .ThenBy(item => item.Station)
                    .ThenBy(item => item.TypeGroup)
                    .ThenBy(item => item.Name)
                    .ToList(),
                StringComparer.OrdinalIgnoreCase);

        var result = new List<TreeRow>();

        AddChildren(RootParentNodeId, level: 0);

        return result;

        void AddChildren(string parentNodeId, int level)
        {
            if (!childrenByParent.TryGetValue(parentNodeId, out var children))
                return;

            foreach (var child in children)
            {
                var nodeId = GetNodeId(child);
                var hasChildren = childrenByParent.ContainsKey(nodeId);
                var isExpanded = _expandedNodeIds.Contains(nodeId);

                result.Add(new TreeRow(child, level, hasChildren, isExpanded));

                if (hasChildren && isExpanded)
                {
                    AddChildren(nodeId, level + 1);
                }
            }
        }
    }

    private void ApplySelectionAfterFilter(string? preferredName, string? preferredNodeId)
    {
        if (_treeRows.Count == 0)
        {
            SetSelectedEquipment(null);
            return;
        }

        EquipmentDto? selected = null;

        if (!string.IsNullOrWhiteSpace(preferredNodeId))
        {
            selected = _treeRows.FirstOrDefault(x =>
                string.Equals(GetNodeId(x.Node), preferredNodeId, StringComparison.OrdinalIgnoreCase))?.Node;
        }

        if (selected is null && !string.IsNullOrWhiteSpace(preferredName))
        {
            selected = _treeRows.FirstOrDefault(x =>
                string.Equals(x.Node.Name, preferredName, StringComparison.OrdinalIgnoreCase))?.Node;
        }

        // Как и в Messages:
        // если старый выбранный элемент остался в дереве — оставляем его;
        // если исчез после фильтра — выбираем первый видимый узел.
        SetSelectedEquipment(selected ?? _treeRows.First().Node);
    }

    private void SelectEquipment(EquipmentDto equipment)
    {
        SetSelectedEquipment(equipment);
    }

    private Task SelectEquipmentByNameAsync(string equipmentName)
    {
        equipmentName = (equipmentName ?? string.Empty).Trim();
        if (equipmentName.Length == 0)
            return Task.CompletedTask;

        var match = _allEquipments
            .Where(x => !x.IsGroup)
            .OrderBy(x => x.IsEquipmentChildNode ? 1 : 0)
            .FirstOrDefault(x => string.Equals(x.Name, equipmentName, StringComparison.OrdinalIgnoreCase));

        if (match is null)
        {
            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Warning,
                Summary = "Param",
                Detail = $"Equipment was not found: {equipmentName}",
                Duration = 3000
            });

            return Task.CompletedTask;
        }

        _selectedStation = !string.IsNullOrWhiteSpace(match.Station)
            && _stationItems.Contains(match.Station, StringComparer.OrdinalIgnoreCase)
                ? match.Station
                : AllStationsText;

        _selectedType = _typeItems.Contains(match.TypeGroup.ToString(), StringComparer.OrdinalIgnoreCase)
            ? match.TypeGroup.ToString()
            : AllTypesText;

        _searchText = match.Name;
        ExpandParents(match);
        ApplyFilters(match.Name, match.NodeId);

        return Task.CompletedTask;
    }

    private void SetSelectedEquipment(EquipmentDto? equipment)
    {
        _selectedEquipment = equipment;

        // Сохраняем выбор в общем state service.
        // Теперь другие страницы могут узнать, какое оборудование выбрано.
        SelectedEquipmentState.SetSelectedEquipment(equipment);
    }

    private async Task ToggleSelectedFavoriteAsync()
    {
        if (_selectedEquipment is null || _selectedEquipment.IsGroup || _isFavoriteSaving)
            return;

        var equipmentName = _selectedEquipment.Name;
        var preferredNodeId = _selectedEquipment.NodeId;
        var oldValue = _selectedEquipment.IsFavorite;
        var newValue = !oldValue;

        _isFavoriteSaving = true;
        SetFavoriteFlagInLoadedEquipments(equipmentName, newValue);

        try
        {
            var updated = await EquipmentApi.SetFavoriteAsync(equipmentName, newValue);

            if (updated is null)
                throw new InvalidOperationException("Equipment was not found in Runtime Service.");

            SetFavoriteFlagInLoadedEquipments(equipmentName, updated.IsFavorite);
            ApplyFilters(equipmentName, preferredNodeId);
        }
        catch (Exception ex)
        {
            SetFavoriteFlagInLoadedEquipments(equipmentName, oldValue);
            ApplyFilters(equipmentName, preferredNodeId);

            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Error,
                Summary = "Favorite",
                Detail = ex.Message,
                Duration = 3500
            });
        }
        finally
        {
            _isFavoriteSaving = false;
        }
    }

    private void SetFavoriteFlagInLoadedEquipments(string equipmentName, bool isFavorite)
    {
        foreach (var equipment in _allEquipments)
        {
            if (equipment.IsGroup)
                continue;

            if (string.Equals(equipment.Name, equipmentName, StringComparison.OrdinalIgnoreCase))
            {
                equipment.IsFavorite = isFavorite;
            }
        }

        if (_selectedEquipment is not null
            && !_selectedEquipment.IsGroup
            && string.Equals(_selectedEquipment.Name, equipmentName, StringComparison.OrdinalIgnoreCase))
        {
            _selectedEquipment.IsFavorite = isFavorite;
        }
    }

    private void ToggleNode(EquipmentDto equipment)
    {
        var nodeId = GetNodeId(equipment);

        if (!_expandedNodeIds.Add(nodeId))
        {
            _expandedNodeIds.Remove(nodeId);
        }

        ApplyFilters(_selectedEquipment?.Name, _selectedEquipment?.NodeId);
    }

    private string GetTreeRowStyle(TreeRow row)
    {
        var selected = IsSelected(row.Node);

        var baseStyle = "border-radius: 10px; padding: 8px; margin-bottom: 4px; cursor: pointer; border: 1px solid transparent;";

        if (selected)
            return baseStyle + " border-color: var(--rz-primary); background: var(--rz-primary-lighter);";

        if (row.Node.IsGroup)
            return baseStyle + " background: rgba(0, 0, 0, 0.025);";

        if (row.Node.IsEquipmentChildNode)
            return baseStyle + " background: rgba(0, 0, 0, 0.015);";

        return baseStyle;
    }

    private bool IsSelected(EquipmentDto equipment)
    {
        return string.Equals(
            _selectedEquipment?.NodeId,
            GetNodeId(equipment),
            StringComparison.OrdinalIgnoreCase);
    }

    private static bool TryGetTypeGroup(string? typeText, out EquipmentTypeGroup typeGroup)
    {
        if (Enum.TryParse(typeText, ignoreCase: true, out typeGroup))
            return true;

        typeGroup = EquipmentTypeGroup.Unknown;
        return false;
    }

    private static string GetFavoriteIcon(EquipmentDto equipment)
    {
        return equipment.IsFavorite ? "star" : "star_border";
    }

    private static string GetFavoriteButtonClass(EquipmentDto equipment)
    {
        return equipment.IsFavorite
            ? "equipment-favorite-button is-favorite"
            : "equipment-favorite-button";
    }

    private static bool ShouldShowLocation(EquipmentDto equipment)
    {
        return !string.IsNullOrWhiteSpace(equipment.Location)
            && !string.Equals(equipment.Location, "Unknown", StringComparison.OrdinalIgnoreCase);
    }

    private static string FormatLocation(string? raw)
    {
        raw = (raw ?? "").Trim();

        if (string.IsNullOrWhiteSpace(raw))
            return "";

        if (raw.Equals("Unknown", StringComparison.OrdinalIgnoreCase))
            return raw;

        var parts = raw.Split('.', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);

        if (parts.Length >= 2)
            return $"module: {parts[0]}, chanel: {parts[1]}";

        return raw;
    }

    private static string GetDescriptionText(EquipmentDto equipment)
    {
        return string.IsNullOrWhiteSpace(equipment.Description)
            ? "-"
            : equipment.Description;
    }

    private static string GetNodeId(EquipmentDto equipment)
    {
        return string.IsNullOrWhiteSpace(equipment.NodeId)
            ? equipment.Name
            : equipment.NodeId;
    }

    private static void NormalizeTreeFields(List<EquipmentDto> equipments)
    {
        // InMemory provider и будущие адаптеры могут вернуть старую плоскую модель.
        // Здесь WEB аккуратно достраивает NodeId/ParentNodeId, чтобы Tree UI не падал.
        foreach (var equipment in equipments)
        {
            if (string.IsNullOrWhiteSpace(equipment.NodeId))
            {
                equipment.NodeId = equipment.IsGroup
                    ? $"GRP:{equipment.Name}"
                    : string.IsNullOrWhiteSpace(equipment.ParentName)
                        ? $"EQ:{equipment.Name}"
                        : $"CH:{equipment.ParentName}:{equipment.Name}";
            }

            if (string.IsNullOrWhiteSpace(equipment.ParentNodeId))
            {
                equipment.ParentNodeId = RootParentNodeId;
            }
        }

        var groupNodeByName = equipments
            .Where(x => x.IsGroup)
            .GroupBy(x => x.Name, StringComparer.OrdinalIgnoreCase)
            .ToDictionary(x => x.Key, x => x.First().NodeId, StringComparer.OrdinalIgnoreCase);

        foreach (var equipment in equipments)
        {
            if (string.IsNullOrWhiteSpace(equipment.ParentName))
                continue;

            if (groupNodeByName.TryGetValue(equipment.ParentName, out var parentNodeId))
            {
                equipment.ParentNodeId = parentNodeId;
                equipment.IsEquipmentChildNode = true;
            }
        }
    }

    private static List<string> BuildSearchSuggestions(IEnumerable<EquipmentDto> equipments)
    {
        return equipments
            .Select(x => x.Name)
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Select(x => x.Trim())
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(x => x, StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private static bool HasInfoIndicators(EquipmentDto equipment)
    {
        return equipment.PhotoCount > 0
            || equipment.InstructionCount > 0
            || equipment.SchemeCount > 0
            || equipment.NoteCount > 0;
    }

    private void OnInfoCountsChanged()
    {
        StateHasChanged();
    }

    /// <summary>
    /// Handles QR text published by the global header scanner and converts it into
    /// the normal equipment selection flow: choose station/type filters, expand
    /// parents, select the node, and refresh the details panel.
    /// </summary>
    private Task SelectEquipmentFromQrAsync(string qrText)
    {
        return InvokeAsync(() =>
        {
            qrText = (qrText ?? string.Empty).Trim();
            if (string.IsNullOrWhiteSpace(qrText))
                return;

            var match = FindEquipmentForQrText(qrText);
            if (match is null)
            {
                NotificationService.Notify(new NotificationMessage
                {
                    Severity = NotificationSeverity.Warning,
                    Summary = "QR",
                    Detail = $"Equipment was not found: {qrText}",
                    Duration = 3500
                });

                StateHasChanged();
                return;
            }

            if (!string.IsNullOrWhiteSpace(match.Station)
                && _stationItems.Contains(match.Station, StringComparer.OrdinalIgnoreCase))
            {
                _selectedStation = match.Station;
            }
            else
            {
                _selectedStation = AllStationsText;
            }

            _selectedType = _typeItems.Contains(match.TypeGroup.ToString(), StringComparer.OrdinalIgnoreCase)
                ? match.TypeGroup.ToString()
                : AllTypesText;

            _searchText = match.Name;
            ExpandParents(match);
            ApplyFilters(match.Name, match.NodeId);

            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Success,
                Summary = "QR",
                Detail = $"Selected: {match.Name}",
                Duration = 2500
            });

            StateHasChanged();
        });
    }

    private EquipmentDto? FindEquipmentForQrText(string qrText)
    {
        qrText = (qrText ?? string.Empty).Trim();
        if (string.IsNullOrWhiteSpace(qrText))
            return null;

        var items = _allEquipments
            .Where(x => !x.IsGroup)
            .ToList();

        return items.FirstOrDefault(x => string.Equals(x.Name, qrText, StringComparison.OrdinalIgnoreCase))
            ?? items.FirstOrDefault(x => string.Equals(x.DisplayName, qrText, StringComparison.OrdinalIgnoreCase))
            ?? items.FirstOrDefault(x => x.Name.StartsWith(qrText, StringComparison.OrdinalIgnoreCase))
            ?? items.FirstOrDefault(x => x.DisplayName.StartsWith(qrText, StringComparison.OrdinalIgnoreCase))
            ?? items.FirstOrDefault(x => x.Name.Contains(qrText, StringComparison.OrdinalIgnoreCase))
            ?? items.FirstOrDefault(x => x.DisplayName.Contains(qrText, StringComparison.OrdinalIgnoreCase));
    }

    private sealed record TreeRow(
        EquipmentDto Node,
        int Level,
        bool HasChildren,
        bool IsExpanded);

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
        QrScannerState.Scanned -= SelectEquipmentFromQrAsync;
        EquipmentFooterState.Clear();
    }
}
