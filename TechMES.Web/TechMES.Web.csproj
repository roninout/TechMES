<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Authentication.Negotiate" Version="10.0.8" />
	<!-- SignalR Client нужен WEB-приложению, чтобы получать live-события от Runtime.Service. -->    
    <PackageReference Include="Microsoft.AspNetCore.SignalR.Client" Version="10.0.8" />
    <PackageReference Include="Microsoft.Extensions.Hosting.WindowsServices" Version="10.0.8" />
	<!-- Radzen — библиотека UI-компонентов для Blazor: кнопки, списки, формы, layout. -->
    <PackageReference Include="Radzen.Blazor" Version="10.4.3" />
    <PackageReference Include="QRCoder" Version="1.7.0" />
    <PackageReference Include="ZXing.Net" Version="0.16.11" />
  </ItemGroup>

  <ItemGroup>
    <!-- Web использует Contracts, чтобы понимать DTO/request/response классы Runtime Service. -->
    <ProjectReference Include="..\TechMES.Contracts\TechMES.Contracts.csproj" />
  </ItemGroup>

</Project>
