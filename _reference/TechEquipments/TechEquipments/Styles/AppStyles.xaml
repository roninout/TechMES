<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
    xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
    xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
    xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
    xmlns:local="clr-namespace:TechEquipments">

    <!-- ============ BASE TEXT ============ -->
    <Style x:Key="AppTextBlockStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="TextWrapping" Value="NoWrap"/>
    </Style>

    <!-- ============ EDITORS (TextEdit / ComboBoxEdit etc) ============ -->
    <Style x:Key="AppBaseEditStyle" TargetType="{x:Type dxe:BaseEdit}">
        <Setter Property="Height" Value="40"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Padding" Value="10,0"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
    </Style>

    <!-- ============ Автоматически для всех ComboBoxEdit ============ -->
    <Style TargetType="{x:Type dxe:ComboBoxEdit}"
       BasedOn="{StaticResource AppBaseEditStyle}">
        <Setter Property="StyleSettings">
            <Setter.Value>
                <dxe:ComboBoxStyleSettings>
                    <dxe:ComboBoxStyleSettings.ItemContainerStyle>
                        <Style TargetType="{x:Type dxe:ComboBoxEditItem}">
                            <Setter Property="MinHeight" Value="30"/>
                        </Style>
                    </dxe:ComboBoxStyleSettings.ItemContainerStyle>
                </dxe:ComboBoxStyleSettings>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============ BUTTONS ============ -->
    <Style x:Key="AppButtonStyle" TargetType="{x:Type dx:SimpleButton}">
        <Setter Property="Height" Value="40"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Padding" Value="16,0"/>
    </Style>

    <!-- ToggleButton (стрелка слева / др. тумблеры) -->
    <Style x:Key="AppToggleStyle" TargetType="{x:Type ToggleButton}">
        <Setter Property="Height" Value="40"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Padding" Value="14,0"/>
    </Style>

    <!-- ============ LISTBOX ============ -->
    <Style x:Key="AppListBoxItemStyle" TargetType="{x:Type ListBoxItem}">
        <Setter Property="MinHeight" Value="36"/>
        <Setter Property="Padding" Value="10,4"/>
        <Setter Property="FontSize" Value="14"/>
    </Style>

    <!-- Общий стиль иконки по EquipTypeGroup. В Image.Tag передаём EquipTypeGroup. -->
    <Style x:Key="EquipTypeIconImageStyle" TargetType="{x:Type Image}">
        <Setter Property="Width" Value="16"/>
        <Setter Property="Height" Value="16"/>
        <Setter Property="Margin" Value="0,0,6,0"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>

        <!-- Иконка по умолчанию -->
        <Setter Property="Source" Value="{dx:DXImage 'Office2013/Actions/Show_16x16.png'}"/>

        <Style.Triggers>
            <!-- Equipment -->
            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="{x:Static local:EquipTypeGroup.Equipment}">
                <Setter Property="Source" Value="{dx:DXImage 'Office2013/Reports/GroupFieldCollection_16x16.png'}"/>
            </DataTrigger>

            <!-- AI -->
            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="{x:Static local:EquipTypeGroup.AI}">
                <Setter Property="Source" Value="{dx:DXImage 'Office2013/Chart/FullStackedLine_16x16.png'}"/>
            </DataTrigger>

            <!-- DI -->
            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="{x:Static local:EquipTypeGroup.DI}">
                <Setter Property="Source" Value="{dx:DXImage 'Office2013/Chart/Stepline_16x16.png'}"/>
            </DataTrigger>

            <!-- DO -->
            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="{x:Static local:EquipTypeGroup.DO}">
                <Setter Property="Source" Value="{dx:DXImage 'Office2013/Chart/OpenHighLowCloseCandleStick_16x16.png'}"/>
            </DataTrigger>

            <!-- Motor -->
            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="{x:Static local:EquipTypeGroup.Motor}">
                <Setter Property="Source" Value="{dx:DXImage 'Office2013/Programming/Technology_16x16.png'}"/>
            </DataTrigger>

            <!-- VGA -->
            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="{x:Static local:EquipTypeGroup.VGA}">
                <Setter Property="Source" Value="{dx:DXImage 'Office2013/Gauges/GaugeStyleLinearVertical_16x16.png'}"/>
            </DataTrigger>

            <!-- VGA_EL -->
            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="{x:Static local:EquipTypeGroup.VGA_EL}">
                <Setter Property="Source" Value="{dx:DXImage 'Office2013/Gauges/GaugeStyleRightQuarterCircular_16x16.png'}"/>
            </DataTrigger>

            <!-- VGD -->
            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="{x:Static local:EquipTypeGroup.VGD}">
                <Setter Property="Source" Value="{dx:DXImage 'Office2013/Chart/StepArea_16x16.png'}"/>
            </DataTrigger>

            <!-- Atv -->
            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="{x:Static local:EquipTypeGroup.Atv}">
                <Setter Property="Source" Value="{dx:DXImage 'Office2013/Gauges/GaugeStyleLinearHorizontal_16x16.png'}"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!--Шаблон элемента левого списка.DataContext = EquipListBoxItem-->
    <DataTemplate x:Key="EquipmentListItemTemplate">
        <Grid Margin="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Image Grid.Column="0"
               Tag="{Binding TypeGroup}"
               Style="{StaticResource EquipTypeIconImageStyle}"/>

            <TextBlock Grid.Column="1"
                   VerticalAlignment="Center"
                   Text="{Binding Equipment}"
                   TextTrimming="CharacterEllipsis">
                <TextBlock.ToolTip>
                    <StackPanel>
                        <TextBlock Text="{Binding Equipment}" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding Type}"/>
                        <TextBlock Text="{Binding Description}" TextWrapping="Wrap" MaxWidth="320"/>
                    </StackPanel>
                </TextBlock.ToolTip>
        </TextBlock>

        <TextBlock Grid.Column="2"
                Text="★"
                FontSize="16"
                Foreground="#C79A00"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">
            <TextBlock.Style>
                <Style TargetType="{x:Type TextBlock}">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        </Grid>
    </DataTemplate>

    <!-- Шаблон элемента Type ComboBox. DataContext = EquipTypeGroup (enum)-->
    <DataTemplate x:Key="EquipTypeFilterItemTemplate">
        <StackPanel Orientation="Horizontal">
            <Grid Width="16" Height="16" Margin="0,0,6,0">
                <Image Tag="{Binding}">
                    <Image.Style>
                        <Style TargetType="{x:Type Image}" BasedOn="{StaticResource EquipTypeIconImageStyle}">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding}" Value="{x:Static local:EquipTypeGroup.Favorites}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Image.Style>
                </Image>

                <TextBlock Text="★"
                       FontSize="18"
                       Foreground="#C79A00"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="{x:Type TextBlock}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding}" Value="{x:Static local:EquipTypeGroup.Favorites}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>

            <TextBlock Text="{Binding}"
                   VerticalAlignment="Center"/>
        </StackPanel>
    </DataTemplate>

    <!-- ============ GRID HEADERS ============ -->
    <Style x:Key="AppGridColumnHeaderStyle" TargetType="{x:Type dxg:GridColumnHeader}">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="MinHeight" Value="40"/>
    </Style>

    <!-- ============ TABLE VIEW ============ -->
    <Style x:Key="AppTableViewStyle" TargetType="{x:Type dxg:TableView}">
        <Setter Property="AllowEditing" Value="False"/>
        <Setter Property="RowMinHeight" Value="36"/>
        <Setter Property="ColumnHeaderStyle" Value="{StaticResource AppGridColumnHeaderStyle}"/>
        <Setter Property="ShowGroupPanel" Value="False"/>
        <Setter Property="AllowPerPixelScrolling" Value="True"/>
    </Style>

    <!-- ============ TABS ============ -->
    <Style x:Key="AppTabControlStyle" TargetType="{x:Type dx:DXTabControl}">
        <Setter Property="FontSize" Value="14"/>
    </Style>

    <Style x:Key="AppTabItemStyle" TargetType="{x:Type dx:DXTabItem}">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Padding" Value="14,8"/>
        <Setter Property="MinHeight" Value="40"/>
    </Style>

    <!-- ============ Label / Caption text ============ -->
    <Style x:Key="AppLabelTextStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Opacity" Value="0.85"/>
        <Setter Property="Margin" Value="0,0,0,4"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- ============ обычный текст ============ -->
    <Style x:Key="AppTextStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Opacity" Value="0.9"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- Общий шаблон лейбла Enabled/Disabled + жирность -->
    <DataTemplate x:Key="EnabledDisabledLabelTemplate">
        <TextBlock>
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Text" Value="Disabled"/>
                    <Setter Property="FontWeight" Value="Normal"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Path=Content.IsChecked, RelativeSource={RelativeSource AncestorType={x:Type dxlc:LayoutItem}}}" Value="True">
                            <Setter Property="Text" Value="Enabled"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>
    </DataTemplate>

    <!-- Стиль для LayoutItem с CheckEdit внутри -->
    <Style x:Key="BoolCheckLayoutItemStyle" TargetType="{x:Type dxlc:LayoutItem}">
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>

        <!-- чтобы зона лейбла гарантированно была -->
        <Setter Property="Label" Value=" "/>

        <Setter Property="LabelTemplate" Value="{StaticResource EnabledDisabledLabelTemplate}"/>
    </Style>

    <!-- (опционально) стиль для чекбокса -->
    <Style x:Key="BoolParamCheckEditStyle" TargetType="{x:Type dxe:CheckEdit}">
        <Setter Property="Width" Value="20"/>
        <Setter Property="IsReadOnly" Value="False"/>
    </Style>
    
    <!--FOR TREND-->
    <Style x:Key="HideWhenChartVisible_Group" TargetType="{x:Type dxlc:LayoutGroup}">
        <Setter Property="Visibility" Value="Visible"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsParamChartVisible, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                <Setter Property="Visibility" Value="Collapsed"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ShowWhenChartVisible_Item" TargetType="{x:Type dxlc:LayoutItem}">
        <Setter Property="Visibility" Value="Collapsed"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsParamChartVisible, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                <Setter Property="Visibility" Value="Visible"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ChartsToggleButtonStyle" TargetType="{x:Type dx:SimpleButton}" BasedOn="{StaticResource AppButtonStyle}">
        <Setter Property="Content" Value="Графики"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsParamChartVisible, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                <Setter Property="Content" Value="Параметры"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- Мигающий текст для Forced -->
    <Style x:Key="ForcedBlinkTextStyle" TargetType="{x:Type TextBlock}">
        <!-- Внешний вид -->
        <Setter Property="Foreground" Value="DarkOrange"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Opacity" Value="1"/>

        <Style.Triggers>
            <!-- Когда ForceCmd=true -> запускаем мигание -->
            <DataTrigger Binding="{Binding ForceCmd}" Value="True">
                <DataTrigger.EnterActions>
                    <BeginStoryboard x:Name="ForcedBlinkBegin">
                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                            <!-- Мигание: Opacity 1 <-> 0.15 -->
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             From="1.0" To="0.15"
                                             Duration="0:0:0.45"/>
                        </Storyboard>
                    </BeginStoryboard>
                </DataTrigger.EnterActions>

                <!-- Когда ForceCmd станет false -> стопаем мигание и возвращаем Opacity -->
                <DataTrigger.ExitActions>
                    <StopStoryboard BeginStoryboardName="ForcedBlinkBegin"/>
                </DataTrigger.ExitActions>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- Мигающий текст для AlarmHealth -->
    <Style x:Key="AlarmHealthBlinkTextStyle" TargetType="{x:Type TextBlock}">
        <!-- Внешний вид -->
        <Setter Property="Foreground" Value="Red"/>
        <!--<Setter Property="Foreground" Value="CornflowerBlue"/>-->
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Opacity" Value="1"/>

        <Style.Triggers>
            <!-- Когда AlarmHealth=true -> запускаем мигание -->
            <DataTrigger Binding="{Binding AlarmHealth}" Value="True">
                <DataTrigger.EnterActions>
                    <BeginStoryboard x:Name="AlarmHealthBlinkBegin">
                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                            <!-- Мигание: Opacity 1 <-> 0.15 -->
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             From="1.0" To="0.15"
                                             Duration="0:0:0.45"/>
                        </Storyboard>
                    </BeginStoryboard>
                </DataTrigger.EnterActions>

                <!-- Когда AlarmHealth станет false -> стопаем мигание и возвращаем Opacity -->
                <DataTrigger.ExitActions>
                    <StopStoryboard BeginStoryboardName="AlarmHealthBlinkBegin"/>
                </DataTrigger.ExitActions>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- VGD: State TextEdit style (color + blink) -->
    <Style x:Key="StateTextEditStyle"
       TargetType="{x:Type dxe:TextEdit}"
       BasedOn="{StaticResource AppBaseEditStyle}">

        <Setter Property="IsReadOnly" Value="True"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="BorderBrush" Value="Black"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground" Value="Black"/>

        <Setter Property="Background">
            <Setter.Value>
                <SolidColorBrush Color="#FFE6E6E6"/>
            </Setter.Value>
        </Setter>

        <Style.Triggers>

            <DataTrigger Binding="{Binding State}" Value="0">
                <Setter Property="Background" Value="#FFD6D6D6"/>
                <Setter Property="BorderBrush" Value="Black"/>
            </DataTrigger>

            <DataTrigger Binding="{Binding State}" Value="1">
                <Setter Property="Background" Value="#FFB7F2B7"/>
                <Setter Property="BorderBrush" Value="Black"/>
            </DataTrigger>

            <DataTrigger Binding="{Binding State}" Value="2">
                <Setter Property="Background" Value="#FFFFD0D0"/>
                <Setter Property="BorderBrush" Value="#FFB00000"/>
                <DataTrigger.EnterActions>
                    <BeginStoryboard x:Name="BlinkAlarmOpen">
                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                            <ColorAnimation Storyboard.TargetProperty="Background.Color"
                                        From="#FFFFD0D0" To="#FFFF4D4D" Duration="0:0:0.45"/>
                        </Storyboard>
                    </BeginStoryboard>
                </DataTrigger.EnterActions>
                <DataTrigger.ExitActions>
                    <RemoveStoryboard BeginStoryboardName="BlinkAlarmOpen"/>
                </DataTrigger.ExitActions>
            </DataTrigger>

            <DataTrigger Binding="{Binding State}" Value="3">
                <Setter Property="Background" Value="#FFFFD0D0"/>
                <Setter Property="BorderBrush" Value="#FFB00000"/>
                <DataTrigger.EnterActions>
                    <BeginStoryboard x:Name="BlinkAlarmClose">
                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                            <ColorAnimation Storyboard.TargetProperty="Background.Color"
                                        From="#FFFFD0D0" To="#FFFF4D4D" Duration="0:0:0.45"/>
                        </Storyboard>
                    </BeginStoryboard>
                </DataTrigger.EnterActions>
                <DataTrigger.ExitActions>
                    <RemoveStoryboard BeginStoryboardName="BlinkAlarmClose"/>
                </DataTrigger.ExitActions>
            </DataTrigger>

            <DataTrigger Binding="{Binding State}" Value="4">
                <Setter Property="Background" Value="#FFD6FFD6"/>
                <Setter Property="BorderBrush" Value="#FF007A00"/>
                <DataTrigger.EnterActions>
                    <BeginStoryboard x:Name="BlinkOpening">
                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                            <ColorAnimation Storyboard.TargetProperty="Background.Color"
                                        From="#FFD6FFD6" To="#FF2ECC71" Duration="0:0:0.45"/>
                        </Storyboard>
                    </BeginStoryboard>
                </DataTrigger.EnterActions>
                <DataTrigger.ExitActions>
                    <RemoveStoryboard BeginStoryboardName="BlinkOpening"/>
                </DataTrigger.ExitActions>
            </DataTrigger>

            <DataTrigger Binding="{Binding State}" Value="5">
                <Setter Property="Background" Value="#FFEDEDED"/>
                <Setter Property="BorderBrush" Value="#FF606060"/>
                <DataTrigger.EnterActions>
                    <BeginStoryboard x:Name="BlinkClosing">
                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                            <ColorAnimation Storyboard.TargetProperty="Background.Color"
                                        From="#FFEDEDED" To="#FFB0B0B0" Duration="0:0:0.45"/>
                        </Storyboard>
                    </BeginStoryboard>
                </DataTrigger.EnterActions>
                <DataTrigger.ExitActions>
                    <RemoveStoryboard BeginStoryboardName="BlinkClosing"/>
                </DataTrigger.ExitActions>
            </DataTrigger>

        </Style.Triggers>
    </Style>

    <!-- MotorParam.State status style (0..6)
     ВАЖНО: этот стиль читает State (а не Value), поэтому используем его ТОЛЬКО в MotorParamView.
     Старый PlcMotorStatusTextEditStyle (под Value) оставляем для PLC settings (PlcRefRow.Value). -->
    <Style x:Key="PlcMotorStatusStateTextEditStyle"
       TargetType="{x:Type dxe:TextEdit}"
       BasedOn="{StaticResource AppBaseEditStyle}">

        <!-- ReadOnly поле статуса -->
        <Setter Property="IsReadOnly" Value="True"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="BorderBrush" Value="Black"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground" Value="Black"/>

        <!-- дефолтный фон -->
        <Setter Property="Background">
            <Setter.Value>
                <SolidColorBrush Color="#FFE6E6E6"/>
            </Setter.Value>
        </Setter>

        <Style.Triggers>

            <!-- 0 stop -->
            <DataTrigger Binding="{Binding State}" Value="0">
                <Setter Property="Background" Value="#FFD6D6D6"/>
            </DataTrigger>

            <!-- 1 run -->
            <DataTrigger Binding="{Binding State}" Value="1">
                <Setter Property="Background" Value="#FFB7F2B7"/>
            </DataTrigger>

            <!-- 2 alarm (blink red) -->
            <DataTrigger Binding="{Binding State}"  Value="2">
                <Setter Property="Background">
                    <Setter.Value>
                        <SolidColorBrush Color="#FFFFD0D0"/>
                    </Setter.Value>
                </Setter>
                <Setter Property="BorderBrush" Value="#FFB00000"/>
                <DataTrigger.EnterActions>
                    <BeginStoryboard x:Name="PlcMotorBlink2_State">
                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                            <ColorAnimation Storyboard.TargetProperty="Background.Color"
                                        From="#FFFFD0D0" To="#FFFF4D4D" Duration="0:0:0.45"/>
                        </Storyboard>
                    </BeginStoryboard>
                </DataTrigger.EnterActions>
                <DataTrigger.ExitActions>
                    <RemoveStoryboard BeginStoryboardName="PlcMotorBlink2_State"/>
                </DataTrigger.ExitActions>
            </DataTrigger>

            <!-- 3 alarm (blink red) -->
            <DataTrigger Binding="{Binding State}"  Value="3">
                <Setter Property="Background">
                    <Setter.Value>
                        <SolidColorBrush Color="#FFFFD0D0"/>
                    </Setter.Value>
                </Setter>
                <Setter Property="BorderBrush" Value="#FFB00000"/>
                <DataTrigger.EnterActions>
                    <BeginStoryboard x:Name="PlcMotorBlink3_State">
                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                            <ColorAnimation Storyboard.TargetProperty="Background.Color"
                                        From="#FFFFD0D0" To="#FFFF4D4D" Duration="0:0:0.45"/>
                        </Storyboard>
                    </BeginStoryboard>
                </DataTrigger.EnterActions>
                <DataTrigger.ExitActions>
                    <RemoveStoryboard BeginStoryboardName="PlcMotorBlink3_State"/>
                </DataTrigger.ExitActions>
            </DataTrigger>

            <!-- 4 starting (blink green) -->
            <DataTrigger Binding="{Binding State}"  Value="4">
                <Setter Property="Background">
                    <Setter.Value>
                        <SolidColorBrush Color="#FFD6FFD6"/>
                    </Setter.Value>
                </Setter>
                <Setter Property="BorderBrush" Value="#FF007A00"/>
                <DataTrigger.EnterActions>
                    <BeginStoryboard x:Name="PlcMotorBlink4_State">
                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                            <ColorAnimation Storyboard.TargetProperty="Background.Color"
                                        From="#FFD6FFD6" To="#FF2ECC71" Duration="0:0:0.45"/>
                        </Storyboard>
                    </BeginStoryboard>
                </DataTrigger.EnterActions>
                <DataTrigger.ExitActions>
                    <RemoveStoryboard BeginStoryboardName="PlcMotorBlink4_State"/>
                </DataTrigger.ExitActions>
            </DataTrigger>

            <!-- 5 stopping (blink gray) -->
            <DataTrigger Binding="{Binding State}"  Value="5">
                <Setter Property="Background">
                    <Setter.Value>
                        <SolidColorBrush Color="#FFEDEDED"/>
                    </Setter.Value>
                </Setter>
                <Setter Property="BorderBrush" Value="#FF606060"/>
                <DataTrigger.EnterActions>
                    <BeginStoryboard x:Name="PlcMotorBlink5_State">
                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                            <ColorAnimation Storyboard.TargetProperty="Background.Color"
                                        From="#FFEDEDED" To="#FFB0B0B0" Duration="0:0:0.45"/>
                        </Storyboard>
                    </BeginStoryboard>
                </DataTrigger.EnterActions>
                <DataTrigger.ExitActions>
                    <RemoveStoryboard BeginStoryboardName="PlcMotorBlink5_State"/>
                </DataTrigger.ExitActions>
            </DataTrigger>

            <!-- 6 waiting (blink green) -->
            <DataTrigger Binding="{Binding State}"  Value="6">
                <Setter Property="Background">
                    <Setter.Value>
                        <SolidColorBrush Color="#FFD6FFD6"/>
                    </Setter.Value>
                </Setter>
                <Setter Property="BorderBrush" Value="#FF007A00"/>
                <DataTrigger.EnterActions>
                    <BeginStoryboard x:Name="PlcMotorBlink6_State">
                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                            <ColorAnimation Storyboard.TargetProperty="Background.Color"
                                        From="#FFD6FFD6" To="#FF2ECC71" Duration="0:0:0.45"/>
                        </Storyboard>
                    </BeginStoryboard>
                </DataTrigger.EnterActions>
                <DataTrigger.ExitActions>
                    <RemoveStoryboard BeginStoryboardName="PlcMotorBlink6_State"/>
                </DataTrigger.ExitActions>
            </DataTrigger>

        </Style.Triggers>
    </Style>

    <!-- Man==true => зелёная подложка, иначе прозрачная/серая -->
    <Style x:Key="ManStationBackgroundStyle" TargetType="{x:Type Border}">
        <!--<Setter Property="Background" Value="#40A0A0A0"/>-->
        <!-- серый полупрозрачный -->
        <Style.Triggers>
            <DataTrigger Binding="{Binding Man}" Value="True">
                <Setter Property="Background" Value="#97DC74"/>
                <!-- зелёный полупрозрачный -->
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- Общий стиль кнопок Man/Auto -->
    <Style x:Key="ManStationButtonStyle" TargetType="{x:Type dx:SimpleButton}">
        <Setter Property="Width" Value="Auto"/>
        <Setter Property="Height" Value="Auto"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Margin" Value="8"/>
        <Setter Property="BorderBrush" Value="Black"/>
        <!--<Setter Property="BorderThickness" Value="1"/>-->
        <!--<Setter Property="Background" Value="#FFD6D6D6"/>-->
        <Setter Property="Foreground" Value="Black"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <!-- Forced label: по умолчанию скрыт, при ForceCmd=True показывает и мигает -->
    <Style x:Key="DIDOForcedBlinkTextStyle"
       TargetType="{x:Type TextBlock}"
       BasedOn="{StaticResource AppTextBlockStyle}">
        <Setter Property="Text" Value="Forced"/>
        <Setter Property="Foreground" Value="Orange"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Opacity" Value="1"/>
        <Setter Property="Visibility" Value="Collapsed"/>

        <Style.Triggers>
            <DataTrigger Binding="{Binding ForceCmd}" Value="True">
                <Setter Property="Visibility" Value="Visible"/>

                <DataTrigger.EnterActions>
                    <BeginStoryboard x:Name="ForcedBlinkStoryboard">
                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                            <!-- мигание: 1.0 -> 0.25 -> 1.0 -->
                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1.0" To="0.25" Duration="0:0:0.45"/>
                        </Storyboard>
                    </BeginStoryboard>
                </DataTrigger.EnterActions>

                <DataTrigger.ExitActions>
                    <RemoveStoryboard BeginStoryboardName="ForcedBlinkStoryboard"/>
                </DataTrigger.ExitActions>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- Мигающий текст для TimeWorkAlarmW -->
    <Style x:Key="TimeWorkAlarmBlinkTextStyle"
       TargetType="{x:Type TextBlock}"
       BasedOn="{StaticResource AppTextBlockStyle}">

        <!-- Внешний вид -->
        <Setter Property="Text" Value="Time Work!"/>
        <Setter Property="Foreground" Value="CornflowerBlue"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Opacity" Value="1"/>
        <Setter Property="Visibility" Value="Collapsed"/>

        <Style.Triggers>
            <!-- Когда TimeWorkAlarmW=true -> показываем и запускаем мигание -->
            <DataTrigger Binding="{Binding TimeWorkAlarmW}" Value="True">
                <Setter Property="Visibility" Value="Visible"/>

                <DataTrigger.EnterActions>
                    <BeginStoryboard x:Name="TimeWorkAlarmBlinkBegin">
                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                         From="1.0" To="0.15"
                                         Duration="0:0:0.45"/>
                        </Storyboard>
                    </BeginStoryboard>
                </DataTrigger.EnterActions>

                <DataTrigger.ExitActions>
                    <RemoveStoryboard BeginStoryboardName="TimeWorkAlarmBlinkBegin"/>
                </DataTrigger.ExitActions>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- Мигающий синий Label (жирный + мигает), когда TimeWorkAlarmW=true -->
    <DataTemplate x:Key="TimeWorkAlarmBlinkLabelTemplate">
        <TextBlock Text="{Binding}"
               Foreground="CornflowerBlue"
               Opacity="1">
            <TextBlock.Style>
                <Style TargetType="{x:Type TextBlock}">
                    <Setter Property="FontWeight" Value="Normal"/>

                    <Style.Triggers>
                        <!-- Берём флаг из DataContext LayoutControl (он точно в дереве) -->
                        <DataTrigger Binding="{Binding DataContext.TimeWorkAlarmW, RelativeSource={RelativeSource AncestorType=dxlc:LayoutControl}}"
                                 Value="True">

                            <!-- ЖИРНЫЙ -->
                            <Setter Property="FontWeight" Value="Bold"/>

                            <!-- МИГАНИЕ -->
                            <DataTrigger.EnterActions>
                                <BeginStoryboard x:Name="TimeWorkAlarmLabelBlink">
                                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     From="1.0" To="0.15"
                                                     Duration="0:0:0.45"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>

                            <DataTrigger.ExitActions>
                                <RemoveStoryboard BeginStoryboardName="TimeWorkAlarmLabelBlink"/>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>
    </DataTemplate>

    <!-- LayoutItem: мигающий/жирный Label, когда TimeWorkAlarmW=true -->
    <Style x:Key="TimeWorkAlarmBlinkLayoutItemStyle"
       TargetType="{x:Type dxlc:LayoutItem}">
        <Style.Triggers>
            <DataTrigger Binding="{Binding DataContext.TimeWorkAlarmW, RelativeSource={RelativeSource AncestorType=UserControl}}"
                     Value="True">
                <Setter Property="LabelTemplate" Value="{StaticResource TimeWorkAlarmBlinkLabelTemplate}"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- Кнопки + / - для history zoom -->
    <Style x:Key="ParamTrendHistoryZoomButtonStyle"
           TargetType="{x:Type dx:SimpleButton}"
           BasedOn="{StaticResource AppButtonStyle}">
        <Setter Property="Width" Value="60"/>
        <Setter Property="Height" Value="60"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="FontSize" Value="24"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Visibility" Value="Collapsed"/>

        <Style.Triggers>
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding DataContext.Trend.IsChartVisible, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" Value="True"/>
                    <Condition Binding="{Binding DataContext.Trend.IsLiveMode, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" Value="False"/>
                </MultiDataTrigger.Conditions>
                <Setter Property="Visibility" Value="Visible"/>
            </MultiDataTrigger>
        </Style.Triggers>
    </Style>

    <!-- Toggle Live / History с иконкой вместо текста -->
    <Style x:Key="ParamTrendModeToggleStyle"
           TargetType="{x:Type ToggleButton}"
           BasedOn="{StaticResource AppToggleStyle}">
        <Setter Property="Width" Value="60"/>
        <Setter Property="Height" Value="60"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Visibility" Value="Collapsed"/>
        <Setter Property="IsChecked"
                Value="{Binding DataContext.Trend.IsLiveMode,
                                RelativeSource={RelativeSource AncestorType={x:Type Window}},
                                Mode=OneWay}"/>

        <!-- По умолчанию: History -->
        <Setter Property="ToolTip" Value="History"/>
        <Setter Property="Content">
            <Setter.Value>
                <Image Width="40"
                       Height="40"
                       Source="{dx:DXImage SvgImages/Arrows/Last.svg}"/>
            </Setter.Value>
        </Setter>

        <Style.Triggers>
            <!-- Показываем кнопку только когда график видим -->
            <DataTrigger Binding="{Binding DataContext.Trend.IsChartVisible,
                                           RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                         Value="True">
                <Setter Property="Visibility" Value="Visible"/>
            </DataTrigger>

            <!-- Live -->
            <Trigger Property="IsChecked" Value="True">
                <Setter Property="ToolTip" Value="Live"/>
                <Setter Property="Content">
                    <Setter.Value>
                        <Image Width="40"
                               Height="40"
                               Source="{dx:DXImage SvgImages/XAF/Action_Debug_Start.svg}"/>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!--
    Шаблон ячейки TreeList оборудования.
    DataContext = EditGridCellData -> RowData.Row = EquipListBoxItem
    -->
    <DataTemplate x:Key="EquipmentTreeCellTemplate">
        <Border Padding="10,4"
            Background="Transparent">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="18"/>
                </Grid.ColumnDefinitions>

                <!-- Type icon -->
                <Image Grid.Column="0"
                   Tag="{Binding RowData.Row.TypeGroup}"
                   Style="{StaticResource EquipTypeIconImageStyle}"/>

                <!-- Equipment text -->
                <TextBlock Grid.Column="1"
                       VerticalAlignment="Center"
                       FontSize="14"
                       Text="{Binding RowData.Row.DisplayText}"
                       TextTrimming="CharacterEllipsis">
                    <TextBlock.ToolTip>
                        <StackPanel>
                            <TextBlock Text="{Binding RowData.Row.Equipment}" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding RowData.Row.Type}"/>
                            <TextBlock Text="{Binding RowData.Row.Description}" TextWrapping="Wrap" MaxWidth="320"/>
                        </StackPanel>
                    </TextBlock.ToolTip>
            </TextBlock>

                <!-- Linked image indicator -->
                <Image Grid.Column="2"
                   Width="16"
                   Height="16"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"
                   Source="{dx:DXImage 'Office2013/Content/Image_16x16.png'}"
                   ToolTip="Has linked image">
                    <Image.Style>
                        <Style TargetType="{x:Type Image}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RowData.Row.HasLinkedImage}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Image.Style>
                </Image>

                <!-- Linked instruction indicator -->
                <Image Grid.Column="3"
                   Width="16"
                   Height="16"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"
                   Source="{dx:DXImage 'Office2013/Support/Info_16x16.png'}"
                   ToolTip="Has linked instruction">
                    <Image.Style>
                        <Style TargetType="{x:Type Image}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RowData.Row.HasLinkedInstruction}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Image.Style>
                </Image>

                <!-- Linked scheme indicator -->
                <Image Grid.Column="4"
                   Width="16"
                   Height="16"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"
                   Source="{dx:DXImage 'Office2013/Miscellaneous/Design_16x16.png'}"
                   ToolTip="Has linked scheme">
                    <Image.Style>
                        <Style TargetType="{x:Type Image}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RowData.Row.HasLinkedScheme}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Image.Style>
                </Image>

                <!-- Notes indicator -->
                <Image Grid.Column="5"
                   Width="16"
                   Height="16"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"
                   Source="{dx:DXImage 'Office2013/Miscellaneous/Comment_16x16.png'}"
                   ToolTip="Has notes">
                    <Image.Style>
                        <Style TargetType="{x:Type Image}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RowData.Row.HasNotes}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Image.Style>
                </Image>

                <!-- Favorite indicator -->
                <TextBlock Grid.Column="6"
                       Text="★"
                       FontSize="18"
                       Foreground="#C79A00"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="{x:Type TextBlock}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RowData.Row.IsFavorite}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </Border>
    </DataTemplate>

</ResourceDictionary>
