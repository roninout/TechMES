<UserControl x:Class="TechEquipments.Views.Info.InfoTabHost"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxpdf="http://schemas.devexpress.com/winfx/2008/xaml/pdf"
             xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
             xmlns:conv="clr-namespace:TechEquipments.Converts"
             xmlns:local="clr-namespace:TechEquipments">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:FilePathToImageSourceConverter x:Key="FilePathToImageSourceConverter"/>
    </UserControl.Resources>

    <dxlc:LayoutControl Margin="0">
        <dxlc:LayoutGroup View="Group" GroupBoxDisplayMode="Light" Orientation="Vertical">

            <dxlc:LayoutGroup View="Group" Orientation="Horizontal">

                <!-- ================= CENTER ================= -->
                <dxlc:LayoutGroup View="Group" Orientation="Vertical" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">

                    <!-- ===== GENERAL ===== -->
                    <dxlc:LayoutGroup View="GroupBox" GroupBoxDisplayMode="Light"
                                      HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                      Visibility="{Binding IsInfoGeneralPage, Converter={StaticResource BoolToVis}}">

                        <dxlc:LayoutGroup Orientation="Vertical">

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Верхние поля -->
                                <Grid Margin="6,0,0,8" Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <!-- Left info block -->
                                        <ColumnDefinition Width="105"/>
                                        <ColumnDefinition Width="400"/>
                                        <!-- Spacer -->
                                        <ColumnDefinition Width="20"/>
                                        <!-- Description block -->
                                        <ColumnDefinition Width="0"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="50"/>
                                        <RowDefinition Height="50"/>
                                        <RowDefinition Height="50"/>
                                    </Grid.RowDefinitions>

                                    <!-- Equipment -->
                                    <TextBlock Grid.Row="0"
                                               Grid.Column="0"
                                               Text="Equipment:"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="0"
                                               Grid.Column="1"
                                               Text="{Binding CurrentEquipInfo.EquipName}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>

                                    <!-- Product code -->
                                    <TextBlock Grid.Row="1"
                                               Grid.Column="0"
                                               Margin="0,6,0,0"
                                               Text="Product code:"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>

                                    <!-- Product code: view mode -->
                                    <TextBlock Grid.Row="1"
                                               Grid.Column="1"
                                               Margin="0,6,0,0"
                                               Text="{Binding CurrentEquipInfo.ProductCode, TargetNullValue=Not set, FallbackValue=Not set}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis">
                                        
                                        <TextBlock.Style>
                                            <Style TargetType="{x:Type TextBlock}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsInfoEditMode}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                        
                                    </TextBlock>

                                    <!-- Product code: edit mode -->
                                    <dxe:ComboBoxEdit Grid.Row="1"
                                                      Grid.Column="1"
                                                      Margin="0,6,0,0"
                                                      ItemsSource="{Binding AvailableProductCodeOptions}"
                                                      DisplayMember="ProductCode"
                                                      ValueMember="ProductCode"
                                                      IsTextEditable="False"
                                                      NullText="Select product code"
                                                      ImmediatePopup="True"
                                                      AutoComplete="True"
                                                      IncrementalFiltering="True"
                                                      HorizontalContentAlignment="Left"
                                                      EditValue="{Binding CurrentEquipInfo.ProductCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      EditValueChanged="ProductCode_EditValueChanged">

                                        <dxe:ComboBoxEdit.Style>
                                            <Style TargetType="{x:Type dxe:ComboBoxEdit}" BasedOn="{StaticResource AppBaseEditStyle}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsInfoEditMode}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </dxe:ComboBoxEdit.Style>
                                        
                                    </dxe:ComboBoxEdit>

                                    <!-- Supplier -->
                                    <TextBlock Grid.Row="2"
                                               Grid.Column="0"
                                               Margin="0,6,0,0"
                                               Text="Supplier:"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>

                                    <Grid Grid.Row="2"
                                          Grid.Column="1"
                                          Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="120"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Supplier always read-only -->
                                        <TextBlock Grid.Column="0"
                                                   HorizontalAlignment="Left"
                                                   VerticalAlignment="Center"
                                                   Text="{Binding CurrentEquipInfo.Supplier}"/>

                                        <Border Grid.Column="1">
                                            <Image Source="{Binding CurrentEquipInfo.SupplierLogoCachePath, Converter={StaticResource FilePathToImageSourceConverter}}"
                                                   Stretch="Uniform"
                                                   Margin="2"/>
                                        </Border>
                                    </Grid>

                                    <!-- Description -->
                                    <!--<TextBlock Grid.Row="0"
                                               Grid.Column="3"
                                               Text="Description:"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Top"
                                               Margin="0,4,0,0"/>-->

                                    <!-- Description always read-only. MemoEdit removed. -->
                                    <!--<Border Grid.Row="0"
                                            Grid.Column="4"
                                            Grid.RowSpan="3"
                                            MinHeight="86"
                                            MaxHeight="200"
                                            BorderBrush="#33000000"
                                            BorderThickness="1"                                            
                                            Background="#08FFFFFF"
                                            Padding="6,4">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <TextBlock Text="{Binding CurrentEquipInfo.Description}"
                                                       TextWrapping="Wrap"
                                                       VerticalAlignment="Top"/>
                                        </ScrollViewer>
                                    </Border>-->

                                    <!-- Description always read-only -->
                                    <TextBox Grid.Row="0"
                                             Grid.Column="4"
                                             Grid.RowSpan="3"
                                             Text="{Binding CurrentEquipInfo.Description, Mode=OneWay}"
                                             IsReadOnly="True"
                                             TextWrapping="Wrap"
                                             AcceptsReturn="True"
                                             VerticalScrollBarVisibility="Auto"
                                             HorizontalScrollBarVisibility="Disabled"
                                             VerticalContentAlignment="Top"
                                             MinHeight="86"
                                             MaxHeight="200"
                                             Padding="6,4"
                                             BorderBrush="#33000000"
                                             BorderThickness="1"
                                             Background="#08FFFFFF"
                                             Foreground="#222222"
                                             FontSize="13"/>
                                </Grid>

                                <!-- ===== PHOTO ===== -->
                                <dxlc:LayoutItem Grid.Row="1" VerticalAlignment="Stretch">
                                    <Grid MinHeight="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="235"/>
                                            <ColumnDefinition Width="10"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- ===== Слева: список фото ===== -->
                                        <dxlc:LayoutGroup Grid.Column="0"
                                                          View="GroupBox"
                                                          GroupBoxDisplayMode="Light"
                                                          Orientation="Vertical"
                                                          VerticalAlignment="Stretch"
                                                          MinHeight="0">

                                            <dxlc:LayoutItem VerticalAlignment="Stretch">
                                                <Grid MinHeight="0">
                                                    <!-- ===== View mode: только linked photos ===== -->
                                                    <ListBox x:Name="PhotoViewListBox"
                                                             ItemsSource="{Binding CurrentEquipInfo.Photos}"
                                                             SelectedItem="{Binding SelectedInfoPhotoFile, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             SelectionChanged="PhotoThumbs_SelectionChanged"
                                                             BorderThickness="0"
                                                             Background="Transparent"
                                                             HorizontalContentAlignment="Stretch"
                                                             VerticalAlignment="Stretch"
                                                             MinHeight="0"
                                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                             ScrollViewer.CanContentScroll="True">

                                                        <ListBox.Style>
                                                            <Style TargetType="{x:Type ListBox}">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsInfoEditMode}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </ListBox.Style>

                                                        <ListBox.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <StackPanel Orientation="Vertical"/>
                                                            </ItemsPanelTemplate>
                                                        </ListBox.ItemsPanel>

                                                        <ListBox.ItemContainerStyle>
                                                            <Style TargetType="{x:Type ListBoxItem}">
                                                                <Setter Property="Padding" Value="0"/>
                                                                <Setter Property="Margin" Value="0,0,0,8"/>
                                                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                                <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                                                                <Setter Property="BorderThickness" Value="0"/>
                                                                <Setter Property="Background" Value="Transparent"/>
                                                                <Setter Property="Focusable" Value="True"/>
                                                                <EventSetter Event="PreviewMouseLeftButtonDown" Handler="PhotoThumbItem_PreviewMouseLeftButtonDown"/>
                                                            </Style>
                                                        </ListBox.ItemContainerStyle>

                                                        <ListBox.ItemTemplate>
                                                            <DataTemplate>
                                                                <Grid Width="170" Height="104" Background="White">
                                                                    <Grid.RowDefinitions>
                                                                        <RowDefinition Height="*"/>
                                                                        <RowDefinition Height="22"/>
                                                                    </Grid.RowDefinitions>

                                                                    <dxe:ImageEdit Grid.Row="0"
                                                                                   EditValue="{Binding FileData}"
                                                                                   Stretch="UniformToFill"
                                                                                   NullText="No preview"
                                                                                   IsReadOnly="True"
                                                                                   ShowMenu="False"
                                                                                   IsHitTestVisible="False"/>

                                                                    <Grid Grid.Row="1" Background="#88000000" IsHitTestVisible="False">
                                                                        <TextBlock Text="{Binding DisplayName}"
                                                                                   Margin="6,0"
                                                                                   VerticalAlignment="Center"
                                                                                   Foreground="White"
                                                                                   FontSize="11"
                                                                                   TextTrimming="CharacterEllipsis"/>
                                                                    </Grid>

                                                                    <Rectangle x:Name="ThumbRect"
                                                                               Grid.RowSpan="2"
                                                                               Stroke="#BFBFBF"
                                                                               StrokeThickness="1"
                                                                               Fill="Transparent"
                                                                               IsHitTestVisible="False"/>
                                                                </Grid>

                                                                <DataTemplate.Triggers>
                                                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                                        <Setter TargetName="ThumbRect" Property="Stroke" Value="#2D8CFF"/>
                                                                        <Setter TargetName="ThumbRect" Property="StrokeThickness" Value="2"/>
                                                                    </DataTrigger>
                                                                </DataTemplate.Triggers>
                                                            </DataTemplate>
                                                        </ListBox.ItemTemplate>
                                                    </ListBox>

                                                    <!-- ===== Edit mode: вся library + checkbox ===== -->
                                                    <ListBox x:Name="PhotoEditListBox"
                                                             ItemsSource="{Binding AvailableInfoPhotoLibrary}"
                                                             SelectedItem="{Binding SelectedInfoPhotoLibraryFile, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             SelectionChanged="PhotoThumbs_SelectionChanged"
                                                             BorderThickness="0"
                                                             Background="Transparent"
                                                             HorizontalContentAlignment="Stretch"
                                                             VerticalAlignment="Stretch"
                                                             MinHeight="0"
                                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                             ScrollViewer.CanContentScroll="True">

                                                        <ListBox.Style>
                                                            <Style TargetType="{x:Type ListBox}">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsInfoEditMode}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </ListBox.Style>

                                                        <ListBox.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <StackPanel Orientation="Vertical"/>
                                                            </ItemsPanelTemplate>
                                                        </ListBox.ItemsPanel>

                                                        <ListBox.ItemContainerStyle>
                                                            <Style TargetType="{x:Type ListBoxItem}">
                                                                <Setter Property="Padding" Value="0"/>
                                                                <Setter Property="Margin" Value="0,0,0,8"/>
                                                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                                <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                                                                <Setter Property="BorderThickness" Value="0"/>
                                                                <Setter Property="Background" Value="Transparent"/>
                                                                <Setter Property="Focusable" Value="True"/>
                                                                <EventSetter Event="PreviewMouseLeftButtonDown" Handler="PhotoThumbItem_PreviewMouseLeftButtonDown"/>
                                                            </Style>
                                                        </ListBox.ItemContainerStyle>

                                                        <ListBox.ItemTemplate>
                                                            <DataTemplate>
                                                                <Grid Width="170" Height="126" Background="White">
                                                                    <Grid.RowDefinitions>
                                                                        <RowDefinition Height="26"/>
                                                                        <RowDefinition Height="*"/>
                                                                        <RowDefinition Height="22"/>
                                                                    </Grid.RowDefinitions>

                                                                    <!-- checkbox -->
                                                                    <dxe:CheckEdit Grid.Row="0"
                                                                                   Margin="4,2,4,0"
                                                                                   HorizontalAlignment="Left"
                                                                                   VerticalAlignment="Center"
                                                                                   IsChecked="{Binding IsLinkedToCurrentEquipment, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                   Checked="PhotoLibraryCheckEdit_Changed"
                                                                                   Unchecked="PhotoLibraryCheckEdit_Changed"/>

                                                                    <!-- thumb -->
                                                                    <dxe:ImageEdit Grid.Row="1"
                                                                                   EditValue="{Binding FileData}"
                                                                                   Stretch="UniformToFill"
                                                                                   NullText="No preview"
                                                                                   IsReadOnly="True"
                                                                                   ShowMenu="False"
                                                                                   IsHitTestVisible="False"/>

                                                                    <!-- caption -->
                                                                    <Grid Grid.Row="2" Background="#88000000" IsHitTestVisible="False">
                                                                        
                                                                        <TextBlock Text="{Binding DisplayName}"
                                                                                   Margin="6,0"
                                                                                   VerticalAlignment="Center"
                                                                                   Foreground="White"
                                                                                   FontSize="11"
                                                                                   TextTrimming="CharacterEllipsis"/>
                                                                    </Grid>

                                                                    <Rectangle x:Name="ThumbRect"
                                                                               Grid.RowSpan="3"
                                                                               Stroke="#BFBFBF"
                                                                               StrokeThickness="1"
                                                                               Fill="Transparent"
                                                                               IsHitTestVisible="False"/>
                                                                </Grid>

                                                                <DataTemplate.Triggers>
                                                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                                        <Setter TargetName="ThumbRect" Property="Stroke" Value="#2D8CFF"/>
                                                                        <Setter TargetName="ThumbRect" Property="StrokeThickness" Value="2"/>
                                                                    </DataTrigger>
                                                                </DataTemplate.Triggers>
                                                            </DataTemplate>
                                                        </ListBox.ItemTemplate>
                                                    </ListBox>
                                                </Grid>
                                            </dxlc:LayoutItem>
                                        </dxlc:LayoutGroup>

                                        <!-- ===== Справа: большое preview ===== -->
                                        <dxlc:LayoutGroup Grid.Column="2"
                                                          View="GroupBox"
                                                          GroupBoxDisplayMode="Light"
                                                          Orientation="Vertical"
                                                          VerticalAlignment="Stretch"
                                                          MinHeight="0">

                                            <dxlc:LayoutItem Label="" VerticalAlignment="Stretch">
                                                <Grid x:Name="PhotoPreviewHost" MinHeight="0" Background="Transparent">

                                                    <dxe:ImageEdit EditValue="{Binding CurrentPhotoPreviewFile.FileData}"
                                                                   NullText="Image is empty"
                                                                   Stretch="Uniform"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   MaxWidth="{Binding ActualWidth, ElementName=PhotoPreviewHost}"
                                                                   MaxHeight="{Binding ActualHeight, ElementName=PhotoPreviewHost}"
                                                                   BorderThickness="0"
                                                                   Padding="0"
                                                                   IsReadOnly="True"
                                                                   ShowMenu="False"/>

                                                </Grid>
                                            </dxlc:LayoutItem>
                                        </dxlc:LayoutGroup>

                                    </Grid>
                                </dxlc:LayoutItem>

                            </Grid>

                        </dxlc:LayoutGroup>
                    </dxlc:LayoutGroup>

                    <!-- ===== INSTRUCTION / SCHEME ===== -->
                    <dxlc:LayoutGroup Header="{Binding CurrentInfoDocumentHeader}" 
                                      View="GroupBox" GroupBoxDisplayMode="Light"
                                      Visibility="{Binding IsInfoDocumentPage, Converter={StaticResource BoolToVis}}"
                                      HorizontalAlignment="Stretch" VerticalAlignment="Stretch">

                        <dxlc:LayoutGroup Orientation="Vertical">

                            <!-- Checked-combo: только в Edit mode -->
                            <dxe:ComboBoxEdit Height="40" Padding="10,0" Margin="0,0,0,8"
                                              ItemsSource="{Binding CurrentInfoAvailableLibraryItems}"
                                              DisplayMember="DisplayName"
                                              ValueMember="Id"
                                              EditValue="{Binding CurrentInfoCheckedLibraryIds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              SeparatorString="; "
                                              NullText="Select existing PDF files"
                                              EditValueChanged="DocumentLibraryEditValueChanged">
                                <dxe:ComboBoxEdit.Style>
                                    <Style TargetType="{x:Type dxe:ComboBoxEdit}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsInfoEditMode}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </dxe:ComboBoxEdit.Style>

                                <dxe:ComboBoxEdit.StyleSettings>
                                    <dxe:CheckedComboBoxStyleSettings ShowSelectAllItem="True"/>
                                </dxe:ComboBoxEdit.StyleSettings>
                            </dxe:ComboBoxEdit>

                            <!-- Обычный ComboBox: только вне Edit mode -->
                            <dxe:ComboBoxEdit Height="40" Padding="10,0" Margin="0,0,0,8"
                                      ItemsSource="{Binding CurrentInfoDocumentItems}"
                                      SelectedItem="{Binding CurrentInfoSelectedDocumentFile, Mode=TwoWay}"
                                      DisplayMember="DisplayName"
                                      IsTextEditable="False"
                                      EditValueChanged="DocumentSelectionChanged"
                                      IsSynchronizedWithCurrentItem="False">
                                
                                <dxe:ComboBoxEdit.Style>
                                    <Style TargetType="{x:Type dxe:ComboBoxEdit}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsInfoEditMode}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </dxe:ComboBoxEdit.Style>
                                
                            </dxe:ComboBoxEdit>

                            
                            <dxlc:LayoutItem Label="" VerticalAlignment="Stretch">
                                <Grid MinHeight="520">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0"
                                                Margin="0,0,0,12"
                                                Visibility="{Binding IsInfoDocumentMessageVisible, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="{Binding InfoDocumentMessage}"
                                                   TextWrapping="Wrap"
                                                   Style="{StaticResource AppTextStyle}"/>

                                        <dx:SimpleButton Content="Export PDF"
                                                         Width="140"
                                                         Margin="0,10,0,0"
                                                         HorizontalAlignment="Left"
                                                         Style="{StaticResource AppButtonStyle}"
                                                         Click="ExportPdf_Click"
                                                         Visibility="{Binding IsInfoDocumentExportVisible, Converter={StaticResource BoolToVis}}"/>
                                    </StackPanel>

                                    <dxpdf:PdfViewerControl x:Name="PdfViewer"
                                                            Grid.Row="1"
                                                            CommandBarStyle="None"
                                                            ShowStartScreen="False"
                                                            CursorMode="HandTool"
                                                            DocumentLoaded="PdfViewer_DocumentLoaded"
                                                            DocumentSource="{Binding CurrentInfoDocumentPreviewPath}"
                                                            Visibility="{Binding IsInfoDocumentViewerVisible, Converter={StaticResource BoolToVis}}"/>
                                </Grid>
                            </dxlc:LayoutItem>

                        </dxlc:LayoutGroup>
                    </dxlc:LayoutGroup>

                    <!--===== NOTES =====-->
                    <dxlc:LayoutGroup View="GroupBox"
                                      GroupBoxDisplayMode="Light"
                                      Visibility="{Binding IsInfoNotesPage, Converter={StaticResource BoolToVis}}"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Stretch">

                        <dxlc:LayoutGroup Orientation="Vertical">

                            <Grid Margin="6,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="265"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Left: notes list -->
                                <ListBox Grid.Column="0"
                                         ItemsSource="{Binding CurrentEquipInfo.Notes}"
                                         SelectedItem="{Binding SelectedInfoNote, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         BorderThickness="0"
                                         Background="Transparent"                                         
                                         HorizontalContentAlignment="Stretch"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto">

                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="{x:Type ListBoxItem}">
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="Margin" Value="0,0,0,8"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        </Style>
                                    </ListBox.ItemContainerStyle>

                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#33000000"
                                                    BorderThickness="1"
                                                    CornerRadius="4"
                                                    Padding="8"
                                                    Background="White">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <TextBlock Grid.Row="0"
                                                               Text="{Binding CreatedBy}"
                                                               FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis"/>

                                                    <TextBlock Grid.Row="1"
                                                               Margin="0,2,0,0"
                                                               Text="{Binding CreatedAtText}"
                                                               FontSize="11"
                                                               Foreground="Gray"/>

                                                    <TextBlock Grid.Row="2"
                                                               Margin="0,6,0,0"
                                                               Text="{Binding PreviewText}"
                                                               TextWrapping="Wrap"
                                                               MaxHeight="44"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <!-- Right: note editor/viewer -->
                                <Grid Grid.Column="2">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBox Grid.Row="0"
                                             Text="{Binding SelectedInfoNote.NoteText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             IsReadOnly="{Binding IsInfoReadOnly}"
                                             TextWrapping="Wrap"
                                             AcceptsReturn="True"
                                             AcceptsTab="True"
                                             VerticalScrollBarVisibility="Auto"
                                             HorizontalScrollBarVisibility="Disabled"
                                             VerticalContentAlignment="Top"
                                             MinHeight="260"
                                             Padding="8"
                                             BorderBrush="#33000000"
                                             BorderThickness="1"
                                             FontSize="13">
                                        <TextBox.Style>
                                            <Style TargetType="{x:Type TextBox}">
                                                <!-- View mode -->
                                                <Setter Property="Background" Value="#08FFFFFF"/>

                                                <!-- Edit mode -->
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsInfoEditMode}" Value="True">
                                                        <Setter Property="Background" Value="White"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>

                                    <StackPanel Grid.Row="1"
                                                Orientation="Horizontal"
                                                HorizontalAlignment="Right"
                                                Margin="0,8,0,0">

                                        <TextBlock Text="Created:"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>

                                        <TextBlock Margin="8,0,0,0"
                                                   Text="{Binding SelectedInfoNote.CreatedAtText}"
                                                   VerticalAlignment="Center"/>

                                        <TextBlock Margin="16,0,0,0"
                                                   Text="By:"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>

                                        <TextBlock Margin="8,0,0,0"
                                                   Text="{Binding SelectedInfoNote.CreatedBy}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </Grid>

                        </dxlc:LayoutGroup>
                    </dxlc:LayoutGroup>

                </dxlc:LayoutGroup>

                <!-- ================= RIGHT ================= -->
                <dxlc:LayoutGroup View="Group" GroupBoxDisplayMode="Light" HorizontalAlignment="Right">
                    <dxlc:LayoutItem VerticalAlignment="Stretch">
                        <Grid VerticalAlignment="Stretch">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Up: навигационные кнопки Info. В обычном режиме видны. В режиме редактирования скрываются, чтобы остались только кнопки редактирования/Save. -->
                            <StackPanel Grid.Row="0" Orientation="Vertical" VerticalAlignment="Top">

                                <StackPanel.Style>
                                    <Style TargetType="{x:Type StackPanel}">
                                        <Setter Property="Visibility" Value="Visible"/>

                                        <Style.Triggers>
                                            <!-- Когда включили Edit mode — прячем верхние кнопки Images / Instruction / Scheme / Notes -->
                                            <DataTrigger Binding="{Binding IsInfoEditMode}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>

                                <!-- Images -->
                                <dxlc:LayoutItem Label="">
                                    <dx:SimpleButton Width="60"
                                         Height="60"
                                         Padding="0"
                                         GlyphWidth="40"
