<UserControl x:Class="TechEquipments.Views.Param.ParamTabHost"
                    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                    xmlns:local="clr-namespace:TechEquipments.Views.Param"
                    xmlns:models="clr-namespace:TechEquipments"
                    xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                    xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                    mc:Ignorable="d"
                    d:DesignHeight="400" d:DesignWidth="700">

    <UserControl.Resources>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- ✅ Автовыбор разметки по типу модели (CurrentParamModel) -->

        <!--
        Теперь ParamTabHost работает не с "сырыми" AIParam/DIParam/...,
        а с новыми UI-обертками AiModel/DiModel/...
        -->

        <DataTemplate DataType="{x:Type models:AiModel}">
            <local:AIParamView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type models:DiModel}">
            <local:DIParamView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type models:DoModel}">
            <local:DIParamView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type models:VgaModel}">
            <local:VGAParamView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type models:VgaElModel}">
            <local:VGA_ELParamView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type models:VgdModel}">
            <local:VGDParamView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type models:MotorModel}">
            <local:MotorParamView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type models:AtvModel}">
            <local:ATVParamView />
        </DataTemplate>

    </UserControl.Resources>

    <Grid Margin="0">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Margin="12,0,0,0">

            <!-- Скрываем весь верхний блок Name / Type / Location / Desc, пока CurrentParamModel ещё не загружена. -->
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding CurrentParamModel}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <Grid.ColumnDefinitions >
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Name -->
            <TextBlock Grid.Row="0" Grid.Column="0" Padding="0, 4" Text="Name: " FontWeight="SemiBold"/>

            <!-- QR generate button -->
            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Left">
                
                <TextBlock Grid.Row="0" Grid.Column="1" Padding="0, 4"
                           Text="{Binding Vm.EquipmentList.SelectedListBoxEquipment.Equipment, RelativeSource={RelativeSource AncestorType=Window}, TargetNullValue='-'}" />

                <!--<dx:SimpleButton Grid.Row="0" Grid.Column="1" Margin="10,0,0,0" Width="20" Height="20"
                                 Padding="0" GlyphWidth="15" GlyphHeight="15"
                                 Click="GenerateQr_Click"
                                 ToolTip="Generate QR"
                                 Glyph="{dx:DXImage 'SvgImages/DiagramIcons/save.svg'}"
                                 Style="{StaticResource AppButtonStyle}"
                                 Visibility="{Binding DataContext.Param_ShowGenerateQrButton, RelativeSource={RelativeSource AncestorType=Window},Converter={StaticResource BoolToVis}}"/>-->

                <!-- Favorite -->
                <ToggleButton Margin="12,0,0,0"
                              Width="24"
                              Height="24"
                              Padding="0"
                              Cursor="Hand"
                              ToolTip="Favorite"
                              IsChecked="{Binding Vm.EquipmentList.SelectedListBoxEquipment.IsFavorite,
                                                  RelativeSource={RelativeSource AncestorType=Window},
                                                  Mode=TwoWay,
                                                  TargetNullValue=False}"
                              Click="FavoriteToggle_Click">
                    <ToggleButton.Template>
                        <ControlTemplate TargetType="{x:Type ToggleButton}">
                            <Border Background="Transparent">
                                <TextBlock x:Name="StarGlyph"
                                            Text="☆"
                                            FontSize="18"
                                            Foreground="#7F7F7F"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                            </Border>

                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="StarGlyph" Property="Text" Value="★"/>
                                    <Setter TargetName="StarGlyph" Property="Foreground" Value="#C79A00"/>
                                </Trigger>

                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="StarGlyph" Property="FontSize" Value="19"/>
                                </Trigger>

                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="StarGlyph" Property="Opacity" Value="0.45"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </ToggleButton.Template>
                </ToggleButton>

            </StackPanel>

            <!-- Type -->
            <TextBlock Grid.Row="1" Grid.Column="0" Padding="0, 4" Text="Type: " FontWeight="SemiBold" />

            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Left">
                <Image Tag="{Binding Vm.EquipmentList.SelectedListBoxEquipment.TypeGroup, RelativeSource={RelativeSource AncestorType=Window}}"
                       Style="{StaticResource EquipTypeIconImageStyle}"/>
                <TextBlock Padding="0,4" Text="{Binding Vm.EquipmentList.SelectedListBoxEquipment.Type, RelativeSource={RelativeSource AncestorType=Window}, TargetNullValue='-'}" />
            </StackPanel>

            <!-- Location -->
            <TextBlock Grid.Row="2" Grid.Column="0" Padding="0,4" Text="Location: " FontWeight="SemiBold"
                       Visibility="{Binding IsCurrentParamChanelVisible, Converter={StaticResource BoolToVis}}"/>
            <TextBlock Grid.Row="2" Grid.Column="1" Padding="0,4" Text="{Binding CurrentParamChanel}"
                       Visibility="{Binding IsCurrentParamChanelVisible, Converter={StaticResource BoolToVis}}"/>

            <!-- Desc -->
            <TextBlock Grid.Row="3" Grid.Column="0" Padding="0, 4" Text="Desc: " FontWeight="SemiBold" />
            <TextBlock Grid.Row="3" Grid.Column="1" Padding="0, 4" Text="{Binding Vm.EquipmentList.SelectedListBoxEquipment.Description, RelativeSource={RelativeSource AncestorType=Window}, TargetNullValue='-'}" />

        </Grid>

        <!-- ✅ В зависимости от CurrentParamModel подставится нужный *ParamView.xaml -->
        <Grid Grid.Row="1">

            <ContentControl Content="{Binding CurrentParamModel}" />

            <!-- Loading overlay для центральной области Param -->
            <Border Panel.ZIndex="100"
                    Background="#55FFFFFF"                    
                    Visibility="{Binding Vm.Shell.ShouldShowParamOverlay, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}">

                <Border Width="240"
                        Padding="16"
                        Background="White"
                        BorderBrush="#D0D0D0"
                        BorderThickness="1"
                        CornerRadius="6"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">

                    <StackPanel>
                        <TextBlock Text="Updating data..."
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"/>

                        <ProgressBar Height="14"
                                     Margin="0,12,0,8"
                                     IsIndeterminate="True"/>

                        <TextBlock Text="{Binding Vm.Shell.ParamStatusText, RelativeSource={RelativeSource AncestorType=Window}}"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   Style="{StaticResource AppTextStyle}"/>
                    </StackPanel>

                </Border>
            </Border>

        </Grid>

        <StackPanel Grid.Row="0"
            Orientation="Vertical"
            Margin="0,0,0,0"
            VerticalAlignment="Top"
            HorizontalAlignment="Right">

            <!-- Строка состояния именно для Param -->
            <TextBlock Grid.Row="0"
               Margin="0,0,13,0"
               Text="{Binding Vm.Shell.ParamStatusText, RelativeSource={RelativeSource AncestorType=Window}}"
               Style="{StaticResource AppTextStyle}"
               VerticalAlignment="Top"
               HorizontalAlignment="Right" />

        </StackPanel>

    </Grid>
    
</UserControl>
