<local:ParamViewBase x:Class="TechEquipments.Views.Param.DIParamView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:TechEquipments.Views.Param"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxc="http://schemas.devexpress.com/winfx/2008/xaml/charts"
             xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
             xmlns:dxch="clr-namespace:DevExpress.Xpf.Charts;assembly=DevExpress.Xpf.Charts.v21.2"
             xmlns:conv="clr-namespace:TechEquipments"
             MinHeight="260" MinWidth="520">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- ====== LEFT BLOCK "LED boxes" styles ====== -->
        <Style x:Key="LedBoxBaseStyle" TargetType="{x:Type Border}">
            <Setter Property="Width" Value="86"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="BorderBrush" Value="Black"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#FFD0D0D0"/>
            <Setter Property="Padding" Value="4"/>
        </Style>

        <!-- DO Chanel -> ValueTrue -->
        <Style x:Key="LedBoxValueTrueStyle" TargetType="{x:Type Border}" BasedOn="{StaticResource LedBoxBaseStyle}">
            <Style.Triggers>
                <!-- если bool -->
                <DataTrigger Binding="{Binding ValueTrue}" Value="True">
                    <Setter Property="Background" Value="#FF52FF52"/>
                </DataTrigger>
                <!-- если int 0/1 -->
                <DataTrigger Binding="{Binding ValueTrue}" Value="1">
                    <Setter Property="Background" Value="#FF52FF52"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- ForcedValue -> ValueForced -->
        <Style x:Key="LedBoxValueForcedStyle" TargetType="{x:Type Border}" BasedOn="{StaticResource LedBoxBaseStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding ValueForced}" Value="True">
                    <Setter Property="Background" Value="#FF52FF52"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding ValueForced}" Value="1">
                    <Setter Property="Background" Value="#FF52FF52"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- ShowValue -> Value -->
        <Style x:Key="LedBoxValueStyle" TargetType="{x:Type Border}" BasedOn="{StaticResource LedBoxBaseStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Value}" Value="True">
                    <Setter Property="Background" Value="#FF52FF52"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Value}" Value="1">
                    <Setter Property="Background" Value="#FF52FF52"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        
    </UserControl.Resources>


    <dxlc:LayoutControl Margin="0" DataContext="{Binding Param}">
        <dxlc:LayoutGroup View="Group" GroupBoxDisplayMode="Light">

            <!-- ================= LEFT BLOCK ================= -->
            <dxlc:LayoutGroup View="GroupBox" GroupBoxDisplayMode="Light" Width="260" HorizontalAlignment="Left">

                <dxlc:LayoutGroup Orientation="Vertical">

                    <!-- Alarm Health chanel text -->
                    <dxlc:LayoutGroup Header="LayoutGroup" View="Group">
                        <TextBlock Text="Chanel error!"
                                   Style="{StaticResource AlarmHealthBlinkTextStyle}"
                                   Visibility="{Binding AlarmHealth, Converter={StaticResource BoolToVis}}"/>
                    </dxlc:LayoutGroup>

                    <!-- Forced chanel text -->
                    <dxlc:LayoutGroup Header="LayoutGroup" View="Group">
                        <TextBlock Text="Forced chanel!"
                                   Style="{StaticResource ForcedBlinkTextStyle}"
                                   Visibility="{Binding ForceCmd, Converter={StaticResource BoolToVis}}"/>
                    </dxlc:LayoutGroup>

                    <!-- ====== LEFT BLOCK: responsive схема (Grid + растягиваемые линии) ====== -->
                    <Grid Margin="0,8,0,0" HorizontalAlignment="Stretch" SnapsToDevicePixels="True">

                        <!-- 3 строки: верх / середина (пружина) / низ -->
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- 3 колонки: левый блок / растягиваемая область линий / правый блок -->
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- ====== ЛЕВЫЕ прямоугольники ====== -->

                        <!-- Chanel -> ValueTrue -->
                        <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource LedBoxValueTrueStyle}">
                            <TextBlock Text="Chanel" FontWeight="SemiBold" FontSize="12" TextAlignment="Center" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>

                        <!-- ForcedValue -> ValueForced -->
                        <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource LedBoxValueForcedStyle}">
                            <TextBlock Text="Forced&#x0a;Value" FontWeight="SemiBold" FontSize="12" TextAlignment="Center" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>

                        <!-- Вертикальная “шина” справа в колонке линий -->
                        <!-- Margin 20 сверху/снизу, чтобы попасть примерно в центр прямоугольников (высота ~40) -->
                        <Rectangle Grid.Row="0" Grid.RowSpan="3" Grid.Column="1" Width="2" Fill="Black" HorizontalAlignment="Right" Margin="0,20,0,20"/>

                        <!-- Горизонтальная линия: DO -> шина (растягивается) -->
                        <Rectangle Grid.Row="0" Grid.Column="1" Height="2" Fill="Black" VerticalAlignment="Center" HorizontalAlignment="Stretch"/>

                        <!-- Горизонтальная линия: Forced -> шина (растягивается) -->
                        <Rectangle Grid.Row="2" Grid.Column="1" Height="2" Fill="Black" VerticalAlignment="Center" HorizontalAlignment="Stretch"/>

                        <!-- ====== ПРАВЫЙ прямоугольник (ShowValue) ПО ЦЕНТРУ ====== -->
                        <!-- Делаем маленький “вход” линией 14px от шины к прямоугольнику -->
                        <Grid Grid.Row="1" Grid.Column="2" VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- короткая линия к ShowValue -->
                            <Rectangle Grid.Column="0" Height="2" Fill="Black" VerticalAlignment="Center"/>

                            <!-- ShowValue -> Value -->
                            <Border Grid.Column="1" Style="{StaticResource LedBoxValueStyle}">
                                <TextBlock Text="Show&#x0a;Value" FontWeight="SemiBold" FontSize="12" TextAlignment="Center" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>
                        </Grid>

                    </Grid>

                </dxlc:LayoutGroup>

            </dxlc:LayoutGroup>

            <!-- ================= CENTER BLOCK ================= -->
            <dxlc:LayoutGroup Orientation="Vertical" HorizontalAlignment="Stretch">

                <!-- ====== CHART (по умолчанию виден) ====== -->
                <dxlc:LayoutItem
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Visibility="{Binding DataContext.Trend.IsChartVisible, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}">

                    <!-- Trend chart (DevExpress WPF Charts).
                         IMPORTANT:
                         - VisualRange (AxisXMin/AxisXMax) = текущая видимая область.
                         - WholeRange  (AxisXWholeMin/AxisXWholeMax) = весь диапазон загруженных данных.
                           WholeRange должен быть шире VisualRange, чтобы работали scrollbars/пан.
                    -->
                    <dxc:ChartControl DataSource="{Binding DataContext.Trend.Points, RelativeSource={RelativeSource AncestorType=Window}}"
                                      BoundDataChanged="ParamChart_BoundDataChanged"
                                      CustomDrawCrosshair="Chart_CustomDrawCrosshair"
                                      IsManipulationEnabled="True">
                        <dxc:ChartControl.Diagram>
                            <dxc:XYDiagram2D
                                SeriesDataMember="Series"
                                EnableAxisXNavigation="True"
                                EnableAxisYNavigation="False"
                                Scroll="ParamChart_DiagramScroll"
                                Zoom="ParamChart_DiagramZoom">

                                <dxc:XYDiagram2D.NavigationOptions>
                                    <dxc:NavigationOptions UseMouse="True" UseScrollBars="True" UseKeyboard="True" UseTouchDevice="True"/>
                                </dxc:XYDiagram2D.NavigationOptions>

                                <!-- AxisX -->
                                <dxc:XYDiagram2D.AxisX>
                                    <dxc:AxisX2D>

                                        <dxc:AxisX2D.VisualRange>
                                            <dxc:Range AutoSideMargins="False" SideMarginsValue="0"
                                                MinValue="{Binding DataContext.Trend.AxisXMin, RelativeSource={RelativeSource AncestorType=Window}}"
                                                MaxValue="{Binding DataContext.Trend.AxisXMax, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                        </dxc:AxisX2D.VisualRange>

                                        <dxc:AxisX2D.WholeRange>
                                            <dxc:Range AutoSideMargins="False" SideMarginsValue="0"
                                                MinValue="{Binding DataContext.Trend.AxisXWholeMin, RelativeSource={RelativeSource AncestorType=Window}}"
                                                MaxValue="{Binding DataContext.Trend.AxisXWholeMax, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                        </dxc:AxisX2D.WholeRange>

                                        <dxc:AxisX2D.DateTimeScaleOptions>
                                            <dxc:ContinuousDateTimeScaleOptions GridAlignment="Second" AutoGrid="True"/>
                                        </dxc:AxisX2D.DateTimeScaleOptions>

                                    </dxc:AxisX2D>
                                </dxc:XYDiagram2D.AxisX>

                                <!-- AxisY: -->
                                <dxc:XYDiagram2D.AxisY>
                                    <dxc:AxisY2D>
                                        <dxc:AxisY2D.VisualRange>
                                            <dxc:Range AutoSideMargins="False" SideMarginsValue="0"
                                                       MinValue="{Binding DataContext.Trend.AxisYMin, RelativeSource={RelativeSource AncestorType=Window}}"
                                                       MaxValue="{Binding DataContext.Trend.AxisYMax, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                        </dxc:AxisY2D.VisualRange>
                                        <dxc:AxisY2D.WholeRange>
                                            <dxc:Range AutoSideMargins="False" SideMarginsValue="0"
                                                       MinValue="{Binding DataContext.Trend.AxisYMin, RelativeSource={RelativeSource AncestorType=Window}}"
                                                       MaxValue="{Binding DataContext.Trend.AxisYMax, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                        </dxc:AxisY2D.WholeRange>
                                    </dxc:AxisY2D>
                                </dxc:XYDiagram2D.AxisY>

                                <dxc:XYDiagram2D.SeriesTemplate>
                                    <dxc:AreaStepSeries2D
                                        ArgumentDataMember="Time"
                                        ValueDataMember="Value"
                                        ArgumentScaleType="DateTime"
                                        MarkerVisible="False">
                                    </dxc:AreaStepSeries2D>
                                </dxc:XYDiagram2D.SeriesTemplate>

                            </dxc:XYDiagram2D>
                        </dxc:ChartControl.Diagram>
                    </dxc:ChartControl>

                </dxlc:LayoutItem>

                <!-- ====== SETTINGS (PLC / Chanel / Alarm) ====== -->
                <dxlc:LayoutItem Visibility="{Binding DataContext.Trend.IsSettingsVisible, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}">

                    <!-- вложенный LayoutControl, чтобы можно было показывать/скрывать целиком -->
                    <dxlc:LayoutControl Margin="-12">

                        <dxlc:LayoutGroup Orientation="Vertical" View="Group" GroupBoxDisplayMode="Light">

                            <!-- ====== Forced ====== -->
                            <dxlc:LayoutGroup Header="Forced" View="GroupBox" HorizontalAlignment="Stretch" Orientation="Vertical">

                                <dxlc:LayoutGroup Orientation="Horizontal">
                                    <dxlc:LayoutItem Style="{StaticResource BoolCheckLayoutItemStyle}">
                                        <dxe:ToggleSwitchEdit
                                            Tag="ForceCmd"
                                            IsChecked="{Binding ForceCmd, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"                                            
                                            EditValueChanged="ParamEditable_EditValueChanged"/>
                                    </dxlc:LayoutItem>

                                    <dxlc:LayoutItem Label="Forcing the chanel: " HorizontalAlignment="Right">

                                            <dxe:ToggleSwitchEdit Tag="ValueForced"
                                                                  Width="80"
                                                                  HorizontalAlignment="Left"
                                                                  UncheckedStateContent="Off"
                                                                  CheckedStateContent="On"
                                                                  IsChecked="{Binding ValueForced, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                  IsEnabled="{Binding ForceCmd}"
                                                                  EditValueChanged="ParamEditable_EditValueChanged"
                                                                  Style="{StaticResource AppBaseEditStyle}" />
                                    </dxlc:LayoutItem>
                                </dxlc:LayoutGroup>

                            </dxlc:LayoutGroup>

                        </dxlc:LayoutGroup>

                    </dxlc:LayoutControl>

                </dxlc:LayoutItem>

            </dxlc:LayoutGroup>

            <!-- ================= RIGHT BLOCK (buttons) ================= -->
            <dxlc:LayoutGroup View="Group" GroupBoxDisplayMode="Light"
                  Header=""
                  HorizontalAlignment="Right"
                  VerticalAlignment="Stretch">

                <!-- Один LayoutItem, внутри Grid с "пружиной" -->
                <dxlc:LayoutItem VerticalAlignment="Stretch">
                    <Grid VerticalAlignment="Stretch">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <!-- верхние кнопки -->
                            <RowDefinition Height="*"/>
                            <!-- пружина -->
                            <RowDefinition Height="Auto"/>
                            <!-- нижняя кнопка -->
                        </Grid.RowDefinitions>

                        <!-- Верх: Chart + Params -->
                        <StackPanel Grid.Row="0" Orientation="Vertical" VerticalAlignment="Top">

                            <!-- Chart -->
                            <dx:SimpleButton x:Name="ChartButton"
                                 Width="60" Height="60"
                                 Padding="0" GlyphWidth="40" GlyphHeight="40"
                                 Click="ShowChartButton_Click"
                                 ToolTip="Chart"
                                 Glyph="{dx:DXImage 'SvgImages/Spreadsheet/CreateScatterChartLinesAndMarkers.svg'}"
                                 Style="{StaticResource AppButtonStyle}" />

                            <!-- Params -->
                            <dx:SimpleButton x:Name="ParamButton"
                                 Width="60" Height="60"
                                 Margin="0,8,0,0"
                                 Padding="0" GlyphWidth="40" GlyphHeight="40"
                                 Click="ShowParamsButton_Click"
                                 ToolTip="Params"
                                 Glyph="{dx:DXImage SvgImages/Outlook Inspired/List.svg}"
                                 Style="{StaticResource AppButtonStyle}" />

                        </StackPanel>

                        <!-- Низ: + / - / Live-History -->
                        <StackPanel Grid.Row="2" Orientation="Vertical" VerticalAlignment="Bottom">

                            <dx:SimpleButton Padding="0"
                                             GlyphWidth="40" GlyphHeight="40"
                                             Glyph="{dx:DXImage 'SvgImages/DiagramIcons/ZoomIn.svg'}"
                                             ToolTip="Zoom in"
                                             Style="{StaticResource ParamTrendHistoryZoomButtonStyle}"
                                             Click="TrendZoomIn_Click"/>

                            <dx:SimpleButton Margin="0,8,0,0" Padding="0"
                                             GlyphWidth="40" GlyphHeight="40"
                                             Glyph="{dx:DXImage 'SvgImages/DiagramIcons/ZoomOut.svg'}"
                                             Click="TrendZoomOut_Click"
                                             ToolTip="Zoom out"
                                             Style="{StaticResource ParamTrendHistoryZoomButtonStyle}"/>

                            <ToggleButton x:Name="TrendModeButton"
                                          Margin="0,8,0,0"
                                          Click="TrendModeToggle_Click"
                                          Style="{StaticResource ParamTrendModeToggleStyle}"/>

                        </StackPanel>

                    </Grid>
                </dxlc:LayoutItem>

            </dxlc:LayoutGroup>

        </dxlc:LayoutGroup>

    </dxlc:LayoutControl>

</local:ParamViewBase>