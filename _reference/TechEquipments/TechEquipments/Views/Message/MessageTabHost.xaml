<UserControl x:Class="TechEquipments.Views.Message.MessageTabHost"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:local="clr-namespace:TechEquipments">

    <Grid Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="70"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <!-- Main content -->
            <RowDefinition Height="*"/>
            <!-- Global footer -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Left ListBox -->
        <ListBox Grid.Row="0"
                 Grid.Column="0"
                 ItemsSource="{Binding Messages}"
                 SelectedItem="{Binding SelectedMessage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 SelectionChanged="MessagesList_SelectionChanged"
                 BorderThickness="0"
                 Background="Transparent"
                 HorizontalContentAlignment="Stretch"
                 ScrollViewer.VerticalScrollBarVisibility="Auto">

            <ListBox.ItemContainerStyle>
                <Style TargetType="{x:Type ListBoxItem}">
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0,0,0,8"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                </Style>
            </ListBox.ItemContainerStyle>

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="#33000000"
                            BorderThickness="1"
                            CornerRadius="5"
                            Padding="8">
                        <Border.Style>
                            <Style TargetType="{x:Type Border}">
                                <Setter Property="Background" Value="#EAF3FF"/>
                                <Setter Property="Opacity" Value="1"/>

                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding MessageType}"
                                                 Value="{x:Static local:MessageType.Warning}">
                                        <Setter Property="Background" Value="#FFF3CD"/>
                                    </DataTrigger>

                                    <DataTrigger Binding="{Binding MessageType}"
                                                 Value="{x:Static local:MessageType.Critical}">
                                        <Setter Property="Background" Value="#F8D7DA"/>
                                    </DataTrigger>

                                    <DataTrigger Binding="{Binding IsActive}"
                                                 Value="False">
                                        <Setter Property="Opacity" Value="0.55"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Type icon -->
                            <Image Grid.Row="0"
                                   Grid.Column="0"
                                   Width="18"
                                   Height="18"
                                   Margin="0,0,6,0"
                                   VerticalAlignment="Center">
                                <Image.Style>
                                    <Style TargetType="{x:Type Image}">
                                        <Setter Property="Source"
                                                Value="{dx:DXImage 'SvgImages/Icon Builder/Actions_Info.svg'}"/>

                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding MessageType}"
                                                         Value="{x:Static local:MessageType.Warning}">
                                                <Setter Property="Source"
                                                        Value="{dx:DXImage 'SvgImages/XAF/State_Validation_Warning.svg'}"/>
                                            </DataTrigger>

                                            <DataTrigger Binding="{Binding MessageType}"
                                                         Value="{x:Static local:MessageType.Critical}">
                                                <Setter Property="Source"
                                                        Value="{dx:DXImage 'SvgImages/Outlook Inspired/HighImportance.svg'}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>

                            <!-- Subject -->
                            <TextBlock Grid.Row="0"
                                       Grid.Column="1"
                                       Text="{Binding MessageSubject}"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"/>

                            <TextBlock Grid.Row="0"
                                       Grid.Column="2"
                                       Text="{Binding ActivityText}"
                                       Foreground="Gray"
                                       FontSize="11"/>

                            <TextBlock Grid.Row="1"
                                       Grid.Column="1"
                                       Grid.ColumnSpan="2"
                                       Margin="0,3,0,0"
                                       Text="{Binding CreatedAtText}"
                                       FontSize="11"
                                       Foreground="Gray"/>

                            <TextBlock Grid.Row="2"
                                       Grid.Column="1"
                                       Grid.ColumnSpan="2"
                                       Margin="0,2,0,0"
                                       Text="{Binding CreatedBy}"
                                       FontSize="11"
                                       Foreground="Gray"
                                       TextTrimming="CharacterEllipsis"/>

                            <Grid Grid.Row="3"
                                  Grid.Column="1"
                                  Grid.ColumnSpan="2"
                                  Margin="0,7,0,0">

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="{Binding PreviewText}"
                                           TextWrapping="Wrap"
                                           MaxHeight="48"/>

                                <!-- Viewed check -->
                                <TextBlock Grid.Column="1"
                                           Text="✓✓"
                                           Margin="8,0,0,0"
                                           Foreground="#2E7D32"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Bottom"
                                           Visibility="{Binding IsViewedByOtherDevice, Converter={StaticResource BoolToVis}}"/>
                            </Grid>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Right content -->
        <Grid Grid.Row="0"
              Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Type / Subject / Activity -->
            <Grid Grid.Row="0"
                  Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="125"/>
                </Grid.ColumnDefinitions>

                <dxe:ComboBoxEdit Grid.Column="0"
                                  ItemsSource="{Binding MessageTypeOptions}"
                                  EditValue="{Binding SelectedMessage.MessageType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  IsEnabled="{Binding IsEditMode}"
                                  IsTextEditable="False"
                                  HorizontalContentAlignment="Left">

                    <dxe:ComboBoxEdit.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Image Width="16"
                                       Height="16"
                                       Margin="0,0,6,0"
                                       VerticalAlignment="Center">
                                    <Image.Style>
                                        <Style TargetType="{x:Type Image}">
                                            <Setter Property="Source"
                                                    Value="{dx:DXImage 'SvgImages/Icon Builder/Actions_Info.svg'}"/>

                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding}"
                                                             Value="{x:Static local:MessageType.Warning}">
                                                    <Setter Property="Source"
                                                            Value="{dx:DXImage 'SvgImages/XAF/State_Validation_Warning.svg'}"/>
                                                </DataTrigger>

                                                <DataTrigger Binding="{Binding}"
                                                             Value="{x:Static local:MessageType.Critical}">
                                                    <Setter Property="Source"
                                                            Value="{dx:DXImage 'SvgImages/Outlook Inspired/HighImportance.svg'}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Image.Style>
                                </Image>

                                <TextBlock Text="{Binding}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </dxe:ComboBoxEdit.ItemTemplate>
                </dxe:ComboBoxEdit>

                <TextBlock Grid.Column="2"
                           Text="Subject:"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>

                <TextBox Grid.Column="3"
                         Text="{Binding SelectedMessage.MessageSubject, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         IsReadOnly="{Binding IsReadOnly}"
                         Padding="6,3"
                         BorderBrush="#33000000"
                         BorderThickness="1"
                         VerticalContentAlignment="Center">
                    <TextBox.Style>
                        <Style TargetType="{x:Type TextBox}">
                            <Setter Property="Background" Value="#08FFFFFF"/>

                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditMode}"
                                             Value="True">
                                    <Setter Property="Background" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <!-- Activity toggle -->
                <StackPanel Grid.Column="5"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">

                    <TextBlock Text="{Binding SelectedMessage.ActivityText}"
                               Margin="0,0,8,0"
                               VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="{x:Type TextBlock}">
                                <Setter Property="FontWeight" Value="Normal"/>
                                <Setter Property="Foreground" Value="Gray"/>

                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedMessage.IsActive}"
                                                 Value="True">
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Foreground" Value="#222222"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <dxe:ToggleSwitchEdit Width="55"
                                          Height="34"
                                          VerticalAlignment="Center"
                                          IsChecked="{Binding SelectedMessage.IsActive, Mode=OneWay}"
                                          PreviewMouseLeftButtonDown="ActivityToggle_PreviewMouseLeftButtonDown"
                                          PreviewKeyDown="ActivityToggle_PreviewKeyDown"
                                          ToolTip="Toggle active/inactive"/>
                </StackPanel>
            </Grid>

            <!-- Text -->
            <TextBox Grid.Row="1"
                     Text="{Binding SelectedMessage.MessageText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     IsReadOnly="{Binding IsReadOnly}"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     AcceptsTab="True"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Disabled"
                     VerticalContentAlignment="Top"
                     Padding="8"
                     BorderBrush="#33000000"
                     BorderThickness="1"
                     FontSize="13">
                <TextBox.Style>
                    <Style TargetType="{x:Type TextBox}">
                        <Setter Property="Background" Value="#08FFFFFF"/>

                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsEditMode}"
                                         Value="True">
                                <Setter Property="Background" Value="White"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>
        </Grid>

        <!-- Right buttons -->
        <Grid Grid.Row="0"
              Grid.Column="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Filter button: visible only in view mode -->
            <dx:SimpleButton Grid.Row="0"
                             Width="60"
                             Height="60"
                             Margin="0,48,0,0"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Top"
                             Padding="0"
                             GlyphWidth="36"
                             GlyphHeight="36"
                             Click="Show_Click">

                <dx:SimpleButton.Style>
                    <Style TargetType="{x:Type dx:SimpleButton}"
                           BasedOn="{StaticResource AppButtonStyle}">

                        <!-- Default state: Show active only -->
                        <Setter Property="Glyph"
                                Value="{dx:DXImage 'SvgImages/Dashboards/MasterFilter.svg'}"/>
                        <Setter Property="ToolTip"
                                Value="Show all messages"/>

                        <Setter Property="Visibility" Value="Visible"/>

                        <Style.Triggers>

                            <!-- ShowAllMessages = true: currently showing all -->
                            <DataTrigger Binding="{Binding ShowAllMessages}" Value="True">
                                <Setter Property="Glyph"
                                        Value="{dx:DXImage 'SvgImages/Dashboards/IgnoreMasterFilters.svg'}"/>
                                <Setter Property="ToolTip"
                                        Value="Show active messages only"/>
                            </DataTrigger>

                            <!-- Hide in edit mode -->
                            <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>

                        </Style.Triggers>
                    </Style>
                </dx:SimpleButton.Style>
            </dx:SimpleButton>

            <!-- View mode buttons -->
            <StackPanel Grid.Row="2"
                        Orientation="Vertical"
                        VerticalAlignment="Bottom"
                        HorizontalAlignment="Center">
                <StackPanel.Style>
                    <Style TargetType="{x:Type StackPanel}">
                        <Setter Property="Visibility" Value="Visible"/>

                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsEditMode}"
                                         Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>

                <!-- Add -->
                <dx:SimpleButton Width="60"
                                 Height="60"
                                 Padding="0"
                                 Margin="0,0,0,0"
                                 GlyphWidth="36"
                                 GlyphHeight="36"
                                 Glyph="{dx:DXImage 'SvgImages/Spreadsheet/NewComment.svg'}"
                                 Click="Add_Click"
                                 ToolTip="Add message"
                                 Style="{StaticResource AppButtonStyle}"/>

                <!-- Edit -->
                <dx:SimpleButton Width="60"
                                 Height="60"
                                 Padding="0"
                                 Margin="0,40,0,0"
                                 GlyphWidth="36"
                                 GlyphHeight="36"
                                 Glyph="{dx:DXImage 'SvgImages/Spreadsheet/EditComment.svg'}"
                                 Click="Edit_Click"
                                 ToolTip="Edit message"
                                 Style="{StaticResource AppButtonStyle}"/>
            </StackPanel>

            <!-- Edit mode buttons -->
            <StackPanel Grid.Row="2"
                        Orientation="Vertical"
                        VerticalAlignment="Bottom"
                        HorizontalAlignment="Center">
                <StackPanel.Style>
                    <Style TargetType="{x:Type StackPanel}">
                        <Setter Property="Visibility" Value="Collapsed"/>

                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsEditMode}"
                                         Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>

                <!-- Delete -->
                <dx:SimpleButton Width="60"
                                 Height="60"
                                 Padding="0"
                                 Margin="0,8,0,40"
                                 GlyphWidth="36"
                                 GlyphHeight="36"
                                 Glyph="{dx:DXImage 'SvgImages/Icon Builder/Actions_Trash.svg'}"
                                 Click="Delete_Click"
                                 ToolTip="Delete message">
                    <dx:SimpleButton.Style>
                        <Style TargetType="{x:Type dx:SimpleButton}"
                               BasedOn="{StaticResource AppButtonStyle}">
                            <Setter Property="Visibility" Value="Collapsed"/>

                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsEditMode}" Value="True"/>
                                        <Condition Binding="{Binding ShowDeleteButton}" Value="True"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </dx:SimpleButton.Style>
                </dx:SimpleButton>

                <!-- Save -->
                <dx:SimpleButton Width="60"
                                 Height="60"
                                 Padding="0"
                                 Margin="0,0,0,0"
                                 GlyphWidth="36"
                                 GlyphHeight="36"
                                 Glyph="{dx:DXImage 'SvgImages/DiagramIcons/save.svg'}"
                                 Click="Save_Click"
                                 ToolTip="Save message"
                                 Style="{StaticResource AppButtonStyle}"/>

            </StackPanel>
        </Grid>

        <!-- Global footer -->
        <Grid Grid.Row="1"
              Grid.Column="0"
              Grid.ColumnSpan="4"
              Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="330"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Status -->
            <TextBlock Grid.Column="0"
                       Text="{Binding StatusText}"
                       Foreground="Gray"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"/>

            <!-- Metadata -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Left">

                <!-- Created by -->
                <TextBlock Text="Created by:"
                           Foreground="Gray"
                            FontWeight="SemiBold"                            
                            VerticalAlignment="Center"/>

                <TextBlock Margin="8,0,0,0"
                           Text="{Binding SelectedMessage.CreatedBy}"                           
                           Foreground="Gray"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="160"/>

                <!-- Created -->
                <TextBlock Margin="16,0,0,0"
                           Text="Created:"
                           Foreground="Gray"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>

                <TextBlock Margin="8,0,0,0"
                           Text="{Binding SelectedMessage.CreatedAtText}"
                           Foreground="Gray"
                           VerticalAlignment="Center"/>

                <!-- Updated label -->
                <TextBlock Margin="16,0,0,0"
                           Text="Updated:"
                           Foreground="Gray"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="{x:Type TextBlock}">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedMessage.UpdatedAtText}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Updated value -->
                <TextBlock Margin="8,0,0,0"
                           Text="{Binding SelectedMessage.UpdatedAtText}"
                           Foreground="Gray"
                           VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="{x:Type TextBlock}">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedMessage.UpdatedAtText}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">

                <!-- Viewed by -->
                <TextBlock Margin="10,0,0,0"
                           Text="Viewed by:"
                           Foreground="Gray"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>

                <!-- Viewed by -->
                <dxe:ComboBoxEdit Margin="8,0,70,0"
                                  Height="25"
                                  Width="150"
                                  ItemsSource="{Binding SelectedMessage.ViewedByDevices}"
                                  EditValue="{Binding SelectedMessage.SelectedViewedByDevice, Mode=OneWay}"
                                  IsTextEditable="False"
                                  ImmediatePopup="True"
                                  Background="#08FFFFFF"
                                  NullText="—"
                                  HorizontalContentAlignment="Left"
                                  VerticalAlignment="Center">
                    <dxe:ComboBoxEdit.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}"
                                       HorizontalAlignment="Left"
                                       TextAlignment="Left"/>
                        </DataTemplate>
                    </dxe:ComboBoxEdit.ItemTemplate>
                </dxe:ComboBoxEdit>
            </StackPanel>

        </Grid>
        
    </Grid>
</UserControl>