<UserControl x:Class="TechEquipments.Views.Common.ParamPlcRowsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:param="clr-namespace:TechEquipments.Views.Param">

    <Grid>
        <ScrollViewer Height="482" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="RowsList"
                          ItemsSource="{Binding DataContext.ParamPlcRows,RelativeSource={RelativeSource AncestorType={x:Type param:ParamTabHost}}}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="30"/>
                            </Grid.ColumnDefinitions>

                            <!-- Title -->
                            <TextBlock Grid.Column="0"
                                       Text="{Binding Title}"
                                       VerticalAlignment="Center"
                                       TextWrapping="Wrap"
                                       Style="{StaticResource AppTextBlockStyle}"/>

                            <!-- Value -->
                            <ContentControl Grid.Column="1"
                                            Content="{Binding}"
                                            ContentTemplateSelector="{StaticResource PlcTypeTemplateSelector}"/>

                            <!-- Unit -->
                            <TextBlock Grid.Column="2"
                                       Margin="6,0,0,0"
                                       Text="{Binding Unit}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Left"
                                       Style="{StaticResource AppTextBlockStyle}"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Сообщение, если PLC rows отсутствуют -->
        <TextBlock Text="No PLC settings available."
                   Margin="8"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   FontStyle="Italic"
                   Opacity="0.7">
            <TextBlock.Style>
                <Style TargetType="{x:Type TextBlock}">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ElementName=RowsList, Path=HasItems}" Value="False">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>
    </Grid>
</UserControl>