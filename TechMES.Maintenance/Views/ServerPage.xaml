<views:MaintenancePageControl x:Class="TechMES.Maintenance.Views.ServerPage"
                              xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                              xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                              xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                              xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                              xmlns:control="http://filterdatagrid.control.com/2021"
                              xmlns:views="clr-namespace:TechMES.Maintenance.Views"
                              mc:Ignorable="d">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <views:MaintenanceCard Grid.Row="0"
                                Background="{DynamicResource TechMesPanelBrush}"
                                BorderBrush="{DynamicResource TechMesBorderBrush}"
                                BorderThickness="1"
                                Padding="12"
                                Margin="0,0,0,10">
            <Grid>
                <StackPanel>
                    <TextBlock Text="Server access" Style="{StaticResource SectionTitleText}" />
                    <TextBlock Text="WEB должен быть доступен по одному из адресов ниже." Style="{StaticResource MutedText}" />
                    <TextBlock Text="Runtime Service остается локальным и наружу не открывается. HTTPS нужен для камеры, QR-сканера и браузерных API." Style="{StaticResource MutedText}" />
                </StackPanel>
            </Grid>
        </views:MaintenanceCard>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <views:MaintenanceCard Grid.Column="0"
                                    Background="{DynamicResource TechMesPanelBrush}"
                                    BorderBrush="{DynamicResource TechMesBorderBrush}"
                                    BorderThickness="1"
                                    Padding="10">
                <DockPanel>
                    <control:FilterDataGrid ItemsSource="{Binding ServerAddresses}"
                                            AutoGenerateColumns="False"
                                            IsReadOnly="True"
                                            CanUserAddRows="False"
                                            HeadersVisibility="Column"
                                            GridLinesVisibility="Horizontal"
                                            Background="{DynamicResource TechMesPanelBrush}"
                                            ShowStatusBar="False"
                                            ShowElapsedTime="False"
                                            DateFormatString="dd.MM.yyyy"
                                            FilterLanguage="Russian">
                        <control:FilterDataGrid.Columns>
                            <control:DataGridTextColumn Header="Adapter"
                                                        Binding="{Binding AdapterName}"
                                                        IsColumnFiltered="True"
                                                        Width="220" />
                            <control:DataGridTextColumn Header="IP"
                                                        Binding="{Binding Address}"
                                                        IsColumnFiltered="True"
                                                        Width="150" />
                            <control:DataGridTextColumn Header="WEB URL"
                                                        Binding="{Binding WebUrl}"
                                                        IsColumnFiltered="True"
                                                        Width="*" />
                            <control:DataGridTextColumn Header="HTTPS URL"
                                                        Binding="{Binding HttpsUrl}"
                                                        IsColumnFiltered="True"
                                                        Width="*" />
                        </control:FilterDataGrid.Columns>
                    </control:FilterDataGrid>
                </DockPanel>
            </views:MaintenanceCard>

            <views:MaintenanceCard Grid.Column="2"
                                    Background="{DynamicResource TechMesPanelBrush}"
                                    BorderBrush="{DynamicResource TechMesBorderBrush}"
                                    BorderThickness="1"
                                    Padding="10">
                <DockPanel LastChildFill="True">
                    <Grid DockPanel.Dock="Bottom"
                          Margin="0,22,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <ui:Button Grid.Column="0"
                                Content="Prepare server"
                                HorizontalAlignment="Left"
                                MinWidth="100"
                                Click="OnPrepareServerClick" />
                        <ui:Button Grid.Column="2"
                                Content="Refresh server"
                                HorizontalAlignment="Right"
                                MinWidth="100"
                                Click="OnRefreshServerClick" />
                    </Grid>

                    <StackPanel>
                        <TextBlock Text="Server checks"
                                   Style="{StaticResource SectionTitleText}" />

                    <TextBlock Text="WEB port"
                                               Style="{StaticResource MutedText}" />
                    <TextBlock Text="{Binding ServerWebPortLine}"
                                               Margin="0,0,0,8"
                                               FontWeight="SemiBold" />

                    <TextBlock Text="HTTPS port"
                                               Style="{StaticResource MutedText}" />
                    <TextBlock Text="{Binding ServerHttpsPortLine}"
                                               Margin="0,0,0,8"
                                               FontWeight="SemiBold" />

                    <TextBlock Text="Runtime port"
                                               Style="{StaticResource MutedText}" />
                    <TextBlock Text="{Binding ServerRuntimePortLine}"
                                               Margin="0,0,0,8"
                                               FontWeight="SemiBold" />

                    <TextBlock Text="FirewallRule"
                                               Style="{StaticResource MutedText}" />
                    <TextBlock Text="{Binding ServerFirewallRuleLine}"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding ServerHttpsFirewallRuleLine}"
                                               Margin="0,2,0,8"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap" />

                    <TextBlock Text="Certificate"
                                               Style="{StaticResource MutedText}"
                                               Margin="0,8,0,0" />
                    <TextBlock Text="{Binding ServerCertificateStatus}"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding ServerCertificatePfxPath}"
                                               Style="{StaticResource MutedText}"
                                               TextWrapping="Wrap" />
                        <TextBlock Text="{Binding ServerPublicCertificatePath}"
                                   Style="{StaticResource MutedText}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </DockPanel>
            </views:MaintenanceCard>
        </Grid>

        <views:MaintenanceSection Grid.Row="2"
                                  Header="Server log"
                                  Margin="0,12,0,0">
            <ui:TextBox Text="{Binding ServerLogText}"
                                     IsReadOnly="True"
                                     TextChanged="OnAutoScrollLogTextChanged"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     FontFamily="Consolas"
                                     BorderThickness="0"
                                     Padding="8" />
        </views:MaintenanceSection>
    </Grid>
</views:MaintenancePageControl>




