<views:MaintenancePageControl x:Class="TechMES.Maintenance.Views.DeployPage"
                              xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                              xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                              xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                              xmlns:views="clr-namespace:TechMES.Maintenance.Views"
                              mc:Ignorable="d">
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="170" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0"
                              Grid.RowSpan="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0"
                                        Orientation="Horizontal"
                                        Margin="0,0,0,8">
                                <Button Content="Publish all"
                                        Click="OnPublishAllClick" />
                                <Button Content="Install/Update all"
                                        Click="OnInstallAllClick" />
                                <Button Content="Start all"
                                        Click="OnStartAllDeployClick" />
                                <Button Content="Deploy all"
                                        Click="OnDeployAllClick" />
                            </StackPanel>

                            <DataGrid Grid.Row="1"
                                      ItemsSource="{Binding DeploymentServices}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      CanUserAddRows="False"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      Background="{StaticResource TechMesPanelBrush}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Service"
                                                        Binding="{Binding DisplayName}"
                                                        Width="160" />
                                    <DataGridTextColumn Header="Windows name"
                                                        Binding="{Binding ServiceName}"
                                                        Width="210" />
                                    <DataGridTextColumn Header="Project"
                                                        Binding="{Binding ProjectPath}"
                                                        Width="240" />
                                    <DataGridTextColumn Header="Publish directory"
                                                        Binding="{Binding PublishDirectory}"
                                                        Width="*" />
                                    <DataGridTextColumn Header="Status"
                                                        Binding="{Binding Status}"
                                                        Width="170" />
                                    <DataGridTemplateColumn Header="Actions"
                                                            Width="230">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <Button Content="Publish"
                                                            Tag="{Binding}"
                                                            Click="OnPublishDeployServiceClick" />
                                                    <Button Content="Install"
                                                            Tag="{Binding}"
                                                            Click="OnInstallDeployServiceClick" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>

                        <GroupBox Grid.Row="2"
                                  Header="Deploy log"
                                  Margin="0,12,0,0">
                            <TextBox Text="{Binding DeploymentLogText}"
                                     IsReadOnly="True"
                                     TextChanged="OnAutoScrollLogTextChanged"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     FontFamily="Consolas"
                                     BorderThickness="0"
                                     Padding="8" />
                        </GroupBox>
                    </Grid>
</views:MaintenancePageControl>
