<views:MaintenancePageControl x:Class="TechMES.Maintenance.Views.ServicesPage"
                              xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                              xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                              xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                              xmlns:views="clr-namespace:TechMES.Maintenance.Views"
                              mc:Ignorable="d">
    <TabControl HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                HorizontalContentAlignment="Stretch"
                VerticalContentAlignment="Stretch">
        <TabItem>
            <TabItem.Header>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE9F5;" FontSize="18" Margin="0,0,8,0" />
                    <TextBlock Text="Services" />
                </StackPanel>
            </TabItem.Header>
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="180" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0"
                              Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="Services"
                                           Style="{StaticResource SectionTitleText}" />
                                <TextBlock Text="Статусы читаются из Windows Service Control Manager через sc.exe. Если службы еще не установлены, это нормально."
                                           Style="{StaticResource MutedText}" />
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <Button Content="Refresh all"
                                        MinWidth="90"
                                        Click="OnRefreshAllClick" />
                                <Button Content=" Open services"
                                        MinWidth="90"
                                        Click="OnOpenServicesConsoleClick" />
                            </StackPanel>
                        </Grid>

                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding ServiceStatuses}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  Background="{StaticResource TechMesPanelBrush}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Service"
                                                    Binding="{Binding DisplayName}"
                                                    Width="170" />
                                <DataGridTextColumn Header="Windows name"
                                                    Binding="{Binding ServiceName}"
                                                    Width="210" />
                                <DataGridTextColumn Header="Status"
                                                    Binding="{Binding Status}"
                                                    Width="130" />
                                <DataGridTextColumn Header="Health"
                                                    Binding="{Binding Health}"
                                                    Width="130" />
                                <DataGridTextColumn Header="Health URL"
                                                    Binding="{Binding HealthUrl}"
                                                    Width="*" />
                                <DataGridTextColumn Header="Checked"
                                                    Binding="{Binding LastChecked, StringFormat={}{0:HH:mm:ss}}"
                                                    Width="100" />
                                <DataGridTemplateColumn Header="Actions"
                                                        Width="310">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="Start"
                                                        Tag="{Binding}"
                                                        Click="OnStartServiceClick" />
                                                <Button Content="Stop"
                                                        Tag="{Binding}"
                                                        Click="OnStopServiceClick" />
                                                <Button Content="Restart"
                                                        Tag="{Binding}"
                                                        Click="OnRestartServiceClick" />
                                                <Button Content="Probe"
                                                        Tag="{Binding}"
                                                        Click="OnProbeServiceClick" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <GroupBox Grid.Row="2"
                                  Header="Diagnostics"
                                  Margin="0,12,0,0">
                            <TextBox Text="{Binding DiagnosticsText}"
                                     IsReadOnly="True"
                                     TextChanged="OnAutoScrollLogTextChanged"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     FontFamily="Consolas"
                                     BorderThickness="0"
                                     Padding="8" />
                        </GroupBox>
                    </Grid>
        </TabItem>
        <TabItem>
            <TabItem.Header>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE968;" FontSize="18" Margin="0,0,8,0" />
                    <TextBlock Text="Server" />
                </StackPanel>
            </TabItem.Header>
            <views:ServerPage HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch" />
        </TabItem>
        <TabItem>
            <TabItem.Header>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE896;" FontSize="18" Margin="0,0,8,0" />
                    <TextBlock Text="Deploy" />
                </StackPanel>
            </TabItem.Header>
            <views:DeployPage HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch" />
        </TabItem>
    </TabControl>
                
</views:MaintenancePageControl>
