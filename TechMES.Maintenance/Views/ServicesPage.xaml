<views:MaintenancePageControl x:Class="TechMES.Maintenance.Views.ServicesPage"
                              xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                              xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                              xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                              xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                              xmlns:control="http://filterdatagrid.control.com/2021"
                              xmlns:views="clr-namespace:TechMES.Maintenance.Views"
                              mc:Ignorable="d">
    <TabControl HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                HorizontalContentAlignment="Stretch"
                VerticalContentAlignment="Stretch">
        <TabItem>
            <TabItem.Header>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:SymbolIcon Symbol="Server24" Width="20" Height="20" Margin="0,0,8,0" />
                    <TextBlock Text="Server" />
                </StackPanel>
            </TabItem.Header>
            <views:ServerPage HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch" />
        </TabItem>

        <TabItem>
            <TabItem.Header>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:SymbolIcon Symbol="WindowWrench24" Width="20" Height="20" Margin="0,0,8,0" />
                    <TextBlock Text="Services" />
                </StackPanel>
            </TabItem.Header>
            <Grid Margin="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="350" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <views:MaintenanceCard Grid.Row="0"
                                Background="{DynamicResource TechMesPanelBrush}"
                                BorderBrush="{DynamicResource TechMesBorderBrush}"
                                BorderThickness="1"
                                Padding="12"
                                Margin="0,0,0,10">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="Services"
                               Style="{StaticResource SectionTitleText}" />
                            <TextBlock Text="Статусы читаются из Windows Service Control Manager через sc.exe. Если службы еще не установлены, это нормально."
                               Style="{StaticResource MutedText}" />
                        </StackPanel>
                    </Grid>
                </views:MaintenanceCard>

                <views:MaintenanceCard Grid.Row="1"
                                    Background="{DynamicResource TechMesPanelBrush}"
                                    BorderBrush="{DynamicResource TechMesBorderBrush}"
                                    BorderThickness="1"
                                    Padding="12"
                                    Margin="0,0,0,10">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>


                        <control:FilterDataGrid
                                        ItemsSource="{Binding ServiceStatuses}"
                                        AutoGenerateColumns="False"
                                        IsReadOnly="True"
                                        CanUserAddRows="False"
                                        HeadersVisibility="Column"
                                        GridLinesVisibility="Horizontal"
                                        Background="{DynamicResource TechMesPanelBrush}"
                                        ShowStatusBar="False"
                                        ShowElapsedTime="False"
                                        DateFormatString="dd.MM.yyyy"
                                        FilterLanguage="Russian">
                    <control:FilterDataGrid.Columns>
                        <control:DataGridTextColumn Header="Service"
                                                    Binding="{Binding DisplayName}"
                                                    IsColumnFiltered="True"
                                                    Width="200" />
                        <control:DataGridTextColumn Header="Windows name"
                                                    Binding="{Binding ServiceName}"
                                                    IsColumnFiltered="True"
                                                    Width="210" 
                                                    Visibility="Collapsed"/>
                        <control:DataGridTextColumn Header="Status"
                                                    Binding="{Binding Status}"
                                                    IsColumnFiltered="True"
                                                    Width="130" />
                        <control:DataGridTextColumn Header="Health"
                                                    Binding="{Binding Health}"
                                                    IsColumnFiltered="True"
                                                    Width="130" />
                        <control:DataGridTextColumn Header="Health URL"
                                                    Binding="{Binding HealthUrl}"
                                                    IsColumnFiltered="True"
                                                    Width="*" />
                        <control:DataGridTextColumn Header="Checked"
                                                    Binding="{Binding LastChecked, StringFormat={}{0:HH:mm:ss}}"
                                                    IsColumnFiltered="True"
                                                    Width="100" />
                        <control:DataGridTemplateColumn Header="Actions" Width="280">
                            
                            <control:DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <ui:Button Content="Start"
                                                Tag="{Binding}"
                                                MinWidth="62" Margin="0,2,6,2"
                                                Click="OnStartServiceClick" />
                                        <ui:Button Content="Stop"
                                                Tag="{Binding}"
                                                MinWidth="62" Margin="0,2,6,2"
                                                Click="OnStopServiceClick" />
                                        <ui:Button Content="Restart"
                                                Tag="{Binding}"
                                                MinWidth="62" Margin="0,2,6,2"
                                                Click="OnRestartServiceClick" />
                                        <ui:Button Content="Probe"
                                                Tag="{Binding}"
                                                MinWidth="62" Margin="0,2,6,2"
                                                Click="OnProbeServiceClick" />
                                    </StackPanel>
                                </DataTemplate>
                            </control:DataGridTemplateColumn.CellTemplate>
                            
                        </control:DataGridTemplateColumn>
                        
                    </control:FilterDataGrid.Columns>
                </control:FilterDataGrid>

                        <Grid Grid.Row="1" Margin="0,12,0,0">

                            <ui:Button
                                Content="Open services"
                                HorizontalAlignment="Left"
                                MinWidth="110"
                                Click="OnOpenServicesConsoleClick" />

                            <ui:Button
                                Content="Refresh all"
                                HorizontalAlignment="Right"
                                MinWidth="110"
                                Click="OnRefreshAllClick" />

                        </Grid>
                    </Grid>

                </views:MaintenanceCard>
                    
                <views:MaintenanceSection Grid.Row="3"
                          Header="Diagnostics"
                          Margin="0,8,0,0">
                    <ui:TextBox Text="{Binding DiagnosticsText}"
                             IsReadOnly="True"
                             TextChanged="OnAutoScrollLogTextChanged"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             FontFamily="Consolas"
                             BorderThickness="0"
                             Padding="8" />
                </views:MaintenanceSection>
            </Grid>
        </TabItem>

        <TabItem>
            <TabItem.Header>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:SymbolIcon Symbol="DocumentText24" Width="20" Height="20" Margin="0,0,8,0" />
                    <TextBlock Text="Deploy" />
                </StackPanel>
            </TabItem.Header>
            <views:DeployPage HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch" />
        </TabItem>
    </TabControl>
</views:MaintenancePageControl>




