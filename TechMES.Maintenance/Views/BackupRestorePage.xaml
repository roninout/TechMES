<views:MaintenancePageControl x:Class="TechMES.Maintenance.Views.BackupRestorePage"
                              xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                              xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                              xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                              xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                              xmlns:control="http://filterdatagrid.control.com/2021"
                              xmlns:views="clr-namespace:TechMES.Maintenance.Views"
                              mc:Ignorable="d">
    <TabControl HorizontalContentAlignment="Stretch"
                VerticalContentAlignment="Stretch">
        <TabItem>
            <TabItem.Header>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:SymbolIcon Symbol="ArchiveArrowBack24" Width="20" Height="20" Margin="0,0,8,0" />
                    <TextBlock Text="Backup / Restore" />
                </StackPanel>
            </TabItem.Header>
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <views:MaintenanceCard Grid.Row="0"
                                Background="{DynamicResource TechMesPanelBrush}"
                                BorderBrush="{DynamicResource TechMesBorderBrush}"
                                BorderThickness="1"
                                Padding="12"
                                Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="8" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.ColumnSpan="2">
                                    <TextBlock Text="Backup / Restore"
                                               Style="{StaticResource SectionTitleText}" />
                                    <TextBlock Text="Backup сохраняет maintenance.settings.json, исходные Runtime/Web appsettings, published appsettings и HTTPS-сертификаты. Restore перед перезаписью делает .restore-backup копию текущего файла."
                                               Style="{StaticResource MutedText}"
                                               TextWrapping="Wrap" />
                                </StackPanel>

                                <StackPanel Grid.Row="2"
                                            Grid.Column="0"
                                            Margin="0,0,12,0">
                                    <TextBlock Text="Backup root"
                                               Style="{StaticResource MutedText}" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <ui:TextBox Text="{Binding BackupRoot, UpdateSourceTrigger=PropertyChanged}"
                                                 LostFocus="OnBackupRootLostFocus" />
                                        <ui:Button Grid.Column="2"
                                                Content="Browse..."
                                                MinWidth="96"
                                                Click="OnBrowseBackupRootClick" />
                                    </Grid>
                                </StackPanel>

                                <StackPanel Grid.Row="2"
                                            Grid.Column="1"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Bottom">
                                    <ui:Button Content="Create backup"
                                            Click="OnCreateBackupClick" />
                                </StackPanel>
                            </Grid>
                        </views:MaintenanceCard>

                        <control:FilterDataGrid Grid.Row="1"
                                                ItemsSource="{Binding BackupItems}"
                                                SelectedItem="{Binding SelectedBackup, Mode=TwoWay}"
                                                AutoGenerateColumns="False"
                                                IsReadOnly="True"
                                                CanUserAddRows="False"
                                                HeadersVisibility="Column"
                                                GridLinesVisibility="Horizontal"
                                                Background="{DynamicResource TechMesPanelBrush}"
                                                ShowStatusBar="False"
                                                ShowElapsedTime="False"
                                                DateFormatString="dd.MM.yyyy"
                                                FilterLanguage="Russian">
                            <control:FilterDataGrid.Columns>
                                <control:DataGridTextColumn Header="Backup"
                                                            Binding="{Binding DisplayName}"
                                                            IsColumnFiltered="True"
                                                            Width="160" />
                                <control:DataGridTextColumn Header="Created"
                                                            Binding="{Binding CreatedAt, StringFormat={}{0:dd.MM.yyyy HH:mm:ss}}"
                                                            IsColumnFiltered="True"
                                                            Width="160" />
                                <control:DataGridTextColumn Header="Files"
                                                            Binding="{Binding FileCount}"
                                                            IsColumnFiltered="True"
                                                            Width="80" />
                                <control:DataGridTextColumn Header="Size"
                                                            Binding="{Binding SizeText}"
                                                            IsColumnFiltered="True"
                                                            Width="90" />
                                <control:DataGridTextColumn Header="Summary"
                                                            Binding="{Binding Summary}"
                                                            IsColumnFiltered="True"
                                                            Width="*" />
                                <control:DataGridTextColumn Header="Folder"
                                                            Binding="{Binding FullPath}"
                                                            IsColumnFiltered="True"
                                                            Width="320" />
                            </control:FilterDataGrid.Columns>
                        </control:FilterDataGrid>

                        <Grid Grid.Row="2"
                              Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <views:MaintenanceCard Grid.Column="0"
                                    Background="{DynamicResource TechMesPanelBrush}"
                                    BorderBrush="{DynamicResource TechMesBorderBrush}"
                                    BorderThickness="1"
                                    Padding="10"
                                    Margin="0,0,12,0">
                                <TextBlock Text="{Binding BackupStatusText}"
                                           TextWrapping="Wrap" />
                            </views:MaintenanceCard>

                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center">
                                <ui:Button Content="Refresh backups"
                                        Click="OnRefreshBackupsClick" />
                                <ui:Button Content="Restore selected"
                                        Click="OnRestoreBackupClick" />
                                <ui:Button Content="Export ZIP"
                                        Click="OnExportBackupZipClick" />
                                <ui:Button Content="Import ZIP"
                                        Click="OnImportBackupZipClick" />
                            </StackPanel>
                        </Grid>
                    </Grid>
        </TabItem>
    </TabControl>
                
</views:MaintenancePageControl>




