<views:MaintenancePageControl x:Class="TechMES.Maintenance.Views.BackupRestorePage"
                              xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                              xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                              xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                              xmlns:views="clr-namespace:TechMES.Maintenance.Views"
                              mc:Ignorable="d">
    <TabControl HorizontalContentAlignment="Stretch"
                VerticalContentAlignment="Stretch">
        <TabItem>
            <TabItem.Header>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE74E;" FontSize="18" Margin="0,0,8,0" />
                    <TextBlock Text="Backup / Restore" />
                </StackPanel>
            </TabItem.Header>
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="{StaticResource TechMesPanelBrush}"
                                BorderBrush="{StaticResource TechMesBorderBrush}"
                                BorderThickness="1"
                                Padding="12"
                                Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="8" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.ColumnSpan="2">
                                    <TextBlock Text="Backup / Restore"
                                               Style="{StaticResource SectionTitleText}" />
                                    <TextBlock Text="Backup сохраняет maintenance.settings.json, исходные Runtime/Web appsettings, published appsettings и HTTPS-сертификаты. Restore перед перезаписью делает .restore-backup копию текущего файла."
                                               Style="{StaticResource MutedText}"
                                               TextWrapping="Wrap" />
                                </StackPanel>

                                <StackPanel Grid.Row="2"
                                            Grid.Column="0"
                                            Margin="0,0,12,0">
                                    <TextBlock Text="Backup root"
                                               Style="{StaticResource MutedText}" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Text="{Binding BackupRoot, UpdateSourceTrigger=PropertyChanged}"
                                                 LostFocus="OnBackupRootLostFocus" />
                                        <Button Grid.Column="2"
                                                Content="Browse..."
                                                MinWidth="96"
                                                Click="OnBrowseBackupRootClick" />
                                    </Grid>
                                </StackPanel>

                                <StackPanel Grid.Row="2"
                                            Grid.Column="1"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Bottom">
                                    <Button Content="Create backup"
                                            Click="OnCreateBackupClick" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding BackupItems}"
                                  SelectedItem="{Binding SelectedBackup, Mode=TwoWay}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  Background="{StaticResource TechMesPanelBrush}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Backup"
                                                    Binding="{Binding DisplayName}"
                                                    Width="160" />
                                <DataGridTextColumn Header="Created"
                                                    Binding="{Binding CreatedAt, StringFormat={}{0:dd.MM.yyyy HH:mm:ss}}"
                                                    Width="160" />
                                <DataGridTextColumn Header="Files"
                                                    Binding="{Binding FileCount}"
                                                    Width="80" />
                                <DataGridTextColumn Header="Size"
                                                    Binding="{Binding SizeText}"
                                                    Width="90" />
                                <DataGridTextColumn Header="Summary"
                                                    Binding="{Binding Summary}"
                                                    Width="*" />
                                <DataGridTextColumn Header="Folder"
                                                    Binding="{Binding FullPath}"
                                                    Width="320" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <Grid Grid.Row="2"
                              Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Background="{StaticResource TechMesPanelBrush}"
                                    BorderBrush="{StaticResource TechMesBorderBrush}"
                                    BorderThickness="1"
                                    Padding="10"
                                    Margin="0,0,12,0">
                                <TextBlock Text="{Binding BackupStatusText}"
                                           TextWrapping="Wrap" />
                            </Border>

                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center">
                                <Button Content="Refresh backups"
                                        Click="OnRefreshBackupsClick" />
                                <Button Content="Restore selected"
                                        Click="OnRestoreBackupClick" />
                                <Button Content="Export ZIP"
                                        Click="OnExportBackupZipClick" />
                                <Button Content="Import ZIP"
                                        Click="OnImportBackupZipClick" />
                            </StackPanel>
                        </Grid>
                    </Grid>
        </TabItem>
    </TabControl>
                
</views:MaintenancePageControl>
