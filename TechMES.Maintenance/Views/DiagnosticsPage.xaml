<views:MaintenancePageControl x:Class="TechMES.Maintenance.Views.DiagnosticsPage"
                              xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                              xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                              xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                              xmlns:views="clr-namespace:TechMES.Maintenance.Views"
                              mc:Ignorable="d">
    <views:MaintenancePageControl.Resources>
        <Style x:Key="DiagnosticsStatusRowStyle" TargetType="DataGridRow">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="Warning">
                    <Setter Property="Background" Value="#FFF3CD" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Error">
                    <Setter Property="Background" Value="#F8D7DA" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </views:MaintenancePageControl.Resources>

    <TabControl HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                HorizontalContentAlignment="Stretch"
                VerticalContentAlignment="Stretch">
        <TabItem>
            <TabItem.Header>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE9D9;" FontSize="18" Margin="0,0,8,0" />
                    <TextBlock Text="Checks" />
                </StackPanel>
            </TabItem.Header>
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="{StaticResource TechMesPanelBrush}"
                                BorderBrush="{StaticResource TechMesBorderBrush}"
                                BorderThickness="1"
                                Padding="12"
                                Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Preflight checks"
                                               Style="{StaticResource SectionTitleText}" />
                                    <TextBlock Text="Проверяет HTTP health, PostgreSQL TCP, CtApi-настройки, папки публикации, appsettings, сертификаты и log-директории. Проверки ничего не меняют в системе."
                                               Style="{StaticResource MutedText}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding DependencyCheckStatusText}"
                                               Margin="0,8,0,0"
                                               FontWeight="SemiBold" />
                                </StackPanel>

                                <Button Grid.Column="1"
                                        Content="Run checks"
                                        VerticalAlignment="Center"
                                        Click="OnRunDependencyChecksClick" />
                            </Grid>
                        </Border>

                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding DependencyChecks}"
                                  RowStyle="{StaticResource DiagnosticsStatusRowStyle}"
                                  Loaded="OnAutoScrollDataGridLoaded"
                                  Unloaded="OnAutoScrollDataGridUnloaded"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  Background="{StaticResource TechMesPanelBrush}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Category"
                                                    Binding="{Binding Category}"
                                                    Width="130" />
                                <DataGridTextColumn Header="Name"
                                                    Binding="{Binding Name}"
                                                    Width="220" />
                                <DataGridTextColumn Header="Status"
                                                    Binding="{Binding Status}"
                                                    Width="110" />
                                <DataGridTextColumn Header="Details"
                                                    Binding="{Binding Details}"
                                                    Width="*" />
                                <DataGridTextColumn Header="Checked"
                                                    Binding="{Binding CheckedAt, StringFormat={}{0:HH:mm:ss}}"
                                                    Width="100" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
        </TabItem>
        <TabItem>
            <TabItem.Header>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE946;" FontSize="18" Margin="0,0,8,0" />
                    <TextBlock Text="Server profile" />
                </StackPanel>
            </TabItem.Header>
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="{StaticResource TechMesPanelBrush}"
                                BorderBrush="{StaticResource TechMesBorderBrush}"
                                BorderThickness="1"
                                Padding="12"
                                Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Server profile"
                                               Style="{StaticResource SectionTitleText}" />

                                    <StackPanel Orientation="Horizontal"
                                                Margin="0,0,0,6">
                                        <TextBlock Text="Readiness: "
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding ServerProfileReadinessStatus}"
                                                   FontWeight="Bold" />
                                        <TextBlock Text="   "
                                                   Style="{StaticResource MutedText}" />
                                        <TextBlock Text="{Binding ServerProfileLastUpdated}"
                                                   Style="{StaticResource MutedText}" />
                                    </StackPanel>

                                    <TextBlock Text="{Binding ServerProfileReadinessDetails}"
                                               TextWrapping="Wrap"
                                               Style="{StaticResource MutedText}" />
                                </StackPanel>

                                <Button Grid.Column="1"
                                        Content="Refresh profile"
                                        VerticalAlignment="Center"
                                        Click="OnRefreshServerProfileClick" />
                            </Grid>
                        </Border>

                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding ServerProfileItems}"
                                  RowStyle="{StaticResource DiagnosticsStatusRowStyle}"
                                  Loaded="OnAutoScrollDataGridLoaded"
                                  Unloaded="OnAutoScrollDataGridUnloaded"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  Background="{StaticResource TechMesPanelBrush}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Section"
                                                    Binding="{Binding Section}"
                                                    Width="130" />
                                <DataGridTextColumn Header="Name"
                                                    Binding="{Binding Name}"
                                                    Width="210" />
                                <DataGridTextColumn Header="Value"
                                                    Binding="{Binding Value}"
                                                    Width="260" />
                                <DataGridTextColumn Header="Status"
                                                    Binding="{Binding Status}"
                                                    Width="110" />
                                <DataGridTextColumn Header="Details"
                                                    Binding="{Binding Details}"
                                                    Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
        </TabItem>
        <TabItem>
            <TabItem.Header>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE72E;" FontSize="18" Margin="0,0,8,0" />
                    <TextBlock Text="Windows auth" />
                </StackPanel>
            </TabItem.Header>
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="{StaticResource TechMesPanelBrush}"
                                BorderBrush="{StaticResource TechMesBorderBrush}"
                                BorderThickness="1"
                                Padding="12"
                                Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Windows auth diagnostics"
                                               Style="{StaticResource SectionTitleText}" />
                                    <TextBlock Text="Показывает текущего Windows-пользователя Maintenance, его группы, состояние WEB Windows Authentication и результат проверки Runtime allow-list."
                                               Style="{StaticResource MutedText}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding WindowsAuthDiagnosticsStatusText}"
                                               Margin="0,8,0,0"
                                               FontWeight="SemiBold" />
                                </StackPanel>

                                <Button Grid.Column="1"
                                        Content="Refresh auth"
                                        VerticalAlignment="Center"
                                        Click="OnRefreshWindowsAuthDiagnosticsClick" />
                            </Grid>
                        </Border>

                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding WindowsAuthDiagnostics}"
                                  RowStyle="{StaticResource DiagnosticsStatusRowStyle}"
                                  Loaded="OnAutoScrollDataGridLoaded"
                                  Unloaded="OnAutoScrollDataGridUnloaded"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  Background="{StaticResource TechMesPanelBrush}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Category"
                                                    Binding="{Binding Category}"
                                                    Width="130" />
                                <DataGridTextColumn Header="Name"
                                                    Binding="{Binding Name}"
                                                    Width="220" />
                                <DataGridTextColumn Header="Status"
                                                    Binding="{Binding Status}"
                                                    Width="110" />
                                <DataGridTextColumn Header="Details"
                                                    Binding="{Binding Details}"
                                                    Width="*" />
                                <DataGridTextColumn Header="Checked"
                                                    Binding="{Binding CheckedAt, StringFormat={}{0:HH:mm:ss}}"
                                                    Width="100" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
        </TabItem>
        <TabItem>
            <TabItem.Header>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE7C3;" FontSize="18" Margin="0,0,8,0" />
                    <TextBlock Text="Operator actions" />
                </StackPanel>
            </TabItem.Header>
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="{StaticResource TechMesPanelBrush}"
                                BorderBrush="{StaticResource TechMesBorderBrush}"
                                BorderThickness="1"
                                Padding="12"
                                Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Operator actions readiness"
                                               Style="{StaticResource SectionTitleText}" />
                                    <TextBlock Text="Проверяет связку Param write, CtApi write, SCADA audit SaveActionOperators, Event DB и страницу Operation actions."
                                               Style="{StaticResource MutedText}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding OperatorActionDiagnosticsStatusText}"
                                               Margin="0,8,0,0"
                                               FontWeight="SemiBold" />
                                </StackPanel>

                                <Button Grid.Column="1"
                                        Content="Refresh actions"
                                        VerticalAlignment="Center"
                                        Click="OnRefreshOperatorActionDiagnosticsClick" />
                            </Grid>
                        </Border>

                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding OperatorActionDiagnostics}"
                                  RowStyle="{StaticResource DiagnosticsStatusRowStyle}"
                                  Loaded="OnAutoScrollDataGridLoaded"
                                  Unloaded="OnAutoScrollDataGridUnloaded"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  Background="{StaticResource TechMesPanelBrush}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Category"
                                                    Binding="{Binding Category}"
                                                    Width="130" />
                                <DataGridTextColumn Header="Name"
                                                    Binding="{Binding Name}"
                                                    Width="220" />
                                <DataGridTextColumn Header="Status"
                                                    Binding="{Binding Status}"
                                                    Width="110" />
                                <DataGridTextColumn Header="Details"
                                                    Binding="{Binding Details}"
                                                    Width="*" />
                                <DataGridTextColumn Header="Checked"
                                                    Binding="{Binding CheckedAt, StringFormat={}{0:HH:mm:ss}}"
                                                    Width="100" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
        </TabItem>
    </TabControl>
                
</views:MaintenancePageControl>
