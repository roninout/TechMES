<views:MaintenancePageControl x:Class="TechMES.Maintenance.Views.DiagnosticsPage"
                              xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                              xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                              xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                              xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                              xmlns:control="http://filterdatagrid.control.com/2021"
                              xmlns:views="clr-namespace:TechMES.Maintenance.Views"
                              mc:Ignorable="d">
    <views:MaintenancePageControl.Resources>
        <Style x:Key="DiagnosticsStatusRowStyle" TargetType="DataGridRow">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="Warning">
                    <Setter Property="Background" Value="{DynamicResource TechMesWarningRowBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Error">
                    <Setter Property="Background" Value="{DynamicResource TechMesErrorRowBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </views:MaintenancePageControl.Resources>

    <TabControl HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                HorizontalContentAlignment="Stretch"
                VerticalContentAlignment="Stretch">
        <TabItem>
            <TabItem.Header>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:SymbolIcon Symbol="Pulse24" Width="20" Height="20" Margin="0,0,8,0" />
                    <TextBlock Text="Checks" />
                </StackPanel>
            </TabItem.Header>
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <views:MaintenanceCard Grid.Row="0"
                                Background="{DynamicResource TechMesPanelBrush}"
                                BorderBrush="{DynamicResource TechMesBorderBrush}"
                                BorderThickness="1"
                                Padding="12"
                                Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Preflight checks"
                                               Style="{StaticResource SectionTitleText}" />
                                    <TextBlock Text="Проверяет HTTP health, PostgreSQL TCP, CtApi-настройки, папки публикации, appsettings, сертификаты и log-директории. Проверки ничего не меняют в системе."
                                               Style="{StaticResource MutedText}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding DependencyCheckStatusText}"
                                               Margin="0,8,0,0"
                                               FontWeight="SemiBold" />
                                </StackPanel>

                                <ui:Button Grid.Column="1"
                                        Content="Run checks"
                                        VerticalAlignment="Center"
                                        Click="OnRunDependencyChecksClick" />
                            </Grid>
                        </views:MaintenanceCard>

                        <control:FilterDataGrid Grid.Row="1"
                                                ItemsSource="{Binding DependencyChecks}"
                                                RowStyle="{StaticResource DiagnosticsStatusRowStyle}"
                                                Loaded="OnAutoScrollDataGridLoaded"
                                                Unloaded="OnAutoScrollDataGridUnloaded"
                                                AutoGenerateColumns="False"
                                                IsReadOnly="True"
                                                CanUserAddRows="False"
                                                HeadersVisibility="Column"
                                                GridLinesVisibility="Horizontal"
                                                Background="{DynamicResource TechMesPanelBrush}"
                                                ShowStatusBar="False"
                                                ShowElapsedTime="False"
                                                DateFormatString="dd.MM.yyyy"
                                                FilterLanguage="Russian">
                            <control:FilterDataGrid.Columns>
                                <control:DataGridTextColumn Header="Category"
                                                            Binding="{Binding Category}"
                                                            IsColumnFiltered="True"
                                                            Width="130" />
                                <control:DataGridTextColumn Header="Name"
                                                            Binding="{Binding Name}"
                                                            IsColumnFiltered="True"
                                                            Width="220" />
                                <control:DataGridTextColumn Header="Status"
                                                            Binding="{Binding Status}"
                                                            IsColumnFiltered="True"
                                                            Width="110" />
                                <control:DataGridTextColumn Header="Details"
                                                            Binding="{Binding Details}"
                                                            IsColumnFiltered="True"
                                                            Width="*" />
                                <control:DataGridTextColumn Header="Checked"
                                                            Binding="{Binding CheckedAt, StringFormat={}{0:HH:mm:ss}}"
                                                            IsColumnFiltered="True"
                                                            Width="100" />
                            </control:FilterDataGrid.Columns>
                        </control:FilterDataGrid>
                    </Grid>
        </TabItem>
        <TabItem>
            <TabItem.Header>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:SymbolIcon Symbol="Info24" Width="20" Height="20" Margin="0,0,8,0" />
                    <TextBlock Text="Server profile" />
                </StackPanel>
            </TabItem.Header>
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <views:MaintenanceCard Grid.Row="0"
                                Background="{DynamicResource TechMesPanelBrush}"
                                BorderBrush="{DynamicResource TechMesBorderBrush}"
                                BorderThickness="1"
                                Padding="12"
                                Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Server profile"
                                               Style="{StaticResource SectionTitleText}" />

                                    <StackPanel Orientation="Horizontal"
                                                Margin="0,0,0,6">
                                        <TextBlock Text="Readiness: "
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding ServerProfileReadinessStatus}"
                                                   FontWeight="Bold" />
                                        <TextBlock Text="   "
                                                   Style="{StaticResource MutedText}" />
                                        <TextBlock Text="{Binding ServerProfileLastUpdated}"
                                                   Style="{StaticResource MutedText}" />
                                    </StackPanel>

                                    <TextBlock Text="{Binding ServerProfileReadinessDetails}"
                                               TextWrapping="Wrap"
                                               Style="{StaticResource MutedText}" />
                                </StackPanel>

                                <ui:Button Grid.Column="1"
                                        Content="Refresh profile"
                                        VerticalAlignment="Center"
                                        Click="OnRefreshServerProfileClick" />
                            </Grid>
                        </views:MaintenanceCard>

                        <control:FilterDataGrid Grid.Row="1"
                                                ItemsSource="{Binding ServerProfileItems}"
                                                RowStyle="{StaticResource DiagnosticsStatusRowStyle}"
                                                Loaded="OnAutoScrollDataGridLoaded"
                                                Unloaded="OnAutoScrollDataGridUnloaded"
                                                AutoGenerateColumns="False"
                                                IsReadOnly="True"
                                                CanUserAddRows="False"
                                                HeadersVisibility="Column"
                                                GridLinesVisibility="Horizontal"
                                                Background="{DynamicResource TechMesPanelBrush}"
                                                ShowStatusBar="False"
                                                ShowElapsedTime="False"
                                                DateFormatString="dd.MM.yyyy"
                                                FilterLanguage="Russian">
                            <control:FilterDataGrid.Columns>
                                <control:DataGridTextColumn Header="Section"
                                                            Binding="{Binding Section}"
                                                            IsColumnFiltered="True"
                                                            Width="130" />
                                <control:DataGridTextColumn Header="Name"
                                                            Binding="{Binding Name}"
                                                            IsColumnFiltered="True"
                                                            Width="210" />
                                <control:DataGridTextColumn Header="Value"
                                                            Binding="{Binding Value}"
                                                            IsColumnFiltered="True"
                                                            Width="260" />
                                <control:DataGridTextColumn Header="Status"
                                                            Binding="{Binding Status}"
                                                            IsColumnFiltered="True"
                                                            Width="110" />
                                <control:DataGridTextColumn Header="Details"
                                                            Binding="{Binding Details}"
                                                            IsColumnFiltered="True"
                                                            Width="*" />
                            </control:FilterDataGrid.Columns>
                        </control:FilterDataGrid>
                    </Grid>
        </TabItem>
        <TabItem>
            <TabItem.Header>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:SymbolIcon Symbol="ShieldCheckmark24" Width="20" Height="20" Margin="0,0,8,0" />
                    <TextBlock Text="Windows auth" />
                </StackPanel>
            </TabItem.Header>
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <views:MaintenanceCard Grid.Row="0"
                                Background="{DynamicResource TechMesPanelBrush}"
                                BorderBrush="{DynamicResource TechMesBorderBrush}"
                                BorderThickness="1"
                                Padding="12"
                                Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Windows auth diagnostics"
                                               Style="{StaticResource SectionTitleText}" />
                                    <TextBlock Text="Показывает текущего Windows-пользователя Maintenance, его группы, состояние WEB Windows Authentication и результат проверки Runtime allow-list."
                                               Style="{StaticResource MutedText}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding WindowsAuthDiagnosticsStatusText}"
                                               Margin="0,8,0,0"
                                               FontWeight="SemiBold" />
                                </StackPanel>

                                <ui:Button Grid.Column="1"
                                        Content="Refresh auth"
                                        VerticalAlignment="Center"
                                        Click="OnRefreshWindowsAuthDiagnosticsClick" />
                            </Grid>
                        </views:MaintenanceCard>

                        <control:FilterDataGrid Grid.Row="1"
                                                ItemsSource="{Binding WindowsAuthDiagnostics}"
                                                RowStyle="{StaticResource DiagnosticsStatusRowStyle}"
                                                Loaded="OnAutoScrollDataGridLoaded"
                                                Unloaded="OnAutoScrollDataGridUnloaded"
                                                AutoGenerateColumns="False"
                                                IsReadOnly="True"
                                                CanUserAddRows="False"
                                                HeadersVisibility="Column"
                                                GridLinesVisibility="Horizontal"
                                                Background="{DynamicResource TechMesPanelBrush}"
                                                ShowStatusBar="False"
                                                ShowElapsedTime="False"
                                                DateFormatString="dd.MM.yyyy"
                                                FilterLanguage="Russian">
                            <control:FilterDataGrid.Columns>
                                <control:DataGridTextColumn Header="Category"
                                                            Binding="{Binding Category}"
                                                            IsColumnFiltered="True"
                                                            Width="130" />
                                <control:DataGridTextColumn Header="Name"
                                                            Binding="{Binding Name}"
                                                            IsColumnFiltered="True"
                                                            Width="220" />
                                <control:DataGridTextColumn Header="Status"
                                                            Binding="{Binding Status}"
                                                            IsColumnFiltered="True"
                                                            Width="110" />
                                <control:DataGridTextColumn Header="Details"
                                                            Binding="{Binding Details}"
                                                            IsColumnFiltered="True"
                                                            Width="*" />
                                <control:DataGridTextColumn Header="Checked"
                                                            Binding="{Binding CheckedAt, StringFormat={}{0:HH:mm:ss}}"
                                                            IsColumnFiltered="True"
                                                            Width="100" />
                            </control:FilterDataGrid.Columns>
                        </control:FilterDataGrid>
                    </Grid>
        </TabItem>
        <TabItem>
            <TabItem.Header>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:SymbolIcon Symbol="WrenchScrewdriver24" Width="20" Height="20" Margin="0,0,8,0" />
                    <TextBlock Text="Operator actions" />
                </StackPanel>
            </TabItem.Header>
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <views:MaintenanceCard Grid.Row="0"
                                Background="{DynamicResource TechMesPanelBrush}"
                                BorderBrush="{DynamicResource TechMesBorderBrush}"
                                BorderThickness="1"
                                Padding="12"
                                Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Operator actions readiness"
                                               Style="{StaticResource SectionTitleText}" />
                                    <TextBlock Text="Проверяет связку Param write, CtApi write, SCADA audit SaveActionOperators, Event DB и страницу Operation actions."
                                               Style="{StaticResource MutedText}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding OperatorActionDiagnosticsStatusText}"
                                               Margin="0,8,0,0"
                                               FontWeight="SemiBold" />
                                </StackPanel>

                                <ui:Button Grid.Column="1"
                                        Content="Refresh actions"
                                        VerticalAlignment="Center"
                                        Click="OnRefreshOperatorActionDiagnosticsClick" />
                            </Grid>
                        </views:MaintenanceCard>

                        <control:FilterDataGrid Grid.Row="1"
                                                ItemsSource="{Binding OperatorActionDiagnostics}"
                                                RowStyle="{StaticResource DiagnosticsStatusRowStyle}"
                                                Loaded="OnAutoScrollDataGridLoaded"
                                                Unloaded="OnAutoScrollDataGridUnloaded"
                                                AutoGenerateColumns="False"
                                                IsReadOnly="True"
                                                CanUserAddRows="False"
                                                HeadersVisibility="Column"
                                                GridLinesVisibility="Horizontal"
                                                Background="{DynamicResource TechMesPanelBrush}"
                                                ShowStatusBar="False"
                                                ShowElapsedTime="False"
                                                DateFormatString="dd.MM.yyyy"
                                                FilterLanguage="Russian">
                            <control:FilterDataGrid.Columns>
                                <control:DataGridTextColumn Header="Category"
                                                            Binding="{Binding Category}"
                                                            IsColumnFiltered="True"
                                                            Width="130" />
                                <control:DataGridTextColumn Header="Name"
                                                            Binding="{Binding Name}"
                                                            IsColumnFiltered="True"
                                                            Width="220" />
                                <control:DataGridTextColumn Header="Status"
                                                            Binding="{Binding Status}"
                                                            IsColumnFiltered="True"
                                                            Width="110" />
                                <control:DataGridTextColumn Header="Details"
                                                            Binding="{Binding Details}"
                                                            IsColumnFiltered="True"
                                                            Width="*" />
                                <control:DataGridTextColumn Header="Checked"
                                                            Binding="{Binding CheckedAt, StringFormat={}{0:HH:mm:ss}}"
                                                            IsColumnFiltered="True"
                                                            Width="100" />
                            </control:FilterDataGrid.Columns>
                        </control:FilterDataGrid>
                    </Grid>
        </TabItem>
    </TabControl>
                
</views:MaintenancePageControl>




