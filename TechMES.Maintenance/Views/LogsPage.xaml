<views:MaintenancePageControl x:Class="TechMES.Maintenance.Views.LogsPage"
                              xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                              xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                              xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                              xmlns:views="clr-namespace:TechMES.Maintenance.Views"
                              mc:Ignorable="d">
    <TabControl HorizontalContentAlignment="Stretch"
                VerticalContentAlignment="Stretch">
        <TabItem>
            <TabItem.Header>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8A5;" FontSize="18" Margin="0,0,8,0" />
                    <TextBlock Text="Logs" />
                </StackPanel>
            </TabItem.Header>
                    <Grid Margin="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="360" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Background="{StaticResource TechMesPanelBrush}"
                                BorderBrush="{StaticResource TechMesBorderBrush}"
                                BorderThickness="1"
                                Padding="10">
                            <DockPanel>
                                <Button DockPanel.Dock="Top"
                                        Content="Refresh logs"
                                        Margin="0,0,0,8"
                                        Click="OnRefreshLogsClick" />
                                <ListBox ItemsSource="{Binding LogFiles}"
                                         SelectedItem="{Binding SelectedLogFile}"
                                         DisplayMemberPath="DisplayName"
                                         SelectionChanged="OnLogFileSelected" />
                            </DockPanel>
                        </Border>

                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0"
                                        Margin="0,0,0,8">
                                <TextBlock Text="{Binding SelectedLogFile.DisplayName}"
                                           FontSize="18"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="{Binding SelectedLogFile.FullPath}"
                                           Style="{StaticResource MutedText}" />
                            </StackPanel>

                            <TextBox Grid.Row="1"
                                     Text="{Binding SelectedLogText}"
                                     IsReadOnly="True"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     FontFamily="Consolas"
                                     FontSize="13"
                                     Padding="10"
                                     TextWrapping="NoWrap" />
                        </Grid>
                    </Grid>
                
        </TabItem>
        <TabItem>
            <TabItem.Header>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE74D;" FontSize="18" Margin="0,0,8,0" />
                    <TextBlock Text="CleanUp" />
                </StackPanel>
            </TabItem.Header>
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="120" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="{StaticResource TechMesPanelBrush}"
                                BorderBrush="{StaticResource TechMesBorderBrush}"
                                BorderThickness="1"
                                Padding="12"
                                Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="8" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.ColumnSpan="2">
                                    <TextBlock Text="Service actions"
                                               Style="{StaticResource SectionTitleText}" />
                                    <TextBlock Text="Сканирует свободное место и безопасные кандидаты на ручную очистку: старые .log, side-backup appsettings и старые backup-папки. Автоматического удаления нет."
                                               Style="{StaticResource MutedText}"
                                               TextWrapping="Wrap" />
                                </StackPanel>

                                <Grid Grid.Row="2"
                                      Grid.Column="0"
                                      Margin="0,0,12,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="8" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="Log days"
                                               Style="{StaticResource MutedText}" />
                                    <TextBlock Grid.Column="1"
                                               Text="Appsettings days"
                                               Style="{StaticResource MutedText}" />
                                    <TextBlock Grid.Column="2"
                                               Text="Backup days"
                                               Style="{StaticResource MutedText}" />
                                    <TextBlock Grid.Column="3"
                                               Text="Target machine"
                                               Style="{StaticResource MutedText}" />

                                    <TextBox Grid.Row="2"
                                             Text="{Binding CleanupLogRetentionDays, UpdateSourceTrigger=LostFocus}"
                                             Margin="0,0,8,0" />
                                    <TextBox Grid.Row="2"
                                             Grid.Column="1"
                                             Text="{Binding CleanupAppSettingsBackupRetentionDays, UpdateSourceTrigger=LostFocus}"
                                             Margin="0,0,8,0" />
                                    <TextBox Grid.Row="2"
                                             Grid.Column="2"
                                             Text="{Binding CleanupBackupRetentionDays, UpdateSourceTrigger=LostFocus}"
                                             Margin="0,0,8,0" />
                                    <TextBox Grid.Row="2"
                                             Grid.Column="3"
                                             Text="{Binding TargetMachineDisplayName, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>

                                <StackPanel Grid.Row="2"
                                            Grid.Column="1"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Bottom">
                                    <Button Content="Save profile"
                                            Click="OnSaveMaintenanceProfileClick" />
                                    <Button Content="Scan cleanup"
                                            Click="OnScanCleanupClick" />
                                    <Button Content="Delete candidates"
                                            Click="OnDeleteCleanupCandidatesClick" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding DiskStatuses}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  Background="{StaticResource TechMesPanelBrush}"
                                  Margin="0,0,0,10">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Name"
                                                    Binding="{Binding Name}"
                                                    Width="140" />
                                <DataGridTextColumn Header="Drive"
                                                    Binding="{Binding Drive}"
                                                    Width="90" />
                                <DataGridTextColumn Header="Free"
                                                    Binding="{Binding FreeText}"
                                                    Width="120" />
                                <DataGridTextColumn Header="Total"
                                                    Binding="{Binding TotalText}"
                                                    Width="120" />
                                <DataGridTextColumn Header="Status"
                                                    Binding="{Binding Status}"
                                                    Width="120" />
                                <DataGridTextColumn Header="Path"
                                                    Binding="{Binding Path}"
                                                    Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <DataGrid Grid.Row="2"
                                  ItemsSource="{Binding CleanupItems}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  Background="{StaticResource TechMesPanelBrush}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Kind"
                                                    Binding="{Binding Kind}"
                                                    Width="150" />
                                <DataGridTextColumn Header="Name"
                                                    Binding="{Binding Name}"
                                                    Width="220" />
                                <DataGridTextColumn Header="Last write"
                                                    Binding="{Binding LastWriteTime, StringFormat={}{0:dd.MM.yyyy HH:mm:ss}}"
                                                    Width="160" />
                                <DataGridTextColumn Header="Size"
                                                    Binding="{Binding SizeText}"
                                                    Width="100" />
                                <DataGridTextColumn Header="Path"
                                                    Binding="{Binding FullPath}"
                                                    Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <Border Grid.Row="3"
                                Background="{StaticResource TechMesPanelBrush}"
                                BorderBrush="{StaticResource TechMesBorderBrush}"
                                BorderThickness="1"
                                Padding="10"
                                Margin="0,10,0,0">
                            <TextBlock Text="{Binding CleanupStatusText}"
                                       TextWrapping="Wrap" />
                        </Border>
                    </Grid>
                
        </TabItem>
    </TabControl>
</views:MaintenancePageControl>
