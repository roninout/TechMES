<views:MaintenancePageControl x:Class="TechMES.Maintenance.Views.LogsPage"
                              xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                              xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                              xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                              xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                              xmlns:control="http://filterdatagrid.control.com/2021"
                              xmlns:views="clr-namespace:TechMES.Maintenance.Views"
                              mc:Ignorable="d">
    <TabControl HorizontalContentAlignment="Stretch"
                VerticalContentAlignment="Stretch">
        <TabItem>
            <TabItem.Header>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:SymbolIcon Symbol="DocumentText24" Width="20" Height="20" Margin="0,0,8,0" />
                    <TextBlock Text="Logs" />
                </StackPanel>
            </TabItem.Header>
                    <Grid Margin="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="360" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <views:MaintenanceCard Grid.Column="0"
                                Background="{DynamicResource TechMesPanelBrush}"
                                BorderBrush="{DynamicResource TechMesBorderBrush}"
                                BorderThickness="1"
                                Padding="10">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Top"
                                            Margin="0,0,0,8">
                                    <TextBlock Text="Log date"
                                               Style="{StaticResource MutedText}" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="42" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="82" />
                                            <ColumnDefinition Width="42" />
                                        </Grid.ColumnDefinitions>
                                        <ui:Button Icon="{ui:SymbolIcon Symbol=ChevronLeft24}"
                                                ToolTip="Previous day"
                                                Click="OnPreviousLogDateClick" />
                                        <ui:CalendarDatePicker Grid.Column="1"
                                                               Date="{Binding LogSelectedDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                               Height="32"
                                                               FontSize="14"
                                                               Margin="6,0" />
                                        <ui:Button Grid.Column="2"
                                                Content="Today"
                                                Click="OnTodayLogDateClick" />
                                        <ui:Button Grid.Column="3"
                                                Icon="{ui:SymbolIcon Symbol=ChevronRight24}"
                                                ToolTip="Next day"
                                                Click="OnNextLogDateClick" />
                                    </Grid>
                                </StackPanel>
                                <ui:Button DockPanel.Dock="Top"
                                        Content="Refresh logs"
                                        Margin="0,0,0,8"
                                        Click="OnRefreshLogsClick" />
                                <ListBox ItemsSource="{Binding LogFiles}"
                                         SelectedItem="{Binding SelectedLogFile}"
                                         DisplayMemberPath="DisplayName"
                                         SelectionChanged="OnLogFileSelected" />
                            </DockPanel>
                        </views:MaintenanceCard>

                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0"
                                        Margin="0,0,0,8">
                                <TextBlock Text="{Binding SelectedLogFile.DisplayName}"
                                           FontSize="18"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="{Binding SelectedLogFile.FullPath}"
                                           Style="{StaticResource MutedText}" />
                            </StackPanel>

                            <ui:TextBox Grid.Row="1"
                                     Text="{Binding SelectedLogText}"
                                     IsReadOnly="True"
                                     TextChanged="OnAutoScrollLogTextChanged"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     FontFamily="Consolas"
                                     FontSize="13"
                                     Padding="10"
                                     TextWrapping="NoWrap" />
                        </Grid>
                    </Grid>
                
        </TabItem>
        <TabItem>
            <TabItem.Header>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:SymbolIcon Symbol="Delete24" Width="20" Height="20" Margin="0,0,8,0" />
                    <TextBlock Text="CleanUp" />
                </StackPanel>
            </TabItem.Header>
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="120" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <views:MaintenanceCard Grid.Row="0"
                                Background="{DynamicResource TechMesPanelBrush}"
                                BorderBrush="{DynamicResource TechMesBorderBrush}"
                                BorderThickness="1"
                                Padding="12"
                                Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="8" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.ColumnSpan="2">
                                    <TextBlock Text="Service actions"
                                               Style="{StaticResource SectionTitleText}" />
                                    <TextBlock Text="Сканирует свободное место и безопасные кандидаты на ручную очистку: старые .log, side-backup appsettings и старые backup-папки. Автоматического удаления нет."
                                               Style="{StaticResource MutedText}"
                                               TextWrapping="Wrap" />
                                </StackPanel>

                                <Grid Grid.Row="2"
                                      Grid.Column="0"
                                      Margin="0,0,12,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="8" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="Log days"
                                               Style="{StaticResource MutedText}" />
                                    <TextBlock Grid.Column="1"
                                               Text="Appsettings days"
                                               Style="{StaticResource MutedText}" />
                                    <TextBlock Grid.Column="2"
                                               Text="Backup days"
                                               Style="{StaticResource MutedText}" />
                                    <TextBlock Grid.Column="3"
                                               Text="Target machine"
                                               Style="{StaticResource MutedText}" />

                                    <ui:TextBox Grid.Row="2"
                                             Text="{Binding CleanupLogRetentionDays, UpdateSourceTrigger=LostFocus}"
                                             Margin="0,0,8,0" />
                                    <ui:TextBox Grid.Row="2"
                                             Grid.Column="1"
                                             Text="{Binding CleanupAppSettingsBackupRetentionDays, UpdateSourceTrigger=LostFocus}"
                                             Margin="0,0,8,0" />
                                    <ui:TextBox Grid.Row="2"
                                             Grid.Column="2"
                                             Text="{Binding CleanupBackupRetentionDays, UpdateSourceTrigger=LostFocus}"
                                             Margin="0,0,8,0" />
                                    <ui:TextBox Grid.Row="2"
                                             Grid.Column="3"
                                             Text="{Binding TargetMachineDisplayName, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>

                                <StackPanel Grid.Row="2"
                                            Grid.Column="1"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Bottom">
                                    <ui:Button Content="Save profile"
                                            Click="OnSaveMaintenanceProfileClick" />
                                    <ui:Button Content="Scan cleanup"
                                            Click="OnScanCleanupClick" />
                                    <ui:Button Content="Delete candidates"
                                            Click="OnDeleteCleanupCandidatesClick" />
                                </StackPanel>
                            </Grid>
                        </views:MaintenanceCard>

                        <control:FilterDataGrid Grid.Row="1"
                                                ItemsSource="{Binding DiskStatuses}"
                                                AutoGenerateColumns="False"
                                                IsReadOnly="True"
                                                CanUserAddRows="False"
                                                HeadersVisibility="Column"
                                                GridLinesVisibility="Horizontal"
                                                Background="{DynamicResource TechMesPanelBrush}"
                                                ShowStatusBar="False"
                                                ShowElapsedTime="False"
                                                DateFormatString="dd.MM.yyyy"
                                                FilterLanguage="Russian"
                                                Margin="0,0,0,10">
                            <control:FilterDataGrid.Columns>
                                <control:DataGridTextColumn Header="Name"
                                                            Binding="{Binding Name}"
                                                            IsColumnFiltered="True"
                                                            Width="140" />
                                <control:DataGridTextColumn Header="Drive"
                                                            Binding="{Binding Drive}"
                                                            IsColumnFiltered="True"
                                                            Width="90" />
                                <control:DataGridTextColumn Header="Free"
                                                            Binding="{Binding FreeText}"
                                                            IsColumnFiltered="True"
                                                            Width="120" />
                                <control:DataGridTextColumn Header="Total"
                                                            Binding="{Binding TotalText}"
                                                            IsColumnFiltered="True"
                                                            Width="120" />
                                <control:DataGridTextColumn Header="Status"
                                                            Binding="{Binding Status}"
                                                            IsColumnFiltered="True"
                                                            Width="120" />
                                <control:DataGridTextColumn Header="Path"
                                                            Binding="{Binding Path}"
                                                            IsColumnFiltered="True"
                                                            Width="*" />
                            </control:FilterDataGrid.Columns>
                        </control:FilterDataGrid>

                        <control:FilterDataGrid Grid.Row="2"
                                                ItemsSource="{Binding CleanupItems}"
                                                AutoGenerateColumns="False"
                                                IsReadOnly="True"
                                                CanUserAddRows="False"
                                                HeadersVisibility="Column"
                                                GridLinesVisibility="Horizontal"
                                                Background="{DynamicResource TechMesPanelBrush}"
                                                ShowStatusBar="False"
                                                ShowElapsedTime="False"
                                                DateFormatString="dd.MM.yyyy"
                                                FilterLanguage="Russian">
                            <control:FilterDataGrid.Columns>
                                <control:DataGridTextColumn Header="Kind"
                                                            Binding="{Binding Kind}"
                                                            IsColumnFiltered="True"
                                                            Width="150" />
                                <control:DataGridTextColumn Header="Name"
                                                            Binding="{Binding Name}"
                                                            IsColumnFiltered="True"
                                                            Width="220" />
                                <control:DataGridTextColumn Header="Last write"
                                                            Binding="{Binding LastWriteTime, StringFormat={}{0:dd.MM.yyyy HH:mm:ss}}"
                                                            IsColumnFiltered="True"
                                                            Width="160" />
                                <control:DataGridTextColumn Header="Size"
                                                            Binding="{Binding SizeText}"
                                                            IsColumnFiltered="True"
                                                            Width="100" />
                                <control:DataGridTextColumn Header="Path"
                                                            Binding="{Binding FullPath}"
                                                            IsColumnFiltered="True"
                                                            Width="*" />
                            </control:FilterDataGrid.Columns>
                        </control:FilterDataGrid>

                        <views:MaintenanceCard Grid.Row="3"
                                Background="{DynamicResource TechMesPanelBrush}"
                                BorderBrush="{DynamicResource TechMesBorderBrush}"
                                BorderThickness="1"
                                Padding="10"
                                Margin="0,10,0,0">
                            <TextBlock Text="{Binding CleanupStatusText}"
                                       TextWrapping="Wrap" />
                        </views:MaintenanceCard>
                    </Grid>
                
        </TabItem>
    </TabControl>
</views:MaintenancePageControl>




