<views:MaintenancePageControl x:Class="TechMES.Maintenance.Views.SettingsPage"
                              xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                              xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                              xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                              xmlns:views="clr-namespace:TechMES.Maintenance.Views"
                              mc:Ignorable="d">
    <views:MaintenancePageControl.Resources>
        <Style x:Key="SettingsFieldLabel" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,14,0" />
        </Style>
        <Style x:Key="SettingsTextBox" TargetType="TextBox">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="6,3" />
        </Style>
        <Style x:Key="SettingsHintText" TargetType="TextBlock" BasedOn="{StaticResource MutedText}">
            <Setter Property="Margin" Value="0,3,0,0" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>
        <Style TargetType="ScrollViewer">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
        </Style>
    </views:MaintenancePageControl.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    HorizontalContentAlignment="Stretch"
                    VerticalContentAlignment="Stretch">
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE968;" FontSize="18" Margin="0,0,8,0" />
                        <TextBlock Text="Server" />
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="12">
                        <GroupBox Header="Repository" Margin="0,0,0,12">
                            <StackPanel Margin="12">
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="240" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Repository path" Style="{StaticResource SettingsFieldLabel}" />
                                    <StackPanel Grid.Column="1">
                                        <TextBox Text="{Binding RepositoryRootPath, Mode=OneWay}" IsReadOnly="True" Style="{StaticResource SettingsTextBox}" />
                                        <TextBlock Text="Корень рабочей папки, из которой Maintenance берет проекты, appsettings, логи и backup-операции." Style="{StaticResource SettingsHintText}" />
                                    </StackPanel>
                                </Grid>
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="240" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Settings folder" Style="{StaticResource SettingsFieldLabel}" />
                                    <StackPanel Grid.Column="1">
                                        <Button Content="Open settings folder"
                                                MinWidth="160"
                                                HorizontalAlignment="Left"
                                                Click="OnOpenMaintenanceFolderClick" />
                                        <TextBlock Text="Открывает папку TechMES.Maintenance с maintenance.settings.json и служебными файлами Maintenance." Style="{StaticResource SettingsHintText}" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Header="Deploy profile" Margin="0,0,0,12">
                            <StackPanel Margin="12">
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="240" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Publish root" Style="{StaticResource SettingsFieldLabel}" />
                                    <StackPanel Grid.Column="1">
                                        <TextBox Text="{Binding DeploymentPublishRoot, UpdateSourceTrigger=PropertyChanged}" Width="360" HorizontalAlignment="Left" Style="{StaticResource SettingsTextBox}" />
                                        <TextBlock Text="Папка, куда публикуются файлы Runtime Service и WEB." Style="{StaticResource SettingsHintText}" />
                                    </StackPanel>
                                </Grid>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="240" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Configuration" Style="{StaticResource SettingsFieldLabel}" />
                                    <StackPanel Grid.Column="1">
                                        <TextBox Text="{Binding DeploymentConfigurationName, UpdateSourceTrigger=PropertyChanged}" Width="360" HorizontalAlignment="Left" Style="{StaticResource SettingsTextBox}" />
                                        <TextBlock Text="Конфигурация сборки для dotnet publish, обычно Release." Style="{StaticResource SettingsHintText}" />
                                    </StackPanel>
                                </Grid>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="240" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Runtime identifier" Style="{StaticResource SettingsFieldLabel}" />
                                    <StackPanel Grid.Column="1">
                                        <TextBox Text="{Binding DeploymentRuntimeIdentifier, UpdateSourceTrigger=PropertyChanged}" Width="360" HorizontalAlignment="Left" Style="{StaticResource SettingsTextBox}" />
                                        <TextBlock Text="Целевая платформа публикации Windows Services, например win-x64." Style="{StaticResource SettingsHintText}" />
                                    </StackPanel>
                                </Grid>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="240" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Self contained" Style="{StaticResource SettingsFieldLabel}" />
                                    <StackPanel Grid.Column="1">
                                        <CheckBox Content="Enabled" IsChecked="{Binding DeploymentSelfContained}" VerticalAlignment="Center" />
                                        <TextBlock Text="Публикует .NET Runtime вместе с файлами сервисов." Style="{StaticResource SettingsHintText}" />
                                    </StackPanel>
                                </Grid>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="240" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Auto start services" Style="{StaticResource SettingsFieldLabel}" />
                                    <StackPanel Grid.Column="1">
                                        <CheckBox Content="Enabled" IsChecked="{Binding DeploymentAutoStart}" VerticalAlignment="Center" />
                                        <TextBlock Text="Автоматически запускает службы после установки или обновления." Style="{StaticResource SettingsHintText}" />
                                    </StackPanel>
                                </Grid>
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="240" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Deploy profile actions" Style="{StaticResource SettingsFieldLabel}" />
                                    <StackPanel Grid.Column="1">
                                        <Button Content="Save profile"
                                                Width="160"
                                                HorizontalAlignment="Left"
                                                Click="OnSaveDeploymentProfileClick" />
                                        <TextBlock Text="Сохраняет только параметры профиля публикации, которые используются во вкладке Deploy." Style="{StaticResource SettingsHintText}" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Header="Ports" Margin="0,0,0,12">
                            <StackPanel Margin="12">
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="240" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="WEB HTTP port" Style="{StaticResource SettingsFieldLabel}" />
                                    <StackPanel Grid.Column="1">
                                        <TextBox Text="{Binding ServerWebPort, UpdateSourceTrigger=LostFocus}" Width="200" HorizontalAlignment="Left" Style="{StaticResource SettingsTextBox}" />
                                        <TextBlock Text="Обычный HTTP-порт WEB-службы." Style="{StaticResource SettingsHintText}" />
                                    </StackPanel>
                                </Grid>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="240" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="WEB HTTPS port" Style="{StaticResource SettingsFieldLabel}" />
                                    <StackPanel Grid.Column="1">
                                        <TextBox Text="{Binding ServerHttpsPort, UpdateSourceTrigger=LostFocus}" Width="200" HorizontalAlignment="Left" Style="{StaticResource SettingsTextBox}" />
                                        <TextBlock Text="HTTPS-порт для браузеров, камеры и QR-сканера." Style="{StaticResource SettingsHintText}" />
                                    </StackPanel>
                                </Grid>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="240" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Runtime HTTP port" Style="{StaticResource SettingsFieldLabel}" />
                                    <StackPanel Grid.Column="1">
                                        <TextBox Text="{Binding ServerRuntimePort, UpdateSourceTrigger=LostFocus}" Width="200" HorizontalAlignment="Left" Style="{StaticResource SettingsTextBox}" />
                                        <TextBlock Text="Локальный API-порт Runtime Service; обычно наружу он не открывается." Style="{StaticResource SettingsHintText}" />
                                    </StackPanel>
                                </Grid>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="240" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Apply HTTPS" Style="{StaticResource SettingsFieldLabel}" />
                                    <StackPanel Grid.Column="1">
                                        <Button Content="Apply HTTPS"
                                                Width="160"
                                                HorizontalAlignment="Left"
                                                Click="OnApplyHttpsConfigClick" />
                                        <TextBlock Text="Записывает HTTPS endpoint и настройки сертификата Kestrel в WEB appsettings. После применения перезапусти TechMES WEB." Style="{StaticResource SettingsHintText}" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Header="Firewall" Margin="0,0,0,12">
                            <StackPanel Margin="12">
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="240" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="HTTP firewall rule" Style="{StaticResource SettingsFieldLabel}" />
                                    <StackPanel Grid.Column="1">
                                        <TextBox Text="{Binding ServerFirewallRuleName, UpdateSourceTrigger=PropertyChanged}" Width="360" HorizontalAlignment="Left" Style="{StaticResource SettingsTextBox}" />
                                        <TextBlock Text="Имя входящего правила Windows Firewall для HTTP-порта WEB." Style="{StaticResource SettingsHintText}" />
                                    </StackPanel>
                                </Grid>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="240" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="HTTPS firewall rule" Style="{StaticResource SettingsFieldLabel}" />
                                    <StackPanel Grid.Column="1">
                                        <TextBox Text="{Binding ServerHttpsFirewallRuleName, UpdateSourceTrigger=PropertyChanged}" Width="360" HorizontalAlignment="Left" Style="{StaticResource SettingsTextBox}" />
                                        <TextBlock Text="Имя входящего правила Windows Firewall для HTTPS-порта WEB." Style="{StaticResource SettingsHintText}" />
                                    </StackPanel>
                                </Grid>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="240" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Open WEB firewall" Style="{StaticResource SettingsFieldLabel}" />
                                    <StackPanel Grid.Column="1">
                                        <Button Content="Open WEB firewall"
                                                Width="160"
                                                HorizontalAlignment="Left"
                                                Click="OnOpenWebFirewallClick" />
                                        <TextBlock Text="Создает или обновляет входящее правило Windows Firewall для HTTP-порта WEB." Style="{StaticResource SettingsHintText}" />
                                    </StackPanel>
                                </Grid>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="240" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Open HTTPS firewall" Style="{StaticResource SettingsFieldLabel}" />
                                    <StackPanel Grid.Column="1">
                                        <Button Content="Open HTTPS firewall"
                                                Width="160"
                                                HorizontalAlignment="Left"
                                                Click="OnOpenHttpsFirewallClick" />
                                        <TextBlock Text="Создает или обновляет входящее правило Windows Firewall для HTTPS-порта WEB." Style="{StaticResource SettingsHintText}" />
                                    </StackPanel>
                                </Grid>
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="240" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Firewall console" Style="{StaticResource SettingsFieldLabel}" />
                                    <StackPanel Grid.Column="1">
                                        <Button Content="Open firewall console"
                                                Width="160"
                                                HorizontalAlignment="Left"
                                                Click="OnOpenFirewallAdvancedClick" />
                                        <TextBlock Text="Открывает Windows Defender Firewall with Advanced Security для ручной проверки правил." Style="{StaticResource SettingsHintText}" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Header="Runtime and WEB endpoints" Margin="0,0,0,12">
                            <StackPanel Margin="12">
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="240" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Runtime URLs" Style="{StaticResource SettingsFieldLabel}" />
                                    <StackPanel Grid.Column="1">
                                        <TextBox Text="{Binding TypedAppSettings.RuntimeUrls, UpdateSourceTrigger=PropertyChanged}" Width="360" HorizontalAlignment="Left" Style="{StaticResource SettingsTextBox}" />
                                        <TextBlock Text="Значение ASPNETCORE_URLS для TechMES Runtime Service." Style="{StaticResource SettingsHintText}" />
                                    </StackPanel>
                                </Grid>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="240" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Runtime device name" Style="{StaticResource SettingsFieldLabel}" />
                                    <StackPanel Grid.Column="1">
                                        <TextBox Text="{Binding TypedAppSettings.RuntimeDeviceName, UpdateSourceTrigger=PropertyChanged}" Width="360" HorizontalAlignment="Left" Style="{StaticResource SettingsTextBox}" />
                                        <TextBlock Text="Имя устройства, которое Runtime пишет в действия операторов и диагностику." Style="{StaticResource SettingsHintText}" />
                                    </StackPanel>
                                </Grid>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="240" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Runtime user name" Style="{StaticResource SettingsFieldLabel}" />
                                    <StackPanel Grid.Column="1">
                                        <TextBox Text="{Binding TypedAppSettings.RuntimeUserName, UpdateSourceTrigger=PropertyChanged}" Width="360" HorizontalAlignment="Left" Style="{StaticResource SettingsTextBox}" />
                                        <TextBlock Text="Имя сервисного пользователя в Runtime appsettings для записей, созданных службой." Style="{StaticResource SettingsHintText}" />
                                    </StackPanel>
                                </Grid>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="240" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="WEB URLs" Style="{StaticResource SettingsFieldLabel}" />
                                    <StackPanel Grid.Column="1">
                                        <TextBox Text="{Binding TypedAppSettings.WebUrls, UpdateSourceTrigger=PropertyChanged}" Width="360" HorizontalAlignment="Left" Style="{StaticResource SettingsTextBox}" />
                                        <TextBlock Text="Значение ASPNETCORE_URLS для TechMES WEB; здесь должны быть HTTP и HTTPS listener-ы." Style="{StaticResource SettingsHintText}" />
                                    </StackPanel>
                                </Grid>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="240" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Runtime base URL" Style="{StaticResource SettingsFieldLabel}" />
                                    <StackPanel Grid.Column="1">
                                        <TextBox Text="{Binding TypedAppSettings.WebRuntimeBaseUrl, UpdateSourceTrigger=PropertyChanged}" Width="360" HorizontalAlignment="Left" Style="{StaticResource SettingsTextBox}" />
                                        <TextBlock Text="Базовый URL, по которому WEB обращается к HTTP API Runtime Service." Style="{StaticResource SettingsHintText}" />
                                    </StackPanel>
                                </Grid>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="240" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Runtime timeout, sec" Style="{StaticResource SettingsFieldLabel}" />
                                    <StackPanel Grid.Column="1">
                                        <TextBox Text="{Binding TypedAppSettings.WebRuntimeTimeoutSeconds, UpdateSourceTrigger=LostFocus}" Width="200" HorizontalAlignment="Left" Style="{StaticResource SettingsTextBox}" />
                                        <TextBlock Text="Таймаут HTTP-запросов WEB к Runtime Service." Style="{StaticResource SettingsHintText}" />
                                    </StackPanel>
                                </Grid>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="240" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Messages hub path" Style="{StaticResource SettingsFieldLabel}" />
                                    <StackPanel Grid.Column="1">
                                        <TextBox Text="{Binding TypedAppSettings.WebMessagesHubPath, UpdateSourceTrigger=PropertyChanged}" Width="360" HorizontalAlignment="Left" Style="{StaticResource SettingsTextBox}" />
                                        <TextBlock Text="Путь SignalR hub для live-обновлений сообщений в WEB." Style="{StaticResource SettingsHintText}" />
                                    </StackPanel>
                                </Grid>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="240" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="WEB device name" Style="{StaticResource SettingsFieldLabel}" />
                                    <StackPanel Grid.Column="1">
                                        <TextBox Text="{Binding TypedAppSettings.WebDeviceName, UpdateSourceTrigger=PropertyChanged}" Width="360" HorizontalAlignment="Left" Style="{StaticResource SettingsTextBox}" />
                                        <TextBlock Text="Имя клиента или устройства, которое WEB показывает в созданных сообщениях и действиях." Style="{StaticResource SettingsHintText}" />
                                    </StackPanel>
                                </Grid>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="240" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="WEB title" Style="{StaticResource SettingsFieldLabel}" />
                                    <StackPanel Grid.Column="1">
                                        <TextBox Text="{Binding TypedAppSettings.WebTitle, UpdateSourceTrigger=PropertyChanged}" Width="360" HorizontalAlignment="Left" Style="{StaticResource SettingsTextBox}" />
                                        <TextBlock Text="Заголовок приложения в браузере и в шапке WEB-интерфейса." Style="{StaticResource SettingsHintText}" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Header="Target machine" Margin="0,0,0,12">
                            <StackPanel Margin="12">
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="240" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Display name" Style="{StaticResource SettingsFieldLabel}" />
                                    <StackPanel Grid.Column="1">
                                        <TextBox Text="{Binding TargetMachineDisplayName, UpdateSourceTrigger=PropertyChanged}" Width="360" HorizontalAlignment="Left" Style="{StaticResource SettingsTextBox}" />
                                        <TextBlock Text="Понятное имя профиля сервера, которое отображается в Maintenance." Style="{StaticResource SettingsHintText}" />
                                    </StackPanel>
                                </Grid>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="240" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Host name" Style="{StaticResource SettingsFieldLabel}" />
                                    <StackPanel Grid.Column="1">
                                        <TextBox Text="{Binding TargetMachineHostName, UpdateSourceTrigger=PropertyChanged}" Width="360" HorizontalAlignment="Left" Style="{StaticResource SettingsTextBox}" />
                                        <TextBlock Text="DNS или Windows-имя целевого TechMES-сервера." Style="{StaticResource SettingsHintText}" />
                                    </StackPanel>
                                </Grid>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="240" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="IP address" Style="{StaticResource SettingsFieldLabel}" />
                                    <StackPanel Grid.Column="1">
                                        <TextBox Text="{Binding TargetMachineIpAddress, UpdateSourceTrigger=PropertyChanged}" Width="360" HorizontalAlignment="Left" Style="{StaticResource SettingsTextBox}" />
                                        <TextBlock Text="Основной IP-адрес в локальной сети, который используют планшеты и проверки сервера." Style="{StaticResource SettingsHintText}" />
                                    </StackPanel>
                                </Grid>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="240" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Notes" Style="{StaticResource SettingsFieldLabel}" />
                                    <StackPanel Grid.Column="1">
                                        <TextBox Text="{Binding TargetMachineNotes, UpdateSourceTrigger=PropertyChanged}" Width="640" Style="{StaticResource SettingsTextBox}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="70"/>
                                        <TextBlock Text="Свободные заметки по этому серверу: место установки, особенности доступа, обслуживание." Style="{StaticResource SettingsHintText}" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE71C;" FontSize="18" Margin="0,0,8,0" />
                        <TextBlock Text="CtApi" />
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="12">
                        <GroupBox Header="Equipment catalog" Margin="0,0,0,12">
                            <StackPanel Margin="12">
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="240" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Provider" Style="{StaticResource SettingsFieldLabel}" />
                                    <StackPanel Grid.Column="1">
                                        <TextBox Text="{Binding TypedAppSettings.RuntimeEquipmentProvider, UpdateSourceTrigger=PropertyChanged}" Width="200" HorizontalAlignment="Left" Style="{StaticResource SettingsTextBox}" />
                                        <TextBlock Text="Источник каталога оборудования для Runtime Service, например CtApi или InMemory." Style="{StaticResource SettingsHintText}" />
                                    </StackPanel>
                                </Grid>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="240" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="CtApi table" Style="{StaticResource SettingsFieldLabel}" />
                                    <StackPanel Grid.Column="1">
                                        <TextBox Text="{Binding TypedAppSettings.RuntimeCtApiTableName, UpdateSourceTrigger=PropertyChanged}" Width="200" HorizontalAlignment="Left" Style="{StaticResource SettingsTextBox}" />
                                        <TextBlock Text="Имя таблицы CtApi, из которой Runtime читает каталог оборудования." Style="{StaticResource SettingsHintText}" />
                                    </StackPanel>
                                </Grid>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="240" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="CtApi cluster" Style="{StaticResource SettingsFieldLabel}" />
                                    <StackPanel Grid.Column="1">
                                        <TextBox Text="{Binding TypedAppSettings.RuntimeCtApiCluster, UpdateSourceTrigger=PropertyChanged}" Width="200" HorizontalAlignment="Left" Style="{StaticResource SettingsTextBox}" />
                                        <TextBlock Text="Имя CtApi-кластера для чтения каталога и тегов." Style="{StaticResource SettingsHintText}" />
                                    </StackPanel>
                                </Grid>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="240" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="CtApi filter" Style="{StaticResource SettingsFieldLabel}" />
                                    <StackPanel Grid.Column="1">
                                        <TextBox Text="{Binding TypedAppSettings.RuntimeCtApiFilter, UpdateSourceTrigger=PropertyChanged}" Width="360" HorizontalAlignment="Left" Style="{StaticResource SettingsTextBox}" />
                                        <TextBlock Text="Необязательный фильтр, который применяется при чтении оборудования из CtApi." Style="{StaticResource SettingsHintText}" />
                                    </StackPanel>
                                </Grid>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="240" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Use CtApi type filter" Style="{StaticResource SettingsFieldLabel}" />
                                    <StackPanel Grid.Column="1">
                                        <CheckBox Content="Enabled" IsChecked="{Binding TypedAppSettings.RuntimeUseCtApiTypeFilter}" VerticalAlignment="Center" />
                                        <TextBlock Text="Ограничивает загрузку каталога настроенными alias-ами типов оборудования TechMES." Style="{StaticResource SettingsHintText}" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Header="CtApi connection" Margin="0,0,0,12">
                            <StackPanel Margin="12">
                                <Grid Margin="0,0,0,10">
