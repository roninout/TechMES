                            </StackPanel>
                        </GroupBox>
                        <GroupBox Header="WEB file logging" Margin="0,0,0,12">
                            <StackPanel Margin="12">
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="240" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Enabled" Style="{StaticResource SettingsFieldLabel}" />
                                    <StackPanel Grid.Column="1">
                                        <CheckBox Content="Enabled" IsChecked="{Binding TypedAppSettings.WebFileLoggingEnabled}" VerticalAlignment="Center" />
                                        <TextBlock Text="Enables file logging for TechMES WEB." Style="{StaticResource SettingsHintText}" />
                                    </StackPanel>
                                </Grid>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="240" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Minimum level" Style="{StaticResource SettingsFieldLabel}" />
                                    <StackPanel Grid.Column="1">
                                        <TextBox Text="{Binding TypedAppSettings.WebFileLoggingMinimumLevel, UpdateSourceTrigger=PropertyChanged}" Width="360" HorizontalAlignment="Left" Style="{StaticResource SettingsTextBox}" />
                                        <TextBlock Text="Minimum WEB log level, for example Information, Warning or Error." Style="{StaticResource SettingsHintText}" />
                                    </StackPanel>
                                </Grid>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="240" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Directory" Style="{StaticResource SettingsFieldLabel}" />
                                    <StackPanel Grid.Column="1">
                                        <TextBox Text="{Binding TypedAppSettings.WebFileLoggingDirectory, UpdateSourceTrigger=PropertyChanged}" Width="360" HorizontalAlignment="Left" Style="{StaticResource SettingsTextBox}" />
                                        <TextBlock Text="WEB log directory, relative to service folder or absolute path." Style="{StaticResource SettingsHintText}" />
                                    </StackPanel>
                                </Grid>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="240" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="File name prefix" Style="{StaticResource SettingsFieldLabel}" />
                                    <StackPanel Grid.Column="1">
                                        <TextBox Text="{Binding TypedAppSettings.WebFileLoggingPrefix, UpdateSourceTrigger=PropertyChanged}" Width="360" HorizontalAlignment="Left" Style="{StaticResource SettingsTextBox}" />
                                        <TextBlock Text="WEB log file name prefix." Style="{StaticResource SettingsHintText}" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8A5;" FontSize="18" Margin="0,0,8,0" />
                        <TextBlock Text="Raw settings" />
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                                        Background="{StaticResource TechMesPanelBrush}"
                                        BorderBrush="{StaticResource TechMesBorderBrush}"
                                        BorderThickness="1"
                                        Padding="10">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top"
                                                   Text="appsettings files"
                                                   Style="{StaticResource SectionTitleText}" />
                            <ListBox ItemsSource="{Binding SettingsFiles}"
                                                 SelectedItem="{Binding SelectedSettingsFile}"
                                                 DisplayMemberPath="DisplayName"
                                                 SelectionChanged="OnSettingsFileSelected" />
                        </DockPanel>
                    </Border>

                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0"
                                               Margin="0,0,0,8">
                            <StackPanel DockPanel.Dock="Right"
                                                    Orientation="Horizontal">
                                <Button Content="Reload"
                                                    Click="OnReloadSettingsClick" />
                                <Button Content="Save with backup"
                                                    Click="OnSaveSettingsClick" />
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="{Binding SelectedSettingsFile.DisplayName}"
                                                       FontSize="18"
                                                       FontWeight="SemiBold" />
                                <TextBlock Text="{Binding SelectedSettingsFile.FullPath}"
                                                       Style="{StaticResource MutedText}" />
                            </StackPanel>
                        </DockPanel>

                        <TextBox Grid.Row="1"
                                             Text="{Binding SelectedSettingsFile.Content, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                             AcceptsReturn="True"
                                             AcceptsTab="True"
                                             VerticalScrollBarVisibility="Auto"
                                             HorizontalScrollBarVisibility="Auto"
                                             FontFamily="Consolas"
                                             FontSize="13"
                                             Padding="10"
                                             TextWrapping="NoWrap" />

                        <TextBlock Grid.Row="2"
                                               Text="{Binding SelectedSettingsFile.Status}"
                                               Style="{StaticResource MutedText}"
                                               Margin="0,8,0,0" />
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>

        <Grid Grid.Row="1" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Content="Reload"
                    MinWidth="110"
                    Click="OnReloadAllTypedSettingsClick" />
            <TextBlock Grid.Column="1"
                       Text="{Binding TypedAppSettings.Status}"
                       Style="{StaticResource MutedText}"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       VerticalAlignment="Center"
                       Margin="12,0" />
            <Button Grid.Column="2"
                    Content="Save"
                    MinWidth="130"
                    Click="OnSaveAllTypedSettingsClick" />
        </Grid>
    </Grid>
</views:MaintenancePageControl>

