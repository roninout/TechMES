<views:MaintenancePageControl x:Class="TechMES.Maintenance.Views.ImportEditPage"
                              xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                              xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                              xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                              xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                              xmlns:control="http://filterdatagrid.control.com/2021"
                              xmlns:views="clr-namespace:TechMES.Maintenance.Views"
                              mc:Ignorable="d">
    <views:MaintenancePageControl.Resources>
        <!--<Style x:Key="ImportGrid" TargetType="{x:Type control:FilterDataGrid}">-->
        <Style x:Key="ImportGrid" TargetType="{x:Type control:FilterDataGrid}" BasedOn="{StaticResource TechMesFilterDataGridStyle}">
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="True" />
            <Setter Property="CanUserDeleteRows" Value="True" />
            <Setter Property="SelectionMode" Value="Extended" />
            <Setter Property="SelectionUnit" Value="CellOrRowHeader" />
            <Setter Property="ClipboardCopyMode" Value="IncludeHeader" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="Background" Value="{DynamicResource TechMesPanelBrush}" />
            <EventSetter Event="PreviewKeyDown" Handler="OnImportGridPreviewKeyDown" />
        </Style>
    </views:MaintenancePageControl.Resources>

    <TabControl HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                HorizontalContentAlignment="Stretch"
                VerticalContentAlignment="Stretch"
                SelectionChanged="OnImportTabSelectionChanged">
        <TabItem Tag="SUPPLIER">
            <TabItem.Header>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:SymbolIcon Symbol="PersonAccounts20" Width="20" Height="20" Margin="0,0,8,0" />
                    <TextBlock Text="SUPPLIER" />
                </StackPanel>
            </TabItem.Header>

            <Grid Margin="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <views:MaintenanceCard Grid.Row="0"
                        Background="{DynamicResource TechMesPanelBrush}"
                        BorderBrush="{DynamicResource TechMesBorderBrush}"
                        BorderThickness="1"
                        Padding="12"
                        Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Suppliers"
                                   Style="{StaticResource SectionTitleText}" />
                        <TextBlock Text="Редактирует public.equip_supplier: имя поставщика и логотип. Новый логотип выбирается файлом и попадает в БД после Save."
                                   Style="{StaticResource MutedText}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </views:MaintenanceCard>

                <control:FilterDataGrid Grid.Row="1"
                                        Style="{StaticResource ImportGrid}"
                                        RowHeight="72"
                                        ColumnHeaderHeight="36"
                                        CanUserSortColumns="True"
                                        ShowStatusBar="False"
                                        ShowElapsedTime="False"
                                        DateFormatString="dd.MM.yyyy"
                                        FilterLanguage="Russian"
                                        ItemsSource="{Binding ImportSuppliers}">
                    <control:FilterDataGrid.Resources>
                        <Style x:Key="PendingDeleteTextBlockStyle" TargetType="{x:Type TextBlock}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPendingDelete}" Value="True">
                                    <Setter Property="TextDecorations" Value="Strikethrough" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </control:FilterDataGrid.Resources>
                    <control:FilterDataGrid.RowStyle>
                        <Style TargetType="{x:Type DataGridRow}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPendingDelete}" Value="True">
                                    <Setter Property="Opacity" Value="0.55" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </control:FilterDataGrid.RowStyle>
                    <control:FilterDataGrid.Columns>
                        <control:DataGridTemplateColumn Header="Logo"
                                                        FieldName="LogoFileName"
                                                        IsColumnFiltered="True"
                                                        Width="130"
                                                        SortMemberPath="LogoFileName"
                                                        IsReadOnly="True">
                            <control:DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <views:MaintenanceCard Width="104"
                                            Height="58"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            BorderBrush="{DynamicResource TechMesBorderBrush}"
                                            BorderThickness="1"
                                            Background="{DynamicResource TechMesPanelBrush}">
                                        <Image Source="{Binding LogoPreview}"
                                               Stretch="Uniform"
                                               Margin="3"
                                               ToolTip="{Binding LogoFileName}" />
                                    </views:MaintenanceCard>
                                </DataTemplate>
                            </control:DataGridTemplateColumn.CellTemplate>
                        </control:DataGridTemplateColumn>

                        <control:DataGridTextColumn Header="Supplier"
                                                    Binding="{Binding Supplier, UpdateSourceTrigger=PropertyChanged}"
                                                    SortMemberPath="Supplier"
                                                    IsColumnFiltered="True"
                                                    ElementStyle="{StaticResource PendingDeleteTextBlockStyle}"
                                                    Width="*"
                                                    MinWidth="240" />

                        <control:DataGridTemplateColumn Header="Select"
                                                        IsColumnFiltered="False"
                                                        Width="80">
                            <control:DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ui:Button Content="..."
                                            Width="38"
                                            MinWidth="38"
                                            Height="24"
                                            Padding="0"
                                            Tag="{Binding}"
                                            Click="OnChooseSupplierLogoClick" />
                                </DataTemplate>
                            </control:DataGridTemplateColumn.CellTemplate>
                        </control:DataGridTemplateColumn>

                        <control:DataGridTextColumn Header="Status"
                                                    Binding="{Binding LogoStatus}"
                                                    SortMemberPath="LogoStatus"
                                                    IsColumnFiltered="True"
                                                    ElementStyle="{StaticResource PendingDeleteTextBlockStyle}"
                                                    IsReadOnly="True"
                                                    Width="150" />
                    </control:FilterDataGrid.Columns>
                </control:FilterDataGrid>

                <Grid Grid.Row="2"
                      Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <ui:Button Content="Refresh"
                            MinWidth="100"
                            Click="OnRefreshImportSuppliersClick" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding ImportSupplierStatusText}"
                               Style="{StaticResource MutedText}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap" />
                    <ui:Button Grid.Column="2"
                            Content="Save"
                            MinWidth="100"
                            Click="OnSaveImportSuppliersClick" />
                </Grid>
            </Grid>
        </TabItem>

        <TabItem Tag="ORDERS">
            <TabItem.Header>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:SymbolIcon Symbol="DocumentText24" Width="20" Height="20" Margin="0,0,8,0" />
                    <TextBlock Text="ORDERS" />
                </StackPanel>
            </TabItem.Header>

            <Grid Margin="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <views:MaintenanceCard Grid.Row="0"
                        Background="{DynamicResource TechMesPanelBrush}"
                        BorderBrush="{DynamicResource TechMesBorderBrush}"
                        BorderThickness="1"
                        Padding="12"
                        Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Orders"
                                       Style="{StaticResource SectionTitleText}" />
                            <TextBlock Text="Редактирует public.equip_order. PDF source folder нужен как рабочий источник для будущего добавления новых PDF-файлов."
                                       Style="{StaticResource MutedText}"
                                       TextWrapping="Wrap" />
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="PDF source folder"
                                           VerticalAlignment="Center"
                                           Style="{StaticResource MutedText}" />
                                <ui:TextBox Grid.Column="1"
                                         Text="{Binding OrdersPdfSourceRoot, UpdateSourceTrigger=PropertyChanged}"
                                         LostFocus="OnOrdersPdfSourceLostFocus"
                                         Margin="0,0,8,0" />
                                <ui:Button Grid.Column="2"
                                        Content="Browse..."
                                        MinWidth="96"
                                        Click="OnBrowseOrdersPdfSourceClick" />
                            </Grid>
                        </StackPanel>
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Bottom"
                                    Margin="12,0,0,0">
                            <ui:Button Content="Refresh"
                                    MinWidth="100"
                                    Click="OnRefreshImportOrdersClick" />
                            <ui:Button Content="Save"
                                    MinWidth="100"
                                    Click="OnSaveImportOrdersClick" />
                        </StackPanel>
                    </Grid>
                </views:MaintenanceCard>

                <control:FilterDataGrid Grid.Row="1"
                                        Style="{StaticResource ImportGrid}"
                                        ShowStatusBar="False"
                                        ShowElapsedTime="False"
                                        DateFormatString="dd.MM.yyyy"
                                        FilterLanguage="Russian"
                                        ItemsSource="{Binding ImportOrders}">
                    <control:FilterDataGrid.Columns>
                        <control:DataGridTextColumn Header="Type"
                                                    Binding="{Binding Type, UpdateSourceTrigger=PropertyChanged}"
                                                    IsColumnFiltered="True"
                                                    Width="150" />
                        <control:DataGridTextColumn Header="Product code"
                                                    Binding="{Binding ProductCode, UpdateSourceTrigger=PropertyChanged}"
                                                    IsColumnFiltered="True"
                                                    Width="210" />
                        <control:DataGridTextColumn Header="Supplier"
                                                    Binding="{Binding Supplier, UpdateSourceTrigger=PropertyChanged}"
                                                    IsColumnFiltered="True"
                                                    Width="180" />
                        <control:DataGridTextColumn Header="Source"
                                                    Binding="{Binding Source, UpdateSourceTrigger=PropertyChanged}"
                                                    IsColumnFiltered="True"
                                                    Width="260" />
                        <control:DataGridTextColumn Header="Description"
                                                    Binding="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                                    IsColumnFiltered="True"
                                                    Width="*" />
                        <control:DataGridTextColumn Header="Image"
                                                    Binding="{Binding Image, UpdateSourceTrigger=PropertyChanged}"
                                                    IsColumnFiltered="True"
                                                    Width="220" />
                    </control:FilterDataGrid.Columns>
                </control:FilterDataGrid>

                <TextBlock Grid.Row="2"
                           Text="{Binding ImportOrderStatusText}"
                           Style="{StaticResource MutedText}"
                           Margin="0,8,0,0"
                           TextWrapping="Wrap" />
            </Grid>
        </TabItem>

        <TabItem Tag="INSTRUCTION">
            <TabItem.Header>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:SymbolIcon Symbol="DocumentBulletList24" Width="20" Height="20" Margin="0,0,8,0" />
                    <TextBlock Text="INSTRUCTION" />
                </StackPanel>
            </TabItem.Header>
            <views:MaintenanceCard Margin="12"
                    Background="{DynamicResource TechMesPanelBrush}"
                    BorderBrush="{DynamicResource TechMesBorderBrush}"
                    BorderThickness="1"
                    Padding="16">
                <StackPanel>
                    <TextBlock Text="Instruction import"
                               Style="{StaticResource SectionTitleText}" />
                    <TextBlock Text="Runtime catalog will be loaded before this tab is used. Future rows will map Station, Type, Equipment, Product code, Supplier and Description."
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding ImportRuntimeStatusText}"
                               Style="{StaticResource MutedText}"
                               Margin="0,12,0,0"
                               TextWrapping="Wrap" />
                </StackPanel>
            </views:MaintenanceCard>
        </TabItem>

        <TabItem Tag="SCHEME">
            <TabItem.Header>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:SymbolIcon Symbol="Table24" Width="20" Height="20" Margin="0,0,8,0" />
                    <TextBlock Text="SCHEME" />
                </StackPanel>
            </TabItem.Header>
            <views:MaintenanceCard Margin="12"
                    Background="{DynamicResource TechMesPanelBrush}"
                    BorderBrush="{DynamicResource TechMesBorderBrush}"
                    BorderThickness="1"
                    Padding="16">
                <StackPanel>
                    <TextBlock Text="Scheme import"
                               Style="{StaticResource SectionTitleText}" />
                    <TextBlock Text="Runtime catalog will be loaded before this tab is used. Future rows will map Station, Group and Equipment to scheme files."
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding ImportRuntimeStatusText}"
                               Style="{StaticResource MutedText}"
                               Margin="0,12,0,0"
                               TextWrapping="Wrap" />
                </StackPanel>
            </views:MaintenanceCard>
        </TabItem>
    </TabControl>
</views:MaintenancePageControl>




