<views:MaintenancePageControl x:Class="TechMES.Maintenance.Views.ImportEditPage"
                              xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                              xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                              xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                              xmlns:views="clr-namespace:TechMES.Maintenance.Views"
                              mc:Ignorable="d">
    <views:MaintenancePageControl.Resources>
        <Style x:Key="ImportGrid" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="True" />
            <Setter Property="CanUserDeleteRows" Value="True" />
            <Setter Property="SelectionMode" Value="Extended" />
            <Setter Property="SelectionUnit" Value="CellOrRowHeader" />
            <Setter Property="ClipboardCopyMode" Value="IncludeHeader" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="Background" Value="{StaticResource TechMesPanelBrush}" />
            <EventSetter Event="PreviewKeyDown" Handler="OnImportGridPreviewKeyDown" />
        </Style>
    </views:MaintenancePageControl.Resources>

    <TabControl HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                HorizontalContentAlignment="Stretch"
                VerticalContentAlignment="Stretch"
                SelectionChanged="OnImportTabSelectionChanged">
        <TabItem Tag="SUPPLIER">
            <TabItem.Header>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE716;" FontSize="18" Margin="0,0,8,0" />
                    <TextBlock Text="SUPPLIER" />
                </StackPanel>
            </TabItem.Header>

            <Grid Margin="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{StaticResource TechMesPanelBrush}"
                        BorderBrush="{StaticResource TechMesBorderBrush}"
                        BorderThickness="1"
                        Padding="12"
                        Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Suppliers"
                                   Style="{StaticResource SectionTitleText}" />
                        <TextBlock Text="Редактирует public.equip_supplier: имя поставщика и логотип. Новый логотип выбирается файлом и попадает в БД после Save."
                                   Style="{StaticResource MutedText}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <DataGrid Grid.Row="1"
                          Style="{StaticResource ImportGrid}"
                          RowHeight="72"
                          ColumnHeaderHeight="58"
                          CanUserSortColumns="True"
                          ItemsSource="{Binding ImportSuppliers}">
                    <DataGrid.Resources>
                        <Style x:Key="PendingDeleteTextBlockStyle" TargetType="{x:Type TextBlock}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPendingDelete}" Value="True">
                                    <Setter Property="TextDecorations" Value="Strikethrough" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.RowStyle>
                        <Style TargetType="{x:Type DataGridRow}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPendingDelete}" Value="True">
                                    <Setter Property="Opacity" Value="0.55" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Width="130"
                                                SortMemberPath="LogoFileName"
                                                IsReadOnly="True">
                            <DataGridTemplateColumn.Header>
                                <StackPanel>
                                    <TextBlock Text="Logo" />
                                    <TextBox Tag="Logo"
                                             Width="110"
                                             Height="22"
                                             Margin="0,3,0,0"
                                             TextChanged="OnSupplierFilterTextChanged" />
                                </StackPanel>
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Width="104"
                                            Height="58"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            BorderBrush="{StaticResource TechMesBorderBrush}"
                                            BorderThickness="1"
                                            Background="{StaticResource TechMesPanelBrush}">
                                        <Image Source="{Binding LogoPreview}"
                                               Stretch="Uniform"
                                               Margin="3"
                                               ToolTip="{Binding LogoFileName}" />
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Binding="{Binding Supplier, UpdateSourceTrigger=PropertyChanged}"
                                            SortMemberPath="Supplier"
                                            ElementStyle="{StaticResource PendingDeleteTextBlockStyle}"
                                            Width="*"
                                            MinWidth="240">
                            <DataGridTextColumn.Header>
                                <StackPanel>
                                    <TextBlock Text="Supplier" />
                                    <TextBox Tag="Supplier"
                                             MinWidth="220"
                                             Height="22"
                                             Margin="0,3,0,0"
                                             TextChanged="OnSupplierFilterTextChanged" />
                                </StackPanel>
                            </DataGridTextColumn.Header>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Header="Select"
                                                Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="..."
                                            Width="38"
                                            MinWidth="38"
                                            Height="24"
                                            Padding="0"
                                            Tag="{Binding}"
                                            Click="OnChooseSupplierLogoClick" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Binding="{Binding LogoStatus}"
                                            SortMemberPath="LogoStatus"
                                            ElementStyle="{StaticResource PendingDeleteTextBlockStyle}"
                                            IsReadOnly="True"
                                            Width="150">
                            <DataGridTextColumn.Header>
                                <StackPanel>
                                    <TextBlock Text="Status" />
                                    <TextBox Tag="Status"
                                             Width="130"
                                             Height="22"
                                             Margin="0,3,0,0"
                                             TextChanged="OnSupplierFilterTextChanged" />
                                </StackPanel>
                            </DataGridTextColumn.Header>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <Grid Grid.Row="2"
                      Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button Content="Refresh"
                            MinWidth="100"
                            Click="OnRefreshImportSuppliersClick" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding ImportSupplierStatusText}"
                               Style="{StaticResource MutedText}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap" />
                    <Button Grid.Column="2"
                            Content="Save"
                            MinWidth="100"
                            Click="OnSaveImportSuppliersClick" />
                </Grid>
            </Grid>
        </TabItem>

        <TabItem Tag="ORDERS">
            <TabItem.Header>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8A5;" FontSize="18" Margin="0,0,8,0" />
                    <TextBlock Text="ORDERS" />
                </StackPanel>
            </TabItem.Header>

            <Grid Margin="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{StaticResource TechMesPanelBrush}"
                        BorderBrush="{StaticResource TechMesBorderBrush}"
                        BorderThickness="1"
                        Padding="12"
                        Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Orders"
                                       Style="{StaticResource SectionTitleText}" />
                            <TextBlock Text="Редактирует public.equip_order. PDF source folder нужен как рабочий источник для будущего добавления новых PDF-файлов."
                                       Style="{StaticResource MutedText}"
                                       TextWrapping="Wrap" />
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="PDF source folder"
                                           VerticalAlignment="Center"
                                           Style="{StaticResource MutedText}" />
                                <TextBox Grid.Column="1"
                                         Text="{Binding OrdersPdfSourceRoot, UpdateSourceTrigger=PropertyChanged}"
                                         LostFocus="OnOrdersPdfSourceLostFocus"
                                         Margin="0,0,8,0" />
                                <Button Grid.Column="2"
                                        Content="Browse..."
                                        MinWidth="96"
                                        Click="OnBrowseOrdersPdfSourceClick" />
                            </Grid>
                        </StackPanel>
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Bottom"
                                    Margin="12,0,0,0">
                            <Button Content="Refresh"
                                    MinWidth="100"
                                    Click="OnRefreshImportOrdersClick" />
                            <Button Content="Save"
                                    MinWidth="100"
                                    Click="OnSaveImportOrdersClick" />
                        </StackPanel>
                    </Grid>
                </Border>

                <DataGrid Grid.Row="1"
                          Style="{StaticResource ImportGrid}"
                          ItemsSource="{Binding ImportOrders}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Type"
                                            Binding="{Binding Type, UpdateSourceTrigger=PropertyChanged}"
                                            Width="150" />
                        <DataGridTextColumn Header="Product code"
                                            Binding="{Binding ProductCode, UpdateSourceTrigger=PropertyChanged}"
                                            Width="210" />
                        <DataGridTextColumn Header="Supplier"
                                            Binding="{Binding Supplier, UpdateSourceTrigger=PropertyChanged}"
                                            Width="180" />
                        <DataGridTextColumn Header="Source"
                                            Binding="{Binding Source, UpdateSourceTrigger=PropertyChanged}"
                                            Width="260" />
                        <DataGridTextColumn Header="Description"
                                            Binding="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                            Width="*" />
                        <DataGridTextColumn Header="Image"
                                            Binding="{Binding Image, UpdateSourceTrigger=PropertyChanged}"
                                            Width="220" />
                    </DataGrid.Columns>
                </DataGrid>

                <TextBlock Grid.Row="2"
                           Text="{Binding ImportOrderStatusText}"
                           Style="{StaticResource MutedText}"
                           Margin="0,8,0,0"
                           TextWrapping="Wrap" />
            </Grid>
        </TabItem>

        <TabItem Tag="INSTRUCTION">
            <TabItem.Header>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE82D;" FontSize="18" Margin="0,0,8,0" />
                    <TextBlock Text="INSTRUCTION" />
                </StackPanel>
            </TabItem.Header>
            <Border Margin="12"
                    Background="{StaticResource TechMesPanelBrush}"
                    BorderBrush="{StaticResource TechMesBorderBrush}"
                    BorderThickness="1"
                    Padding="16">
                <StackPanel>
                    <TextBlock Text="Instruction import"
                               Style="{StaticResource SectionTitleText}" />
                    <TextBlock Text="Runtime catalog will be loaded before this tab is used. Future rows will map Station, Type, Equipment, Product code, Supplier and Description."
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding ImportRuntimeStatusText}"
                               Style="{StaticResource MutedText}"
                               Margin="0,12,0,0"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </TabItem>

        <TabItem Tag="SCHEME">
            <TabItem.Header>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8A9;" FontSize="18" Margin="0,0,8,0" />
                    <TextBlock Text="SCHEME" />
                </StackPanel>
            </TabItem.Header>
            <Border Margin="12"
                    Background="{StaticResource TechMesPanelBrush}"
                    BorderBrush="{StaticResource TechMesBorderBrush}"
                    BorderThickness="1"
                    Padding="16">
                <StackPanel>
                    <TextBlock Text="Scheme import"
                               Style="{StaticResource SectionTitleText}" />
                    <TextBlock Text="Runtime catalog will be loaded before this tab is used. Future rows will map Station, Group and Equipment to scheme files."
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding ImportRuntimeStatusText}"
                               Style="{StaticResource MutedText}"
                               Margin="0,12,0,0"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </TabItem>
    </TabControl>
</views:MaintenancePageControl>
