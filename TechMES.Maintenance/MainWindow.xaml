                                                    <TextBox Grid.Row="4"
                                                             Grid.Column="3"
                                                             Text="{Binding TypedAppSettings.RuntimeCtApiFilter, UpdateSourceTrigger=PropertyChanged}" />

                                                    <TextBlock Grid.Row="6"
                                                               Text="Catalog cluster"
                                                               VerticalAlignment="Center" />
                                                    <TextBox Grid.Row="6"
                                                             Grid.Column="1"
                                                             Text="{Binding TypedAppSettings.RuntimeCtApiCluster, UpdateSourceTrigger=PropertyChanged}"
                                                             Margin="0,0,8,0" />
                                                    <CheckBox Grid.Row="6"
                                                              Grid.Column="2"
                                                              Grid.ColumnSpan="2"
                                                              Content="Use CtApi type filter"
                                                              IsChecked="{Binding TypedAppSettings.RuntimeUseCtApiTypeFilter}"
                                                              VerticalAlignment="Center" />

                                                    <TextBlock Grid.Row="8"
                                                               Grid.ColumnSpan="4"
                                                               Text="Списки типов оборудования и TypeAliases остаются в Raw JSON: это тонкая настройка каталога."
                                                               Style="{StaticResource MutedText}"
                                                               TextWrapping="Wrap" />
                                                </Grid>
                                            </GroupBox>

                                            <GroupBox Header="CtApi and PostgreSQL"
                                                      Margin="0,0,0,10">
                                                <Grid Margin="10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="160" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="160" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="8" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="8" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="8" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="8" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="8" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>

                                                    <TextBlock Text="CtApi path" VerticalAlignment="Center" />
