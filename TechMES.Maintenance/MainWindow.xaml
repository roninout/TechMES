                                                </StackPanel>

                                                <StackPanel>
                                                    <TextBlock Text="Typed service appsettings"
                                                               FontSize="16"
                                                               FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding TypedAppSettings.Status}"
                                                               Style="{StaticResource MutedText}"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                            </DockPanel>

                                            <GroupBox Header="Runtime Service"
                                                      Margin="0,0,0,10">
                                                <Grid Margin="10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="160" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="160" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="8" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="8" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="8" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="8" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>

                                                    <TextBlock Text="Urls" VerticalAlignment="Center" />
