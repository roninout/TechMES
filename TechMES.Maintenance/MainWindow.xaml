                                                    <TextBox Grid.Row="4"
                                                             Grid.Column="3"
                                                             Text="{Binding TypedAppSettings.CtApiTagReadParallelism, UpdateSourceTrigger=LostFocus}" />

                                                    <TextBlock Grid.Row="6"
                                                               Text="Health tag"
                                                               VerticalAlignment="Center" />
                                                    <TextBox Grid.Row="6"
                                                             Grid.Column="1"
                                                             Text="{Binding TypedAppSettings.CtApiHealthCheckTag, UpdateSourceTrigger=PropertyChanged}"
                                                             Margin="0,0,8,0" />
                                                    <CheckBox Grid.Row="6"
                                                              Grid.Column="2"
                                                              Grid.ColumnSpan="2"
                                                              Content="Allow CtApi writes"
                                                              IsChecked="{Binding TypedAppSettings.CtApiAllowWrites}"
                                                              VerticalAlignment="Center" />

                                                    <TextBlock Grid.Row="8"
                                                               Text="Main DB"
                                                               VerticalAlignment="Center" />
                                                    <TextBox Grid.Row="8"
                                                             Grid.Column="1"
                                                             Grid.ColumnSpan="3"
                                                             Text="{Binding TypedAppSettings.RuntimeDatabaseConnectionString, UpdateSourceTrigger=PropertyChanged}" />

                                                    <TextBlock Grid.Row="10"
                                                               Text="Event DB"
                                                               VerticalAlignment="Center" />
                                                    <TextBox Grid.Row="10"
                                                             Grid.Column="1"
                                                             Grid.ColumnSpan="3"
                                                             Text="{Binding TypedAppSettings.RuntimeEventDatabaseConnectionString, UpdateSourceTrigger=PropertyChanged}" />
                                                </Grid>
                                            </GroupBox>

                                            <GroupBox Header="Param writes and Runtime file logs"
                                                      Margin="0,0,0,10">
                                                <Grid Margin="10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="180" />
                                                        <ColumnDefinition Width="180" />
                                                        <ColumnDefinition Width="180" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="8" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>

                                                    <CheckBox Content="Writes enabled"
                                                              IsChecked="{Binding TypedAppSettings.ParamWritesEnabled}" />
                                                    <CheckBox Grid.Column="1"
                                                              Content="Dry run"
                                                              IsChecked="{Binding TypedAppSettings.ParamWritesDryRun}" />
                                                    <CheckBox Grid.Column="2"
                                                              Content="Require comment"
                                                              IsChecked="{Binding TypedAppSettings.ParamWritesRequireComment}" />
                                                    <CheckBox Grid.Column="3"
                                                              Content="Audit enabled"
                                                              IsChecked="{Binding TypedAppSettings.ParamWritesAuditEnabled}" />

                                                    <CheckBox Grid.Row="2"
                                                              Content="Runtime file log"
                                                              IsChecked="{Binding TypedAppSettings.RuntimeFileLoggingEnabled}" />
                                                    <TextBox Grid.Row="2"
                                                             Grid.Column="1"
                                                             Text="{Binding TypedAppSettings.RuntimeFileLoggingMinimumLevel, UpdateSourceTrigger=PropertyChanged}"
                                                             Margin="0,0,8,0" />
                                                    <TextBox Grid.Row="2"
                                                             Grid.Column="2"
                                                             Text="{Binding TypedAppSettings.RuntimeFileLoggingDirectory, UpdateSourceTrigger=PropertyChanged}"
                                                             Margin="0,0,8,0" />
                                                    <TextBox Grid.Row="2"
                                                             Grid.Column="3"
                                                             Text="{Binding TypedAppSettings.RuntimeFileLoggingPrefix, UpdateSourceTrigger=PropertyChanged}" />
                                                </Grid>
                                            </GroupBox>

                                            <GroupBox Header="WEB appsettings"
                                                      Margin="0,0,0,10">
                                                <Grid Margin="10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="160" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="160" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="8" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="8" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="8" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="8" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="8" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>

                                                    <TextBlock Text="WEB Urls" VerticalAlignment="Center" />
                                                    <TextBox Grid.Column="1"
                                                             Text="{Binding TypedAppSettings.WebUrls, UpdateSourceTrigger=PropertyChanged}"
                                                             Margin="0,0,8,0" />
                                                    <TextBlock Grid.Column="2"
                                                               Text="Runtime base URL"
                                                               VerticalAlignment="Center" />
                                                    <TextBox Grid.Column="3"
                                                             Text="{Binding TypedAppSettings.WebRuntimeBaseUrl, UpdateSourceTrigger=PropertyChanged}" />

                                                    <TextBlock Grid.Row="2"
                                                               Text="Timeout, sec"
                                                               VerticalAlignment="Center" />
                                                    <TextBox Grid.Row="2"
                                                             Grid.Column="1"
                                                             Text="{Binding TypedAppSettings.WebRuntimeTimeoutSeconds, UpdateSourceTrigger=LostFocus}"
                                                             Margin="0,0,8,0" />
                                                    <TextBlock Grid.Row="2"
                                                               Grid.Column="2"
                                                               Text="Messages hub"
                                                               VerticalAlignment="Center" />
                                                    <TextBox Grid.Row="2"
                                                             Grid.Column="3"
                                                             Text="{Binding TypedAppSettings.WebMessagesHubPath, UpdateSourceTrigger=PropertyChanged}" />

                                                    <TextBlock Grid.Row="4"
                                                               Text="Device name"
                                                               VerticalAlignment="Center" />
                                                    <TextBox Grid.Row="4"
                                                             Grid.Column="1"
                                                             Text="{Binding TypedAppSettings.WebDeviceName, UpdateSourceTrigger=PropertyChanged}"
                                                             Margin="0,0,8,0" />
                                                    <TextBlock Grid.Row="4"
                                                               Grid.Column="2"
                                                               Text="Title"
                                                               VerticalAlignment="Center" />
                                                    <TextBox Grid.Row="4"
                                                             Grid.Column="3"
                                                             Text="{Binding TypedAppSettings.WebTitle, UpdateSourceTrigger=PropertyChanged}" />

