                        <TabItem Header="Raw appsettings JSON">
                            <Grid Margin="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="300" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Background="{StaticResource TechMesPanelBrush}"
                                        BorderBrush="{StaticResource TechMesBorderBrush}"
                                        BorderThickness="1"
                                        Padding="10">
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Top"
                                                   Text="appsettings files"
                                                   Style="{StaticResource SectionTitleText}" />
                                        <ListBox ItemsSource="{Binding SettingsFiles}"
                                                 SelectedItem="{Binding SelectedSettingsFile}"
                                                 DisplayMemberPath="DisplayName"
                                                 SelectionChanged="OnSettingsFileSelected" />
                                    </DockPanel>
                                </Border>

                                <Grid Grid.Column="2">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <DockPanel Grid.Row="0"
                                               Margin="0,0,0,8">
                                        <StackPanel DockPanel.Dock="Right"
                                                    Orientation="Horizontal">
                                            <Button Content="Reload"
                                                    Click="OnReloadSettingsClick" />
                                            <Button Content="Save with backup"
                                                    Background="{StaticResource TechMesBlueBrush}"
                                                    Foreground="White"
                                                    Click="OnSaveSettingsClick" />
                                        </StackPanel>

                                        <StackPanel>
                                            <TextBlock Text="{Binding SelectedSettingsFile.DisplayName}"
                                                       FontSize="18"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding SelectedSettingsFile.FullPath}"
                                                       Style="{StaticResource MutedText}" />
                                        </StackPanel>
                                    </DockPanel>

                                    <TextBox Grid.Row="1"
                                             Text="{Binding SelectedSettingsFile.Content, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                             AcceptsReturn="True"
                                             AcceptsTab="True"
                                             VerticalScrollBarVisibility="Auto"
                                             HorizontalScrollBarVisibility="Auto"
                                             FontFamily="Consolas"
                                             FontSize="13"
                                             Padding="10"
                                             TextWrapping="NoWrap" />

                                    <TextBlock Grid.Row="2"
                                               Text="{Binding SelectedSettingsFile.Status}"
                                               Style="{StaticResource MutedText}"
                                               Margin="0,8,0,0" />
                                </Grid>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </TabItem>

                <TabItem Header="Logs">
                    <Grid Margin="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="360" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Background="{StaticResource TechMesPanelBrush}"
                                BorderBrush="{StaticResource TechMesBorderBrush}"
                                BorderThickness="1"
                                Padding="10">
                            <DockPanel>
                                <Button DockPanel.Dock="Top"
                                        Content="Refresh logs"
                                        Margin="0,0,0,8"
                                        Click="OnRefreshLogsClick" />
                                <ListBox ItemsSource="{Binding LogFiles}"
                                         SelectedItem="{Binding SelectedLogFile}"
                                         DisplayMemberPath="DisplayName"
                                         SelectionChanged="OnLogFileSelected" />
                            </DockPanel>
                        </Border>

                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0"
                                        Margin="0,0,0,8">
                                <TextBlock Text="{Binding SelectedLogFile.DisplayName}"
                                           FontSize="18"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="{Binding SelectedLogFile.FullPath}"
                                           Style="{StaticResource MutedText}" />
                            </StackPanel>

                            <TextBox Grid.Row="1"
                                     Text="{Binding SelectedLogText}"
                                     IsReadOnly="True"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     FontFamily="Consolas"
                                     FontSize="13"
                                     Padding="10"
                                     TextWrapping="NoWrap" />
                        </Grid>
                    </Grid>
                </TabItem>

                <TabItem Header="Next steps">
                    <ScrollViewer Margin="12">
                        <StackPanel MaxWidth="860">
                            <TextBlock Text="Maintenance: что готово и что делаем дальше"
                                       Style="{StaticResource SectionTitleText}" />
                            <TextBlock TextWrapping="Wrap"
                                       FontSize="14"
                                       LineHeight="22">
                                Готово: Dashboard со статусами Windows Services, publish/install/start/deploy, typed-редактор Maintenance, typed-редактор Runtime/Web appsettings, просмотр логов, серверная диагностика HTTP/HTTPS, firewall-правила, подготовка HTTPS-сертификата, Server profile, Checks и Backup / Restore для конфигурации.&#x0a;&#x0a;
                                1. Проверить Backup / Restore на рабочем сервере: создать снимок, изменить тестовую настройку, восстановить снимок и перезапустить службы.&#x0a;
                                2. Добавить экспорт backup в zip-архив и импорт zip-архива, чтобы переносить настройки между машинами.&#x0a;
                                3. Добавить экспорт публичного CER и краткую инструкцию для планшета прямо из Maintenance.&#x0a;
                                4. Добавить сервисные действия для очистки старых publish/log/backup-файлов и просмотра свободного места.&#x0a;
                                5. Позже добавить профиль целевой машины и проверки PostgreSQL на уровне авторизации/версии, чтобы новый сервер готовился максимально близко к сценарию одной кнопки.&#x0a;
                                6. Отдельным этапом подключить Windows-пользователей, роли write-режима, подтверждения и расширенную диагностику действий оператора.
                            </TextBlock>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>
    </DockPanel>
</Window>

