<Window x:Class="TechMES.Maintenance.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="TechMES Maintenance"
        Height="760"
        Width="1180"
        MinHeight="620"
        MinWidth="960"
        Loaded="OnLoaded">
    <Window.Resources>
        <SolidColorBrush x:Key="TechMesBlueBrush" Color="#2563EB" />
        <SolidColorBrush x:Key="TechMesTextBrush" Color="#1F2937" />
        <SolidColorBrush x:Key="TechMesMutedBrush" Color="#6B7280" />
        <SolidColorBrush x:Key="TechMesPanelBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="TechMesBorderBrush" Color="#D1D5DB" />
        <SolidColorBrush x:Key="TechMesShellBrush" Color="#F3F4F6" />

        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="12,4" />
            <Setter Property="Margin" Value="0,0,6,0" />
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TechMesTextBrush}" />
        </Style>

        <Style x:Key="SectionTitleText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="MutedText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TechMesMutedBrush}" />
            <Setter Property="FontSize" Value="12" />
        </Style>
    </Window.Resources>

    <DockPanel Background="{StaticResource TechMesShellBrush}">
        <Border DockPanel.Dock="Top"
                Background="{StaticResource TechMesPanelBrush}"
                BorderBrush="{StaticResource TechMesBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="18,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="TechMES Maintenance"
                               FontSize="24"
                               FontWeight="Bold" />
                    <TextBlock Text="{Binding RepositoryRootText}"
                               Style="{StaticResource MutedText}" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Content="Refresh all"
                            Click="OnRefreshAllClick" />
                    <Button Content="Open settings folder"
                            Click="OnOpenMaintenanceFolderClick" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Margin="14">
            <TabControl>
                <TabItem Header="Dashboard">
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="180" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0"
                                    Margin="0,0,0,10">
                            <TextBlock Text="Services"
                                       Style="{StaticResource SectionTitleText}" />
                            <TextBlock Text="Статусы читаются из Windows Service Control Manager через sc.exe. Если службы еще не установлены, это нормально: Maintenance покажет Not installed."
                                       Style="{StaticResource MutedText}" />
                        </StackPanel>

                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding ServiceStatuses}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  Background="{StaticResource TechMesPanelBrush}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Service"
                                                    Binding="{Binding DisplayName}"
                                                    Width="170" />
                                <DataGridTextColumn Header="Windows name"
                                                    Binding="{Binding ServiceName}"
                                                    Width="210" />
                                <DataGridTextColumn Header="Status"
                                                    Binding="{Binding Status}"
                                                    Width="130" />
                                <DataGridTextColumn Header="Health"
                                                    Binding="{Binding Health}"
                                                    Width="130" />
                                <DataGridTextColumn Header="Health URL"
                                                    Binding="{Binding HealthUrl}"
                                                    Width="*" />
                                <DataGridTextColumn Header="Checked"
                                                    Binding="{Binding LastChecked, StringFormat={}{0:HH:mm:ss}}"
                                                    Width="100" />
                                <DataGridTemplateColumn Header="Actions"
                                                        Width="310">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="Start"
                                                        Tag="{Binding}"
                                                        Click="OnStartServiceClick" />
                                                <Button Content="Stop"
                                                        Tag="{Binding}"
                                                        Click="OnStopServiceClick" />
                                                <Button Content="Restart"
                                                        Tag="{Binding}"
                                                        Click="OnRestartServiceClick" />
                                                <Button Content="Probe"
                                                        Tag="{Binding}"
                                                        Click="OnProbeServiceClick" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <GroupBox Grid.Row="2"
                                  Header="Diagnostics"
                                  Margin="0,12,0,0">
                            <TextBox Text="{Binding DiagnosticsText}"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     FontFamily="Consolas"
                                     BorderThickness="0"
                                     Padding="8" />
                        </GroupBox>
                    </Grid>
                </TabItem>

                <TabItem Header="Server">
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="150" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="{StaticResource TechMesPanelBrush}"
                                BorderBrush="{StaticResource TechMesBorderBrush}"
                                BorderThickness="1"
                                Padding="12"
                                Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Server access"
                                               Style="{StaticResource SectionTitleText}" />
                                    <TextBlock Text="WEB должен быть доступен с планшета по одному из адресов ниже. Runtime Service остается локальным и наружу не открывается. HTTPS нужен для камеры, QR-сканера и браузерных API."
                                               Style="{StaticResource MutedText}" />
                                </StackPanel>

                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <Button Content="Prepare server"
                                            Background="{StaticResource TechMesBlueBrush}"
                                            Foreground="White"
                                            Click="OnPrepareServerClick" />
                                    <Button Content="Refresh server"
                                            Click="OnRefreshServerClick" />
                                    <Button Content="Open WEB firewall"
                                            Background="{StaticResource TechMesBlueBrush}"
                                            Foreground="White"
                                            Click="OnOpenWebFirewallClick" />
                                    <Button Content="Create/replace cert"
                                            Click="OnCreateHttpsCertificateClick" />
                                    <Button Content="Apply HTTPS"
                                            Click="OnApplyHttpsConfigClick" />
                                    <Button Content="Open HTTPS firewall"
                                            Background="{StaticResource TechMesBlueBrush}"
                                            Foreground="White"
                                            Click="OnOpenHttpsFirewallClick" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Background="{StaticResource TechMesPanelBrush}"
                                    BorderBrush="{StaticResource TechMesBorderBrush}"
                                    BorderThickness="1"
                                    Padding="10">
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Top"
                                               Text="Tablet URLs"
                                               Style="{StaticResource SectionTitleText}" />
                                    <DataGrid ItemsSource="{Binding ServerAddresses}"
                                              AutoGenerateColumns="False"
                                              IsReadOnly="True"
                                              CanUserAddRows="False"
                                              HeadersVisibility="Column"
                                              GridLinesVisibility="Horizontal"
                                              Background="{StaticResource TechMesPanelBrush}">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Adapter"
                                                                Binding="{Binding AdapterName}"
                                                                Width="220" />
                                            <DataGridTextColumn Header="IP"
                                                                Binding="{Binding Address}"
                                                                Width="150" />
                                            <DataGridTextColumn Header="WEB URL"
                                                                Binding="{Binding WebUrl}"
                                                                Width="*" />
                                            <DataGridTextColumn Header="HTTPS URL"
                                                                Binding="{Binding HttpsUrl}"
                                                                Width="*" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </DockPanel>
                            </Border>

                            <Border Grid.Column="2"
                                    Background="{StaticResource TechMesPanelBrush}"
                                    BorderBrush="{StaticResource TechMesBorderBrush}"
                                    BorderThickness="1"
                                    Padding="10">
                                <StackPanel>
                                    <TextBlock Text="Server checks"
                                               Style="{StaticResource SectionTitleText}" />

                                    <TextBlock Text="WEB port"
                                               Style="{StaticResource MutedText}" />
                                    <TextBlock Text="{Binding ServerWebPort}"
                                               Margin="0,0,0,8"
                                               FontWeight="SemiBold" />

                                    <TextBlock Text="HTTPS port"
                                               Style="{StaticResource MutedText}" />
                                    <TextBlock Text="{Binding ServerHttpsPort}"
                                               Margin="0,0,0,8"
                                               FontWeight="SemiBold" />

                                    <TextBlock Text="Runtime port"
                                               Style="{StaticResource MutedText}" />
                                    <TextBlock Text="{Binding ServerRuntimePort}"
                                               Margin="0,0,0,8"
                                               FontWeight="SemiBold" />

                                    <TextBlock Text="Ports"
                                               Style="{StaticResource MutedText}" />
                                    <TextBlock Text="{Binding ServerPortStatus}"
                                               Margin="0,0,0,8"
                                               TextWrapping="Wrap" />

                                    <TextBlock Text="Firewall rule"
                                               Style="{StaticResource MutedText}" />
                                    <TextBlock Text="{Binding ServerFirewallRuleName}"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding ServerFirewallStatus}"
                                               Margin="0,2,0,0"
                                               TextWrapping="Wrap" />

                                    <TextBlock Text="HTTPS firewall rule"
                                               Style="{StaticResource MutedText}"
                                               Margin="0,8,0,0" />
                                    <TextBlock Text="{Binding ServerHttpsFirewallRuleName}"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding ServerHttpsFirewallStatus}"
                                               Margin="0,2,0,0"
                                               TextWrapping="Wrap" />

                                    <TextBlock Text="Certificate"
                                               Style="{StaticResource MutedText}"
                                               Margin="0,8,0,0" />
                                    <TextBlock Text="{Binding ServerCertificateStatus}"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding ServerCertificatePfxPath}"
                                               Style="{StaticResource MutedText}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding ServerPublicCertificatePath}"
                                               Style="{StaticResource MutedText}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <GroupBox Grid.Row="2"
                                  Header="Server log"
                                  Margin="0,12,0,0">
                            <TextBox Text="{Binding ServerLogText}"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     FontFamily="Consolas"
                                     BorderThickness="0"
                                     Padding="8" />
                        </GroupBox>
                    </Grid>
                </TabItem>

                <TabItem Header="Server profile">
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="{StaticResource TechMesPanelBrush}"
                                BorderBrush="{StaticResource TechMesBorderBrush}"
                                BorderThickness="1"
                                Padding="12"
                                Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Server profile"
                                               Style="{StaticResource SectionTitleText}" />

                                    <StackPanel Orientation="Horizontal"
                                                Margin="0,0,0,6">
                                        <TextBlock Text="Readiness: "
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding ServerProfileReadinessStatus}"
                                                   FontWeight="Bold" />
                                        <TextBlock Text="   "
                                                   Style="{StaticResource MutedText}" />
                                        <TextBlock Text="{Binding ServerProfileLastUpdated}"
                                                   Style="{StaticResource MutedText}" />
                                    </StackPanel>

                                    <TextBlock Text="{Binding ServerProfileReadinessDetails}"
                                               TextWrapping="Wrap"
                                               Style="{StaticResource MutedText}" />
                                </StackPanel>

                                <Button Grid.Column="1"
                                        Content="Refresh profile"
                                        VerticalAlignment="Center"
                                        Background="{StaticResource TechMesBlueBrush}"
                                        Foreground="White"
                                        Click="OnRefreshServerProfileClick" />
                            </Grid>
                        </Border>

                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding ServerProfileItems}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  Background="{StaticResource TechMesPanelBrush}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Section"
                                                    Binding="{Binding Section}"
                                                    Width="130" />
                                <DataGridTextColumn Header="Name"
                                                    Binding="{Binding Name}"
                                                    Width="210" />
                                <DataGridTextColumn Header="Value"
                                                    Binding="{Binding Value}"
                                                    Width="260" />
                                <DataGridTextColumn Header="Status"
                                                    Binding="{Binding Status}"
                                                    Width="110" />
                                <DataGridTextColumn Header="Details"
                                                    Binding="{Binding Details}"
                                                    Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <TabItem Header="Backup / Restore">
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="{StaticResource TechMesPanelBrush}"
                                BorderBrush="{StaticResource TechMesBorderBrush}"
                                BorderThickness="1"
                                Padding="12"
                                Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="8" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.ColumnSpan="2">
                                    <TextBlock Text="Backup / Restore"
                                               Style="{StaticResource SectionTitleText}" />
                                    <TextBlock Text="Backup сохраняет maintenance.settings.json, исходные Runtime/Web appsettings, published appsettings и HTTPS-сертификаты. Restore перед перезаписью делает .restore-backup копию текущего файла."
                                               Style="{StaticResource MutedText}"
                                               TextWrapping="Wrap" />
                                </StackPanel>

                                <StackPanel Grid.Row="2"
                                            Grid.Column="0"
                                            Margin="0,0,12,0">
                                    <TextBlock Text="Backup root"
                                               Style="{StaticResource MutedText}" />
                                    <TextBox Text="{Binding BackupRoot, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>

                                <StackPanel Grid.Row="2"
                                            Grid.Column="1"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Bottom">
                                    <Button Content="Create backup"
                                            Background="{StaticResource TechMesBlueBrush}"
                                            Foreground="White"
                                            Click="OnCreateBackupClick" />
                                    <Button Content="Refresh backups"
                                            Click="OnRefreshBackupsClick" />
                                    <Button Content="Restore selected"
                                            Click="OnRestoreBackupClick" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding BackupItems}"
                                  SelectedItem="{Binding SelectedBackup, Mode=TwoWay}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  Background="{StaticResource TechMesPanelBrush}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Backup"
                                                    Binding="{Binding DisplayName}"
                                                    Width="160" />
                                <DataGridTextColumn Header="Created"
                                                    Binding="{Binding CreatedAt, StringFormat={}{0:dd.MM.yyyy HH:mm:ss}}"
                                                    Width="160" />
                                <DataGridTextColumn Header="Files"
                                                    Binding="{Binding FileCount}"
                                                    Width="80" />
                                <DataGridTextColumn Header="Size"
                                                    Binding="{Binding SizeText}"
                                                    Width="90" />
                                <DataGridTextColumn Header="Summary"
                                                    Binding="{Binding Summary}"
                                                    Width="*" />
                                <DataGridTextColumn Header="Folder"
                                                    Binding="{Binding FullPath}"
                                                    Width="320" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <Border Grid.Row="2"
                                Background="{StaticResource TechMesPanelBrush}"
                                BorderBrush="{StaticResource TechMesBorderBrush}"
                                BorderThickness="1"
                                Padding="10"
                                Margin="0,10,0,0">
                            <TextBlock Text="{Binding BackupStatusText}"
                                       TextWrapping="Wrap" />
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Checks">
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="{StaticResource TechMesPanelBrush}"
                                BorderBrush="{StaticResource TechMesBorderBrush}"
                                BorderThickness="1"
                                Padding="12"
                                Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Preflight checks"
                                               Style="{StaticResource SectionTitleText}" />
                                    <TextBlock Text="Проверяет HTTP health, PostgreSQL TCP, CtApi-настройки, папки публикации, appsettings, сертификаты и log-директории. Проверки ничего не меняют в системе."
                                               Style="{StaticResource MutedText}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding DependencyCheckStatusText}"
                                               Margin="0,8,0,0"
                                               FontWeight="SemiBold" />
                                </StackPanel>

                                <Button Grid.Column="1"
                                        Content="Run checks"
                                        VerticalAlignment="Center"
                                        Background="{StaticResource TechMesBlueBrush}"
                                        Foreground="White"
                                        Click="OnRunDependencyChecksClick" />
                            </Grid>
                        </Border>

                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding DependencyChecks}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  Background="{StaticResource TechMesPanelBrush}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Category"
                                                    Binding="{Binding Category}"
                                                    Width="130" />
                                <DataGridTextColumn Header="Name"
                                                    Binding="{Binding Name}"
                                                    Width="220" />
                                <DataGridTextColumn Header="Status"
                                                    Binding="{Binding Status}"
                                                    Width="110" />
                                <DataGridTextColumn Header="Details"
                                                    Binding="{Binding Details}"
                                                    Width="*" />
                                <DataGridTextColumn Header="Checked"
                                                    Binding="{Binding CheckedAt, StringFormat={}{0:HH:mm:ss}}"
                                                    Width="100" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <TabItem Header="Deploy">
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="170" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="{StaticResource TechMesPanelBrush}"
                                BorderBrush="{StaticResource TechMesBorderBrush}"
                                BorderThickness="1"
                                Padding="12"
                                Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="160" />
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="8" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.ColumnSpan="6"
                                           Text="Deployment profile"
                                           Style="{StaticResource SectionTitleText}" />

                                <StackPanel Grid.Row="2"
                                            Grid.Column="0"
                                            Margin="0,0,12,0">
                                    <TextBlock Text="Publish root"
                                               Style="{StaticResource MutedText}" />
                                    <TextBox Text="{Binding DeploymentPublishRoot, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>

                                <StackPanel Grid.Row="2"
                                            Grid.Column="1"
                                            Margin="0,0,12,0">
                                    <TextBlock Text="Configuration"
                                               Style="{StaticResource MutedText}" />
                                    <TextBox Text="{Binding DeploymentConfigurationName, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>

                                <StackPanel Grid.Row="2"
                                            Grid.Column="2"
                                            Margin="0,0,12,0">
                                    <TextBlock Text="Runtime"
                                               Style="{StaticResource MutedText}" />
                                    <TextBox Text="{Binding DeploymentRuntimeIdentifier, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>

                                <CheckBox Grid.Row="2"
                                          Grid.Column="3"
                                          Content="Self contained"
                                          IsChecked="{Binding DeploymentSelfContained}"
                                          VerticalAlignment="Center"
                                          Margin="0,18,12,0" />

                                <CheckBox Grid.Row="2"
                                          Grid.Column="4"
                                          Content="Auto start"
                                          IsChecked="{Binding DeploymentAutoStart}"
                                          VerticalAlignment="Center"
                                          Margin="0,18,12,0" />

                                <Button Grid.Row="2"
                                        Grid.Column="5"
                                        Content="Save profile"
                                        VerticalAlignment="Bottom"
                                        Click="OnSaveDeploymentProfileClick" />
                            </Grid>
                        </Border>

                        <Grid Grid.Row="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0"
                                        Orientation="Horizontal"
                                        Margin="0,0,0,8">
                                <Button Content="Publish all"
                                        Click="OnPublishAllClick" />
                                <Button Content="Install/Update all"
                                        Click="OnInstallAllClick" />
                                <Button Content="Start all"
                                        Click="OnStartAllDeployClick" />
                                <Button Content="Deploy all"
                                        Background="{StaticResource TechMesBlueBrush}"
                                        Foreground="White"
                                        Click="OnDeployAllClick" />
                            </StackPanel>

                            <DataGrid Grid.Row="1"
                                      ItemsSource="{Binding DeploymentServices}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      CanUserAddRows="False"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      Background="{StaticResource TechMesPanelBrush}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Service"
                                                        Binding="{Binding DisplayName}"
                                                        Width="160" />
                                    <DataGridTextColumn Header="Windows name"
                                                        Binding="{Binding ServiceName}"
                                                        Width="210" />
                                    <DataGridTextColumn Header="Project"
                                                        Binding="{Binding ProjectPath}"
                                                        Width="240" />
                                    <DataGridTextColumn Header="Publish directory"
                                                        Binding="{Binding PublishDirectory}"
                                                        Width="*" />
                                    <DataGridTextColumn Header="Status"
                                                        Binding="{Binding Status}"
                                                        Width="170" />
                                    <DataGridTemplateColumn Header="Actions"
                                                            Width="230">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <Button Content="Publish"
                                                            Tag="{Binding}"
                                                            Click="OnPublishDeployServiceClick" />
                                                    <Button Content="Install"
                                                            Tag="{Binding}"
                                                            Click="OnInstallDeployServiceClick" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>

                        <GroupBox Grid.Row="2"
                                  Header="Deploy log"
                                  Margin="0,12,0,0">
                            <TextBox Text="{Binding DeploymentLogText}"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     FontFamily="Consolas"
                                     BorderThickness="0"
                                     Padding="8" />
                        </GroupBox>
                    </Grid>
                </TabItem>

                <TabItem Header="Settings">
                    <TabControl Margin="12">
                        <TabItem Header="Typed settings">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel MaxWidth="980">
                                    <DockPanel Margin="0,0,0,10">
                                        <Button DockPanel.Dock="Right"
                                                Content="Save typed settings"
                                                Background="{StaticResource TechMesBlueBrush}"
                                                Foreground="White"
