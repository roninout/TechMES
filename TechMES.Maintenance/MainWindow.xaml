<Window x:Class="TechMES.Maintenance.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:TechMES.Maintenance.Views"
        mc:Ignorable="d"
        Title="TechMES Maintenance"
        Height="800"
        Width="1320"
        MinHeight="740"
        MinWidth="980"
        Loaded="OnLoaded">
    <Window.Resources>
        <SolidColorBrush x:Key="TechMesBlueBrush" Color="#2563EB" />
        <SolidColorBrush x:Key="TechMesTextBrush" Color="#1F2937" />
        <SolidColorBrush x:Key="TechMesMutedBrush" Color="#6B7280" />
        <SolidColorBrush x:Key="TechMesPanelBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="TechMesBorderBrush" Color="#D1D5DB" />
        <SolidColorBrush x:Key="TechMesShellBrush" Color="#F3F4F6" />

        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="12,4" />
            <Setter Property="Margin" Value="0,0,6,0" />
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TechMesTextBrush}" />
        </Style>

        <Style x:Key="SectionTitleText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="MutedText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TechMesMutedBrush}" />
            <Setter Property="FontSize" Value="12" />
        </Style>
    </Window.Resources>

    <DockPanel Background="{StaticResource TechMesShellBrush}">
        <Border DockPanel.Dock="Top"
                Background="{StaticResource TechMesPanelBrush}"
                BorderBrush="{StaticResource TechMesBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="18,12">
            <TextBlock Text="TechMES Maintenance"
                       FontSize="24"
                       FontWeight="Bold" />
        </Border>

        <Grid Margin="14">
            <TabControl TabStripPlacement="Left"
                        BorderThickness="0"
                        Background="Transparent"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        HorizontalContentAlignment="Stretch"
                        VerticalContentAlignment="Stretch"
                        ItemContainerStyle="{StaticResource MaintenanceMenuTabItemStyle}">
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left" Width="190">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE9F5;" FontSize="20" Margin="0,0,10,0" />
                            <TextBlock Text="General" FontWeight="SemiBold" />
                        </StackPanel>
                    </TabItem.Header>
                    <views:ServicesPage />
                </TabItem>

                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left" Width="190">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE713;" FontSize="20" Margin="0,0,10,0" />
                            <TextBlock Text="Settings" FontWeight="SemiBold" />
                        </StackPanel>
                    </TabItem.Header>
                    <views:SettingsPage />
                </TabItem>

                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left" Width="190">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE9D9;" FontSize="20" Margin="0,0,10,0" />
                            <TextBlock Text="Diagnostics" FontWeight="SemiBold" />
                        </StackPanel>
                    </TabItem.Header>
                    <views:DiagnosticsPage />
                </TabItem>

                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left" Width="190">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE74E;" FontSize="20" Margin="0,0,10,0" />
                            <TextBlock Text="Backup/Restore" FontWeight="SemiBold" />
                        </StackPanel>
                    </TabItem.Header>
                    <views:BackupRestorePage />
                </TabItem>

                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left" Width="190">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8A5;" FontSize="20" Margin="0,0,10,0" />
                            <TextBlock Text="Logs" FontWeight="SemiBold" />
                        </StackPanel>
                    </TabItem.Header>
                    <views:LogsPage />
                </TabItem>

                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left" Width="190">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8FD;" FontSize="20" Margin="0,0,10,0" />
                            <TextBlock Text="Next steps" FontWeight="SemiBold" />
                        </StackPanel>
                    </TabItem.Header>
                    <views:NextStepsPage />
                </TabItem>
            </TabControl>
        </Grid>
    </DockPanel>
</Window>


