                                                               Text="Device name"
                                                               VerticalAlignment="Center" />
                                                    <TextBox Grid.Column="3"
                                                             Text="{Binding TypedAppSettings.RuntimeDeviceName, UpdateSourceTrigger=PropertyChanged}" />

                                                    <TextBlock Grid.Row="2"
                                                               Text="User name"
                                                               VerticalAlignment="Center" />
                                                    <TextBox Grid.Row="2"
                                                             Grid.Column="1"
                                                             Text="{Binding TypedAppSettings.RuntimeUserName, UpdateSourceTrigger=PropertyChanged}"
                                                             Margin="0,0,8,0" />
                                                    <TextBlock Grid.Row="2"
                                                               Grid.Column="2"
                                                               Text="Catalog provider"
                                                               VerticalAlignment="Center" />
                                                    <TextBox Grid.Row="2"
                                                             Grid.Column="3"
                                                             Text="{Binding TypedAppSettings.RuntimeEquipmentProvider, UpdateSourceTrigger=PropertyChanged}" />

                                                    <TextBlock Grid.Row="4"
                                                               Text="Catalog table"
                                                               VerticalAlignment="Center" />
                                                    <TextBox Grid.Row="4"
                                                             Grid.Column="1"
                                                             Text="{Binding TypedAppSettings.RuntimeCtApiTableName, UpdateSourceTrigger=PropertyChanged}"
