                                                       Style="{StaticResource MutedText}" />
                                        </Grid>
                                    </GroupBox>
                                    <GroupBox Header="Runtime/Web appsettings"
                                              Margin="0,0,0,10">
                                        <StackPanel Margin="10">
                                            <DockPanel Margin="0,0,0,10">
                                                <StackPanel DockPanel.Dock="Right"
                                                            Orientation="Horizontal">
