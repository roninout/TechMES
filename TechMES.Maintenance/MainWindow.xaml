                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="8" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="8" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <TextBlock Text="Certificate directory"
                                                       Style="{StaticResource MutedText}" />
                                            <TextBlock Grid.Column="1"
                                                       Text="PFX file"
                                                       Style="{StaticResource MutedText}" />
                                            <TextBlock Grid.Column="2"
                                                       Text="CER file"
                                                       Style="{StaticResource MutedText}" />
                                            <TextBlock Grid.Column="3"
                                                       Text="Subject"
                                                       Style="{StaticResource MutedText}" />

                                            <TextBox Grid.Row="2"
                                                     Text="{Binding ServerCertificateDirectory, UpdateSourceTrigger=PropertyChanged}"
                                                     Margin="0,0,8,0" />
                                            <TextBox Grid.Row="2"
                                                     Grid.Column="1"
                                                     Text="{Binding ServerCertificateFileName, UpdateSourceTrigger=PropertyChanged}"
                                                     Margin="0,0,8,0" />
                                            <TextBox Grid.Row="2"
                                                     Grid.Column="2"
                                                     Text="{Binding ServerPublicCertificateFileName, UpdateSourceTrigger=PropertyChanged}"
                                                     Margin="0,0,8,0" />
                                            <TextBox Grid.Row="2"
                                                     Grid.Column="3"
                                                     Text="{Binding ServerCertificateSubject, UpdateSourceTrigger=PropertyChanged}" />

