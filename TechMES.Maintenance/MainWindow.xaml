                                                     Text="{Binding ServerRuntimePort, UpdateSourceTrigger=LostFocus}"
                                                     Margin="0,0,8,0" />
                                            <TextBox Grid.Row="2"
                                                     Grid.Column="3"
                                                     Text="{Binding ServerFirewallRuleName, UpdateSourceTrigger=PropertyChanged}"
                                                     Margin="0,0,8,0" />
                                            <TextBox Grid.Row="2"
                                                     Grid.Column="4"
                                                     Text="{Binding ServerHttpsFirewallRuleName, UpdateSourceTrigger=PropertyChanged}" />
                                        </Grid>
                                    </GroupBox>

                                    <GroupBox Header="HTTPS certificate"
                                              Margin="0,0,0,10">
                                        <Grid Margin="10">
