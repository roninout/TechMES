                                                    <TextBox Grid.Row="10"
                                                             Grid.Column="2"
                                                             Text="{Binding TypedAppSettings.WebFileLoggingDirectory, UpdateSourceTrigger=PropertyChanged}"
                                                             Margin="0,0,8,0" />
                                                    <TextBox Grid.Row="10"
