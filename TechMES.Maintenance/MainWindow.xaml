                                                               Text="CtApi server"
                                                               VerticalAlignment="Center" />
                                                    <TextBox Grid.Column="3"
                                                             Text="{Binding TypedAppSettings.CtApiServer, UpdateSourceTrigger=PropertyChanged}" />

                                                    <TextBlock Grid.Row="2"
                                                               Text="CtApi user"
                                                               VerticalAlignment="Center" />
                                                    <TextBox Grid.Row="2"
                                                             Grid.Column="1"
                                                             Text="{Binding TypedAppSettings.CtApiUser, UpdateSourceTrigger=PropertyChanged}"
                                                             Margin="0,0,8,0" />
                                                    <TextBlock Grid.Row="2"
                                                               Grid.Column="2"
                                                               Text="CtApi password"
                                                               VerticalAlignment="Center" />
                                                    <TextBox Grid.Row="2"
                                                             Grid.Column="3"
                                                             Text="{Binding TypedAppSettings.CtApiPassword, UpdateSourceTrigger=PropertyChanged}" />

                                                    <TextBlock Grid.Row="4"
                                                               Text="Health period"
